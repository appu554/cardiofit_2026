{
  "dashboard": {
    "title": "CDC Connector Monitoring Dashboard",
    "tags": ["cdc", "debezium", "kafka-connect", "postgresql"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Connector Status Overview",
        "type": "stat",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "count(kafka_connect_connector_status{state=\"RUNNING\"})",
            "legendFormat": "Running Connectors",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "none",
          "colorMode": "value",
          "justifyMode": "auto",
          "textMode": "value_and_name",
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 3, "color": "yellow"},
                {"value": 5, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Failed Connectors",
        "type": "stat",
        "gridPos": {
          "x": 6,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "count(kafka_connect_connector_status{state=\"FAILED\"})",
            "legendFormat": "Failed Connectors",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "none",
          "colorMode": "value",
          "textMode": "value_and_name",
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Average Replication Lag",
        "type": "stat",
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "avg(kafka_connect_source_connector_replication_lag_seconds)",
            "legendFormat": "Avg Lag (seconds)",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "textMode": "value_and_name",
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 300, "color": "yellow"},
                {"value": 900, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Total CDC Throughput",
        "type": "stat",
        "gridPos": {
          "x": 18,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "sum(rate(kafka_topic_partition_current_offset{topic=~\"cdc\\\\..*\"}[5m]))",
            "legendFormat": "Messages/sec",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "textMode": "value_and_name",
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "decimals": 2
          }
        }
      },
      {
        "id": 5,
        "title": "Connector Health Status",
        "type": "table",
        "gridPos": {
          "x": 0,
          "y": 4,
          "w": 24,
          "h": 8
        },
        "targets": [
          {
            "expr": "kafka_connect_connector_status",
            "legendFormat": "{{connector}}",
            "refId": "A",
            "instant": true,
            "format": "table"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "job": true,
                "instance": true
              },
              "renameByName": {
                "connector": "Connector",
                "state": "State",
                "worker_id": "Worker"
              }
            }
          }
        ],
        "fieldConfig": {
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "State"},
              "properties": [
                {
                  "id": "mappings",
                  "value": [
                    {"type": "value", "value": "RUNNING", "text": "RUNNING", "color": "green"},
                    {"type": "value", "value": "FAILED", "text": "FAILED", "color": "red"},
                    {"type": "value", "value": "PAUSED", "text": "PAUSED", "color": "yellow"}
                  ]
                },
                {
                  "id": "custom.displayMode",
                  "value": "color-background"
                }
              ]
            }
          ]
        }
      },
      {
        "id": 6,
        "title": "Replication Lag by Connector",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 12,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "kafka_connect_source_connector_replication_lag_seconds",
            "legendFormat": "{{connector}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "format": "s",
            "label": "Lag (seconds)",
            "show": true
          },
          {
            "show": false
          }
        ],
        "alert": {
          "conditions": [
            {
              "evaluator": {
                "params": [300],
                "type": "gt"
              },
              "operator": {
                "type": "and"
              },
              "query": {
                "params": ["A", "5m", "now"]
              },
              "reducer": {
                "type": "avg"
              },
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "handler": 1,
          "name": "Replication Lag Alert",
          "noDataState": "no_data",
          "notifications": []
        }
      },
      {
        "id": 7,
        "title": "CDC Topic Message Rate",
        "type": "graph",
        "gridPos": {
          "x": 12,
          "y": 12,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "rate(kafka_topic_partition_current_offset{topic=~\"cdc\\\\..*\"}[5m])",
            "legendFormat": "{{topic}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "format": "ops",
            "label": "Messages/sec",
            "show": true
          }
        ]
      },
      {
        "id": 8,
        "title": "PostgreSQL Replication Slot Status",
        "type": "table",
        "gridPos": {
          "x": 0,
          "y": 20,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "pg_replication_slots_active{slot_type=\"logical\"}",
            "refId": "A",
            "instant": true,
            "format": "table"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true, "job": true},
              "renameByName": {
                "slot_name": "Slot Name",
                "database": "Database",
                "kb_service": "KB Service",
                "Value": "Active"
              }
            }
          }
        ],
        "fieldConfig": {
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Active"},
              "properties": [
                {
                  "id": "mappings",
                  "value": [
                    {"type": "value", "value": "1", "text": "Active", "color": "green"},
                    {"type": "value", "value": "0", "text": "Inactive", "color": "red"}
                  ]
                },
                {
                  "id": "custom.displayMode",
                  "value": "color-background"
                }
              ]
            }
          ]
        }
      },
      {
        "id": 9,
        "title": "PostgreSQL Replication Slot Lag",
        "type": "graph",
        "gridPos": {
          "x": 12,
          "y": 20,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "pg_replication_slots_lag_bytes{slot_type=\"logical\"}",
            "legendFormat": "{{slot_name}} ({{kb_service}})",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "format": "bytes",
            "label": "Lag (bytes)",
            "show": true
          }
        ]
      },
      {
        "id": 10,
        "title": "Connector Error Rate",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 28,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "rate(kafka_connect_connector_task_errors_total[5m])",
            "legendFormat": "{{connector}} errors/sec",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "format": "ops",
            "label": "Errors/sec",
            "show": true
          }
        ]
      },
      {
        "id": 11,
        "title": "Kafka Connect JVM Memory",
        "type": "graph",
        "gridPos": {
          "x": 12,
          "y": 28,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "kafka_connect_jvm_memory_usage_after_gc",
            "legendFormat": "Memory Usage %",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "format": "percentunit",
            "label": "Memory Usage",
            "show": true,
            "min": 0,
            "max": 1
          }
        ]
      },
      {
        "id": 12,
        "title": "Recent Connector Events",
        "type": "logs",
        "gridPos": {
          "x": 0,
          "y": 36,
          "w": 24,
          "h": 8
        },
        "targets": [
          {
            "expr": "{job=\"kafka-connect\"} |= \"connector\"",
            "refId": "A"
          }
        ],
        "options": {
          "showTime": true,
          "showLabels": false,
          "wrapLogMessage": true
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "connector",
          "type": "query",
          "query": "label_values(kafka_connect_connector_status, connector)",
          "label": "Connector",
          "multi": true,
          "includeAll": true,
          "allValue": ".*"
        },
        {
          "name": "kb_service",
          "type": "custom",
          "options": [
            {"text": "All", "value": "$__all"},
            {"text": "KB1", "value": "KB1"},
            {"text": "KB2", "value": "KB2"},
            {"text": "KB3", "value": "KB3"},
            {"text": "KB6", "value": "KB6"},
            {"text": "KB7", "value": "KB7"}
          ],
          "label": "KB Service",
          "multi": true,
          "includeAll": true
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "datasource": "Prometheus",
          "enable": true,
          "expr": "ALERTS{alertname=~\"CDC.*\"}",
          "name": "CDC Alerts",
          "step": "60s",
          "tagKeys": "alertname,severity",
          "textFormat": "{{alertname}}: {{description}}",
          "titleFormat": "Alert"
        }
      ]
    },
    "editable": true,
    "gnetId": null,
    "graphTooltip": 1,
    "links": [],
    "panels": [],
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    },
    "uid": "cdc-connector-monitoring",
    "version": 1
  }
}
