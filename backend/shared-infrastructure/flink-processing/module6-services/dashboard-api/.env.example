# Server Configuration
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=dashboard-api
KAFKA_GROUP_ID=dashboard-api-consumers
KAFKA_TOPICS=hospital-kpis,department-metrics,patient-risk-profiles,sepsis-surveillance,quality-metrics

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_SECONDS=300

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=clinical_analytics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_MAX_CONNECTIONS=20

# InfluxDB Configuration
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influx-token
INFLUX_ORG=cardiofit
INFLUX_BUCKET=clinical_metrics
INFLUX_TIMEOUT=30000

# Logging Configuration
LOG_LEVEL=info
LOG_PRETTY_PRINT=true

# GraphQL Configuration
GRAPHQL_PLAYGROUND=true
GRAPHQL_INTROSPECTION=true
GRAPHQL_DEBUG=true

# Security Configuration
CORS_ORIGIN=http://localhost:4200
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring Configuration
ENABLE_METRICS=true
HEALTH_CHECK_TIMEOUT=5000
