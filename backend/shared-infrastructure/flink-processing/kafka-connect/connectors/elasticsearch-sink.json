{
  "name": "elasticsearch-clinical-events-sink",
  "config": {
    "connector.class": "io.confluent.connect.elasticsearch.ElasticsearchSinkConnector",
    "topics": "clinical-events-unified.v1",
    "connection.url": "http://localhost:9200",
    "connection.username": "elastic",
    "connection.password": "ElasticCardioFit2024!",
    "type.name": "_doc",
    "index.write.method": "insert",
    "batch.size": 100,
    "max.buffered.records": 1000,
    "flush.timeout.ms": 5000,
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": false,
    "transforms": "routeToElasticsearch,addIndexName,flattenPayload,addTimestamp",
    "transforms.routeToElasticsearch.type": "org.apache.kafka.connect.transforms.Filter",
    "transforms.routeToElasticsearch.predicate": "has-destinations",
    "transforms.routeToElasticsearch.predicate.destinations": "elasticsearch,search,analytics",
    "transforms.addIndexName.type": "org.apache.kafka.connect.transforms.TimestampRouter",
    "transforms.addIndexName.topic.format": "cardiofit-clinical-${timestamp}",
    "transforms.addIndexName.timestamp.format": "yyyy.MM.dd",
    "transforms.flattenPayload.type": "org.apache.kafka.connect.transforms.Flatten$Value",
    "transforms.flattenPayload.delimiter": "_",
    "transforms.addTimestamp.type": "org.apache.kafka.connect.transforms.InsertField$Value",
    "transforms.addTimestamp.timestamp.field": "@timestamp",
    "behavior.on.null.values": "ignore",
    "behavior.on.malformed.documents": "warn",
    "drop.invalid.message": true,
    "schema.ignore": true,
    "errors.tolerance": "all",
    "errors.log.enable": true,
    "errors.log.include.messages": true
  }
}