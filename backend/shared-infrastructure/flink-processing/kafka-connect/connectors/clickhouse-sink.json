{
  "name": "clickhouse-clinical-events-sink",
  "config": {
    "connector.class": "com.clickhouse.kafka.connect.ClickHouseSinkConnector",
    "topics": "prod.ehr.analytics.events",
    "clickhouse.server.url": "http://localhost:8123",
    "clickhouse.server.user": "cardiofit_user",
    "clickhouse.server.password": "ClickHouse2024!",
    "clickhouse.server.database": "cardiofit_analytics",
    "clickhouse.table.name": "clinical_events",
    "clickhouse.table.engine": "MergeTree()",
    "clickhouse.table.order.by": "event_time, patient_id",
    "clickhouse.table.partition.by": "toYYYYMM(event_time)",
    "clickhouse.table.create.auto": true,
    "clickhouse.table.schema": "event_id String, patient_id String, event_type String, event_time DateTime64(3), priority String, confidence_score Float64, payload String",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": false,
    "transforms": "routeToClickHouse,extractFields,convertTimestamp",
    "transforms.routeToClickHouse.type": "org.apache.kafka.connect.transforms.Filter",
    "transforms.routeToClickHouse.predicate": "has-destinations",
    "transforms.routeToClickHouse.predicate.destinations": "clickhouse,analytics,time-series,olap,reporting",
    "transforms.extractFields.type": "org.apache.kafka.connect.transforms.ExtractField$Value",
    "transforms.extractFields.field": "originalPayload",
    "transforms.convertTimestamp.type": "org.apache.kafka.connect.transforms.TimestampConverter$Value",
    "transforms.convertTimestamp.field": "routingTime",
    "transforms.convertTimestamp.target.type": "Timestamp",
    "buffer.count.records": 2000,
    "buffer.flush.time": 3000,
    "errors.retry.timeout": "60000",
    "errors.retry.delay.max.ms": "10000",
    "errors.tolerance": "all",
    "errors.log.enable": true
  }
}