{
  "name": "google-fhir-store-sink",
  "config": {
    "connector.class": "com.google.cloud.healthcare.connect.FhirSinkConnector",
    "topics": "prod.ehr.fhir.upsert,prod.ehr.events.enriched",
    "gcp.credentials.path": "/etc/gcp/service-account.json",
    "fhir.store.url": "https://healthcare.googleapis.com/v1/projects/cardiofit-905a8/locations/us-central1/datasets/clinical_synthesis_hub/fhirStores/fhir_store",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": false,
    "transforms": "routeToFHIR,convertToFHIR,addResourceId",
    "transforms.routeToFHIR.type": "org.apache.kafka.connect.transforms.Filter",
    "transforms.routeToFHIR.predicate": "has-destinations",
    "transforms.routeToFHIR.predicate.destinations": "fhir,fhir_store,clinical_persistence,state_update",
    "transforms.convertToFHIR.type": "org.apache.kafka.connect.transforms.ValueToKey",
    "transforms.convertToFHIR.fields": "sourceEventType,patientId,routingTime",
    "transforms.addResourceId.type": "org.apache.kafka.connect.transforms.InsertField$Value",
    "transforms.addResourceId.static.field": "resourceType",
    "transforms.addResourceId.static.value": "Observation",
    "fhir.resource.type.mapping": "SEMANTIC_EVENT:Observation,PATTERN_EVENT:DiagnosticReport,ML_PREDICTION:RiskAssessment,CONTEXT_SNAPSHOT:Encounter",
    "fhir.patient.id.field": "patientId",
    "fhir.timestamp.field": "routingTime",
    "fhir.batch.size": 50,
    "fhir.retry.attempts": 3,
    "fhir.retry.delay.ms": 1000,
    "errors.tolerance": "all",
    "errors.log.enable": true,
    "errors.log.include.messages": true
  }
}