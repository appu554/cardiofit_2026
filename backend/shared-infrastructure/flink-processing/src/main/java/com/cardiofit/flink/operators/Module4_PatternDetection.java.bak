    private static KafkaSink<PatternEvent> createTrendAnalysisSink() {
        return KafkaSink.<PatternEvent>builder()
            .setBootstrapServers(getBootstrapServers())
            .setRecordSerializer(KafkaRecordSerializationSchema.builder()
