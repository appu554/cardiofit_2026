package com.cardiofit.flink.models;

import com.fasterxml.jackson.annotation.JsonProperty;
import java.io.Serializable;
import java.time.Instant;
import java.util.List;
import java.util.Map;

/**
 * ML prediction model representing machine learning inference results
 * Generated by Module 5: ML Inference Engine
 */
public class MLPrediction implements Serializable {
    private static final long serialVersionUID = 1L;

    @JsonProperty("id")
    private String id;

    @JsonProperty("patient_id")
    private String patientId;

    @JsonProperty("encounter_id")
    private String encounterId;

    @JsonProperty("model_name")
    private String modelName;

    @JsonProperty("model_type")
    private String modelType;

    @JsonProperty("prediction_time")
    private long predictionTime;

    @JsonProperty("prediction_scores")
    private Map<String, Double> predictionScores;

    @JsonProperty("risk_level")
    private String riskLevel;

    @JsonProperty("confidence_interval")
    private ConfidenceInterval confidenceInterval;

    @JsonProperty("feature_importance")
    private Map<String, Double> featureImportance;

    @JsonProperty("input_feature_count")
    private int inputFeatureCount;

    @JsonProperty("model_metadata")
    private Map<String, Object> modelMetadata;

    @JsonProperty("recommended_actions")
    private List<String> recommendedActions;

    @JsonProperty("clinical_interpretation")
    private ClinicalInterpretation clinicalInterpretation;

    @JsonProperty("prediction_quality")
    private PredictionQuality predictionQuality;

    @JsonProperty("correlation_id")
    private String correlationId;

    @JsonProperty("ensemble_metadata")
    private EnsembleMetadata ensembleMetadata;

    // Validation and monitoring fields
    @JsonProperty("validation_status")
    private String validationStatus;

    @JsonProperty("alert_threshold_exceeded")
    private boolean alertThresholdExceeded;

    @JsonProperty("human_review_required")
    private boolean humanReviewRequired;

    @JsonProperty("explainability_data")
    private ExplainabilityData explainabilityData;

    // Default constructor
    public MLPrediction() {
        this.predictionTime = System.currentTimeMillis();
        this.validationStatus = "PENDING";
        this.alertThresholdExceeded = false;
        this.humanReviewRequired = false;
    }

    // Builder pattern
    public static Builder builder() {
        return new Builder();
    }

    public static class Builder {
        private MLPrediction prediction = new MLPrediction();

        public Builder id(String id) {
            prediction.id = id;
            return this;
        }

        public Builder patientId(String patientId) {
            prediction.patientId = patientId;
            return this;
        }

        public Builder encounterId(String encounterId) {
            prediction.encounterId = encounterId;
            return this;
        }

        public Builder modelName(String modelName) {
            prediction.modelName = modelName;
            return this;
        }

        public Builder modelType(String modelType) {
            prediction.modelType = modelType;
            return this;
        }

        public Builder predictionTime(long predictionTime) {
            prediction.predictionTime = predictionTime;
            return this;
        }

        public Builder predictionScores(Map<String, Double> predictionScores) {
            prediction.predictionScores = predictionScores;
            return this;
        }

        public Builder riskLevel(String riskLevel) {
            prediction.riskLevel = riskLevel;
            return this;
        }

        public Builder featureImportance(Map<String, Double> featureImportance) {
            prediction.featureImportance = featureImportance;
            return this;
        }

        public Builder recommendedActions(List<String> recommendedActions) {
            prediction.recommendedActions = recommendedActions;
            return this;
        }

        public Builder correlationId(String correlationId) {
            prediction.correlationId = correlationId;
            return this;
        }

        public MLPrediction build() {
            return prediction;
        }
    }

    // Getters and Setters
    public String getId() { return id; }
    public void setId(String id) { this.id = id; }

    public String getPatientId() { return patientId; }
    public void setPatientId(String patientId) { this.patientId = patientId; }

    public String getEncounterId() { return encounterId; }
    public void setEncounterId(String encounterId) { this.encounterId = encounterId; }

    public String getModelName() { return modelName; }
    public void setModelName(String modelName) { this.modelName = modelName; }

    public String getModelType() { return modelType; }
    public void setModelType(String modelType) { this.modelType = modelType; }

    public long getPredictionTime() { return predictionTime; }
    public void setPredictionTime(long predictionTime) { this.predictionTime = predictionTime; }

    public Map<String, Double> getPredictionScores() { return predictionScores; }
    public void setPredictionScores(Map<String, Double> predictionScores) { this.predictionScores = predictionScores; }

    public String getRiskLevel() { return riskLevel; }
    public void setRiskLevel(String riskLevel) { this.riskLevel = riskLevel; }

    public ConfidenceInterval getConfidenceInterval() { return confidenceInterval; }
    public void setConfidenceInterval(ConfidenceInterval confidenceInterval) { this.confidenceInterval = confidenceInterval; }

    public Map<String, Double> getFeatureImportance() { return featureImportance; }
    public void setFeatureImportance(Map<String, Double> featureImportance) { this.featureImportance = featureImportance; }

    public int getInputFeatureCount() { return inputFeatureCount; }
    public void setInputFeatureCount(int inputFeatureCount) { this.inputFeatureCount = inputFeatureCount; }

    public Map<String, Object> getModelMetadata() { return modelMetadata; }
    public void setModelMetadata(Map<String, Object> modelMetadata) { this.modelMetadata = modelMetadata; }

    public List<String> getRecommendedActions() { return recommendedActions; }
    public void setRecommendedActions(List<String> recommendedActions) { this.recommendedActions = recommendedActions; }

    public ClinicalInterpretation getClinicalInterpretation() { return clinicalInterpretation; }
    public void setClinicalInterpretation(ClinicalInterpretation clinicalInterpretation) { this.clinicalInterpretation = clinicalInterpretation; }

    public PredictionQuality getPredictionQuality() { return predictionQuality; }
    public void setPredictionQuality(PredictionQuality predictionQuality) { this.predictionQuality = predictionQuality; }

    public String getCorrelationId() { return correlationId; }
    public void setCorrelationId(String correlationId) { this.correlationId = correlationId; }

    public EnsembleMetadata getEnsembleMetadata() { return ensembleMetadata; }
    public void setEnsembleMetadata(EnsembleMetadata ensembleMetadata) { this.ensembleMetadata = ensembleMetadata; }

    public String getValidationStatus() { return validationStatus; }
    public void setValidationStatus(String validationStatus) { this.validationStatus = validationStatus; }

    public boolean isAlertThresholdExceeded() { return alertThresholdExceeded; }
    public void setAlertThresholdExceeded(boolean alertThresholdExceeded) { this.alertThresholdExceeded = alertThresholdExceeded; }

    public boolean isHumanReviewRequired() { return humanReviewRequired; }
    public void setHumanReviewRequired(boolean humanReviewRequired) { this.humanReviewRequired = humanReviewRequired; }

    public ExplainabilityData getExplainabilityData() { return explainabilityData; }
    public void setExplainabilityData(ExplainabilityData explainabilityData) { this.explainabilityData = explainabilityData; }

    // Utility methods
    /**
     * Get primary prediction score
     */
    public double getPrimaryScore() {
        if (predictionScores != null) {
            return predictionScores.getOrDefault("primary_score",
                predictionScores.getOrDefault("ensemble_score", 0.0));
        }
        return 0.0;
    }

    /**
     * Get confidence score
     */
    public double getConfidenceScore() {
        if (predictionScores != null) {
            return predictionScores.getOrDefault("confidence_score", 0.0);
        }
        return 0.0;
    }

    /**
     * Check if prediction indicates high risk
     */
    public boolean isHighRisk() {
        return "HIGH".equalsIgnoreCase(riskLevel);
    }

    /**
     * Check if prediction indicates moderate risk
     */
    public boolean isModerateRisk() {
        return "MODERATE".equalsIgnoreCase(riskLevel);
    }

    /**
     * Check if prediction indicates low risk
     */
    public boolean isLowRisk() {
        return "LOW".equalsIgnoreCase(riskLevel);
    }

    /**
     * Check if prediction has high confidence
     */
    public boolean isHighConfidence() {
        return getConfidenceScore() > 0.8;
    }

    /**
     * Check if prediction requires immediate attention
     */
    public boolean requiresImmediateAttention() {
        return isHighRisk() && isHighConfidence() && alertThresholdExceeded;
    }

    /**
     * Check if prediction is an ensemble prediction
     */
    public boolean isEnsemblePrediction() {
        return ensembleMetadata != null && ensembleMetadata.getModelCount() > 1;
    }

    /**
     * Get the most important feature
     */
    public String getMostImportantFeature() {
        if (featureImportance == null || featureImportance.isEmpty()) {
            return null;
        }

        return featureImportance.entrySet().stream()
            .max(Map.Entry.comparingByValue())
            .map(Map.Entry::getKey)
            .orElse(null);
    }

    /**
     * Get prediction age in hours
     */
    public double getPredictionAgeHours() {
        return (System.currentTimeMillis() - predictionTime) / (1000.0 * 3600.0);
    }

    /**
     * Check if prediction is stale (older than specified hours)
     */
    public boolean isStale(double maxAgeHours) {
        return getPredictionAgeHours() > maxAgeHours;
    }

    /**
     * Get model version from metadata
     */
    public String getModelVersion() {
        if (modelMetadata != null) {
            Object version = modelMetadata.get("model_version");
            return version != null ? version.toString() : null;
        }
        return null;
    }

    @Override
    public String toString() {
        return "MLPrediction{" +
            "id='" + id + '\'' +
            ", patientId='" + patientId + '\'' +
            ", modelType='" + modelType + '\'' +
            ", predictionTime=" + Instant.ofEpochMilli(predictionTime) +
            ", primaryScore=" + getPrimaryScore() +
            ", riskLevel='" + riskLevel + '\'' +
            ", confidenceScore=" + getConfidenceScore() +
            ", alertThresholdExceeded=" + alertThresholdExceeded +
            '}';
    }

    // Inner classes for structured data
    public static class ConfidenceInterval implements Serializable {
        private double lowerBound;
        private double upperBound;
        private double confidenceLevel;

        public ConfidenceInterval() {}

        public ConfidenceInterval(double lowerBound, double upperBound, double confidenceLevel) {
            this.lowerBound = lowerBound;
            this.upperBound = upperBound;
            this.confidenceLevel = confidenceLevel;
        }

        // Getters and setters
        public double getLowerBound() { return lowerBound; }
        public void setLowerBound(double lowerBound) { this.lowerBound = lowerBound; }

        public double getUpperBound() { return upperBound; }
        public void setUpperBound(double upperBound) { this.upperBound = upperBound; }

        public double getConfidenceLevel() { return confidenceLevel; }
        public void setConfidenceLevel(double confidenceLevel) { this.confidenceLevel = confidenceLevel; }

        public double getWidth() {
            return upperBound - lowerBound;
        }
    }

    public static class ClinicalInterpretation implements Serializable {
        private String summary;
        private String clinicalSignificance;
        private String timeHorizon;
        private List<String> contributingFactors;
        private List<String> mitigatingFactors;
        private String recommendedMonitoring;

        public ClinicalInterpretation() {}

        // Getters and setters
        public String getSummary() { return summary; }
        public void setSummary(String summary) { this.summary = summary; }

        public String getClinicalSignificance() { return clinicalSignificance; }
        public void setClinicalSignificance(String clinicalSignificance) { this.clinicalSignificance = clinicalSignificance; }

        public String getTimeHorizon() { return timeHorizon; }
        public void setTimeHorizon(String timeHorizon) { this.timeHorizon = timeHorizon; }

        public List<String> getContributingFactors() { return contributingFactors; }
        public void setContributingFactors(List<String> contributingFactors) { this.contributingFactors = contributingFactors; }

        public List<String> getMitigatingFactors() { return mitigatingFactors; }
        public void setMitigatingFactors(List<String> mitigatingFactors) { this.mitigatingFactors = mitigatingFactors; }

        public String getRecommendedMonitoring() { return recommendedMonitoring; }
        public void setRecommendedMonitoring(String recommendedMonitoring) { this.recommendedMonitoring = recommendedMonitoring; }
    }

    public static class PredictionQuality implements Serializable {
        private double overallQuality;
        private double dataCompleteness;
        private double featureRelevance;
        private double temporalRelevance;
        private double modelApplicability;
        private List<String> qualityWarnings;

        public PredictionQuality() {}

        // Getters and setters
        public double getOverallQuality() { return overallQuality; }
        public void setOverallQuality(double overallQuality) { this.overallQuality = overallQuality; }

        public double getDataCompleteness() { return dataCompleteness; }
        public void setDataCompleteness(double dataCompleteness) { this.dataCompleteness = dataCompleteness; }

        public double getFeatureRelevance() { return featureRelevance; }
        public void setFeatureRelevance(double featureRelevance) { this.featureRelevance = featureRelevance; }

        public double getTemporalRelevance() { return temporalRelevance; }
        public void setTemporalRelevance(double temporalRelevance) { this.temporalRelevance = temporalRelevance; }

        public double getModelApplicability() { return modelApplicability; }
        public void setModelApplicability(double modelApplicability) { this.modelApplicability = modelApplicability; }

        public List<String> getQualityWarnings() { return qualityWarnings; }
        public void setQualityWarnings(List<String> qualityWarnings) { this.qualityWarnings = qualityWarnings; }

        public boolean isHighQuality() {
            return overallQuality > 0.8;
        }
    }

    public static class EnsembleMetadata implements Serializable {
        private int modelCount;
        private List<String> participatingModels;
        private String ensembleMethod;
        private Map<String, Double> modelWeights;
        private double consensusScore;

        public EnsembleMetadata() {}

        // Getters and setters
        public int getModelCount() { return modelCount; }
        public void setModelCount(int modelCount) { this.modelCount = modelCount; }

        public List<String> getParticipatingModels() { return participatingModels; }
        public void setParticipatingModels(List<String> participatingModels) { this.participatingModels = participatingModels; }

        public String getEnsembleMethod() { return ensembleMethod; }
        public void setEnsembleMethod(String ensembleMethod) { this.ensembleMethod = ensembleMethod; }

        public Map<String, Double> getModelWeights() { return modelWeights; }
        public void setModelWeights(Map<String, Double> modelWeights) { this.modelWeights = modelWeights; }

        public double getConsensusScore() { return consensusScore; }
        public void setConsensusScore(double consensusScore) { this.consensusScore = consensusScore; }
    }

    public static class ExplainabilityData implements Serializable {
        private Map<String, Double> shapValues;
        private List<String> topContributors;
        private String explanationText;
        private Map<String, Object> localExplanations;
        private String explainabilityMethod;

        public ExplainabilityData() {}

        // Getters and setters
        public Map<String, Double> getShapValues() { return shapValues; }
        public void setShapValues(Map<String, Double> shapValues) { this.shapValues = shapValues; }

        public List<String> getTopContributors() { return topContributors; }
        public void setTopContributors(List<String> topContributors) { this.topContributors = topContributors; }

        public String getExplanationText() { return explanationText; }
        public void setExplanationText(String explanationText) { this.explanationText = explanationText; }

        public Map<String, Object> getLocalExplanations() { return localExplanations; }
        public void setLocalExplanations(Map<String, Object> localExplanations) { this.localExplanations = localExplanations; }

        public String getExplainabilityMethod() { return explainabilityMethod; }
        public void setExplainabilityMethod(String explainabilityMethod) { this.explainabilityMethod = explainabilityMethod; }
    }

    // Enums for common values
    public enum ModelType {
        READMISSION_RISK("30-day readmission risk prediction"),
        SEPSIS_PREDICTION("Sepsis onset prediction"),
        DETERIORATION_RISK("Clinical deterioration risk"),
        FALL_RISK("Patient fall risk assessment"),
        MORTALITY_RISK("In-hospital mortality risk"),
        LENGTH_OF_STAY("Length of stay prediction"),
        ICU_TRANSFER("ICU transfer prediction"),
        MEDICATION_ADHERENCE("Medication adherence prediction"),
        ADVERSE_EVENT("Adverse event prediction"),
        PAIN_SCORE("Pain level prediction");

        private final String description;

        ModelType(String description) {
            this.description = description;
        }

        public String getDescription() {
            return description;
        }
    }

    public enum RiskLevel {
        LOW("Low risk - routine monitoring"),
        MODERATE("Moderate risk - enhanced monitoring"),
        HIGH("High risk - immediate attention required"),
        CRITICAL("Critical risk - urgent intervention needed");

        private final String description;

        RiskLevel(String description) {
            this.description = description;
        }

        public String getDescription() {
            return description;
        }

        public boolean requiresIntervention() {
            return this == HIGH || this == CRITICAL;
        }
    }

    public enum ValidationStatus {
        PENDING("Validation pending"),
        VALIDATED("Prediction validated"),
        FLAGGED("Prediction flagged for review"),
        REJECTED("Prediction rejected"),
        EXPIRED("Prediction expired");

        private final String description;

        ValidationStatus(String description) {
            this.description = description;
        }

        public String getDescription() {
            return description;
        }
    }

    public double getConfidence() {
        return confidence != null ? confidence : 0.0;
    }
}
