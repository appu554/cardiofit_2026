
package com.cardiofit.flink.sinks;

import com.cardiofit.flink.models.RoutedEvent;
import com.cardiofit.flink.models.SemanticEvent;
import com.cardiofit.flink.models.PatternEvent;
import org.apache.flink.api.connector.sink2.Sink;
import org.apache.flink.api.connector.sink2.Sink.WriterInitContext;
import org.apache.flink.api.connector.sink2.SinkWriter;
import org.neo4j.driver.*;
import org.neo4j.driver.summary.ResultSummary;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;

import java.io.IOException;
import java.time.LocalDateTime;
import java.util.*;
import java.util.concurrent.CompletableFuture;
import java.util.concurrent.TimeUnit;

/**
 * Neo4j sink for clinical knowledge graph and relationship analytics
 * Stores patient relationships, clinical pathways, and treatment patterns
 * Enables graph-based clinical decision support and pattern mining
 *
 * Migrated to Flink 2.x Sink API (replaces RichSinkFunction)
 */
public class Neo4jGraphSink implements Sink<RoutedEvent> {

    private static final Logger LOG = LoggerFactory.getLogger(Neo4jGraphSink.class);

    // Configuration
    private final String uri;
    private final String username;
    private final String password;
    private final String database;

    public Neo4jGraphSink(String uri, String username, String password, String database) {
        this.uri = uri;
        this.username = username;
        this.password = password;
        this.database = database;
    }

    public Neo4jGraphSink() {
        // Default configuration matching shared infrastructure setup
        this.uri = System.getenv().getOrDefault("NEO4J_URI", "bolt://localhost:7687");
        this.username = System.getenv().getOrDefault("NEO4J_USERNAME", "neo4j");
        this.password = System.getenv().getOrDefault("NEO4J_PASSWORD", "CardioFit2024!");
        this.database = System.getenv().getOrDefault("NEO4J_DATABASE", "cardiofit");
    }

    @Override
    public SinkWriter<RoutedEvent> createWriter(InitContext context) throws IOException {
        return new Neo4jSinkWriter(uri, username, password, database);
    }

    /**
     * SinkWriter implementation for Neo4j graph operations
     */
    private static class Neo4jSinkWriter implements SinkWriter<RoutedEvent> {

        private static final Logger LOG = LoggerFactory.getLogger(Neo4jSinkWriter.class);

        private final String uri;
        private final String username;
        private final String password;
        private final String database;

        private transient Driver driver;
        private transient Session session;

        public Neo4jSinkWriter(String uri, String username, String password, String database) {
            this.uri = uri;
            this.username = username;
            this.password = password;
            this.database = database;

            try {
                // Initialize Neo4j driver
                driver = GraphDatabase.driver(uri, AuthTokens.basic(username, password));

                // Test connection
                try (Session testSession = driver.session(SessionConfig.forDatabase(database))) {
                    testSession.run("RETURN 1").consume();
                    LOG.info("Successfully connected to Neo4j at {} with database {}", uri, database);
                }

                // Create session for operations
                session = driver.session(SessionConfig.forDatabase(database));

                // Create necessary indexes and constraints
                createSchemaIfNotExists();
            } catch (Exception e) {
                LOG.error("Failed to initialize Neo4j sink", e);
                throw new RuntimeException("Neo4j initialization failed", e);
            }
        }

        private void createSchemaIfNotExists() {
            try {
                // Create indexes for better query performance
                session.run("CREATE INDEX patient_id IF NOT EXISTS FOR (p:Patient) ON (p.patientId)");
                session.run("CREATE INDEX event_id IF NOT EXISTS FOR (e:Event) ON (e.eventId)");
                session.run("CREATE INDEX clinical_concept IF NOT EXISTS FOR (c:ClinicalConcept) ON (c.conceptId)");
                session.run("CREATE INDEX medication_id IF NOT EXISTS FOR (m:Medication) ON (m.medicationId)");
                session.run("CREATE INDEX condition_code IF NOT EXISTS FOR (c:Condition) ON (c.code)");

                // Create constraints for data integrity
                session.run("CREATE CONSTRAINT patient_unique IF NOT EXISTS FOR (p:Patient) REQUIRE p.patientId IS UNIQUE");

                LOG.info("Neo4j schema initialized successfully");
            } catch (Exception e) {
                LOG.warn("Schema creation skipped (may already exist): {}", e.getMessage());
            }
        }

        @Override
        public void write(RoutedEvent event, Context context) throws IOException, InterruptedException {
            // Only process events routed to graph database
            if (!event.hasDestination("neo4j") && !event.hasDestination("graph_analytics")) {
                return;
            }

            try {
                // Determine the type of graph update based on event type
                switch (event.getSourceEventType()) {
                    case "SEMANTIC_EVENT":
                        processSemanticEvent(event);
                        break;
                    case "PATTERN_EVENT":
                        processPatternEvent(event);
                        break;
                    case "ML_PREDICTION":
                        processMLPrediction(event);
                        break;
                    case "PATIENT_CONTEXT":
                        processPatientContext(event);
                        break;
                    default:
                        processGenericEvent(event);
                }
            } catch (Exception e) {
                LOG.error("Failed to process event {} in Neo4j", event.getId(), e);
                throw new IOException("Neo4j write failed", e);
            }
        }

        private void processSemanticEvent(RoutedEvent event) {
            if (!(event.getOriginalPayload() instanceof SemanticEvent)) {
                return;
            }

            SemanticEvent semanticEvent = (SemanticEvent) event.getOriginalPayload();

            String query =
                "MERGE (p:Patient {patientId: $patientId}) " +
                "SET p.lastUpdated = datetime() " +
                "CREATE (e:SemanticEvent { " +
                    "eventId: $eventId, " +
                    "timestamp: datetime($timestamp), " +
                    "clinicalSignificance: $significance, " +
                    "confidence: $confidence " +
                "}) " +
                "MERGE (p)-[:HAS_EVENT]->(e) " +
                "WITH p, e " +
                "UNWIND $concepts AS concept " +
                "MERGE (c:ClinicalConcept {conceptId: concept.id}) " +
                "SET c.name = concept.name, " +
                    "c.category = concept.category, " +
                    "c.snomedCode = concept.snomedCode " +
                "MERGE (e)-[:CONTAINS_CONCEPT {confidence: concept.confidence}]->(c) " +
                "WITH p, e " +
                "UNWIND $medications AS med " +
                "MERGE (m:Medication {medicationId: med.id}) " +
                "SET m.name = med.name, " +
                    "m.dosage = med.dosage, " +
                    "m.route = med.route " +
                "MERGE (p)-[:TAKES_MEDICATION {since: datetime($timestamp)}]->(m) " +
                "MERGE (e)-[:INVOLVES_MEDICATION]->(m) " +
                "WITH p, e " +
                "UNWIND $conditions AS cond " +
                "MERGE (c:Condition {code: cond.code}) " +
                "SET c.name = cond.name, " +
                    "c.severity = cond.severity, " +
                    "c.onset = datetime(cond.onset) " +
                "MERGE (p)-[:HAS_CONDITION {active: true}]->(c) " +
                "MERGE (e)-[:RELATED_TO_CONDITION]->(c) " +
                "RETURN p, e";

            Map<String, Object> parameters = new HashMap<>();
            parameters.put("patientId", event.getPatientId());
            parameters.put("eventId", event.getId());
            parameters.put("timestamp", event.getRoutingTime());
            parameters.put("significance", semanticEvent.getClinicalSignificance());
            parameters.put("confidence", semanticEvent.getOverallConfidence());

            // Extract clinical concepts, medications, and conditions from semantic event
            parameters.put("concepts", extractClinicalConcepts(semanticEvent));
            parameters.put("medications", extractMedications(semanticEvent));
            parameters.put("conditions", extractConditions(semanticEvent));

            Result result = session.run(query, parameters);
            ResultSummary summary = result.consume();

            LOG.debug("Created semantic event graph with {} nodes and {} relationships",
                    summary.counters().nodesCreated(), summary.counters().relationshipsCreated());
        }

        private void processPatternEvent(RoutedEvent event) {
            if (!(event.getOriginalPayload() instanceof PatternEvent)) {
                return;
            }

            PatternEvent patternEvent = (PatternEvent) event.getOriginalPayload();

            String query =
                "MERGE (p:Patient {patientId: $patientId}) " +
                "CREATE (pat:Pattern { " +
                    "patternId: $patternId, " +
                    "patternType: $patternType, " +
                    "confidence: $confidence, " +
                    "severity: $severity, " +
                    "detectedAt: datetime($timestamp) " +
                "}) " +
                "MERGE (p)-[:HAS_PATTERN {active: true}]->(pat) " +
                "WITH p, pat " +
                "UNWIND $relatedEvents AS eventId " +
                "MATCH (e:Event {eventId: eventId}) " +
                "MERGE (pat)-[:DETECTED_FROM]->(e) " +
                "WITH p, pat " +
                "MATCH (p)-[:HAS_PATTERN]->(prevPattern:Pattern) " +
                "WHERE prevPattern.patternType = pat.patternType " +
                    "AND prevPattern.detectedAt < pat.detectedAt " +
                "MERGE (prevPattern)-[:EVOLVED_TO]->(pat) " +
                "RETURN p, pat";

            Map<String, Object> parameters = new HashMap<>();
            parameters.put("patientId", event.getPatientId());
            parameters.put("patternId", event.getId());
            parameters.put("patternType", patternEvent.getPatternType());
            parameters.put("confidence", patternEvent.getConfidence());
            parameters.put("severity", patternEvent.getSeverity());
            parameters.put("timestamp", event.getRoutingTime());
            parameters.put("relatedEvents", patternEvent.getInvolvedEvents());

            session.run(query, parameters);
            LOG.debug("Created pattern event graph for patient {}", event.getPatientId());
        }

        private void processMLPrediction(RoutedEvent event) {
            String query =
                "MERGE (p:Patient {patientId: $patientId}) " +
                "CREATE (pred:Prediction { " +
                    "predictionId: $predictionId, " +
                    "predictionType: $predictionType, " +
                    "riskScore: $riskScore, " +
                    "confidence: $confidence, " +
                    "timestamp: datetime($timestamp), " +
                    "validUntil: datetime($validUntil) " +
                "}) " +
                "MERGE (p)-[:HAS_PREDICTION {current: true}]->(pred) " +
                "WITH p, pred " +
                "MATCH (p)-[r:HAS_PREDICTION]->(oldPred:Prediction) " +
                "WHERE oldPred.predictionType = pred.predictionType " +
                    "AND oldPred.timestamp < pred.timestamp " +
                    "AND oldPred <> pred " +
                "SET r.current = false " +
                "RETURN p, pred";

            Map<String, Object> mlData = (Map<String, Object>) event.getOriginalPayload();

            Map<String, Object> parameters = new HashMap<>();
            parameters.put("patientId", event.getPatientId());
            parameters.put("predictionId", event.getId());
            parameters.put("predictionType", mlData.get("predictionType"));
            parameters.put("riskScore", mlData.get("riskScore"));
            parameters.put("confidence", mlData.get("confidence"));
            parameters.put("timestamp", event.getRoutingTime());
            parameters.put("validUntil", System.currentTimeMillis() + TimeUnit.HOURS.toMillis(24));

            session.run(query, parameters);
            LOG.debug("Created ML prediction graph for patient {}", event.getPatientId());
        }

        private void processPatientContext(RoutedEvent event) {
            String query =
                "MERGE (p:Patient {patientId: $patientId}) " +
                "SET p.lastContextUpdate = datetime($timestamp), " +
                    "p.demographics = $demographics, " +
                    "p.riskFactors = $riskFactors, " +
                    "p.careTeam = $careTeam " +
                "WITH p " +
                "UNWIND $recentEvents AS event " +
                "MERGE (e:Event {eventId: event.id}) " +
                "SET e.eventType = event.type, " +
                    "e.timestamp = datetime(event.timestamp) " +
                "MERGE (p)-[:HAS_EVENT]->(e) " +
                "RETURN p";

            Map<String, Object> context = (Map<String, Object>) event.getOriginalPayload();

            Map<String, Object> parameters = new HashMap<>();
            parameters.put("patientId", event.getPatientId());
            parameters.put("timestamp", event.getRoutingTime());
            parameters.put("demographics", context.get("demographics"));
            parameters.put("riskFactors", context.get("riskFactors"));
            parameters.put("careTeam", context.get("careTeam"));
            parameters.put("recentEvents", context.get("recentEvents"));

            session.run(query, parameters);
            LOG.debug("Updated patient context graph for {}", event.getPatientId());
        }

        private void processGenericEvent(RoutedEvent event) {
            String query =
                "MERGE (p:Patient {patientId: $patientId}) " +
                "CREATE (e:Event { " +
                    "eventId: $eventId, " +
                    "eventType: $eventType, " +
                    "timestamp: datetime($timestamp), " +
                    "priority: $priority, " +
                    "data: $data " +
                "}) " +
                "MERGE (p)-[:HAS_EVENT]->(e) " +
                "RETURN p, e";

            Map<String, Object> parameters = new HashMap<>();
            parameters.put("patientId", event.getPatientId());
            parameters.put("eventId", event.getId());
            parameters.put("eventType", event.getSourceEventType());
            parameters.put("timestamp", event.getRoutingTime());
            parameters.put("priority", event.getPriority().name());
            parameters.put("data", convertToString(event.getOriginalPayload()));

            session.run(query, parameters);
            LOG.debug("Created generic event graph for patient {}", event.getPatientId());
        }

        private List<Map<String, Object>> extractClinicalConcepts(SemanticEvent event) {
            List<Map<String, Object>> concepts = new ArrayList<>();
            if (event.getClinicalConcepts() != null) {
                for (String conceptId : event.getClinicalConcepts()) {
                    Map<String, Object> concept = new HashMap<>();
                    concept.put("id", conceptId);
                    concept.put("name", conceptId);
                    concept.put("category", "clinical");
                    concept.put("snomedCode", generateSnomedCode(conceptId));
                    concept.put("confidence", event.getOverallConfidence());
                    concepts.add(concept);
                }
            }
            return concepts;
        }

        private List<Map<String, Object>> extractMedications(SemanticEvent event) {
            List<Map<String, Object>> medications = new ArrayList<>();
            if (event.hasDrugInteractions()) {
                // Extract medication data from semantic event
                // This would parse the actual medication information
                Map<String, Object> med = new HashMap<>();
                med.put("id", "med_" + UUID.randomUUID());
                med.put("name", "extracted_medication");
                med.put("dosage", "as_prescribed");
                med.put("route", "oral");
                medications.add(med);
            }
            return medications;
        }

        private List<Map<String, Object>> extractConditions(SemanticEvent event) {
            List<Map<String, Object>> conditions = new ArrayList<>();
            if (event.getClinicalConcepts() != null) {
                // Extract condition data from clinical concepts
                for (String concept : event.getClinicalConcepts()) {
                    if (concept.contains("condition") || concept.contains("diagnosis")) {
                        Map<String, Object> cond = new HashMap<>();
                        cond.put("code", "ICD10_" + concept.hashCode());
                        cond.put("name", concept);
                        cond.put("severity", event.getClinicalSignificance());
                        cond.put("onset", event.getEventTime());
                        conditions.add(cond);
                    }
                }
            }
            return conditions;
        }

        private String generateSnomedCode(String conceptId) {
            // In production, this would map to actual SNOMED codes
            return "SNOMED_" + conceptId.hashCode();
        }

        private String convertToString(Object payload) {
            if (payload == null) return "";
            try {
                return payload.toString();
            } catch (Exception e) {
                return "";
            }
        }

        @Override
        public void flush(boolean endOfInput) throws IOException, InterruptedException {
            // Neo4j session.run() is synchronous, no explicit flush needed
            LOG.debug("Flush called (endOfInput: {})", endOfInput);
        }

        @Override
        public void close() throws Exception {
            if (session != null) {
                session.close();
            }
            if (driver != null) {
                driver.close();
            }
            LOG.info("Neo4j sink closed");
        }
    }
}
