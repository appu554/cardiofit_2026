### **4.4 Action Generation**\
\
**Generate Actions from Protocols:**\
\
```\
FUNCTION generateActions(protocol, patientContext, confidence):\
    \
    actions = []\
    \
    // 1. Generate mandatory actions\
    FOR EACH mandatory_action IN protocol.mandatory_actions:\
        \
        action = buildAction(mandatory_action, patientContext)\
        \
        // Apply patient-specific modifications\
        action = applyPatientSpecificModifications(action, patientContext)\
        \
        // Check timing constraints\
        action = applyTimingConstraints(action, protocol.time_constraints)\
        \
        actions.add(action)\
    \
    // 2. Generate optional actions (if high confidence)\
    IF confidence >= 0.7:\
        FOR EACH optional_action IN protocol.optional_actions:\
            action = buildAction(optional_action, patientContext)\
            action.is_optional = true\
            actions.add(action)\
    \
    // 3. Add monitoring actions\
    monitoring_actions = generateMonitoringActions(protocol, patientContext)\
    actions.addAll(monitoring_actions)\
    \
    // 4. Add escalation actions (if criteria met)\
    escalation_actions = generateEscalationActions(protocol, patientContext)\
    actions.addAll(escalation_actions)\
    \
    RETURN actions\
\
\
FUNCTION buildAction(action_template, patientContext):\
    \
    action = new RecommendedAction()\
    \
    // Copy template fields\
    action.action_id = action_template.action_id\
    action.action_type = action_template.type\
    action.title = action_template.title\
    action.timeframe = action_template.timing\
    action.rationale = action_template.rationale\
    action.evidence = action_template.evidence_reference\
    \
    // Handle medication actions\
    IF action_template.type == "THERAPEUTIC" AND \
       action_template.medication_selection:\
        \
        // Select appropriate medication\
        medication = selectMedication(\
            action_template.medication_selection,\
            patientContext\
        )\
        \
        // Calculate dose (with adjustments)\
        dose = calculateDose(medication, patientContext)\
        \
        action.specific_recommendation = formatMedicationOrder(medication, dose)\
        action.alternatives = buildAlternatives(\
            action_template.medication_selection.alternatives,\
            patientContext\
        )\
        action.contraindications = medication.contraindications\
        action.monitoring_required = medication.monitoring\
    \
    // Handle diagnostic actions\
    ELSE IF action_template.type == "DIAGNOSTIC":\
        action.specific_recommendation = action_template.specifications\
        action.interpretation_guidance = action_template.interpretation\
    \
    // Handle intervention actions\
    ELSE IF action_template.type == "INTERVENTION":\
        action.steps = action_template.specifications\
        action.targets = action_template.targets\
        action.monitoring_required = action_template.monitoring\
    \
    RETURN action\
\
\
FUNCTION selectMedication(medication_selection, patientContext):\
    \
    // Try primary recommendation first\
    primary = medication_selection.primary\
    \
    // Check if conditions are met\
    IF checkMedicationConditions(primary.conditions, patientContext):\
        RETURN primary\
    \
    // Try alternatives\
    FOR EACH alternative IN medication_selection.alternatives:\
        IF checkMedicationConditions(alternative.conditions, patientContext):\
            RETURN alternative\
    \
    // Fallback: return primary with warning\
    RETURN \{\
        medication: primary,\
        warning: "Primary medication selected but contraindication checking required"\
    \}\
\
\
FUNCTION checkMedicationConditions(conditions, patientContext):\
    \
    FOR EACH condition IN conditions:\
        \
        SWITCH condition:\
            CASE "NO_PENICILLIN_ALLERGY":\
                IF patientContext.allergies.contains("penicillin"):\
                    RETURN false\
            \
            CASE "NORMAL_RENAL_FUNCTION":\
                IF patientContext.renal_function.clearance < 60:\
                    RETURN false\
            \
            CASE "MRSA_RISK":\
                IF patientHasMRSARisk(patientContext):\
                    RETURN true\
                ELSE:\
                    RETURN false\
            \
            CASE "MDR_RISK":\
                IF patientHasMDRRisk(patientContext):\
                    RETURN true\
                ELSE:\
                    RETURN false\
    \
    RETURN true\
\
\
FUNCTION calculateDose(medication, patientContext):\
    \
    // Start with standard dose\
    dose = medication.dosing.standard\
    \
    // Adjust for renal function\
    IF medication.dosing.renal_adjusted:\
        clearance = estimateCreatinineClearance(patientContext)\
        \
        FOR EACH adjustment IN medication.dosing.renal_adjusted:\
            range = parseRange(adjustment.creatinine_clearance)\
            IF clearance >= range.low AND clearance <= range.high:\
                dose = adjustment.dose\
                break\
    \
    // Adjust for weight (if specified)\
    IF medication.dosing.weight_based:\
        weight = patientContext.weight OR estimateWeight(patientContext)\
        dose = medication.dosing.mg_per_kg * weight\
    \
    // Adjust for age (pediatric/geriatric)\
    IF patientContext.age < 18:\
        dose = adjustPediatricDose(dose, patientContext.age, patientContext.weight)\
    ELSE IF patientContext.age > 75:\
        dose = dose * 0.75  // Reduce by 25% for elderly\
    \
    // Hepatic adjustment\
    IF patientContext.hepatic_function == "IMPAIRED":\
        dose = dose * medication.dosing.hepatic_adjustment_factor\
    \
    RETURN dose\
\
\
FUNCTION estimateCreatinineClearance(patientContext):\
    // Cockcroft-Gault equation\
    \
    creatinine = patientContext.getLabValue("2160-0")\
    IF NOT creatinine:\
        RETURN "UNKNOWN"\
    \
    age = patientContext.age\
    weight = patientContext.weight OR estimateWeight(patientContext)\
    sex = patientContext.sex\
    \
    // CrCl = [(140 - age) \'d7 weight \'d7 (0.85 if female)] / (72 \'d7 Cr)\
    clearance = ((140 - age) * weight) / (72 * creatinine.value)\
    \
    IF sex == "female":\
        clearance = clearance * 0.85\
    \
    RETURN clearance\
```\
