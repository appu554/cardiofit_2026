### **6.1 Evidence Linking System**\
\
```\
FUNCTION attachEvidence(action, knowledgeBase):\
    \
    evidence_package = \{\
        primary_guideline: null,\
        supporting_studies: [],\
        evidence_level: null,\
        class_of_recommendation: null,\
        confidence: null\
    \}\
    \
    // Link to clinical guideline\
    IF action.evidence_reference:\
        guideline = knowledgeBase.guidelines.get(action.evidence_reference)\
        IF guideline:\
            evidence_package.primary_guideline = \{\
                title: guideline.title,\
                organization: guideline.organization,\
                year: guideline.year,\
                url: guideline.url,\
                recommendation_text: guideline.recommendation_for_action(action)\
            \}\
            evidence_package.evidence_level = guideline.evidence_level\
            evidence_package.class_of_recommendation = guideline.class\
    \
    // Link to supporting research\
    IF action.supporting_pmids:\
        FOR EACH pmid IN action.supporting_pmids:\
            study = knowledgeBase.evidence.get(pmid)\
            IF study:\
                evidence_package.supporting_studies.add(\{\
                    pmid: study.pmid,\
                    title: study.title,\
                    authors: study.first_author + " et al.",\
                    journal: study.journal,\
                    year: study.year,\
                    key_finding: study.key_finding,\
                    url: "https://pubmed.ncbi.nlm.nih.gov/" + pmid\
                \})\
    \
    // Calculate confidence\
    evidence_package.confidence = calculateEvidenceConfidence(evidence_package)\
    \
    action.evidence = evidence_package\
    \
    RETURN action\
\
\
FUNCTION calculateEvidenceConfidence(evidence_package):\
    \
    confidence = 0.5  // Base confidence\
    \
    // Evidence level contribution\
    SWITCH evidence_package.evidence_level:\
        CASE "A":  // High-quality RCTs, meta-analyses\
            confidence += 0.4\
        CASE "B":  // Moderate-quality studies\
            confidence += 0.3\
        CASE "C":  // Observational studies, case series\
            confidence += 0.15\
        CASE "EXPERT_OPINION":\
            confidence += 0.05\
    \
    // Class of recommendation contribution\
    SWITCH evidence_package.class_of_recommendation:\
        CASE "I":  // Benefit >>> Risk\
            confidence += 0.1\
        CASE "IIa":  // Benefit >> Risk\
            confidence += 0.05\
        CASE "IIb":  // Benefit \uc0\u8805  Risk\
            confidence += 0.02\
    \
    // Supporting studies boost confidence\
    study_count = evidence_package.supporting_studies.length\
    IF study_count >= 5:\
        confidence += 0.1\
    ELSE IF study_count >= 2:\
        confidence += 0.05\
    \
    // Cap at 0.95 (never 100% certain)\
    confidence = min(confidence, 0.95)\
    \
    RETURN confidence\
