## \uc0\u55358 \u56800  **3. Clinical Knowledge Base Design**\
\
### **3.1 Protocol Definition Language**\
\
**YAML-Based Protocol Format:**\
\
```yaml\
protocol:\
  id: "SEPSIS_BUNDLE_SSC_2021"\
  name: "Sepsis Resuscitation Bundle"\
  version: "2021"\
  organization: "Surviving Sepsis Campaign"\
  evidence_level: "A"\
  \
  trigger_criteria:\
    all_of:\
      - condition: "SIRS_CRITERIA"\
        threshold: 2\
        description: "\uc0\u8805 2 SIRS criteria met"\
      \
      - any_of:\
          - condition: "ELEVATED_LACTATE"\
            threshold: 2.0\
            unit: "mmol/L"\
          - condition: "SUSPECTED_INFECTION"\
            indicators: ["FEVER", "LEUKOCYTOSIS", "HYPOTHERMIA"]\
          - condition: "ORGAN_DYSFUNCTION"\
            markers: ["HYPOTENSION", "ALTERED_MENTAL_STATUS", "ELEVATED_CREATININE"]\
  \
  confidence_scoring:\
    base_score: 0.8\
    modifiers:\
      - if: "LACTATE > 4.0"\
        adjust: +0.1\
        reason: "Severe hyperlactatemia strongly suggests sepsis"\
      - if: "MULTIPLE_ORGAN_DYSFUNCTION"\
        adjust: +0.1\
        reason: "Multi-organ failure increases sepsis likelihood"\
      - if: "RECENT_INFECTION_NEGATIVE"\
        adjust: -0.2\
        reason: "No clear infectious source reduces confidence"\
  \
  time_constraints:\
    hour_0:\
      description: "Initial recognition"\
      actions: ["BLOOD_CULTURES", "LACTATE_MEASUREMENT"]\
    \
    hour_1:\
      description: "1-hour bundle"\
      actions: ["BROAD_SPECTRUM_ANTIBIOTICS", "FLUID_RESUSCITATION_INITIATE"]\
      critical: true\
      mortality_impact: "Each hour delay increases mortality by 7.6%"\
    \
    hour_3:\
      description: "3-hour bundle completion"\
      actions: ["FLUID_RESUSCITATION_COMPLETE", "REPEAT_LACTATE"]\
      target: "30 mL/kg crystalloid if hypotensive or lactate \uc0\u8805 4"\
  \
  mandatory_actions:\
    - action_id: "SEPSIS_BLOOD_CULTURES"\
      type: "DIAGNOSTIC"\
      priority: 1\
      title: "Obtain Blood Cultures"\
      timing: "Before antibiotics"\
      specifications:\
        - "2 sets (aerobic + anaerobic)"\
        - "From different sites"\
        - "Minimum 10mL per bottle"\
        - "Sterile technique"\
      rationale: "Identify causative organism for targeted therapy"\
      evidence_reference: "SSC_2021_RECOMMENDATION_1"\
    \
    - action_id: "SEPSIS_ANTIBIOTICS"\
      type: "THERAPEUTIC"\
      priority: 1\
      title: "Administer Broad-Spectrum Antibiotics"\
