## \uc0\u55357 \u57057 \u65039  **5. Contraindication Checking**\
\
### **5.1 Multi-Level Contraindication System**\
\
```\
FUNCTION checkContraindications(action, patientContext):\
    \
    contraindications = \{\
        absolute: [],\
        relative: [],\
        warnings: []\
    \}\
    \
    // Level 1: Allergy checking\
    IF action.action_type == "THERAPEUTIC":\
        allergy_check = checkAllergies(action, patientContext)\
        IF allergy_check.has_absolute_contraindication:\
            contraindications.absolute.add(allergy_check.reason)\
            action.status = "CONTRAINDICATED"\
            RETURN contraindications\
        IF allergy_check.has_cross_reactivity:\
            contraindications.warnings.add(allergy_check.warning)\
    \
    // Level 2: Organ dysfunction\
    organ_contraindications = checkOrganDysfunction(action, patientContext)\
    contraindications.addAll(organ_contraindications)\
    \
    // Level 3: Drug-drug interactions\
    IF action.action_type == "THERAPEUTIC":\
        interactions = checkDrugInteractions(action, patientContext)\
        contraindications.addAll(interactions)\
    \
    // Level 4: Pregnancy/lactation\
    IF patientContext.is_pregnant OR patientContext.is_lactating:\
        pregnancy_check = checkPregnancySafety(action, patientContext)\
        contraindications.addAll(pregnancy_check)\
    \
    // Level 5: Age-related contraindications\
    age_check = checkAgeAppropriateness(action, patientContext)\
    contraindications.addAll(age_check)\
    \
    // Level 6: Disease-specific contraindications\
    disease_check = checkDiseaseContraindications(action, patientContext)\
    contraindications.addAll(disease_check)\
    \
    // Mark action status\
    IF contraindications.absolute.length > 0:\
        action.status = "CONTRAINDICATED"\
        action.recommend_alternative = true\
    ELSE IF contraindications.relative.length > 0:\
        action.status = "USE_WITH_CAUTION"\
    ELSE IF contraindications.warnings.length > 0:\
        action.status = "MONITOR_CLOSELY"\
    ELSE:\
        action.status = "SAFE_TO_PROCEED"\
    \
    action.contraindication_details = contraindications\
    \
    RETURN contraindications\
\
\
FUNCTION checkAllergies(action, patientContext):\
    \
    medication = action.medication\
    patient_allergies = patientContext.allergies\
    \
    result = \{\
        has_absolute_contraindication: false,\
        has_cross_reactivity: false,\
        reason: null,\
        warning: null\
    \}\
    \
    // Check direct allergy\
    IF patient_allergies.contains(medication.generic_name):\
        result.has_absolute_contraindication = true\
        result.reason = "Patient has documented allergy to " + medication.generic_name\
        RETURN result\
    \
    // Check drug class allergy\
    IF patient_allergies.contains(medication.drug_class):\
        result.has_absolute_contraindication = true\
        result.reason = "Patient allergic to " + medication.drug_class + " class"\
        RETURN result\
    \
    // Check cross-reactivity\
    IF medication.drug_class == "BETA_LACTAM":\
        IF patient_allergies.contains("penicillin"):\
            // Cephalosporins have ~1-10% cross-reactivity with penicillin\
            IF medication.subclass == "CEPHALOSPORIN":\
                result.has_cross_reactivity = true\
                result.warning = "10% cross-reactivity risk with penicillin allergy"\
            // Carbapenems have ~1% cross-reactivity\
            ELSE IF medication.subclass == "CARBAPENEM":\
                result.has_cross_reactivity = true\
                result.warning = "1% cross-reactivity risk with penicillin allergy"\
    \
    RETURN result\
\
\
FUNCTION checkOrganDysfunction(action, patientContext):\
    \
    contraindications = \{absolute: [], relative: [], warnings: []\}\
    \
    // Renal dysfunction\
    IF patientContext.renal_function.clearance < 30:\
        IF action.medication AND action.medication.renal_excretion > 70:\
            contraindications.relative.add(\{\
                organ: "KIDNEY",\
                severity: "SEVERE_IMPAIRMENT",\
                recommendation: "Dose reduction required: " + action.medication.adjusted_dose\
            \})\
    \
    // Hepatic dysfunction\
    IF patientContext.hepatic_function == "CIRRHOSIS":\
        IF action.medication AND action.medication.hepatic_metabolism > 80:\
            contraindications.relative.add(\{\
                organ: "LIVER",\
                severity: "CIRRHOSIS",\
                recommendation: "Dose reduction and close monitoring required"\
            \})\
    \
    // Cardiac dysfunction\
    IF patientContext.has_heart_failure:\
        IF action.involves_fluid_administration:\
            IF action.volume > 1000:  // >1L fluid\
                contraindications.warnings.add(\{\
                    organ: "HEART",\
                    issue: "FLUID_OVERLOAD_RISK",\
                    recommendation: "Cautious fluid administration, monitor closely for pulmonary edema"\
                \})\
    \
    RETURN contraindications\
\
\
FUNCTION checkDrugInteractions(action, patientContext):\
    \
    interactions = \{absolute: [], relative: [], warnings: []\}\
    \
    new_medication = action.medication\
    current_medications = patientContext.medications\
    \
    FOR EACH current_med IN current_medications:\
        \
        // Check interaction database\
        interaction = drugInteractionDatabase.query(\
            drug1: new_medication.rxnorm_code,\
            drug2: current_med.rxnorm_code\
        )\
        \
        IF interaction:\
            SWITCH interaction.severity:\
                CASE "CONTRAINDICATED":\
                    interactions.absolute.add(\{\
                        interacting_drug: current_med.name,\
                        mechanism: interaction.mechanism,\
                        consequence: interaction.consequence,\
                        recommendation: "Do not administer. Use alternative."\
                    \})\
                \
                CASE "MAJOR":\
                    interactions.relative.add(\{\
                        interacting_drug: current_med.name,\
                        mechanism: interaction.mechanism,\
                        consequence: interaction.consequence,\
                        recommendation: interaction.management\
                    \})\
                \
                CASE "MODERATE":\
                    interactions.warnings.add(\{\
                        interacting_drug: current_med.name,\
                        recommendation: "Monitor for " + interaction.consequence\
                    \})\
    \
    // Special case: QT prolongation risk\
    IF new_medication.prolongs_qt:\
        qt_prolonging_meds = current_medications.filter(m => m.prolongs_qt)\
        IF qt_prolonging_meds.length > 0:\
            interactions.relative.add(\{\
                issue: "ADDITIVE_QT_PROLONGATION",\
                interacting_drugs: qt_prolonging_meds.map(m => m.name),\
                recommendation: "Obtain baseline ECG, monitor QTc interval"\
            \})\
    \
    RETURN interactions\
```\
