### **4.5 Priority Assignment**\
\
**Multi-Dimensional Priority Scoring:**\
\
```\
FUNCTION assignPriority(action, patientContext, protocolUrgency):\
    \
    score = 0.0\
    \
    // Dimension 1: Clinical Impact (0-10)\
    clinical_impact = assessClinicalImpact(action)\
    score += clinical_impact * 3.0  // Weight: 3x\
    \
    // Dimension 2: Time Sensitivity (0-10)\
    time_sensitivity = assessTimeSensitivity(action)\
    score += time_sensitivity * 2.5  // Weight: 2.5x\
    \
    // Dimension 3: Protocol Priority (0-10)\
    protocol_priority = action.priority OR protocolUrgency\
    score += protocol_priority * 2.0  // Weight: 2x\
    \
    // Dimension 4: Feasibility (0-10)\
    feasibility = assessFeasibility(action, patientContext)\
    score += feasibility * 1.0  // Weight: 1x\
    \
    // Dimension 5: Evidence Strength (0-10)\
    evidence_strength = assessEvidenceStrength(action)\
    score += evidence_strength * 0.5  // Weight: 0.5x\
    \
    // Normalize to 0-100 scale\
    final_score = (score / 90.0) * 100\
    \
    // Assign priority level\
    priority_level = categorizePriority(final_score)\
    \
    action.priority_score = final_score\
    action.priority_level = priority_level\
    \
    RETURN action\
\
\
FUNCTION assessClinicalImpact(action):\
    \
    // Life-saving interventions\
    IF action.action_type IN ["ESCALATION", "CRITICAL_INTERVENTION"]:\
        RETURN 10\
    \
    // Time-sensitive therapeutic actions\
    IF action.action_type == "THERAPEUTIC" AND \
       action.timeframe IN ["IMMEDIATE", "STAT", "Within 1 hour"]:\
        RETURN 9\
    \
    // Diagnostic actions for life-threatening conditions\
    IF action.action_type == "DIAGNOSTIC" AND\
       action.related_to IN ["SEPSIS", "STEMI", "STROKE"]:\
        RETURN 8\
    \
    // Preventive interventions\
    IF action.prevents IN ["ORGAN_FAILURE", "DETERIORATION"]:\
        RETURN 7\
    \
    // Supportive care\
    IF action.action_type == "MONITORING":\
        RETURN 5\
    \
    // Medication reviews\
    IF action.action_type == "MEDICATION_REVIEW":\
        RETURN 4\
    \
    // Optional/comfort measures\
    IF action.is_optional:\
        RETURN 3\
    \
    RETURN 5  // Default\
\
\
FUNCTION assessTimeSensitivity(action):\
    \
    timeframe = action.timeframe.toLowerCase()\
    \
    IF timeframe.contains("immediate") OR timeframe.contains("stat"):\
        RETURN 10\
    \
    IF timeframe.contains("within 1 hour") OR timeframe.contains("<1h"):\
        RETURN 9\
    \
    IF timeframe.contains("within 3 hours") OR timeframe.contains("<3h"):\
        RETURN 7\
    \
    IF timeframe.contains("within 6 hours") OR timeframe.contains("<6h"):\
        RETURN 5\
    \
    IF timeframe.contains("within 24 hours") OR timeframe.contains("urgent"):\
        RETURN 3\
    \
    IF timeframe.contains("routine"):\
        RETURN 1\
    \
    RETURN 5  // Default\
\
\
FUNCTION assessFeasibility(action, patientContext):\
    \
    feasibility = 10  // Start optimistic\
    \
    // Check resource availability\
    IF action.requires_resource:\
        FOR EACH resource IN action.requires_resource:\
            IF NOT patientContext.available_resources.contains(resource):\
                feasibility -= 2\
                action.feasibility_notes.add(\
                    "Resource not immediately available: " + resource\
                )\
    \
    // Check time of day constraints\
    IF action.preferred_time AND NOT matchesCurrentTime(action.preferred_time):\
        feasibility -= 1\
    \
    // Check patient cooperation required\
    IF action.requires_patient_cooperation AND \
       patientContext.consciousness != "Alert":\
        feasibility -= 2\
        action.feasibility_notes.add("Patient may not be able to cooperate")\
    \
    // Check specialty availability\
    IF action.requires_specialist:\
        IF patientContext.time_of_day IN ["night", "weekend"]:\
            feasibility -= 1\
            action.feasibility_notes.add("Specialist may not be immediately available")\
    \
    RETURN max(feasibility, 1)  // Minimum 1\
\
\
FUNCTION assessEvidenceStrength(action):\
    \
    IF NOT action.evidence:\
        RETURN 5  // Default\
    \
    evidence_level = action.evidence.level\
    \
    SWITCH evidence_level:\
        CASE "A":  // High-quality evidence\
            RETURN 10\
        CASE "B":  // Moderate-quality evidence\
            RETURN 7\
        CASE "C":  // Low-quality evidence\
            RETURN 5\
        CASE "EXPERT_OPINION":\
            RETURN 3\
        DEFAULT:\
            RETURN 5\
\
\
FUNCTION categorizePriority(score):\
    \
    IF score >= 85:\
        RETURN "P0_CRITICAL"  // Life-threatening, immediate action\
    \
    IF score >= 70:\
        RETURN "P1_URGENT"    // Time-sensitive, <1 hour\
    \
    IF score >= 50:\
        RETURN "P2_HIGH"      // Important, <6 hours\
    \
    IF score >= 30:\
        RETURN "P3_MEDIUM"    // Moderate, <24 hours\
    \
    RETURN "P4_LOW"           // Routine\
