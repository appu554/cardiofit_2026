### **5.2 Alternative Generation**\
\
```\
FUNCTION generateAlternatives(action, contraindications, patientContext):\
    \
    IF contraindications.absolute.length == 0:\
        RETURN []  // No alternatives needed\
    \
    alternatives = []\
    \
    // Get alternatives from knowledge base\
    IF action.action_type == "THERAPEUTIC":\
        \
        primary_indication = action.indication\
        contraindicated_drug_class = action.medication.drug_class\
        \
        // Find alternative medications for same indication\
        alternative_meds = medicationDatabase.query(\
            indication: primary_indication,\
            exclude_class: contraindicated_drug_class\
        )\
        \
        FOR EACH alt_med IN alternative_meds:\
            \
            // Check if alternative is also contraindicated\
            alt_contraindications = checkContraindications(\
                createActionForMedication(alt_med),\
                patientContext\
            )\
            \
            IF alt_contraindications.absolute.length == 0:\
                alternatives.add(\{\
                    medication: alt_med.name,\
                    dose: alt_med.standard_dose,\
                    rationale: "Alternative to " + action.medication.name + \
                              " due to " + contraindications.absolute[0].reason,\
                    evidence: alt_med.evidence_level\
                \})\
    \
    // Sort alternatives by evidence strength and safety\
    alternatives.sort((a, b) => \
        compareEvidence(a.evidence, b.evidence) OR\
        compareSafety(a, b, patientContext)\
    )\
    \
    RETURN alternatives\
