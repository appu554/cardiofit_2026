## \uc0\u55357 \u56510  **7. State Management**\
\
### **7.1 Patient History Tracking**\
\
```\
CLASS PatientHistoryState \{\
    \
    patient_id: String\
    \
    // Event history\
    recent_events: CircularBuffer<EnrichedPatientContext>  // Last 100 events\
    \
    // Lab history\
    lab_history: Map<String, TimeSeries<LabResult>>  // By LOINC code\
    \
    // Vital history\
    vital_history: Map<String, TimeSeries<VitalReading>>  // By vital name\
    \
    // Medication history\
    medication_history: List<MedicationEvent>\
    \
    // Recommendation history\
    recommendation_history: List<ClinicalRecommendation>\
    acknowledged_recommendations: Map<String, AcknowledgmentInfo>\
    \
    // Protocol execution tracking\
    active_protocols: Map<String, ProtocolExecutionState>\
    completed_protocols: List<ProtocolCompletion>\
    \
    // Baseline tracking\
    chronic_baselines: Map<String, BaselineValue>\
    \
    // Outcome tracking\
    clinical_outcomes: List<OutcomeEvent>\
    \
    \
    FUNCTION addEvent(event: EnrichedPatientContext):\
        recent_events.add(event)\
        \
        // Update lab history\
        FOR EACH lab IN event.labs:\
            IF NOT lab_history.contains(lab.loincCode):\
                lab_history.put(lab.loincCode, new TimeSeries())\
            lab_history.get(lab.loincCode).add(lab)\
        \
        // Update vital history\
        FOR EACH vital IN event.vitals:\
            IF NOT vital_history.contains(vital.name):\
                vital_history.put(vital.name, new TimeSeries())\
            vital_history.get(vital.name).add(vital)\
    \
    \
    FUNCTION addRecommendation(recommendation: ClinicalRecommendation):\
        recommendation_history.add(recommendation)\
        \
        // Track protocol activation\
        IF recommendation.protocol:\
            IF NOT active_protocols.contains(recommendation.protocol.id):\
                active_protocols.put(recommendation.protocol.id, \{\
                    protocol_id: recommendation.protocol.id,\
                    activated_at: now(),\
                    actions_pending: recommendation.actions.length,\
                    actions_completed: 0,\
                    status: "ACTIVE"\
                \})\
    \
    \
    FUNCTION acknowledgeRecommendation(recommendation_id: String, user: String):\
        acknowledged_recommendations.put(recommendation_id, \{\
            acknowledged_at: now(),\
            acknowledged_by: user,\
            actions_selected: []\
        \})\
    \
    \
    FUNCTION recordActionCompleted(action_id: String, completion_info: Map):\
        // Find which protocol this action belongs to\
        FOR EACH protocol IN active_protocols.values():\
            IF protocol.contains(action_id):\
                protocol.actions_completed += 1\
                protocol.action_completion_times.put(action_id, now())\
                \
                // Check if protocol complete\
                IF protocol.actions_completed >= protocol.actions_pending:\
                    protocol.status = "COMPLETED"\
                    protocol.completed_at = now()\
                    \
                    // Move to completed\
                    completed_protocols.add(protocol)\
                    active_protocols.remove(protocol.protocol_id)\
    \
    \
    FUNCTION hasRecentRecommendation(action_type: String, minutes_ago: int):\
        cutoff = now() - (minutes_ago * 60 * 1000)\
        \
        FOR EACH rec IN recommendation_history:\
            IF rec.timestamp > cutoff:\
                IF rec.actions.any(a => a.action_type == action_type):\
                    RETURN true\
        \
        RETURN false\
    \
    \
    FUNCTION getLabTrend(loincCode: String, hours: int):\
        IF NOT lab_history.contains(loincCode):\
            RETURN null\
        \
        series = lab_history.get(loincCode)\
        recent = series.getRecent(hours * 60 * 60 * 1000)\
        \
        IF recent.length < 2:\
            RETURN "INSUFFICIENT_DATA"\
        \
        // Calculate slope\
        first_value = recent.first().value\
        last_value = recent.last().value\
        \
        change = last_value - first_value\
        percent_change = (change / first_value) * 100\
        \
        IF abs(percent_change) < 5:\
            RETURN "STABLE"\
        ELSE IF percent_change > 5:\
            RETURN "INCREASING"\
        ELSE:\
            RETURN "DECREASING"\
    \
    \
    FUNCTION getBaselineValue(lab_or_vital: String):\
        IF chronic_baselines.contains(lab_or_vital):\
            RETURN chronic_baselines.get(lab_or_vital)\
        \
        // Calculate from history if not explicitly set\
        IF lab_history.contains(lab_or_vital):\
            series = lab_history.get(lab_or_vital)\
            values_90days = series.getRecent(90 * 24 * 60 * 60 * 1000)\
            \
            IF values_90days.length >= 3:\
                median = calculateMedian(values_90days.map(v => v.value))\
                std_dev = calculateStdDev(values_90days.map(v => v.value))\
                \
                // Only set as baseline if stable (CV < 15%)\
                IF (std_dev / median) < 0.15:\
                    baseline = \{\
                        value: median,\
                        std_dev: std_dev,\
                        sample_size: values_90days.length,\
                        established_date: now(),\
                        is_stable: true\
                    \}\
                    chronic_baselines.put(lab_or_vital, baseline)\
                    RETURN baseline\
        \
        RETURN null\
\}\
\
\
CLASS TimeSeries<T> \{\
    \
    data: List<TimestampedValue<T>>\
    max_size: int = 1000\
    \
    FUNCTION add(value: T):\
        timestamped = \{\
            timestamp: now(),\
            value: value\
        \}\
        data.add(timestamped)\
        \
        // Trim old data\
        IF data.length > max_size:\
            data.removeFirst()\
    \
    FUNCTION getRecent(time_window_ms: long):\
        cutoff = now() - time_window_ms\
        RETURN data.filter(d => d.timestamp > cutoff)\
    \
    FUNCTION getLast():\
        RETURN data.last().value\
    \
    FUNCTION getFirst():\
        RETURN data.first().value\
\}\
