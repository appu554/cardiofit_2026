### **7.2 Recommendation Deduplication**\
\
```\
FUNCTION deduplicateRecommendations(\
    new_recommendation: ClinicalRecommendation,\
    patient_history: PatientHistoryState\
):\
    \
    // Check if similar recommendation exists recently\
    recent_recs = patient_history.recommendation_history\
        .filter(r => r.timestamp > now() - (30 * 60 * 1000))  // Last 30 minutes\
    \
    FOR EACH recent_rec IN recent_recs:\
        \
        similarity = calculateRecommendationSimilarity(new_recommendation, recent_rec)\
        \
        IF similarity > 0.8:  // 80% similar\
            \
            // Same recommendation recently made\
            IF recent_rec.status == "PENDING":\
                // Don't create duplicate, just update timestamp\
                LOG.info("Suppressing duplicate recommendation - similar rec pending")\
                RETURN null\
            \
            IF recent_rec.status == "ACKNOWLEDGED":\
                // Clinician acknowledged but hasn't acted yet\
                // Only re-recommend if situation worsened\
                IF new_recommendation.urgency_level > recent_rec.urgency_level:\
                    LOG.info("Re-recommending with higher urgency")\
                    new_recommendation.is_escalation = true\
                    new_recommendation.previous_recommendation_id = recent_rec.recommendation_id\
                    RETURN new_recommendation\
                ELSE:\
                    LOG.info("Suppressing - already acknowledged")\
                    RETURN null\
            \
            IF recent_rec.status == "IN_PROGRESS":\
                // Actions are being executed\
                // Only recommend additional actions not in original\
                new_actions = filterNewActions(\
                    new_recommendation.actions,\
                    recent_rec.actions\
                )\
                \
                IF new_actions.length > 0:\
                    new_recommendation.actions = new_actions\
                    new_recommendation.is_addendum = true\
                    new_recommendation.parent_recommendation_id = recent_rec.recommendation_id\
                    RETURN new_recommendation\
                ELSE:\
                    RETURN null\
    \
    // No duplicates found\
    RETURN new_recommendation\
\
\
FUNCTION calculateRecommendationSimilarity(rec1, rec2):\
    \
    // Compare protocols\
    protocol_match = (rec1.protocol.id == rec2.protocol.id) ? 1.0 : 0.0\
    \
    // Compare actions\
    action_overlap = 0\
    FOR EACH action1 IN rec1.actions:\
        FOR EACH action2 IN rec2.actions:\
            IF action1.action_id == action2.action_id:\
                action_overlap += 1\
    \
    action_similarity = action_overlap / max(rec1.actions.length, rec2.actions.length)\
    \
    // Compare clinical problems\
    problem_overlap = 0\
    FOR EACH p1 IN rec1.clinical_problems:\
        FOR EACH p2 IN rec2.clinical_problems:\
            IF p1.problem_type == p2.problem_type:\
                problem_overlap += 1\
    \
    problem_similarity = problem_overlap / max(\
        rec1.clinical_problems.length,\
        rec2.clinical_problems.length\
    )\
    \
    // Weighted average\
    similarity = (protocol_match * 0.4) + \
                 (action_similarity * 0.4) + \
                 (problem_similarity * 0.2)\
    \
    RETURN similarity\
\
\
FUNCTION filterNewActions(new_actions, existing_actions):\
    \
    truly_new = []\
    \
    FOR EACH new_action IN new_actions:\
        is_duplicate = false\
        \
        FOR EACH existing_action IN existing_actions:\
            IF new_action.action_id == existing_action.action_id:\
                is_duplicate = true\
                break\
            \
            // Check semantic similarity (same medication, different formulation)\
            IF areSemanticallyEquivalent(new_action, existing_action):\
                is_duplicate = true\
                break\
        \
        IF NOT is_duplicate:\
            truly_new.add(new_action)\
    \
    RETURN truly_new\
\
\
FUNCTION areSemanticallyEquivalent(action1, action2):\
    \
    // Same action type\
    IF action1.action_type != action2.action_type:\
        RETURN false\
    \
    // For medications\
    IF action1.action_type == "THERAPEUTIC":\
        // Same drug class and indication\
        IF action1.medication.drug_class == action2.medication.drug_class AND\
           action1.indication == action2.indication:\
            RETURN true\
    \
    // For diagnostics\
    IF action1.action_type == "DIAGNOSTIC":\
        // Same test or imaging\
        IF action1.test_code == action2.test_code:\
            RETURN true\
    \
    RETURN false\
```\
