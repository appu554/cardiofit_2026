### **8.2 Output Routing**\
\
```\
FUNCTION routeRecommendation(recommendation: ClinicalRecommendation):\
    \
    // Route based on urgency\
    SWITCH recommendation.urgency_level:\
        \
        CASE "CRITICAL":\
            // Send to multiple channels for redundancy\
            sendToKafkaTopic("clinical-recommendations-critical")\
            sendToNotificationService(recommendation, channels: ["SMS", "PAGER", "PUSH"])\
            sendToEMR(recommendation, priority: "STAT")\
            sendToDashboard(recommendation, highlight: true, sound_alert: true)\
            \
            // Log for audit\
            auditLog.critical(recommendation)\
        \
        CASE "HIGH":\
            sendToKafkaTopic("clinical-recommendations-high")\
            sendToNotificationService(recommendation, channels: ["PUSH", "EMAIL"])\
            sendToEMR(recommendation, priority: "URGENT")\
            sendToDashboard(recommendation, highlight: true)\
            \
            auditLog.high(recommendation)\
        \
        CASE "MEDIUM":\
            sendToKafkaTopic("clinical-recommendations-medium")\
            sendToEMR(recommendation, priority: "ROUTINE")\
            sendToDashboard(recommendation)\
            \
            auditLog.info(recommendation)\
        \
        CASE "LOW":\
            sendToKafkaTopic("clinical-recommendations-routine")\
            sendToEMR(recommendation, priority: "ROUTINE")\
            sendToDashboard(recommendation, silent: true)\
    \
    // Always send to data warehouse for analytics\
    sendToDataWarehouse(recommendation)\
    \
    // Send to ML pipeline for feedback learning\
    sendToMLPipeline(recommendation)\
```\
