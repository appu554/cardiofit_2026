### **4.3 Protocol Matching Algorithm**\
\
**Detailed Matching Logic:**\
\
```\
FUNCTION matchProtocols(patientContext, knowledgeBase):\
    \
    matched_protocols = []\
    \
    FOR EACH protocol IN knowledgeBase.protocols:\
        \
        // Step 1: Evaluate trigger criteria\
        match_result = evaluateTrigger(protocol.trigger_criteria, patientContext)\
        \
        IF match_result.matched:\
            \
            // Step 2: Calculate confidence score\
            confidence = calculateConfidence(protocol, patientContext, match_result)\
            \
            // Step 3: Check exclusions\
            IF NOT hasExclusions(protocol, patientContext):\
                \
                matched_protocols.add(\{\
                    protocol: protocol,\
                    confidence: confidence,\
                    match_details: match_result.details,\
                    triggered_by: match_result.triggers\
                \})\
    \
    // Step 4: Rank by urgency and confidence\
    ranked_protocols = rankProtocols(matched_protocols)\
    \
    // Step 5: Handle conflicts\
    resolved_protocols = resolveConflicts(ranked_protocols, patientContext)\
    \
    RETURN resolved_protocols\
\
\
FUNCTION evaluateTrigger(criteria, patientContext):\
    \
    // Handle ALL_OF logic\
    IF criteria.type == "ALL_OF":\
        results = []\
        FOR EACH condition IN criteria.conditions:\
            result = evaluateCondition(condition, patientContext)\
            results.add(result)\
            IF NOT result.matched:\
                RETURN \{matched: false\}\
        RETURN \{matched: true, details: results\}\
    \
    // Handle ANY_OF logic\
    IF criteria.type == "ANY_OF":\
        FOR EACH condition IN criteria.conditions:\
            result = evaluateCondition(condition, patientContext)\
            IF result.matched:\
                RETURN \{matched: true, details: [result], triggers: [condition]\}\
        RETURN \{matched: false\}\
    \
    // Handle single condition\
    RETURN evaluateCondition(criteria, patientContext)\
\
\
FUNCTION evaluateCondition(condition, patientContext):\
    \
    SWITCH condition.type:\
        \
        CASE "SIRS_CRITERIA":\
            sirs_score = calculateSIRS(patientContext)\
            matched = (sirs_score >= condition.threshold)\
            RETURN \{\
                matched: matched,\
                value: sirs_score,\
                threshold: condition.threshold,\
                components: sirs_components\
            \}\
        \
        CASE "ELEVATED_LACTATE":\
            lactate = patientContext.getLabValue("2524-7")\
            IF lactate:\
                matched = (lactate.value > condition.threshold)\
                RETURN \{\
                    matched: matched,\
                    value: lactate.value,\
                    threshold: condition.threshold,\
                    unit: lactate.unit\
                \}\
            RETURN \{matched: false, reason: "Lactate not available"\}\
        \
        CASE "SUSPECTED_INFECTION":\
            indicators = []\
            IF patientContext.riskIndicators.fever:\
                indicators.add("FEVER")\
            IF patientContext.riskIndicators.leukocytosis OR \
               patientContext.riskIndicators.leukopenia:\
                indicators.add("ABNORMAL_WBC")\
            IF patientContext.riskIndicators.hypothermia:\
                indicators.add("HYPOTHERMIA")\
            \
            matched = (indicators.length > 0)\
            RETURN \{\
                matched: matched,\
                indicators: indicators\
            \}\
        \
        CASE "ORGAN_DYSFUNCTION":\
            dysfunction_markers = []\
            IF patientContext.riskIndicators.hypotension:\
                dysfunction_markers.add("HYPOTENSION")\
            IF patientContext.vitals.consciousness != "Alert":\
                dysfunction_markers.add("ALTERED_MENTAL_STATUS")\
            IF patientContext.riskIndicators.elevatedCreatinine:\
                dysfunction_markers.add("ACUTE_KIDNEY_INJURY")\
            IF patientContext.riskIndicators.hypoxia:\
                dysfunction_markers.add("RESPIRATORY_DYSFUNCTION")\
            \
            matched = (dysfunction_markers.length >= condition.minimum_markers)\
            RETURN \{\
                matched: matched,\
                markers: dysfunction_markers,\
                count: dysfunction_markers.length\
            \}\
        \
        CASE "NEWS2_HIGH_RISK":\
            matched = (patientContext.news2Score >= condition.threshold)\
            RETURN \{\
                matched: matched,\
                score: patientContext.news2Score,\
                threshold: condition.threshold\
            \}\
        \
        CASE "CHEST_PAIN":\
            // Would come from clinical notes or structured data\
            // For now, check if cardiac markers elevated\
            troponin = patientContext.getLabValue("10839-9")\
            matched = (troponin != null AND troponin.abnormal)\
            RETURN \{\
                matched: matched,\
                supportingEvidence: "Elevated troponin"\
            \}\
\
\
FUNCTION calculateConfidence(protocol, patientContext, matchResult):\
    \
    // Start with base confidence\
    confidence = protocol.confidence_scoring.base_score\
    \
    // Apply modifiers based on clinical context\
    FOR EACH modifier IN protocol.confidence_scoring.modifiers:\
        \
        IF evaluateModifierCondition(modifier.condition, patientContext):\
            confidence += modifier.adjust\
            LOG.debug("Confidence adjusted by \{\} due to: \{\}", \
                     modifier.adjust, modifier.reason)\
    \
    // Additional contextual adjustments\
    \
    // Higher confidence if multiple criteria strongly met\
    IF matchResult.details.all(d => d.value > d.threshold * 1.5):\
        confidence += 0.1\
    \
    // Lower confidence if marginal criteria match\
    IF matchResult.details.any(d => d.value < d.threshold * 1.1):\
        confidence -= 0.1\
    \
    // Higher confidence if patient history supports diagnosis\
    IF patientHasRelevantHistory(protocol, patientContext):\
        confidence += 0.05\
    \
    // Cap confidence at 0.95 (never 100% certain)\
    confidence = min(confidence, 0.95)\
    \
    RETURN confidence\
```\
