# Google Healthcare API Configuration for Flink EHR Intelligence Engine
# This configuration file matches the patient-service settings for seamless integration

# Enable/disable Google Healthcare API integration
USE_GOOGLE_HEALTHCARE_API=true

# Google Cloud Project Configuration (matching patient-service)
GOOGLE_CLOUD_PROJECT_ID=cardiofit-905a8
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_DATASET_ID=clinical_synthesis_hub
GOOGLE_CLOUD_FHIR_STORE_ID=fhir_store

# Service Account Credentials
# Path to the service account key file (relative to project root)
GOOGLE_CLOUD_CREDENTIALS_PATH=credentials/google-credentials.json

# Alternative: Use Application Default Credentials (for Cloud deployment)
# When running on Google Cloud (GKE, Cloud Run, etc.), you can omit the credentials path
# and use the default service account attached to the compute instance
# GOOGLE_CLOUD_CREDENTIALS_PATH=

# Flink Job Configuration
FLINK_PARALLELISM=10
FLINK_CHECKPOINT_INTERVAL=30000
FLINK_STATE_BACKEND=rocksdb

# Healthcare API Service Account Details (for reference)
# Service Account Email: healthcare-api-client@cardiofit-905a8.iam.gserviceaccount.com
# Required IAM Roles:
# - roles/healthcare.datasetAdmin
# - roles/healthcare.fhirStoreAdmin
# - roles/healthcare.fhirResourceEditor

# FHIR Store Configuration Details
# Dataset Name: clinical_synthesis_hub
# FHIR Store Name: fhir_store
# FHIR Version: R4
# Location: us-central1
# History Enabled: Yes

# Full FHIR Store Path (automatically constructed):
# projects/cardiofit-905a8/locations/us-central1/datasets/clinical_synthesis_hub/fhirStores/fhir_store

# Kafka Configuration (for reference)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092,localhost:9093,localhost:9094
KAFKA_BOOTSTRAP_SERVERS_DOCKER=kafka1:29092,kafka2:29093,kafka3:29094

# Development vs Production Settings
DEPLOYMENT_ENVIRONMENT=development
# For production, set to: DEPLOYMENT_ENVIRONMENT=production

# Logging Configuration
LOG_LEVEL=INFO
FHIR_STORE_LOG_LEVEL=DEBUG

# Error Handling Configuration
FHIR_STORE_RETRY_ATTEMPTS=3
FHIR_STORE_RETRY_DELAY_MS=1000
FHIR_STORE_TIMEOUT_MS=30000

# Batch Processing Configuration
FHIR_STORE_BATCH_SIZE=100
FHIR_STORE_FLUSH_INTERVAL_MS=5000

# Monitoring Configuration
ENABLE_FHIR_STORE_METRICS=true
METRICS_EXPORT_INTERVAL_SECONDS=60

# Development Notes:
# 1. Copy this file to flink-google-healthcare.env
# 2. Update the GOOGLE_CLOUD_PROJECT_ID if using a different project
# 3. Ensure the service account key file exists at the specified path
# 4. Verify that the FHIR store exists in Google Cloud Healthcare API
# 5. Test the connection using the patient-service first to validate credentials

# Production Notes:
# 1. Use Application Default Credentials when running on Google Cloud
# 2. Store sensitive values in Google Secret Manager
# 3. Use workload identity for secure authentication
# 4. Monitor FHIR store usage and quotas
# 5. Implement proper backup and disaster recovery procedures