# Flink EHR Intelligence Engine - Data Store Configuration
# This file configures connections to all shared infrastructure data stores

# ============================================
# Neo4j Configuration (Clinical Knowledge Graph)
# ============================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CardioFit2024!
NEO4J_DATABASE=cardiofit

# Neo4j Performance Settings
NEO4J_MAX_CONNECTION_LIFETIME=3600000
NEO4J_MAX_CONNECTION_POOL_SIZE=100
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=60000

# ============================================
# ClickHouse Configuration (Time-Series Analytics)
# ============================================
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DATABASE=cardiofit_analytics
CLICKHOUSE_USERNAME=cardiofit_user
CLICKHOUSE_PASSWORD=ClickHouse2024!

# ClickHouse Performance Settings
CLICKHOUSE_BATCH_SIZE=1000
CLICKHOUSE_FLUSH_INTERVAL_MS=5000
CLICKHOUSE_CONNECTION_TIMEOUT=30000
CLICKHOUSE_SOCKET_TIMEOUT=300000
CLICKHOUSE_MAX_CONNECTIONS=100

# ============================================
# Elasticsearch Configuration (Search & Analytics)
# ============================================
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=ElasticCardioFit2024!
ELASTICSEARCH_INDEX_PREFIX=cardiofit-clinical
ELASTICSEARCH_USE_TIME_INDEX=true

# Elasticsearch Performance Settings
ELASTICSEARCH_BATCH_SIZE=100
ELASTICSEARCH_CONNECTION_TIMEOUT=10000
ELASTICSEARCH_SOCKET_TIMEOUT=60000
ELASTICSEARCH_MAX_RETRY_TIMEOUT=60000

# ============================================
# Redis Configuration (Caching & Sessions)
# ============================================
# Redis Master (Write operations)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=RedisCardioFit2024!
REDIS_DATABASE=0

# Redis Replica (Read operations)
REDIS_REPLICA_HOST=localhost
REDIS_REPLICA_PORT=6380

# Redis Performance Settings
REDIS_TTL_SECONDS=3600
REDIS_KEY_PREFIX=cardiofit:
REDIS_MAX_CONNECTIONS=128
REDIS_MIN_IDLE_CONNECTIONS=16
REDIS_CONNECTION_TIMEOUT=2000
REDIS_PIPELINE_SIZE=100

# ============================================
# Google FHIR Store Configuration (Inherited from patient-service)
# ============================================
USE_GOOGLE_HEALTHCARE_API=true
GOOGLE_CLOUD_PROJECT_ID=cardiofit-905a8
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_DATASET_ID=clinical_synthesis_hub
GOOGLE_CLOUD_FHIR_STORE_ID=fhir_store
GOOGLE_CLOUD_CREDENTIALS_PATH=credentials/google-credentials.json

# ============================================
# Kafka Configuration (Event Streaming)
# ============================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_BOOTSTRAP_SERVERS_DOCKER=kafka1:29092,kafka2:29093,kafka3:29094

# ============================================
# Flink Configuration
# ============================================
# Flink Job Manager
FLINK_JOBMANAGER_HOST=localhost
FLINK_JOBMANAGER_PORT=8081

# Flink Performance
FLINK_PARALLELISM=10
FLINK_CHECKPOINT_INTERVAL=30000
FLINK_STATE_BACKEND=rocksdb

# ============================================
# Data Store Routing Configuration
# ============================================
# Enable/disable specific sinks
ENABLE_NEO4J_SINK=true
ENABLE_CLICKHOUSE_SINK=true
ENABLE_ELASTICSEARCH_SINK=true
ENABLE_REDIS_SINK=true
ENABLE_GOOGLE_FHIR_SINK=true

# Default routing destinations
DEFAULT_ANALYTICS_DESTINATIONS=clickhouse,elasticsearch
DEFAULT_CLINICAL_DESTINATIONS=neo4j,fhir_store
DEFAULT_CACHE_DESTINATIONS=redis
DEFAULT_CRITICAL_DESTINATIONS=redis,neo4j,fhir_store

# ============================================
# Healthcare-Specific Settings
# ============================================
DEPLOYMENT_ENVIRONMENT=development
LOG_LEVEL=INFO
FHIR_STORE_LOG_LEVEL=DEBUG

# Error Handling
FHIR_STORE_RETRY_ATTEMPTS=3
FHIR_STORE_RETRY_DELAY_MS=1000
FHIR_STORE_TIMEOUT_MS=30000

# Batch Processing
FHIR_STORE_BATCH_SIZE=100
FHIR_STORE_FLUSH_INTERVAL_MS=5000

# Monitoring
ENABLE_FHIR_STORE_METRICS=true
METRICS_EXPORT_INTERVAL_SECONDS=60

# ============================================
# Data Retention Policies
# ============================================
# Clinical data retention (in days)
CLINICAL_DATA_RETENTION_DAYS=2555  # 7 years for HIPAA compliance
ANALYTICS_DATA_RETENTION_DAYS=90
CACHE_DATA_RETENTION_HOURS=24
LOG_DATA_RETENTION_DAYS=30

# ============================================
# Security Settings
# ============================================
HIPAA_COMPLIANCE_MODE=true
AUDIT_LOGGING_ENABLED=true
ENCRYPTION_AT_REST=false  # Set to true in production
TLS_ENABLED=false         # Set to true in production

# ============================================
# Performance Tuning
# ============================================
# Memory Settings (in MB)
NEO4J_HEAP_SIZE=2048
CLICKHOUSE_MAX_MEMORY_USAGE=4096
ELASTICSEARCH_HEAP_SIZE=2048
REDIS_MAX_MEMORY=2048

# Query Timeouts (in seconds)
NEO4J_QUERY_TIMEOUT=120
CLICKHOUSE_QUERY_TIMEOUT=300
ELASTICSEARCH_QUERY_TIMEOUT=60

# ============================================
# Monitoring Configuration
# ============================================
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000

# Health Check Intervals (in seconds)
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=5

# ============================================
# Development Configuration
# ============================================
DEBUG_MODE=false
ENABLE_QUERY_LOGGING=true
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_HEALTH_CHECKS=true

# Connection Testing
TEST_CONNECTIONS_ON_STARTUP=true
FAIL_FAST_ON_CONNECTION_ERROR=true

# ============================================
# Feature Flags
# ============================================
ENABLE_ADVANCED_ANALYTICS=true
ENABLE_CLINICAL_DECISION_SUPPORT=true
ENABLE_REAL_TIME_ALERTING=true
ENABLE_SEMANTIC_SEARCH=true
ENABLE_GRAPH_ANALYTICS=true

# ============================================
# Alert Thresholds
# ============================================
# Performance alerts
LATENCY_ALERT_THRESHOLD_MS=5000
THROUGHPUT_ALERT_THRESHOLD_EPS=1000
ERROR_RATE_ALERT_THRESHOLD_PERCENT=5

# Resource alerts
CPU_ALERT_THRESHOLD=80
MEMORY_ALERT_THRESHOLD=85
DISK_ALERT_THRESHOLD=90

# ============================================
# Custom Healthcare Settings
# ============================================
# Clinical validation
ENABLE_CLINICAL_VALIDATION=true
CLINICAL_VALIDATION_TIMEOUT_MS=10000

# FHIR Resource Settings
ENABLE_FHIR_VALIDATION=true
FHIR_VERSION=R4
ENABLE_FHIR_PROFILING=true

# Clinical Decision Support
ENABLE_CDS_HOOKS=true
CDS_TIMEOUT_MS=5000
CDS_MAX_RECOMMENDATIONS=10

# ============================================
# Data Store Specific TTLs
# ============================================
# Redis TTLs for different data types
PATIENT_CONTEXT_TTL_SECONDS=3600
CRITICAL_ALERTS_TTL_SECONDS=86400
ML_PREDICTIONS_TTL_SECONDS=7200
PATTERN_CACHE_TTL_SECONDS=7200
SESSION_DATA_TTL_SECONDS=1800

# ClickHouse retention policies
CLINICAL_EVENTS_RETENTION_DAYS=90
PATTERN_METRICS_RETENTION_DAYS=180
ML_PREDICTIONS_RETENTION_DAYS=365

# Neo4j cleanup policies
GRAPH_CLEANUP_INTERVAL_HOURS=24
REMOVE_OLD_RELATIONSHIPS_DAYS=30

# ============================================
# Load Balancing Configuration
# ============================================
# Neo4j
NEO4J_LOAD_BALANCING_STRATEGY=round_robin
NEO4J_MAX_READ_CONNECTIONS=50
NEO4J_MAX_WRITE_CONNECTIONS=25

# Redis
REDIS_USE_REPLICA_FOR_READS=true
REDIS_REPLICA_READ_PREFERENCE=replica_preferred

# ClickHouse
CLICKHOUSE_USE_COMPRESSION=true
CLICKHOUSE_COMPRESSION_METHOD=lz4

# ============================================
# Backup Configuration
# ============================================
ENABLE_AUTOMATIC_BACKUPS=false
BACKUP_SCHEDULE_CRON="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/var/backups/cardiofit

# ============================================
# Integration Settings
# ============================================
# External systems
ENABLE_HL7_INTEGRATION=true
ENABLE_EXTERNAL_APIS=false

# Message broker
ENABLE_KAFKA_INTEGRATION=true
KAFKA_CONSUMER_GROUP_ID=flink-ehr-intelligence

# Module 4 - Clinical Pattern Engine Topics
MODULE4_CDS_INPUT_TOPIC=comprehensive-cds-events.v1
MODULE4_CLINICAL_PATTERNS_TOPIC=clinical-patterns.v1
MODULE4_DAILY_RISK_SCORE_TOPIC=daily-risk-scores.v1

# ============================================
# Custom Sink Configurations
# ============================================
# Sink-specific settings
NEO4J_SINK_BATCH_SIZE=100
CLICKHOUSE_SINK_BATCH_SIZE=1000
ELASTICSEARCH_SINK_BATCH_SIZE=100
REDIS_SINK_PIPELINE_SIZE=100

# Sink error handling
SINK_ERROR_RETRY_ATTEMPTS=3
SINK_ERROR_RETRY_DELAY_MS=1000
SINK_CIRCUIT_BREAKER_THRESHOLD=10