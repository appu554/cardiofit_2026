        "trigger_events": [4, 5, 7],
        "time_window": "6 hours",
        "output_topic": "alert-management.v1"
      },
      {
        "pattern": "RAPID_DETERIORATION",
        "trigger_events": [5, 6, 7],
        "time_window": "4 hours",
        "output_topic": "pattern-events.v1"
      }
    ],
    "windowed_analytics": [
      {
        "window_type": "4-hour sliding",
        "metrics": ["lactate_trend", "vital_sign_trends", "organ_dysfunction_score"],
        "output_topic": "clinical-patterns.v1"
      },
      {
        "window_type": "24-hour tumbling",
        "metrics": ["daily_risk_score", "sepsis_severity_progression"],
        "output_topic": "daily-risk-scores.v1",
        "trigger_event": 14
      }
    ]
  },
  "instructions": {
    "how_to_send": [
      "Copy each event JSON from the 'event' field",
      "Use kafka-console-producer to send to the specified topic",
      "Command format: echo '{event_json}' | docker exec -i kafka kafka-console-producer --broker-list localhost:9092 --topic {topic_name}"
    ],
    "monitoring": [
      "Watch Module 4 metrics in Flink UI: http://localhost:8081",
      "Monitor alert-management.v1 for sepsis pattern detection",
      "Monitor daily-risk-scores.v1 after 24-hour window closes",
      "Check pattern-events.v1 for all detected patterns"
    ]
  }
