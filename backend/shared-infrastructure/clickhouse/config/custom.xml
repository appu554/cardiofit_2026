<?xml version="1.0"?>
<!-- ClickHouse Custom Configuration for CardioFit Platform -->
<clickhouse>
    <!-- Network Configuration -->
    <listen_host>0.0.0.0</listen_host>
    <http_port>8123</http_port>
    <tcp_port>9000</tcp_port>
    <mysql_port>9004</mysql_port>
    <postgresql_port>9005</postgresql_port>

    <!-- Security -->
    <max_connections>1000</max_connections>
    <keep_alive_timeout>3</keep_alive_timeout>
    <max_concurrent_queries>100</max_concurrent_queries>

    <!-- Memory and Performance -->
    <max_memory_usage>4000000000</max_memory_usage> <!-- 4GB -->
    <max_memory_usage_for_user>3000000000</max_memory_usage_for_user> <!-- 3GB -->
    <max_memory_usage_for_all_queries>6000000000</max_memory_usage_for_all_queries> <!-- 6GB -->

    <!-- Query Settings for Healthcare Data -->
    <merge_tree>
        <max_suspicious_broken_parts>10</max_suspicious_broken_parts>
        <parts_to_delay_insert>150</parts_to_delay_insert>
        <parts_to_throw_insert>300</parts_to_throw_insert>
        <max_bytes_to_merge_at_max_space_in_pool>161061273600</max_bytes_to_merge_at_max_space_in_pool>
        <merge_max_block_size>8192</merge_max_block_size>
        <max_part_loading_threads>auto</max_part_loading_threads>
        <max_part_removal_threads>auto</max_part_removal_threads>
    </merge_tree>

    <!-- Compression for Healthcare Data -->
    <compression>
        <case>
            <method>lz4</method>
        </case>
    </compression>

    <!-- Background Processing -->
    <background_pool_size>16</background_pool_size>
    <background_merges_mutations_concurrency_ratio>2</background_merges_mutations_concurrency_ratio>
    <background_schedule_pool_size>16</background_schedule_pool_size>
    <background_fetches_pool_size>8</background_fetches_pool_size>
    <background_message_broker_schedule_pool_size>16</background_message_broker_schedule_pool_size>

    <!-- Healthcare-specific settings -->
    <default_database>cardiofit_analytics</default_database>

    <!-- Session and Query timeouts -->
    <session_timeout>300</session_timeout>
    <max_session_timeout>3600</max_session_timeout>
    <default_session_timeout>60</default_session_timeout>

    <!-- Logging for healthcare compliance -->
    <logger>
        <level>information</level>
        <log>/var/log/clickhouse-server/clickhouse-server.log</log>
        <errorlog>/var/log/clickhouse-server/clickhouse-server.err.log</errorlog>
        <size>1000M</size>
        <count>10</count>
    </logger>

    <!-- Query log for audit purposes -->
    <query_log>
        <database>system</database>
        <table>query_log</table>
        <partition_by>toYYYYMM(event_date)</partition_by>
        <flush_interval_milliseconds>7500</flush_interval_milliseconds>
    </query_log>

    <!-- Part log for healthcare data integrity -->
    <part_log>
        <database>system</database>
        <table>part_log</table>
        <partition_by>toYYYYMM(event_date)</partition_by>
        <flush_interval_milliseconds>7500</flush_interval_milliseconds>
    </part_log>

    <!-- Text log for system monitoring -->
    <text_log>
        <database>system</database>
        <table>text_log</table>
        <partition_by>toYYYYMM(event_date)</partition_by>
        <flush_interval_milliseconds>7500</flush_interval_milliseconds>
        <level>information</level>
    </text_log>

    <!-- Metric log for performance monitoring -->
    <metric_log>
        <database>system</database>
        <table>metric_log</table>
        <partition_by>toYYYYMM(event_date)</partition_by>
        <flush_interval_milliseconds>7500</flush_interval_milliseconds>
        <collect_interval_milliseconds>1000</collect_interval_milliseconds>
    </metric_log>

    <!-- Timezone for healthcare timestamps -->
    <timezone>UTC</timezone>

    <!-- Built-in dictionaries path -->
    <dictionaries_config>*_dictionary.xml</dictionaries_config>

    <!-- User-defined functions -->
    <user_defined_executable_functions_config>*_function.xml</user_defined_executable_functions_config>

    <!-- Remote servers configuration for potential clustering -->
    <remote_servers>
        <cardiofit_cluster>
            <shard>
                <replica>
                    <host>clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </cardiofit_cluster>
    </remote_servers>

    <!-- Distributed DDL -->
    <distributed_ddl>
        <path>/clickhouse/task_queue/ddl</path>
    </distributed_ddl>

    <!-- Healthcare data retention policies -->
    <default_profile>default</default_profile>
    <default_database>cardiofit_analytics</default_database>

    <!-- Custom settings for healthcare analytics -->
    <profiles>
        <default>
            <max_memory_usage>4000000000</max_memory_usage>
            <use_uncompressed_cache>0</use_uncompressed_cache>
            <load_balancing>random</load_balancing>
            <log_queries>1</log_queries>
            <log_query_threads>1</log_query_threads>
            <max_insert_block_size>1048576</max_insert_block_size>
            <max_threads>auto</max_threads>
            <join_use_nulls>1</join_use_nulls>
            <partial_merge_join>1</partial_merge_join>
            <allow_experimental_window_functions>1</allow_experimental_window_functions>
        </default>

        <healthcare_analytics>
            <max_memory_usage>6000000000</max_memory_usage>
            <max_execution_time>3600</max_execution_time>
            <max_rows_to_read>1000000000</max_rows_to_read>
            <max_bytes_to_read>100000000000</max_bytes_to_read>
            <overflow_mode>throw</overflow_mode>
            <log_queries>1</log_queries>
            <log_query_threads>1</log_query_threads>
        </healthcare_analytics>
    </profiles>

    <!-- Users for different access patterns -->
    <users>
        <cardiofit_user>
            <password_sha256_hex>5e884898da28047151d0e56f8dc6292773603d0d6aabbdd62a11ef721d1542d8</password_sha256_hex> <!-- ClickHouse2024! -->
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>healthcare_analytics</profile>
            <quota>default</quota>
            <databases>
                <database>cardiofit_analytics</database>
                <database>system</database>
            </databases>
            <access_management>1</access_management>
        </cardiofit_user>

        <readonly_user>
            <password_sha256_hex>5e884898da28047151d0e56f8dc6292773603d0d6aabbdd62a11ef721d1542d8</password_sha256_hex>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
            <databases>
                <database>cardiofit_analytics</database>
            </databases>
            <readonly>1</readonly>
        </readonly_user>
    </users>

    <!-- Quotas for resource management -->
    <quotas>
        <default>
            <interval>
                <duration>3600</duration>
                <queries>0</queries>
                <errors>0</errors>
                <result_rows>0</result_rows>
                <read_rows>0</read_rows>
                <execution_time>0</execution_time>
            </interval>
        </default>
    </quotas>
</clickhouse>