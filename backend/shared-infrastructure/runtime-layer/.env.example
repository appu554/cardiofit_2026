# ============================================
# CardioFit Runtime Layer Environment Configuration
# ============================================
# Copy this file to .env and customize for your environment

# ============================================
# GENERAL SETTINGS
# ============================================
ENVIRONMENT=development
LOG_LEVEL=INFO

# ============================================
# NEO4J CONFIGURATION
# ============================================
NEO4J_USER=neo4j
NEO4J_PASSWORD=runtime_password
NEO4J_HEAP_SIZE=4G
NEO4J_PAGECACHE_SIZE=4G
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ============================================
# GRAPHDB CONFIGURATION
# ============================================
GRAPHDB_HEAP_SIZE=4G
GRAPHDB_MIN_MEM=2G
GRAPHDB_MAX_MEM=4G
GRAPHDB_PORT=7200

# ============================================
# KAFKA CONFIGURATION
# ============================================
KAFKA_EXTERNAL_PORT=29092
KAFKA_NUM_PARTITIONS=3
KAFKA_RETENTION_HOURS=168
ZOOKEEPER_PORT=2181

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_PORT=6379
REDIS_MAX_MEMORY=2gb

# ============================================
# CLICKHOUSE CONFIGURATION
# ============================================
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse_password
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# ============================================
# MONGODB CONFIGURATION
# ============================================
MONGODB_ROOT_USER=admin
MONGODB_ROOT_PASSWORD=admin_password
MONGODB_EVIDENCE_PORT=27018
MONGODB_SLA_PORT=27019

# ============================================
# FLINK CONFIGURATION
# ============================================
FLINK_UI_PORT=8081
FLINK_METRICS_PORT=9249
FLINK_JM_MEMORY=1600m
FLINK_TM_MEMORY=2048m
FLINK_TASK_SLOTS=4
FLINK_PARALLELISM=2

# ============================================
# APPLICATION SERVICES CONFIGURATION
# ============================================

# Query Router Service
QUERY_ROUTER_PORT=8070
QUERY_ROUTER_DOCKERFILE=Dockerfile

# Cache Prefetcher Service
CACHE_PREFETCHER_PORT=8055
CACHE_PREFETCHER_DOCKERFILE=Dockerfile

# Evidence Envelope Service
EVIDENCE_ENVELOPE_PORT=8060
EVIDENCE_ENVELOPE_DOCKERFILE=Dockerfile

# SLA Monitoring Service
SLA_MONITORING_PORT=8050
SLA_MONITORING_DOCKERFILE=Dockerfile

# ============================================
# MONITORING CONFIGURATION
# ============================================

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_PLUGINS=

# ============================================
# EXTERNAL SERVICE INTEGRATIONS
# ============================================
# These are used by microservices to connect to the runtime layer

# For microservices running outside Docker
EXTERNAL_NEO4J_URI=bolt://localhost:7687
EXTERNAL_REDIS_URL=redis://localhost:6379
EXTERNAL_KAFKA_BROKERS=localhost:29092
EXTERNAL_CLICKHOUSE_URL=http://localhost:8123
EXTERNAL_QUERY_ROUTER_URL=http://localhost:8070

# For microservices running inside Docker network
INTERNAL_NEO4J_URI=bolt://neo4j:7687
INTERNAL_REDIS_URL=redis://redis:6379
INTERNAL_KAFKA_BROKERS=kafka:9092
INTERNAL_CLICKHOUSE_URL=http://clickhouse:8123
INTERNAL_QUERY_ROUTER_URL=http://query-router:8070

# ============================================
# PERFORMANCE TUNING
# ============================================

# JVM Settings
JAVA_OPTS=-Xmx2g -Xms1g

# Docker Resource Limits
DOCKER_MEMORY_LIMIT=32g
DOCKER_CPU_LIMIT=16

# Connection Pool Settings
NEO4J_MAX_CONNECTIONS=50
REDIS_MAX_CONNECTIONS=20
CLICKHOUSE_MAX_CONNECTIONS=10

# ============================================
# SECURITY SETTINGS
# ============================================

# TLS/SSL (set to true for production)
ENABLE_TLS=false
TLS_CERT_PATH=/certs/runtime-cert.pem
TLS_KEY_PATH=/certs/runtime-key.pem

# Network Security
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Authentication
JWT_SECRET=change-this-in-production
JWT_EXPIRATION=3600

# ============================================
# BACKUP CONFIGURATION
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/backups

# ============================================
# DEVELOPMENT/TESTING OVERRIDES
# ============================================

# Set to true to enable debug logging
DEBUG_MODE=false

# Set to true to disable authentication (development only)
DISABLE_AUTH=false

# Set to true to use smaller resource limits for testing
TESTING_MODE=false

# Mock external services (for isolated testing)
MOCK_EXTERNAL_SERVICES=false

# ============================================
# FEATURE FLAGS
# ============================================

# Enable/disable specific features
ENABLE_EVIDENCE_ENVELOPES=true
ENABLE_CACHE_PREFETCHING=true
ENABLE_SLA_MONITORING=true
ENABLE_QUERY_ROUTING=true
ENABLE_STREAM_PROCESSING=true

# Experimental features (use with caution)
EXPERIMENTAL_ML_PREFETCHING=false
EXPERIMENTAL_SMART_ROUTING=false

# ============================================
# MICROSERVICE INTEGRATION EXAMPLES
# ============================================

# Example configuration for connecting external microservices
# Copy and adapt these to your microservice's .env file

# Python FastAPI Service Example:
# NEO4J_URI=${EXTERNAL_NEO4J_URI}
# REDIS_URL=${EXTERNAL_REDIS_URL}/0
# KAFKA_BOOTSTRAP_SERVERS=${EXTERNAL_KAFKA_BROKERS}
# CLICKHOUSE_URL=${EXTERNAL_CLICKHOUSE_URL}
# QUERY_ROUTER_URL=${EXTERNAL_QUERY_ROUTER_URL}

# Node.js Service Example:
# NEO4J_URI=${EXTERNAL_NEO4J_URI}
# REDIS_URL=${EXTERNAL_REDIS_URL}
# KAFKA_BROKERS=${EXTERNAL_KAFKA_BROKERS}
# CLICKHOUSE_URL=${EXTERNAL_CLICKHOUSE_URL}
# QUERY_ROUTER_URL=${EXTERNAL_QUERY_ROUTER_URL}

# Docker Compose Service Example (when microservice runs in same network):
# NEO4J_URI=${INTERNAL_NEO4J_URI}
# REDIS_URL=${INTERNAL_REDIS_URL}/0
# KAFKA_BOOTSTRAP_SERVERS=${INTERNAL_KAFKA_BROKERS}
# CLICKHOUSE_URL=${INTERNAL_CLICKHOUSE_URL}
# QUERY_ROUTER_URL=${INTERNAL_QUERY_ROUTER_URL}

# ============================================
# PRODUCTION OVERRIDES
# ============================================
# Uncomment and customize these for production deployment

# High-performance settings
# NEO4J_HEAP_SIZE=16G
# NEO4J_PAGECACHE_SIZE=16G
# GRAPHDB_HEAP_SIZE=8G
# REDIS_MAX_MEMORY=8gb
# FLINK_JM_MEMORY=4096m
# FLINK_TM_MEMORY=8192m

# Security settings
# ENABLE_TLS=true
# DISABLE_AUTH=false
# JWT_SECRET=your-super-secure-jwt-secret-here
# MONGODB_ROOT_PASSWORD=your-secure-mongodb-password
# NEO4J_PASSWORD=your-secure-neo4j-password
# CLICKHOUSE_PASSWORD=your-secure-clickhouse-password
# GRAFANA_PASSWORD=your-secure-grafana-password

# Production monitoring
# LOG_LEVEL=WARN
# ENVIRONMENT=production
# ENABLE_DETAILED_METRICS=true