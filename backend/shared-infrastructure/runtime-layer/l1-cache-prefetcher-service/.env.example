# L1 Cache and Prefetcher Service Environment Configuration
# Copy this file to .env and update values for your environment

# Service Configuration
SERVICE_NAME=l1-cache-prefetcher-service
VERSION=1.0.0
DEBUG=false
PORT=8030

# L1 Cache Configuration
L1_CACHE_SIZE_MB=512
L1_CACHE_DEFAULT_TTL=10
L1_CACHE_MAX_ENTRIES=50000
MEMORY_PRESSURE_THRESHOLD=0.85

# ML Prefetch Configuration
ML_MODEL_UPDATE_INTERVAL_HOURS=6
ML_MIN_TRAINING_SAMPLES=1000
ML_PREDICTION_HORIZON_HOURS=1

# Prefetch Configuration
MAX_CONCURRENT_FETCHES=20
PREFETCH_BUDGET_MB=100
MIN_CONFIDENCE_THRESHOLD=0.6

# Authentication Configuration
JWT_SECRET_KEY=l1-cache-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# External Data Sources
PATIENT_SERVICE_URL=http://localhost:8003
CLINICAL_SERVICE_URL=http://localhost:8010
MEDICATION_SERVICE_URL=http://localhost:8004
GUIDELINE_SERVICE_URL=http://localhost:8081
SEMANTIC_SERVICE_URL=http://localhost:8090

# Redis Configuration (L2 cache)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=1

# Performance Configuration
REQUEST_TIMEOUT_MS=5000
MAX_REQUEST_SIZE_MB=10
WORKER_THREADS=4

# Monitoring
PROMETHEUS_METRICS_PORT=8031
LOG_LEVEL=INFO
STRUCTURED_LOGGING=true

# ML Model Storage
MODEL_STORAGE_PATH=/app/models
MODEL_BACKUP_ENABLED=true