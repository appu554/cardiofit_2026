{
  "id": null,
  "title": "CardioFit Runtime Layer - SLA Overview",
  "tags": ["cardiofit", "sla", "runtime-layer"],
  "style": "dark",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "System Health Score",
      "type": "stat",
      "targets": [
        {
          "expr": "avg(sla_compliance_percentage) * 100",
          "refId": "A",
          "format": "time_series",
          "intervalFactor": 1
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 95
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal"
      }
    },
    {
      "id": 2,
      "title": "Active SLA Violations",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(sla_violations_active)",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Service Availability",
      "type": "gauge",
      "targets": [
        {
          "expr": "avg by (service_name) (sla_compliance_percentage{metric_type=\"availability\"})",
          "refId": "A",
          "legendFormat": "{{service_name}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "min": 90,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 90
              },
              {
                "color": "yellow",
                "value": 95
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "SLA Compliance by Service",
      "type": "bargauge",
      "targets": [
        {
          "expr": "avg by (service_name) (sla_compliance_percentage)",
          "refId": "A",
          "legendFormat": "{{service_name}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 95
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 5,
      "title": "Response Time Trends",
      "type": "timeseries",
      "targets": [
        {
          "expr": "avg by (service_name) (sla_compliance_percentage{metric_type=\"response_time\"})",
          "refId": "A",
          "legendFormat": "{{service_name}} Response Time"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "gradientMode": "opacity"
          },
          "unit": "percent",
          "min": 80,
          "max": 100
        }
      }
    },
    {
      "id": 6,
      "title": "SLA Violations Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (service_name, severity) (rate(sla_evaluations_total{status=\"violation\"}[5m])) * 60",
          "refId": "A",
          "legendFormat": "{{service_name}} - {{severity}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "reqpm",
          "min": 0
        }
      }
    },
    {
      "id": 7,
      "title": "Error Rate by Service",
      "type": "timeseries",
      "targets": [
        {
          "expr": "100 - avg by (service_name) (sla_compliance_percentage{metric_type=\"error_rate\"})",
          "refId": "A",
          "legendFormat": "{{service_name}} Error Rate"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15
          },
          "unit": "percent",
          "min": 0,
          "max": 10,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Cache Hit Rate (L1 Cache Service)",
      "type": "stat",
      "targets": [
        {
          "expr": "avg(sla_compliance_percentage{service_name=\"l1-cache-prefetcher-service\", metric_type=\"cache_hit_rate\"})",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "green",
                "value": 85
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background"
      }
    },
    {
      "id": 9,
      "title": "ML Prediction Accuracy (L1 Cache Service)",
      "type": "stat",
      "targets": [
        {
          "expr": "avg(sla_compliance_percentage{service_name=\"l1-cache-prefetcher-service\", metric_type=\"ml_prediction_accuracy\"})",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "green",
                "value": 70
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background"
      }
    },
    {
      "id": 10,
      "title": "SLA Evaluation Frequency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(sla_evaluations_total[1m])) * 60",
          "refId": "A",
          "legendFormat": "Evaluations per minute"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "min": 0
        }
      }
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-sla"
        },
        "definition": "label_values(sla_compliance_percentage, service_name)",
        "hide": 0,
        "includeAll": true,
        "label": "Service",
        "multi": true,
        "name": "service",
        "options": [],
        "query": {
          "query": "label_values(sla_compliance_percentage, service_name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 0,
        "tagValuesQuery": "",
        "tagsQuery": "",
        "type": "query",
        "useTags": false
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-sla"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "refresh": "30s",
  "schemaVersion": 36,
  "version": 1,
  "weekStart": ""
}