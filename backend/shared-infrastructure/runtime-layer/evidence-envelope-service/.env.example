# Evidence Envelope Service Environment Configuration
# Copy this file to .env and update values for your environment

# Service Configuration
SERVICE_NAME=evidence-envelope-service
VERSION=1.0.0
DEBUG=false
PORT=8020

# Database Configuration (MongoDB)
MONGODB_CONNECTION_STRING=mongodb://evidence_service:evidence_service_password_change_in_production@mongodb:27017/evidence_envelopes?authSource=evidence_envelopes
MONGODB_DATABASE_NAME=evidence_envelopes
MONGODB_MAX_CONNECTIONS=100
MONGODB_MIN_CONNECTIONS=10

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20
REDIS_RETRY_ON_TIMEOUT=true

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_AUDIT_EVENTS=audit-events
KAFKA_TOPIC_ENVELOPE_EVENTS=envelope-events
KAFKA_CLIENT_ID=evidence-envelope-service
KAFKA_COMPRESSION_TYPE=gzip
KAFKA_BATCH_SIZE=16384
KAFKA_LINGER_MS=10
KAFKA_ACKS=all

# Authentication Configuration
JWT_SECRET_KEY=evidence-envelope-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# Performance Configuration
ENVELOPE_CACHE_SIZE=1000
ENVELOPE_CACHE_TTL=300
MAX_INFERENCE_STEPS=50
MAX_ENVELOPE_SIZE_MB=10

# Regulatory Compliance
AUDIT_RETENTION_DAYS=2555
INTEGRITY_CHECK_INTERVAL=86400
CHECKSUM_ALGORITHM=sha256

# Monitoring
PROMETHEUS_METRICS_PORT=8021
LOG_LEVEL=INFO
STRUCTURED_LOGGING=true