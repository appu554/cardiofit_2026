# Anticholinergic Cognitive Burden (ACB) Scale
# Primary Source: Boustani et al. ACB Scale (2008), updated 2012
# Clinical Use: Assess cumulative anticholinergic burden in elderly patients
# Risk: ACB >= 3 associated with cognitive impairment, falls, delirium
#
# Scoring:
#   ACB 1 = Possible anticholinergic (serum anticholinergic activity)
#   ACB 2 = Definite anticholinergic clinically relevant effect
#   ACB 3 = Definite anticholinergic with known cognitive effects
#
# Knowledge Version: 2025.1
# Last Clinical Review: 2024-12-01
# Jurisdiction: GLOBAL (applies to all regions)

metadata:
  knowledgeType: "anticholinergic_burden"
  knowledgeVersion: "2025.1"
  primaryAuthority: "ACB_SCALE"
  jurisdiction: "GLOBAL"
  effectiveDate: "2024-01-01"
  reviewDate: "2025-06-01"
  totalEntries: 65
  description: "Anticholinergic Cognitive Burden Scale for medication-related cognitive risk assessment"

entries:
