# Australian Potentially Inappropriate Medicines (PIMs) list — Wang et al. 2024
#
# 19 medicines or medicine classes deemed potentially inappropriate for
# older adults living in Australia, developed via Delphi consensus
# (33 then 32 expert panellists across geriatrics, pharmacy, medicine).
#
# Source citation
#   Wang KN, Etherton-Beer CD, Sanfilippo F, Page AT.
#   "Development of a list of Australian potentially inappropriate
#    medicines using the Delphi technique."
#   Internal Medicine Journal 54 (2024) 980-1002
#   DOI: 10.1111/imj.16322
#
# Curation note
#   Criteria sentences below are RE-PHRASED in our own words, per the
#   Layer 1 audit's risk-register guidance:
#     "facts not copyrightable; Wiley prose is. Re-phrase before loading."
#   The clinical content (drugs, conditions, alternatives) is factual
#   and unprotected; the editorial phrasing in this YAML is original.
#
# Schema matches the loader expectations in load_explicit_criteria.py.
# Top keys: metadata, summary, entries (loader reads "entries").

metadata:
  version: "1.0"
  source: "Wang KN et al. 2024 — Australian PIMs list (Delphi consensus)"
  sourcePublication: "Internal Medicine Journal 54 (2024) 980-1002"
  sourceDoi: "10.1111/imj.16322"
  sourceUrl: "https://doi.org/10.1111/imj.16322"
  jurisdiction: "AU"
  applicability: "Adults aged ≥65 years in Australia"
  knowledgeVersion: "2024.1"
  effectiveDate: "2024-02-01"
  curatedBy: "Manual extraction from Table 2 of source article (re-phrased for clarity)"
  lastUpdated: "2026-04-29"

summary:
  totalEntries: 19
  delphiPanelRound1: 33
  delphiPanelRound2: 32

entries:

  - id: "WANG-01"
    section: "Alpha-adrenoreceptor antagonists"
    sectionName: "Cardiovascular / Genitourinary"
    drugClass: "Alpha-adrenoreceptor antagonists"
    drugName: "Prazosin"
    rxnormCodes: ["8629"]   # prazosin
    criteria: "Avoid prazosin in older adults given risk of hypotension, falls, frailty, initial-dose adverse effects, or concurrent use of other antihypertensive medications."
    rationale: "Risk of orthostatic hypotension and falls; safer alternatives exist for both hypertension and benign prostatic hyperplasia indications."
    saferAlternatives:
      - "ACE inhibitors (e.g. enalapril, lisinopril)"
      - "Angiotensin II receptor blockers (e.g. candesartan, irbesartan)"
      - "Calcium channel blockers (e.g. amlodipine, diltiazem)"
      - "Silodosin"
      - "Tamsulosin"
    governance: &gov
      sourceAuthority: "Wang_2024"
      sourceDocument: "Wang KN et al. 2024 IMJ"
      sourceUrl: "https://doi.org/10.1111/imj.16322"
      sourceSection: "Table 2"
      jurisdiction: "AU"
      evidenceLevel: "C"
      effectiveDate: "2024-02-01"
      knowledgeVersion: "2024.1"
      approvalStatus: "ACTIVE"

  - id: "WANG-02"
    section: "Antiemetics — dopamine antagonist"
    sectionName: "Gastrointestinal / CNS"
    drugClass: "Antiemetics — dopamine antagonist"
    drugName: "Chlorpromazine, Prochlorperazine"
    rxnormCodes: ["2403", "8704"]   # chlorpromazine, prochlorperazine
    criteria: "Avoid chlorpromazine and prochlorperazine in older adults with Parkinson disease, Lewy body dementia, neurodegenerative disease (e.g. Alzheimer disease, cognitive impairment), polypharmacy, frailty, or high risk of falls."
    rationale: "Extrapyramidal effects, sedation, fall risk; safer antiemetic options exist."
    saferAlternatives:
      - "Ondansetron"
      - "Domperidone"
    governance: *gov

  - id: "WANG-03"
    section: "Antihypertensives, centrally acting"
    sectionName: "Cardiovascular"
    drugClass: "Centrally acting antihypertensives"
    drugName: "Methyldopa"
    rxnormCodes: ["6876"]   # methyldopa
    criteria: "Avoid methyldopa in older adults with risk of hypotension, falls, frailty, or who are already taking other antihypertensive medications."
    rationale: "High risk of orthostatic hypotension and CNS adverse effects; safer first-line antihypertensives are available."
    saferAlternatives:
      - "ACE inhibitors (e.g. enalapril, lisinopril)"
      - "Angiotensin II receptor blockers (e.g. candesartan, irbesartan)"
      - "Thiazide diuretics (e.g. hydrochlorothiazide)"
    governance: *gov

  - id: "WANG-04"
    section: "Antipsychotics — first-generation (typical)"
    sectionName: "Psychotropic"
    drugClass: "First-generation antipsychotics"
    drugName: "Haloperidol, Zuclopenthixol, Trifluoperazine, Thioridazine, Periciazine, Flupenthixol"
    rxnormCodes: ["5093", "10800", "114176", "114176"]   # haloperidol, zuclopenthixol(approx), trifluoperazine, thioridazine
    criteria: "Avoid first-generation antipsychotics (haloperidol, zuclopenthixol, trifluoperazine, thioridazine, periciazine, flupenthixol) in older adults at risk of extrapyramidal reactions, taking anticholinergics, with polypharmacy, frailty, neurodegenerative disease (e.g. delirium), cognitive impairment, cardiovascular or cerebrovascular disease, or risk of falls."
    rationale: "Marked extrapyramidal, anticholinergic, and cardiovascular risks; second-generation antipsychotics or non-pharmacological strategies are preferred."
    saferAlternatives:
      - "Atypical antipsychotics (e.g. quetiapine)"
      - "Risperidone"
      - "Non-pharmacological strategies (e.g. behavioural management, environmental adjustment)"
    governance: *gov

  - id: "WANG-05"
    section: "Antipsychotics — second-generation (atypical)"
    sectionName: "Psychotropic"
    drugClass: "Second-generation antipsychotics"
    drugName: "Olanzapine"
    rxnormCodes: ["61381"]   # olanzapine
    criteria: "Avoid olanzapine in older adults with cardiometabolic syndrome (high blood pressure, high blood sugar), risk of falls, polypharmacy, neurodegenerative disease (e.g. delirium), long-term use, or when non-pharmacological methods have not been adequately tried."
    rationale: "Significant metabolic, sedative and fall risks with long-term use in older adults."
    saferAlternatives:
      - "Quetiapine"
      - "Risperidone"
    governance: *gov

  - id: "WANG-06"
    section: "Benzodiazepines — long-acting"
    sectionName: "Psychotropic / Sedative"
    drugClass: "Long-acting benzodiazepines"
    drugName: "Clonazepam, Flunitrazepam"
    rxnormCodes: ["2598", "4501"]   # clonazepam, flunitrazepam
    criteria: "Avoid long-acting benzodiazepines (clobazam, clonazepam, diazepam, flunitrazepam, nitrazepam) in older adults with dependence, concurrent use of other sedatives, polypharmacy, frailty, neurodegenerative disease, cognitive impairment, poor renal function, long-term use, or risk of falls."
    rationale: "Prolonged half-life accumulates in older adults; sedation, falls, cognitive impairment, dependence."
    saferAlternatives:
      - "Short-acting benzodiazepine (e.g. oxazepam) for limited duration"
      - "Melatonin (for sleep indication)"
      - "Non-pharmacological strategies (e.g. sleep hygiene)"
    governance: *gov

  - id: "WANG-07"
    section: "Benzodiazepines — medium-acting"
    sectionName: "Psychotropic / Sedative"
    drugClass: "Medium-acting benzodiazepines"
    drugName: "Bromazepam, Lorazepam"
    rxnormCodes: ["1827", "6470"]   # bromazepam, lorazepam
    criteria: "Avoid medium-acting benzodiazepines (bromazepam, lorazepam) in older adults at risk of falls, taking other sedatives, with polypharmacy, frailty, neurodegenerative disease, or cognitive impairment."
    rationale: "Sedation and fall risk; safer short-acting or non-pharmacological alternatives are available."
    saferAlternatives:
      - "Short-acting benzodiazepine"
      - "Melatonin (for sleep indication)"
      - "Non-pharmacological strategies"
    governance: *gov

  - id: "WANG-08"
    section: "Benzodiazepines — short-acting"
    sectionName: "Psychotropic / Sedative"
    drugClass: "Short-acting benzodiazepines"
    drugName: "Alprazolam"
    rxnormCodes: ["596"]   # alprazolam
    criteria: "Avoid alprazolam in older adults at risk of falls, taking other sedatives, with polypharmacy, frailty, neurodegenerative disease, dependency, renal impairment, or with long-term use."
    rationale: "Although short-acting, alprazolam has high dependence potential and adverse cognitive/fall risks in older adults."
    saferAlternatives:
      - "Oxazepam"
      - "Temazepam"
      - "Melatonin (for sleep indication)"
      - "Non-pharmacological strategies"
    governance: *gov

  - id: "WANG-09"
    section: "Genitourinary anticholinergics"
    sectionName: "Genitourinary"
    drugClass: "Genitourinary anticholinergics"
    drugName: "Oxybutynin"
    rxnormCodes: ["7715"]   # oxybutynin
    criteria: "Avoid oxybutynin (and other genitourinary anticholinergics: propantheline, tolterodine, solifenacin) in older adults already taking anticholinergics, frail, with polypharmacy, risk of falls, neurodegenerative disease (e.g. delirium), constipation, or cognitive impairment."
    rationale: "Significant anticholinergic burden contributing to cognitive decline, delirium, constipation, urinary retention; cumulative ACB risk."
    saferAlternatives:
      - "Non-pharmacological behavioural strategies for incontinence"
    governance: *gov

  - id: "WANG-10"
    section: "NSAIDs — non-selective"
    sectionName: "Analgesic / Anti-inflammatory"
    drugClass: "Non-selective NSAIDs"
    drugName: "Diclofenac, Indomethacin, Ibuprofen, Ketoprofen, Piroxicam, Meloxicam, Ketorolac"
    rxnormCodes: ["3355", "5781", "5640", "6135", "6142", "6915", "35827"]
    criteria: "Avoid non-selective NSAIDs (indomethacin, diclofenac, ketorolac, piroxicam, meloxicam, ibuprofen, naproxen, ketoprofen, mefenamic acid) in older adults with history of GI bleeding, increased bleeding risk, frailty, poor renal function, peptic ulcer disease, multimorbidity, chronic kidney disease, heart failure, or cardiovascular disease."
    rationale: "GI bleeding, renal injury, cardiovascular events, fluid retention; risks substantially increased in older adults."
    saferAlternatives:
      - "Paracetamol"
    governance: *gov

  - id: "WANG-11"
    section: "NSAIDs — selective COX-2 inhibitors"
    sectionName: "Analgesic / Anti-inflammatory"
    drugClass: "Selective COX-2 inhibitors"
    drugName: "Celecoxib, Etoricoxib"
    rxnormCodes: ["140587", "307296"]   # 307296=etoricoxib (was 352300 = Glipizide/Metformin combo, fixed 2026-04-30)
    criteria: "Avoid selective COX-2 inhibitors (celecoxib, etoricoxib) in older adults with history of GI bleeding, increased bleeding risk, frailty, poor renal function, heart failure, cardiovascular disease, chronic kidney disease, long-term use, or who are taking ACE inhibitors or diuretics."
    rationale: "Cardiovascular and renal risks; safer analgesic options should be preferred."
    saferAlternatives:
      - "Paracetamol"
      - "Celecoxib at lowest effective dose, short-term, if alternatives unsuitable"
    governance: *gov

  - id: "WANG-12"
    section: "Opioids"
    sectionName: "Analgesic"
    drugClass: "Opioid analgesics"
    drugName: "Pethidine, Fentanyl, Codeine, Hydromorphone, Dextropropoxyphene"
    rxnormCodes: ["8001", "4337", "2670", "3423", "6754"]
    criteria: "Avoid pethidine, fentanyl (including transdermal in opioid-naive), codeine, hydromorphone, and dextropropoxyphene in older adults with polypharmacy, risk of falls, frailty, poor renal function, neurodegenerative disease (e.g. delirium), constipation, opioid dependency, long-term use, or impaired cognition."
    rationale: "Variable metabolism (codeine), neurotoxic metabolites (pethidine), accumulation in renal impairment, cognitive impairment, falls."
    saferAlternatives:
      - "Physiotherapy and non-pharmacological strategies for chronic pain"
      - "Paracetamol (first-line for chronic pain)"
      - "Oxycodone (preferred opioid in older adults if needed)"
      - "Buprenorphine"
    governance: *gov

  - id: "WANG-13"
    section: "Oral anticoagulants — direct thrombin inhibitors"
    sectionName: "Anticoagulant"
    drugClass: "Direct thrombin inhibitors"
    drugName: "Dabigatran"
    rxnormCodes: ["1037045"]   # dabigatran
    criteria: "Avoid dabigatran in older adults with increased bleeding risk, multimorbidity, peptic ulcer disease, frailty, risk of falls, poor blood pressure control, chronic kidney disease, or poor renal function."
    rationale: "Renal-cleared anticoagulant with bleeding risk; alternatives may be more appropriate in this population."
    saferAlternatives: []
    governance: *gov

  - id: "WANG-14"
    section: "Oral anticoagulants — Factor Xa inhibitors"
    sectionName: "Anticoagulant"
    drugClass: "Factor Xa inhibitors"
    drugName: "Apixaban, Rivaroxaban"
    rxnormCodes: ["1364430", "1114195"]
    criteria: "Avoid rivaroxaban (and apixaban with caution) in older adults with peptic ulcer disease, increased bleeding risk, risk of falls, multimorbidity, polypharmacy, poor renal function, or chronic kidney disease."
    rationale: "Bleeding risk; benefit-risk requires individualised assessment."
    saferAlternatives: []
    governance: *gov

  - id: "WANG-15"
    section: "Sedating antihistamines"
    sectionName: "Antihistamine"
    drugClass: "First-generation (sedating) antihistamines"
    drugName: "Promethazine"
    rxnormCodes: ["8745"]
    criteria: "Avoid promethazine and other first-generation sedating antihistamines (diphenhydramine, doxylamine, dexchlorpheniramine, pheniramine, cyclizine, chlorpheniramine, cyproheptadine) in older adults taking other sedatives, with cognitive impairment, taking anticholinergics, frail, with neurodegenerative disease, risk of falls, or polypharmacy."
    rationale: "Strong anticholinergic and sedative properties; high ACB contribution; cognitive and fall risks."
    saferAlternatives:
      - "Non-sedating antihistamines (e.g. fexofenadine, loratadine, cetirizine)"
    governance: *gov

  - id: "WANG-16"
    section: "Sulfonylureas"
    sectionName: "Antidiabetic"
    drugClass: "Sulfonylureas"
    drugName: "Glibenclamide, Glimepiride"
    rxnormCodes: ["4815", "25789"]
    criteria: "Avoid glibenclamide and glimepiride in older adults taking other glucose-lowering medications, with high risk of falls, frailty, chronic kidney disease, polypharmacy, multimorbidity, renal impairment, irregular diet, or dehydration."
    rationale: "Long-acting sulfonylureas have prolonged hypoglycaemia risk in renal impairment; older adults at risk of severe / prolonged hypoglycaemia."
    saferAlternatives:
      - "Metformin"
      - "Gliclazide (shorter-acting sulfonylurea preferred if SU needed)"
      - "DPP-4 inhibitors (e.g. sitagliptin, saxagliptin)"
      - "SGLT2 inhibitors (e.g. dapagliflozin)"
    governance: *gov

  - id: "WANG-17"
    section: "Tramadol"
    sectionName: "Analgesic"
    drugClass: "Atypical opioid"
    drugName: "Tramadol"
    rxnormCodes: ["10689"]
    criteria: "Avoid tramadol in older adults with multimorbidity, frailty, neurodegenerative disease, risk of falls, polypharmacy, poor renal function, cognitive impairment, long-term use, concurrent antidepressants, epilepsy, or risk of seizures."
    rationale: "Serotonin syndrome risk with antidepressants, lowered seizure threshold, CNS effects, and accumulation in renal impairment."
    saferAlternatives:
      - "Paracetamol"
      - "NSAIDs (with usual caveats — see WANG-10)"
    governance: *gov

  - id: "WANG-18"
    section: "Tricyclic antidepressants"
    sectionName: "Antidepressant"
    drugClass: "Tricyclic antidepressants (TCAs)"
    drugName: "Doxepin, Dosulepin (Dothiepin)"
    rxnormCodes: ["3638", "3502"]
    criteria: "Avoid doxepin, dosulepin (and other TCAs: imipramine, clomipramine, amitriptyline, nortriptyline) in older adults taking other anticholinergics, frail, with polypharmacy, risk of falls, neurodegenerative disease, constipation, cognitive impairment, taking other sedatives, with risk of postural hypotension, or with benign prostatic hyperplasia."
    rationale: "Highly anticholinergic and sedating; cardiotoxic at supra-therapeutic doses; multiple safer antidepressant classes available."
    saferAlternatives:
      - "Selective serotonin reuptake inhibitors (e.g. citalopram, paroxetine)"
      - "Serotonin and norepinephrine reuptake inhibitors (e.g. duloxetine)"
      - "Mirtazapine"
    governance: *gov

  - id: "WANG-19"
    section: "Z-drugs"
    sectionName: "Hypnotic"
    drugClass: "Non-benzodiazepine hypnotics (Z-drugs)"
    drugName: "Zolpidem, Zopiclone"
    rxnormCodes: ["39998", "39993"]
    criteria: "Avoid zolpidem and zopiclone in older adults with dependency, taking other sedatives, frail, with neurodegenerative disease (e.g. delirium), risk of falls, polypharmacy, cognitive impairment, or long-term use."
    rationale: "Despite earlier perception of safer profile vs benzodiazepines, evidence shows comparable falls/cognitive risk in older adults."
    saferAlternatives:
      - "Melatonin"
      - "Non-pharmacological strategies (e.g. sleep hygiene, CBT-I)"
    governance: *gov
