      sourceAuthority: "TGA"
      sourceDocument: "TGA Pregnancy Category Database"
      evidenceLevel: "B"
      effectiveDate: "2024-01-01"
      approvalStatus: "ACTIVE"
      jurisdiction: "AU"
      knowledgeVersion: "2025.1"

