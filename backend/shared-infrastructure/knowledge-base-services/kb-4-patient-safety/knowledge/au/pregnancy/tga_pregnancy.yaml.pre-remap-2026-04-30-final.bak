    categoryDescription: "May cause respiratory depression in neonate"
    trimesterRisk:
      first: "Use only if essential"
      second: "Use only if essential"
      third: "Risk of neonatal withdrawal syndrome"
    clinicalGuidance: "Opioid use in pregnancy may cause neonatal abstinence syndrome. Use lowest effective dose for shortest duration."
    governance:
      sourceAuthority: "TGA"
      sourceDocument: "TGA Pregnancy Category Database"
      evidenceLevel: "B"
      effectiveDate: "2024-01-01"
      approvalStatus: "ACTIVE"
      jurisdiction: "AU"
      knowledgeVersion: "2025.1"

