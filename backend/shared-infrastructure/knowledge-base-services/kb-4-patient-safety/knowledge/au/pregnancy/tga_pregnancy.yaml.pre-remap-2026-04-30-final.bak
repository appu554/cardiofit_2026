      second: "Acceptable if clinically needed"
      third: "Risk of neonatal adaptation syndrome"
    clinicalGuidance: "Often preferred SSRI in pregnancy due to lower placental transfer. Balance benefits of treatment against risks."
    governance:
      sourceAuthority: "TGA"
      sourceDocument: "TGA Pregnancy Category Database"
      evidenceLevel: "B"
      effectiveDate: "2024-01-01"
      approvalStatus: "ACTIVE"
      jurisdiction: "AU"
