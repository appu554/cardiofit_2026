# TGA Pregnancy Categories Knowledge Base - Australia
# Source: Therapeutic Goods Administration
# Authority: TGA (Therapeutic Goods Administration, Australia)
# Last Updated: 2025-01-14
# Knowledge Version: 2025.1
# Total Entries: 85

# TGA Pregnancy Category Definitions:
# A: Taken by large number of pregnant women without observed increase in malformations
# B1: Animal studies show no evidence of increased fetal damage; limited human data
# B2: Animal studies inadequate or lacking; no evidence of harm in human use
# B3: Animal studies show increased fetal damage; human relevance uncertain
# C: Caused or suspected to cause harmful pharmacological effects without malformations
# D: Known to cause increased fetal abnormalities; benefits may outweigh risks
# X: High risk of permanent damage; contraindicated in pregnancy

metadata:
  knowledgeType: "pregnancy_safety"
  knowledgeVersion: "2025.1"
  primaryAuthority: "TGA"
  jurisdiction: "AU"
  effectiveDate: "2024-01-01"
  reviewDate: "2025-06-01"
  totalEntries: 85
  description: "TGA Pregnancy Categories from Australian prescribing information"
  categoryDefinitions:
    A: "Safe - Taken by large numbers of pregnant women without observed harm"
    B1: "Limited Data - No animal evidence of harm, limited human data"
    B2: "Inadequate Data - Inadequate animal studies, no known human harm"
    B3: "Uncertain Risk - Animal evidence of harm, human relevance uncertain"
    C: "Pharmacological Risk - May cause reversible pharmacological effects"
    D: "Known Risk - Evidence of fetal harm, use only if benefits outweigh risks"
    X: "Contraindicated - High risk of permanent fetal damage"

entries:
