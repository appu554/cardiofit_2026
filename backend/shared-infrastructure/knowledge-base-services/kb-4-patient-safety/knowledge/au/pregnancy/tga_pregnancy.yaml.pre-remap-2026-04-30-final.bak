    drugName: "Morphine"
    atcCode: "N02AA01"
    category: "C"
    categoryDescription: "May cause neonatal respiratory depression and withdrawal"
    trimesterRisk:
      first: "Use only if essential"
      second: "Use only if essential"
      third: "Risk of neonatal withdrawal syndrome"
    clinicalGuidance: "Regular use causes neonatal abstinence syndrome. Monitor neonate for respiratory depression and withdrawal."
    governance:
      sourceAuthority: "TGA"
      sourceDocument: "TGA Pregnancy Category Database"
      evidenceLevel: "B"
      effectiveDate: "2024-01-01"
      approvalStatus: "ACTIVE"
      jurisdiction: "AU"
      knowledgeVersion: "2025.1"

  - rxnorm: "2670"
    drugName: "Codeine"
    atcCode: "N02AA08"
    category: "C"
    categoryDescription: "May cause neonatal respiratory depression"
    trimesterRisk:
      first: "Use only if essential"
      second: "Use only if essential"
      third: "Risk of neonatal withdrawal"
    clinicalGuidance: "Avoid prolonged use near term. Risk of neonatal withdrawal. Use paracetamol preferentially."
    governance:
      sourceAuthority: "TGA"
      sourceDocument: "TGA Pregnancy Category Database"
      evidenceLevel: "B"
      effectiveDate: "2024-01-01"
      approvalStatus: "ACTIVE"
      jurisdiction: "AU"
      knowledgeVersion: "2025.1"

  - rxnorm: "1649"
    drugName: "Amiodarone"
    atcCode: "C01BD01"
    category: "C"
    categoryDescription: "Iodine content may affect fetal thyroid"
    trimesterRisk:
      first: "Use only if life-threatening arrhythmia"
      second: "Use only if essential"
      third: "Risk of fetal/neonatal thyroid dysfunction"
    clinicalGuidance: "Contains iodine which crosses placenta and affects fetal thyroid. Use only for life-threatening arrhythmias."
    governance:
      sourceAuthority: "TGA"
      sourceDocument: "TGA Pregnancy Category Database"
      evidenceLevel: "B"
      effectiveDate: "2024-01-01"
      approvalStatus: "ACTIVE"
      jurisdiction: "AU"
      knowledgeVersion: "2025.1"

  - rxnorm: "3322"
    drugName: "Diazepam"
    atcCode: "N05BA01"
    category: "C"
    categoryDescription: "Benzodiazepine - neonatal sedation risk"
    trimesterRisk:
      first: "Avoid if possible - older data on cleft palate"
      second: "Use only if essential"
      third: "Risk of floppy infant syndrome"
    clinicalGuidance: "Benzodiazepines near term cause neonatal sedation, hypotonia, and respiratory depression. Use lowest dose for shortest time."
    governance:
      sourceAuthority: "TGA"
      sourceDocument: "TGA Pregnancy Category Database"
      evidenceLevel: "B"
      effectiveDate: "2024-01-01"
      approvalStatus: "ACTIVE"
      jurisdiction: "AU"
      knowledgeVersion: "2025.1"

  - rxnorm: "8640"
    drugName: "Prednisone"
    atcCode: "H02AB07"
    category: "C"
    categoryDescription: "Corticosteroid - pharmacological effects possible"
    trimesterRisk:
      first: "Use only if essential - slight cleft palate risk"
      second: "Acceptable when needed"
      third: "May affect fetal adrenal function"
    clinicalGuidance: "Corticosteroids may be needed for maternal conditions. Risk of cleft palate in first trimester is small. Monitor neonatal adrenals if prolonged use."
    governance:
      sourceAuthority: "TGA"
      sourceDocument: "TGA Pregnancy Category Database"
      evidenceLevel: "B"
      effectiveDate: "2024-01-01"
      approvalStatus: "ACTIVE"
      jurisdiction: "AU"
      knowledgeVersion: "2025.1"

  - rxnorm: "3264"
    drugName: "Dexamethasone"
    atcCode: "H02AB02"
    category: "C"
    categoryDescription: "Crosses placenta - pharmacological effects"
    trimesterRisk:
      first: "Use only if essential"
      second: "Used for fetal lung maturation"
      third: "Used for fetal lung maturation"
    clinicalGuidance: "Used antenatally for fetal lung maturation in threatened preterm birth. Crosses placenta more than prednisone."
    governance:
      sourceAuthority: "TGA"
      sourceDocument: "TGA Pregnancy Category Database"
      evidenceLevel: "B"
      effectiveDate: "2024-01-01"
      approvalStatus: "ACTIVE"
      jurisdiction: "AU"
      knowledgeVersion: "2025.1"

  - rxnorm: "1151"
    drugName: "Betamethasone"
    atcCode: "H02AB01"
    category: "C"
    categoryDescription: "Crosses placenta - used for fetal lung maturation"
    trimesterRisk:
      first: "Use only if essential"
      second: "Used for fetal lung maturation"
      third: "Used for fetal lung maturation"
    clinicalGuidance: "First-line for antenatal corticosteroid therapy for threatened preterm birth 24-34 weeks."
    governance:
      sourceAuthority: "TGA"
      sourceDocument: "TGA Pregnancy Category Database"
      evidenceLevel: "A"
      effectiveDate: "2024-01-01"
      approvalStatus: "ACTIVE"
      jurisdiction: "AU"
      knowledgeVersion: "2025.1"

  - rxnorm: "7531"
    drugName: "Olanzapine"
    atcCode: "N05AH03"
    category: "C"
    categoryDescription: "May cause neonatal effects"
    trimesterRisk:
      first: "Use only if benefits outweigh risks"
      second: "Use only if essential"
      third: "Risk of neonatal extrapyramidal symptoms"
    clinicalGuidance: "Antipsychotic use requires balancing maternal mental health against fetal risks. Monitor neonate for extrapyramidal symptoms."
    governance:
      sourceAuthority: "TGA"
      sourceDocument: "TGA Pregnancy Category Database"
      evidenceLevel: "B"
      effectiveDate: "2024-01-01"
      approvalStatus: "ACTIVE"
      jurisdiction: "AU"
      knowledgeVersion: "2025.1"

  # ==========================================================================
  # CATEGORY D - KNOWN RISK, BENEFITS MAY OUTWEIGH
  # ==========================================================================

  - rxnorm: "6185"
    drugName: "Lisinopril"
    atcCode: "C09AA03"
    category: "D"
    categoryDescription: "Known to cause fetal harm - fetotoxic"
    trimesterRisk:
      first: "Contraindicated - discontinue as soon as pregnancy detected"
      second: "Contraindicated - fetal renal damage, oligohydramnios"
      third: "Contraindicated - fetal/neonatal death possible"
    clinicalGuidance: "ACE inhibitors cause fetal renal dysgenesis, oligohydramnios, skull hypoplasia. Discontinue immediately when pregnancy confirmed."
    governance:
      sourceAuthority: "TGA"
      sourceDocument: "TGA Pregnancy Category Database"
      evidenceLevel: "A"
      effectiveDate: "2024-01-01"
      approvalStatus: "ACTIVE"
      jurisdiction: "AU"
      knowledgeVersion: "2025.1"

  - rxnorm: "29046"
    drugName: "Ramipril"
    atcCode: "C09AA05"
    category: "D"
    categoryDescription: "ACE inhibitor - fetotoxic"
    trimesterRisk:
      first: "Contraindicated"
      second: "Contraindicated"
      third: "Contraindicated"
    clinicalGuidance: "All ACE inhibitors contraindicated throughout pregnancy. Switch to safe alternatives before conception."
