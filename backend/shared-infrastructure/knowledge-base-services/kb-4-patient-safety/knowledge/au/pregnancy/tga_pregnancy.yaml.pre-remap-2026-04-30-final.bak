  # CATEGORY C - PHARMACOLOGICAL EFFECTS WITHOUT MALFORMATIONS
  # ==========================================================================

  - rxnorm: "5640"
    drugName: "Ibuprofen"
    atcCode: "M01AE01"
    category: "C"
    categoryDescription: "May cause harmful pharmacological effects on fetus"
    trimesterRisk:
      first: "Avoid - potential fertility effects"
      second: "Use with caution if essential"
      third: "Contraindicated - premature ductus arteriosus closure, oligohydramnios"
    clinicalGuidance: "NSAIDs should be avoided in third trimester. Risk of premature closure of ductus arteriosus and fetal renal impairment."
    governance:
      sourceAuthority: "TGA"
      sourceDocument: "TGA Pregnancy Category Database"
      evidenceLevel: "A"
      effectiveDate: "2024-01-01"
      approvalStatus: "ACTIVE"
      jurisdiction: "AU"
      knowledgeVersion: "2025.1"

  - rxnorm: "7804"
