    trimesterRisk:
      first: "Acceptable - often continued"
      second: "Acceptable"
      third: "Acceptable - may reduce insulin requirements"
    clinicalGuidance: "Increasingly used in gestational diabetes. Crosses placenta but no evidence of teratogenicity. May be continued from preconception."
    governance:
      sourceAuthority: "TGA"
      sourceDocument: "TGA Pregnancy Category Database"
      evidenceLevel: "B"
      effectiveDate: "2024-01-01"
      approvalStatus: "ACTIVE"
      jurisdiction: "AU"
      knowledgeVersion: "2025.1"

