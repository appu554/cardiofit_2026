# KB-12 Order Sets & Care Plans - Environment Configuration Example
# =============================================================================
# PRODUCTION CONFIGURATION - NO MOCKS, NO FALLBACKS
# Copy this file to .env.production and update values
# =============================================================================

# =============================================================================
# Service Configuration
# =============================================================================
ENVIRONMENT=production
LOG_LEVEL=info
LOG_FORMAT=json
PORT=8092
GIN_MODE=release

# =============================================================================
# PostgreSQL Database (REQUIRED)
# External port: 5448, Internal port: 5432
# =============================================================================
POSTGRES_HOST=kb-12-postgres
POSTGRES_PORT=5432
POSTGRES_USER=kb12_user
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
POSTGRES_DB=kb12_ordersets
POSTGRES_SSL_MODE=disable
KB12_DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# Connection Pool Settings
POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_CONN_MAX_LIFETIME=5m

# =============================================================================
# Redis Cache (REQUIRED - Not Optional)
# External port: 6406, Internal port: 6379
# =============================================================================
REDIS_HOST=kb-12-redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Cache Settings
REDIS_MAX_RETRIES=3
REDIS_POOL_SIZE=10
CACHE_TTL=3600

# =============================================================================
# KB Services (ALL REQUIRED - No Fallbacks)
# Update URLs based on your deployment
# =============================================================================

# KB-1 Drug Rules & Dosing (REQUIRED)
KB1_ENABLED=true
KB1_URL=http://kb-drug-rules:8081
KB1_TIMEOUT=10s
KB1_RETRY_ATTEMPTS=3

# KB-3 Guidelines & Evidence (REQUIRED)
KB3_ENABLED=true
KB3_URL=http://kb-3-guidelines:8087
KB3_TIMEOUT=10s
KB3_RETRY_ATTEMPTS=3

# KB-6 Formulary (REQUIRED)
KB6_ENABLED=true
KB6_URL=http://kb-6-formulary:8091
KB6_TIMEOUT=10s
KB6_RETRY_ATTEMPTS=3

# KB-7 Terminology (REQUIRED)
KB7_ENABLED=true
KB7_URL=http://kb-7-terminology:8092
KB7_TIMEOUT=10s
KB7_RETRY_ATTEMPTS=3

# =============================================================================
# Server Timeouts
# =============================================================================
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_SHUTDOWN_TIMEOUT=15s

# =============================================================================
# Metrics & Monitoring
# =============================================================================
METRICS_ENABLED=true
METRICS_PORT=9092
PROMETHEUS_ENABLED=true
HEALTH_CHECK_INTERVAL=30s
