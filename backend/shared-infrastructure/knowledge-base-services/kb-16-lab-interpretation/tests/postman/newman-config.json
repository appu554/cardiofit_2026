{
  "collection": "./KB16_Lab_Interpretation.postman_collection.json",
  "environment": "./environments/docker.postman_environment.json",
  "reporters": ["cli", "json", "htmlextra", "junit"],
  "reporter": {
    "json": {
      "export": "./reports/newman-results.json"
    },
    "htmlextra": {
      "export": "./reports/newman-report.html",
      "title": "KB-16 Lab Interpretation - Clinical Validation Report",
      "skipHeaders": [],
      "showMarkdownLinks": true,
      "noSyntaxHighlighting": false,
      "showFolderDescription": true,
      "skipSensitiveData": true,
      "browserTitle": "KB-16 Validation Report",
      "displayProgressBar": true
    },
    "junit": {
      "export": "./reports/newman-junit.xml"
    }
  },
  "iterationCount": 1,
  "delayRequest": 100,
  "timeout": 30000,
  "timeoutRequest": 10000,
  "timeoutScript": 5000,
  "insecure": false,
  "bail": false,
  "color": "auto",
  "sslClientCert": null,
  "sslClientKey": null,
  "sslClientPassphrase": null,
  "workingDir": "./tests/postman"
}
