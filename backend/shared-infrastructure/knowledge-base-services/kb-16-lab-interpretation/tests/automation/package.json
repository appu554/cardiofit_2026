{
  "name": "kb16-clinical-validation-automation",
  "version": "1.0.0",
  "description": "Newman automation suite for KB-16 Lab Interpretation Clinical Validation Tests",
  "scripts": {
    "test": "newman run KB16_Lab_Interpretation.postman_collection.json -e kb16_local.postman_environment.json",
    "test:health": "./run_newman_tests.sh --health-only",
    "test:phase1": "./run_newman_tests.sh --phase 1",
    "test:phase2": "./run_newman_tests.sh --phase 2",
    "test:phase3": "./run_newman_tests.sh --phase 3",
    "test:phase4": "./run_newman_tests.sh --phase 4",
    "test:phase5": "./run_newman_tests.sh --phase 5",
    "test:phase6": "./run_newman_tests.sh --phase 6",
    "test:phase7": "./run_newman_tests.sh --phase 7",
    "test:phase8": "./run_newman_tests.sh --phase 8",
    "test:phase9": "./run_newman_tests.sh --phase 9",
    "test:all": "./run_newman_tests.sh",
    "test:junit": "./run_newman_tests.sh --report junit",
    "test:html": "./run_newman_tests.sh --report html",
    "test:ci": "CI_MODE=true ./run_newman_tests.sh --report junit"
  },
  "dependencies": {
    "newman": "^6.0.0"
  },
  "devDependencies": {
    "newman-reporter-htmlextra": "^1.23.1",
    "newman-reporter-junitfull": "^1.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "kb-16",
    "lab-interpretation",
    "clinical-validation",
    "newman",
    "postman",
    "api-testing",
    "healthcare"
  ],
  "author": "CardioFit Clinical Engineering",
  "license": "PROPRIETARY"
}
