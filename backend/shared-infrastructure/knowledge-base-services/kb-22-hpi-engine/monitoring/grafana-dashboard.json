{
  "annotations": { "list": [] },
  "description": "KB-22 HPI Engine: Bayesian differential diagnosis, safety flags, upstream KB latency",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Session Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Sessions Started (rate/min)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "targets": [
        { "expr": "rate(kb22_sessions_started_total[5m]) * 60", "legendFormat": "sessions/min" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      }
    },
    {
      "title": "Questions Asked (rate/min)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "targets": [
        { "expr": "rate(kb22_questions_asked_total[5m]) * 60", "legendFormat": "questions/min" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      }
    },
    {
      "title": "Sessions by Status",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "targets": [
        { "expr": "kb22_sessions_by_status", "legendFormat": "{{status}}" }
      ]
    },
    {
      "title": "Convergence Rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 7 },
      "targets": [
        {
          "expr": "rate(kb22_differential_converged_total[1h]) / rate(kb22_sessions_started_total[1h])",
          "legendFormat": "convergence %"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "thresholds": { "steps": [
          { "value": null, "color": "red" },
          { "value": 0.5, "color": "yellow" },
          { "value": 0.7, "color": "green" }
        ]}}
      }
    },
    {
      "title": "Pata-Nahi Rate by Node",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 10, "x": 6, "y": 7 },
      "targets": [
        { "expr": "kb22_patanahi_rate", "legendFormat": "{{node_id}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "thresholds": { "steps": [
          { "value": null, "color": "green" },
          { "value": 0.3, "color": "yellow" },
          { "value": 0.5, "color": "red" }
        ]}}
      }
    },
    {
      "title": "Calibration Concordance (Top-1)",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 7 },
      "targets": [
        { "expr": "kb22_calibration_concordance", "legendFormat": "{{node_id}} / {{stratum}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "thresholds": { "steps": [
          { "value": null, "color": "red" },
          { "value": 0.6, "color": "yellow" },
          { "value": 0.8, "color": "green" }
        ]}}
      }
    },
    {
      "title": "Safety & Alerts",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "collapsed": false
    },
    {
      "title": "Safety Flags Fired (by severity)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "rate(kb22_safety_flags_raised_total[5m]) * 60", "legendFormat": "{{severity}} / {{flag_id}}" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "IMMEDIATE.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" }}] },
          { "matcher": { "id": "byRegexp", "options": "URGENT.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" }}] }
        ]
      }
    },
    {
      "title": "Safety Flags Total (cumulative)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "sum(kb22_safety_flags_raised_total) by (severity)", "legendFormat": "{{severity}}" }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [
          { "value": null, "color": "green" },
          { "value": 10, "color": "yellow" },
          { "value": 50, "color": "red" }
        ]}}
      }
    },
    {
      "title": "Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "title": "Answer Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 19 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(kb22_answer_latency_ms_bucket[5m]))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, rate(kb22_answer_latency_ms_bucket[5m]))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, rate(kb22_answer_latency_ms_bucket[5m]))", "legendFormat": "P99" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "thresholds": { "steps": [
          { "value": null, "color": "green" },
          { "value": 30, "color": "yellow" },
          { "value": 100, "color": "red" }
        ]}}
      }
    },
    {
      "title": "Session Init Latency (P50 / P95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 19 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(kb22_session_init_latency_ms_bucket[5m]))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, rate(kb22_session_init_latency_ms_bucket[5m]))", "legendFormat": "P95" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "title": "Upstream KB Dependencies",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false
    },
    {
      "title": "KB-20 Stratum Fetch (P95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 26 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(kb22_kb20_fetch_duration_ms_bucket[5m]))", "legendFormat": "KB-20 P95" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "thresholds": { "steps": [
          { "value": null, "color": "green" },
          { "value": 30, "color": "yellow" },
          { "value": 40, "color": "red" }
        ]}}
      }
    },
    {
      "title": "KB-21 Adherence/Reliability Fetch (P95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 26 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(kb22_kb21_fetch_duration_ms_bucket[5m]))", "legendFormat": "KB-21 P95" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "title": "KB-23 Perturbation Fetch (P95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 26 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(kb22_kb23_fetch_duration_ms_bucket[5m]))", "legendFormat": "KB-23 P95" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "title": "Entropy Computation Time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 32 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(kb22_entropy_computation_ms_bucket[5m]))", "legendFormat": "entropy P95" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["kb-22", "hpi-engine", "clinical"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "title": "KB-22 HPI Engine",
  "uid": "kb22-hpi-engine"
}
