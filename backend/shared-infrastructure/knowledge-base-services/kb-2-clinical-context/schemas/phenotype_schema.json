{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://clinical-kb.health/schemas/phenotype/v2.0.0",
  "title": "Clinical Phenotype Schema v2.0",
  "description": "Comprehensive schema for clinical phenotype definitions with temporal validity and logic engines",
  "type": "object",
  "required": ["id", "name", "domain", "version", "criteria", "priority"],
  
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^PHE-[A-Z0-9]{8}$",
      "description": "Unique phenotype identifier (e.g., PHE-CV000001)"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Human-readable phenotype name"
    },
    "domain": {
      "type": "string",
      "enum": [
        "cardiovascular", "diabetes", "respiratory", "renal", "hepatic",
        "oncology", "neurology", "psychiatry", "infectious", "rheumatology",
        "hematology", "endocrine", "gastroenterology", "geriatrics", "pediatrics",
        "obstetrics", "emergency", "surgery", "cross_domain"
      ],
      "description": "Primary clinical domain"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the phenotype"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "deprecated"],
      "default": "active",
      "description": "Lifecycle status of the phenotype"
    },
    "effective_date": {
      "type": "string",
      "format": "date",
      "description": "Date when phenotype becomes active"
    },
    "deprecated_date": {
      "type": "string",
      "format": "date",
      "description": "Date when phenotype was deprecated"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Detailed clinical description"
    },
    
    "criteria": {
      "type": "object",
      "required": ["logic_engine", "expression", "data_requirements"],
      "properties": {
        "logic_engine": {
          "type": "string",
          "enum": ["cel", "rego", "python", "sql"],
          "description": "Logic evaluation engine"
        },
        "expression": {
          "type": "string",
          "minLength": 1,
          "description": "Logic expression in the specified engine language"
        },
        "data_requirements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["field", "type", "required", "source"],
            "properties": {
              "field": {
                "type": "string",
                "description": "Data field name using dot notation (e.g., patient.age, bp.systolic)"
              },
              "type": {
                "type": "string",
                "enum": ["string", "integer", "float", "boolean", "array", "object", "date", "icd10", "loinc", "rxnorm"],
                "description": "Expected data type"
              },
              "required": {
                "type": "boolean",
                "description": "Whether field is required for phenotype evaluation"
              },
              "source": {
                "type": "string",
                "enum": ["context_gateway", "ehr", "patient_reported", "calculated", "external_api"],
                "description": "Data source system"
              },
              "units": {
                "type": "string",
                "description": "Measurement units if applicable"
              },
              "time_window": {
                "type": "string",
                "pattern": "^\\d+[hdwmy]$",
                "description": "Time window for data validity (e.g., 30d, 6m, 1y)"
              },
              "validation_rules": {
                "type": "object",
                "properties": {
                  "min_value": { "type": "number" },
                  "max_value": { "type": "number" },
                  "allowed_values": { "type": "array" },
                  "regex_pattern": { "type": "string" },
                  "code_system": { 
                    "type": "string",
                    "enum": ["ICD-10", "LOINC", "RXNORM", "SNOMED-CT", "CPT"]
                  }
                }
              }
            }
          }
        },
        "exclusion_criteria": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["condition", "rationale"],
            "properties": {
              "condition": { "type": "string" },
              "rationale": { "type": "string" },
              "expression": { "type": "string" }
            }
          }
        }
      }
    },
    
    "priority": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000,
      "description": "Priority for conflict resolution (1000 = highest priority)"
    },
    
    "exclusivity": {
      "type": "object",
      "description": "Rules for mutual exclusivity with other phenotypes",
      "properties": {
        "exclusive_with": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Phenotype IDs that cannot coexist"
        },
        "scope": {
          "type": "string",
          "enum": ["domain", "global"],
          "default": "domain",
          "description": "Scope of exclusivity rules"
        }
      }
    },
    
    "outputs": {
      "type": "object",
      "description": "Clinical outputs and classifications",
      "properties": {
        "risk_category": {
          "type": "string",
          "enum": ["low", "moderate", "high", "very_high", "extreme"],
          "description": "Overall risk classification"
        },
        "treatment_intensity": {
          "type": "string",
          "enum": ["conservative", "standard", "aggressive", "palliative"],
          "description": "Recommended treatment approach"
        },
        "monitoring_level": {
          "type": "string",
          "enum": ["routine", "enhanced", "intensive", "critical"],
          "description": "Required monitoring intensity"
        },
        "care_setting": {
          "type": "string",
          "enum": ["primary", "specialty", "multidisciplinary", "emergency", "inpatient"],
          "description": "Appropriate care setting"
        },
        "clinical_urgency": {
          "type": "string",
          "enum": ["routine", "urgent", "emergent", "stat"],
          "description": "Urgency of clinical action"
        },
        "estimated_outcomes": {
          "type": "object",
          "properties": {
            "mortality_risk_1yr": { "type": "number", "minimum": 0, "maximum": 100 },
            "hospitalization_risk_1yr": { "type": "number", "minimum": 0, "maximum": 100 },
            "progression_risk": { "type": "string" }
          }
        }
      }
    },
    
    "clinical_implications": {
      "type": "array",
      "description": "Clinical implications and required actions",
      "items": {
        "type": "object",
        "required": ["implication", "severity", "action_required"],
        "properties": {
          "implication": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500,
            "description": "Clinical implication description"
          },
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "critical", "emergency"],
            "description": "Severity level of the implication"
          },
          "action_required": {
            "type": "boolean",
            "description": "Whether immediate action is required"
          },
          "timeframe": {
            "type": "string",
            "enum": ["immediate", "within_1h", "within_24h", "within_week", "routine"],
            "description": "Timeframe for required action"
          },
          "action_type": {
            "type": "string",
            "enum": ["medication_change", "lab_order", "referral", "follow_up", "alert", "education"],
            "description": "Type of action required"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Confidence level for this implication"
          }
        }
      }
    },
    
    "evidence_links": {
      "type": "object",
      "description": "Links to supporting clinical evidence",
      "properties": {
        "kb3_guidelines": {
          "type": "array",
          "items": { "type": "string" },
          "description": "References to KB-3 clinical guidelines"
        },
        "kb4_safety_rules": {
          "type": "array",
          "items": { "type": "string" },
          "description": "References to KB-4 safety rules"
        },
        "literature_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "pmid": { "type": "string" },
              "doi": { "type": "string" },
              "citation": { "type": "string" },
              "evidence_level": { 
                "type": "string",
                "enum": ["1a", "1b", "2a", "2b", "3a", "3b", "4", "5"]
              }
            }
          },
          "description": "Literature citations supporting this phenotype"
        },
        "internal_policies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Institution-specific policy references"
        },
        "quality_measures": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Quality measure identifiers"
        }
      }
    },
    
    "metadata": {
      "type": "object",
      "description": "Metadata for governance and maintenance",
      "properties": {
        "author": { "type": "string" },
        "clinical_reviewer": { "type": "string" },
        "last_review_date": { "type": "string", "format": "date" },
        "next_review_date": { "type": "string", "format": "date" },
        "review_frequency": {
          "type": "string",
          "enum": ["monthly", "quarterly", "semi_annual", "annual"]
        },
        "validation_status": {
          "type": "string",
          "enum": ["draft", "clinical_review", "approved", "implemented"]
        },
        "change_log": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["version", "date", "changes"],
            "properties": {
              "version": { "type": "string" },
              "date": { "type": "string", "format": "date" },
              "changes": { "type": "array", "items": { "type": "string" } },
              "reviewer": { "type": "string" }
            }
          }
        }
      }
    }
  }
}