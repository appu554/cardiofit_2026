{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://clinical-kb.health/schemas/risk-model/v2.0.0",
  "title": "Risk Stratification Model Schema v2.0",
  "description": "Schema for clinical risk assessment and stratification models",
  "type": "object",
  "required": ["id", "name", "version", "inputs", "calculation", "outputs"],
  
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^RISK-[A-Z0-9]{3,6}$",
      "description": "Unique risk model identifier (e.g., RISK-CVD001)"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Human-readable risk model name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the risk model"
    },
    "domain": {
      "type": "string",
      "enum": [
        "cardiovascular", "diabetes", "respiratory", "renal", "hepatic",
        "oncology", "neurology", "surgical", "infectious", "bleeding",
        "thrombosis", "mortality", "composite"
      ],
      "description": "Clinical domain for risk assessment"
    },
    "effective_date": {
      "type": "string",
      "format": "date",
      "description": "Date when model becomes active"
    },
    "deprecated_date": {
      "type": "string",
      "format": "date",
      "description": "Date when model was deprecated"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Detailed description of the risk model"
    },
    
    "inputs": {
      "type": "array",
      "minItems": 1,
      "description": "Required input parameters for risk calculation",
      "items": {
        "type": "object",
        "required": ["parameter", "type", "required"],
        "properties": {
          "parameter": {
            "type": "string",
            "description": "Parameter name (e.g., age, systolic_bp)"
          },
          "type": {
            "type": "string",
            "enum": ["integer", "float", "boolean", "string", "date", "enum"],
            "description": "Data type of the parameter"
          },
          "required": {
            "type": "boolean",
            "description": "Whether parameter is required for calculation"
          },
          "units": {
            "type": "string",
            "description": "Measurement units (e.g., mmHg, mg/dL, years)"
          },
          "range": {
            "type": "object",
            "properties": {
              "min": { "type": "number" },
              "max": { "type": "number" },
              "default": { "type": "number" }
            },
            "description": "Valid range and default value"
          },
          "enum_values": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Valid values for enum type parameters"
          },
          "transformation": {
            "type": "string",
            "enum": ["none", "log", "sqrt", "square", "inverse"],
            "default": "none",
            "description": "Mathematical transformation applied to input"
          }
        }
      }
    },
    
    "calculation": {
      "type": "object",
      "required": ["type", "algorithm"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["weighted_score", "regression", "machine_learning", "lookup_table", "framingham", "pooled_cohort", "custom"],
          "description": "Type of risk calculation method"
        },
        "algorithm": {
          "type": "string",
          "description": "Mathematical algorithm or formula"
        },
        "weights": {
          "type": "object",
          "description": "Parameter weights for weighted scoring models",
          "patternProperties": {
            "^[a-zA-Z_][a-zA-Z0-9_]*$": { "type": "number" }
          }
        },
        "coefficients": {
          "type": "object",
          "description": "Regression coefficients for statistical models",
          "patternProperties": {
            "^[a-zA-Z_][a-zA-Z0-9_]*$": { "type": "number" }
          }
        },
        "lookup_table": {
          "type": "array",
          "description": "Lookup table for table-based calculations",
          "items": {
            "type": "object",
            "properties": {
              "conditions": { "type": "object" },
              "risk_score": { "type": "number" }
            }
          }
        },
        "modifiers": {
          "type": "array",
          "description": "Risk modifiers or adjustments",
          "items": {
            "type": "object",
            "required": ["condition", "multiplier"],
            "properties": {
              "condition": { "type": "string" },
              "multiplier": { "type": "number" },
              "additive": { "type": "number" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    
    "outputs": {
      "type": "object",
      "required": ["risk_categories"],
      "properties": {
        "risk_categories": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["range", "category", "color"],
            "properties": {
              "range": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 2,
                "maxItems": 2,
                "description": "Risk score range [min, max]"
              },
              "category": {
                "type": "string",
                "description": "Risk category name"
              },
              "color": {
                "type": "string",
                "enum": ["green", "yellow", "orange", "red", "purple"],
                "description": "Display color for UI"
              },
              "recommendations": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Clinical recommendations for this risk level"
              },
              "monitoring_frequency": {
                "type": "string",
                "enum": ["weekly", "monthly", "quarterly", "semi_annual", "annual"],
                "description": "Recommended monitoring frequency"
              }
            }
          }
        },
        "units": {
          "type": "string",
          "description": "Units of the risk score (%, absolute risk, etc.)"
        },
        "time_horizon": {
          "type": "string",
          "pattern": "^\\d+[hdwmy]$",
          "description": "Time horizon for risk prediction (e.g., 1y, 5y, 10y)"
        },
        "confidence_interval": {
          "type": "object",
          "properties": {
            "lower": { "type": "number" },
            "upper": { "type": "number" },
            "level": { "type": "number", "enum": [0.90, 0.95, 0.99] }
          },
          "description": "Confidence interval for risk estimates"
        }
      }
    },
    
    "validation": {
      "type": "object",
      "description": "Model validation metrics and performance",
      "properties": {
        "c_statistic": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 1.0,
          "description": "Discrimination (AUC/C-statistic)"
        },
        "calibration_chi2": {
          "type": "number",
          "minimum": 0,
          "description": "Hosmer-Lemeshow chi-square statistic"
        },
        "calibration_p_value": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "P-value for calibration test"
        },
        "last_validated": {
          "type": "string",
          "format": "date",
          "description": "Date of last validation"
        },
        "validation_cohort_size": {
          "type": "integer",
          "minimum": 100,
          "description": "Size of validation cohort"
        },
        "validation_population": {
          "type": "string",
          "description": "Description of validation population"
        },
        "performance_metrics": {
          "type": "object",
          "properties": {
            "sensitivity": { "type": "number", "minimum": 0, "maximum": 1 },
            "specificity": { "type": "number", "minimum": 0, "maximum": 1 },
            "positive_predictive_value": { "type": "number", "minimum": 0, "maximum": 1 },
            "negative_predictive_value": { "type": "number", "minimum": 0, "maximum": 1 },
            "net_reclassification_improvement": { "type": "number" }
          }
        }
      }
    },
    
    "applicability": {
      "type": "object",
      "description": "Population and conditions where model applies",
      "properties": {
        "age_range": {
          "type": "object",
          "properties": {
            "min": { "type": "integer" },
            "max": { "type": "integer" }
          }
        },
        "population": {
          "type": "array",
          "items": { 
            "type": "string",
            "enum": ["general", "primary_prevention", "secondary_prevention", "high_risk", "diabetes", "ckd", "elderly"]
          }
        },
        "exclusions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Conditions where model should not be applied"
        },
        "geographic_validity": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Geographic regions where model is validated"
        }
      }
    },
    
    "implementation": {
      "type": "object",
      "description": "Implementation details for the model",
      "properties": {
        "calculation_engine": {
          "type": "string",
          "enum": ["javascript", "python", "r", "sql", "cel"],
          "description": "Engine used for calculation"
        },
        "performance_requirements": {
          "type": "object",
          "properties": {
            "max_calculation_time_ms": { "type": "integer" },
            "concurrent_calculations": { "type": "integer" },
            "memory_usage_mb": { "type": "integer" }
          }
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "External dependencies or libraries required"
        }
      }
    }
  }
}