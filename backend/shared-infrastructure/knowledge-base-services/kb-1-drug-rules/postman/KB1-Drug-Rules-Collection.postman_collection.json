    {
      "name": "Dose Calculation",
      "description": "Clinical dose calculation endpoints - core dosing logic",
      "item": [
        {
          "name": "Calculate Standard Dose",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rxnorm_code\": \"161\",\n  \"indication\": \"hypertension\",\n  \"patient\": {\n    \"age\": 55,\n    \"weight_kg\": 70,\n    \"height_cm\": 175,\n    \"sex\": \"male\",\n    \"renal_function\": {\n      \"creatinine\": 1.2,\n      \"egfr\": 65\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/{{api_version}}/calculate",
              "host": ["{{base_url}}"],
              "path": ["{{api_version}}", "calculate"]
