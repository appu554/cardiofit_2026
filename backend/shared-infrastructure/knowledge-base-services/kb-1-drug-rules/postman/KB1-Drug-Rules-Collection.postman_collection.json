    {
      "name": "Admin - Approval Workflow",
      "description": "Hospital-grade governance workflow for drug rule approval. Only ACTIVE rules are used for clinical dosing.",
      "item": [
        {
          "name": "Get Approval Statistics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/{{api_version}}/admin/approval-stats",
              "host": ["{{base_url}}"],
              "path": ["{{api_version}}", "admin", "approval-stats"]
            },
            "description": "Get approval workflow statistics: counts by status (DRAFT, REVIEWED, ACTIVE, RETIRED) and risk level"
          }
        },
        {
          "name": "Get Pending Reviews",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/{{api_version}}/admin/pending?limit=20&risk_level=CRITICAL",
              "host": ["{{base_url}}"],
              "path": ["{{api_version}}", "admin", "pending"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "risk_level",
                  "value": "CRITICAL",
                  "description": "Filter by risk: CRITICAL, HIGH, STANDARD, LOW"
                }
              ]
            },
            "description": "Get queue of rules pending pharmacist/CMO review. Filter by risk level for prioritization."
          }
        },
        {
          "name": "Get Pending Reviews (All)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/{{api_version}}/admin/pending",
              "host": ["{{base_url}}"],
              "path": ["{{api_version}}", "admin", "pending"]
            },
            "description": "Get all rules pending review without filters"
          }
        },
        {
          "name": "Submit Pharmacist Review",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewed_by\": \"Dr. Sarah Johnson (Clinical Pharmacist)\",\n  \"review_notes\": \"Dosing ranges verified against FDA label. Renal adjustment thresholds confirmed. Black box warning appropriately flagged.\",\n  \"dosing_verified\": true,\n  \"renal_verified\": true,\n  \"hepatic_verified\": true,\n  \"interactions_verified\": true,\n  \"safety_verified\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/{{api_version}}/admin/review/:rule_id",
              "host": ["{{base_url}}"],
              "path": ["{{api_version}}", "admin", "review", ":rule_id"],
              "variable": [
                {
                  "key": "rule_id",
                  "value": "{{rule_id}}",
                  "description": "UUID of the rule to review"
                }
              ]
            },
            "description": "Submit pharmacist review (DRAFT → REVIEWED). Rule then awaits CMO approval for CRITICAL/HIGH risk drugs."
          }
        },
        {
          "name": "Approve Rule (CMO/Pharmacist)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"approved_by\": \"Dr. Michael Chen (Chief Medical Officer)\",\n  \"review_notes\": \"Final approval after pharmacist review. Dosing verified against current clinical guidelines.\",\n  \"skip_verification\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/{{api_version}}/admin/approve/:rule_id",
              "host": ["{{base_url}}"],
              "path": ["{{api_version}}", "admin", "approve", ":rule_id"],
              "variable": [
                {
                  "key": "rule_id",
                  "value": "{{rule_id}}",
                  "description": "UUID of the rule to approve"
                }
              ]
            },
            "description": "Approve rule and activate for clinical use. CRITICAL/HIGH risk drugs require skip_verification=true to acknowledge risk."
          }
        },
        {
          "name": "Reject Rule",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rejected_by\": \"Dr. Sarah Johnson (Clinical Pharmacist)\",\n  \"rejection_reason\": \"FDA label dosing information incomplete for this formulation. Recommend manual rule creation with verified dosing from clinical pharmacology references.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/{{api_version}}/admin/reject/:rule_id",
              "host": ["{{base_url}}"],
              "path": ["{{api_version}}", "admin", "reject", ":rule_id"],
              "variable": [
                {
                  "key": "rule_id",
                  "value": "{{rule_id}}",
                  "description": "UUID of the rule to reject"
                }
              ]
            },
            "description": "Reject rule and move to RETIRED status. Rule will not be used for clinical dosing."
          }
        },
        {
          "name": "Get Rule Audit History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/{{api_version}}/admin/audit/:rxnorm_code",
              "host": ["{{base_url}}"],
              "path": ["{{api_version}}", "admin", "audit", ":rxnorm_code"],
              "variable": [
                {
                  "key": "rxnorm_code",
                  "value": "161",
                  "description": "RxNorm code of the drug"
                }
              ]
            },
            "description": "Get complete audit trail for a drug rule: all status changes, reviews, and approvals"
          }
        },
        {
          "name": "Admin Get Rule (All Statuses)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/{{api_version}}/admin/rules/:rxnorm_code",
              "host": ["{{base_url}}"],
              "path": ["{{api_version}}", "admin", "rules", ":rxnorm_code"],
              "variable": [
                {
                  "key": "rxnorm_code",
                  "value": "161",
                  "description": "RxNorm code of the drug"
                }
              ]
            },
            "description": "Admin view of drug rule including DRAFT/REVIEWED status (not just ACTIVE). Shows full governance metadata."
          }
        }
      ]
    },
    {
      "name": "Example Workflows",
      "description": "Common clinical workflow examples",
      "item": [
        {
          "name": "Workflow: Renal Patient Dosing",
          "item": [
            {
              "name": "1. Calculate CrCl",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"age\": 72,\n  \"weight_kg\": 68,\n  \"serum_creatinine\": 2.1,\n  \"sex\": \"female\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/{{api_version}}/patient/crcl",
                  "host": ["{{base_url}}"],
                  "path": ["{{api_version}}", "patient", "crcl"]
                },
                "description": "Step 1: Calculate creatinine clearance for elderly female patient"
              }
            },
            {
              "name": "2. Get Renal Adjustments",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/{{api_version}}/adjustments/renal?rxnorm_code=1191",
                  "host": ["{{base_url}}"],
                  "path": ["{{api_version}}", "adjustments", "renal"],
                  "query": [
                    {
                      "key": "rxnorm_code",
                      "value": "1191",
                      "description": "Aspirin"
                    }
                  ]
                },
                "description": "Step 2: Get renal adjustment recommendations"
              }
            },
            {
              "name": "3. Calculate Renal Dose",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"rxnorm_code\": \"1191\",\n  \"base_dose\": 500,\n  \"creatinine_clearance\": 25,\n  \"egfr\": 25\n}"
                },
                "url": {
                  "raw": "{{base_url}}/{{api_version}}/calculate/renal",
                  "host": ["{{base_url}}"],
                  "path": ["{{api_version}}", "calculate", "renal"]
