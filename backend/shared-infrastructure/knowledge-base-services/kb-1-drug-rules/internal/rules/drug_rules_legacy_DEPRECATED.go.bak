// Package rules provides the built-in drug dosing rules repository.
// Contains 24 drugs across 5 categories as specified in the OpenAPI documentation.
package rules

import (
	"strings"
	"sync"

	"kb-1-drug-rules/internal/models"
)

// Repository provides access to drug rules.
type Repository struct {
	rules map[string]*models.DrugRule
	mu    sync.RWMutex
}

// NewRepository creates a new rules repository with all 24 built-in drugs.
func NewRepository() *Repository {
	r := &Repository{
		rules: make(map[string]*models.DrugRule),
	}
	r.loadBuiltInRules()
	return r
}

// GetByRxNorm retrieves a drug rule by RxNorm code.
func (r *Repository) GetByRxNorm(rxnorm string) (*models.DrugRule, bool) {
	r.mu.RLock()
	defer r.mu.RUnlock()
	rule, ok := r.rules[rxnorm]
	return rule, ok
}

// GetAll returns all drug rules.
func (r *Repository) GetAll() []*models.DrugRule {
	r.mu.RLock()
	defer r.mu.RUnlock()
	result := make([]*models.DrugRule, 0, len(r.rules))
	for _, rule := range r.rules {
		result = append(result, rule)
	}
	return result
}

// Search searches drug rules by name or category.
func (r *Repository) Search(query string, category string, highAlertOnly bool) []*models.DrugRule {
	r.mu.RLock()
	defer r.mu.RUnlock()

	var results []*models.DrugRule
	queryLower := strings.ToLower(query)
	categoryLower := strings.ToLower(category)

	for _, rule := range r.rules {
		// Filter by high alert
		if highAlertOnly && !rule.IsHighAlert {
			continue
		}

		// Filter by category
		if category != "" && strings.ToLower(rule.Category) != categoryLower {
			continue
		}

		// Filter by name query
		if query != "" {
			nameLower := strings.ToLower(rule.DrugName)
			if !strings.Contains(nameLower, queryLower) {
				continue
			}
		}

		results = append(results, rule)
	}

	return results
}

