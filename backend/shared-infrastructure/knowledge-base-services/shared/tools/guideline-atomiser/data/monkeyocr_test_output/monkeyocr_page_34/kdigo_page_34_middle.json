                                    ],
                                    "score": 1.0,
                                    "content": "Practice Point 1.2.1: For patients with diabetes, albuminuria, and normal blood pressure, treatment with an ACEi or ARB may be considered.",
                                    "type": "text"
                                }
                            ]
