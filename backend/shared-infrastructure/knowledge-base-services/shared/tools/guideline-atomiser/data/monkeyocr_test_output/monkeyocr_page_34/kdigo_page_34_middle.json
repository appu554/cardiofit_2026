                            "spans": [
                                {
                                    "bbox": [
                                        43,
                                        496,
                                        290,
                                        542
                                    ],
                                    "score": 1.0,
                                    "content": "Resource use and costs. Generic formulations of both ACEi and ARBs are widely available at low cost in many parts of the world. Moreover, both have been included in the World Health Organization (WHO) list of essential medicines.$^{58}$",
                                    "type": "text"
                                }
                            ]
                        }
                    ],
                    "index": 3
                },
                {
                    "type": "text",
                    "bbox": [
                        44,
