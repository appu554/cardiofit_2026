                            "spans": [
                                {
                                    "bbox": [
                                        44,
                                        364,
                                        290,
                                        493
                                    ],
                                    "score": 1.0,
                                    "content": "The evidence does not demonstrate superior efficacy of ACEi over ARB treatment or vice versa, and the choice between these 2 drug classes will depend on other factors, including patient preferences, cost, availability of generic formulations, and side-effects profiles of individual drugs. ACEi-induced cough is the predominant symptom of intolerance to this class of drug, affecting about 10% of patients.$^{57}$ In clinical practice, affected patients are often switched to an ARB so as not to lose the kidney protective effects of RAS blockade, although the improvement in tolerability has not been evaluated in an RCT.",
                                    "type": "text"
                                }
                            ]
                        }
                    ],
                    "index": 2
                },
                {
                    "type": "text",
                    "bbox": [
                        43,
                        496,
                        290,
                        542
                    ],
                    "lines": [
                        {
                            "bbox": [
                                43,
                                496,
                                290,
                                542
