      "block_type": "heading",
      "level": 1,
      "children": [
        {
          "section_id": "4.4.2",
          "heading": "4.4.2 Gadolinium-containing contrast media",
          "start_offset": 39306,
          "end_offset": 41025,
          "page_number": 9,
          "block_type": "heading",
          "level": 1,
          "children": [
            {
              "section_id": "4.4.1.2",
              "heading": "Practice Point 4.4.1.2: The intravenous administration of radiocontrast media can be managed in accordance with consensus statements from the radiology societies in people with AKI or GFR <60 mL/min/1.73m\u00b2 (CKD G3a\u2013G5) undergoing elective investigation.",
              "start_offset": 39689,
              "end_offset": 40183,
              "page_number": 9,
              "block_type": "heading",
              "level": 1,
              "children": []
            },
            {
              "section_id": "4.4.2.1",
              "heading": "Practice Point 4.4.2.1: For people with GFR <30 mL/min/1.73m\u00b2 (CKD G4\u2013G5) who require gadolinium\\-containing contrast media, preferentially offer them American College of Radiology group II and III gadolinium\\-based contrast agents.",
              "start_offset": 40183,
              "end_offset": 41025,
              "page_number": 9,
              "block_type": "heading",
              "level": 1,
              "children": []
            }
          ]
        }
      ]
    },
