          "heading": "3.4 Blood pressure control",
          "start_offset": 49932,
          "end_offset": 53227,
          "page_number": 13,
          "block_type": "heading",
          "level": 1,
          "children": [
            {
              "section_id": "3.4.1",
              "heading": "Recommendation 3.4.1: We suggest that adults with high BP and CKD be treated with a target systolic blood pressure (SBP) of <120 mm Hg, when tolerated, using standardized office BP measurement (2B).",
              "start_offset": 51342,
              "end_offset": 53227,
              "page_number": 13,
              "block_type": "recommendation",
              "level": 1,
              "children": []
            }
