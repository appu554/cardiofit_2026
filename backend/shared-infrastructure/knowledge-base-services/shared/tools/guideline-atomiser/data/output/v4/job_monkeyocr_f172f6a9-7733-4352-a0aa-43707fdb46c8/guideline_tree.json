          "page_number": 13,
          "block_type": "heading",
          "level": 1,
          "children": [
            {
              "section_id": "3.6.7",
              "heading": "Practice Point 3.6.7: Continue ACEi or ARB in people with CKD even when the eGFR falls below 30 ml/min per 1.73\\ \\mathrm{m}^{2}.",
