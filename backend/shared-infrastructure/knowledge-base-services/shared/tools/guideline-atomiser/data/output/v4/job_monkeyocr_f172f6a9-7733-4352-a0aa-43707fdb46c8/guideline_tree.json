        {
          "section_id": "3.3.2",
          "heading": "3.3.2 Sodium intake",
          "start_offset": 44114,
          "end_offset": 45604,
          "page_number": 13,
          "block_type": "heading",
          "level": 1,
          "children": [
            {
              "section_id": "3.3.2.1",
              "heading": "Recommendation 3.3.2.1: We suggest that sodium intake be <2 g of sodium per day (or <90 mmol of sodium per day, or <5 g of sodium chloride per day) in people with CKD (2C).",
              "start_offset": 44408,
              "end_offset": 45604,
              "page_number": 13,
              "block_type": "recommendation",
              "level": 1,
              "children": []
            }
