  "sections": [
    {
      "section_id": "4",
      "heading": "Chapter 4: Medication management and drug stewardship in CKD",
      "start_offset": 104,
      "end_offset": 10222,
      "page_number": 4,
      "block_type": "heading",
      "level": 1,
      "children": [
        {
          "section_id": "4.1.1",
          "heading": "Practice Point 4.1.1: People with CKD may be more sus\\- cepible to the nephrotoxic effects of medications. When prescribing such medications to people with CKD, always consider the benefits versus potential harms.",
          "start_offset": 1983,
          "end_offset": 2927,
          "page_number": 4,
          "block_type": "heading",
          "level": 1,
          "children": []
        },
        {
          "section_id": "4.1",
          "heading": "4.1 Medication choices and monitoring for safety",
          "start_offset": 2927,
          "end_offset": 10222,
          "page_number": 4,
          "block_type": "heading",
          "level": 1,
          "children": []
        }
      ]
    },
    {
      "section_id": "Special_considerations",
      "heading": "Special considerations",
      "start_offset": 10222,
      "end_offset": 18349,
      "page_number": 4,
      "block_type": "heading",
      "level": 1,
      "children": [
        {
          "section_id": "4.2",
          "heading": "4.2 Dose adjustments by level of eGFR",
          "start_offset": 14324,
          "end_offset": 18349,
          "page_number": 4,
          "block_type": "heading",
          "level": 1,
          "children": [
            {
              "section_id": "4.2.1",
              "heading": "Practice Point 4.2.1: Consider eGFR when dosing medications cleared by the kidneys.",
              "start_offset": 14365,
              "end_offset": 14992,
              "page_number": 4,
              "block_type": "heading",
              "level": 1,
              "children": []
            },
            {
              "section_id": "4.2.2",
              "heading": "Practice Point 4.2.2: For most people and clinical settings, validated eGFR equations using SCr are appropriate for drug dosing.",
              "start_offset": 14992,
              "end_offset": 17620,
              "page_number": 4,
              "block_type": "heading",
              "level": 1,
              "children": []
            },
            {
              "section_id": "4.2.5",
              "heading": "Practice Point 4.2.5: Consider and adapt drug dosing in people where eGFR, non-eGFR determinants of the filtration markers, or volume of distribution are not in a steady state.",
              "start_offset": 17620,
              "end_offset": 18349,
              "page_number": 4,
              "block_type": "heading",
              "level": 1,
              "children": []
            }
          ]
        }
      ]
    },
    {
