# V3 Clinical Guideline Curation Pipeline - Environment Configuration
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED: Anthropic API Key (L3 Claude Extraction)
# ═══════════════════════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED: Path to your local vaidshala repository
# ═══════════════════════════════════════════════════════════════════════════════
VAIDSHALA_LOCAL_PATH=/path/to/your/vaidshala

# ═══════════════════════════════════════════════════════════════════════════════
# L2: GLiNER NER Configuration
# ═══════════════════════════════════════════════════════════════════════════════
GLINER_MODEL=urchade/gliner_mediumv2.1
GLINER_DEVICE=cpu
# Set to "cuda" if you have GPU: GLINER_DEVICE=cuda
GLINER_THRESHOLD=0.5

# ═══════════════════════════════════════════════════════════════════════════════
# L4: Snow Owl Terminology Server
# ═══════════════════════════════════════════════════════════════════════════════
SNOW_OWL_URL=http://localhost:8080
SNOW_OWL_USER=snowowl
SNOW_OWL_PASSWORD=snowowl123

# ═══════════════════════════════════════════════════════════════════════════════
# Database Configuration
# ═══════════════════════════════════════════════════════════════════════════════
POSTGRES_USER=v3user
POSTGRES_PASSWORD=v3pass
POSTGRES_DB=v3_facts
POSTGRES_URL=postgresql://v3user:v3pass@localhost:5434/v3_facts

# ═══════════════════════════════════════════════════════════════════════════════
# Redis Cache
# ═══════════════════════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6381/0

# ═══════════════════════════════════════════════════════════════════════════════
# Optional: GPU Memory Configuration (if using CUDA)
# ═══════════════════════════════════════════════════════════════════════════════
# PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512
