# L2 GLiNER Test Dockerfile
FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
RUN pip install --no-cache-dir \
    gliner==0.2.10 \
    torch==2.1.0 --index-url https://download.pytorch.org/whl/cpu

# Copy extraction module
COPY ../../../extraction/gliner /app/extraction/gliner

# Copy test script
COPY test_l1_l2_pipeline.py /app/

# Set Python path
ENV PYTHONPATH=/app

CMD ["python", "test_l1_l2_pipeline.py"]
