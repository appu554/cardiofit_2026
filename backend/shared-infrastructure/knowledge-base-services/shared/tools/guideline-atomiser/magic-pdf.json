{
  "models-dir": "/root/.cache/huggingface/hub",
  "device-mode": "cpu",
  "layout-config": {
    "model": "doclayout_yolo"
  },
  "formula-config": {
    "mfd_model": "yolo_v8_mfd",
    "mfr_model": "unimernet_small",
    "enable": false
  },
  "table-config": {
    "model": "rapid_table",
    "enable": false,
    "max_time": 400
  },
  "latex-delimiter-config": {
    "display": {
      "left": "$$",
      "right": "$$"
    },
    "inline": {
      "left": "$",
      "right": "$"
    }
  }
}
