<?xml version="1.0" encoding="UTF-8"?>
<!--
  Synthetic CDA R2 pathology document — NOT from ADHA conformance pack.
  Hand-crafted to exercise cda_parser.go logic against a realistic-but-minimal
  structure. V1 will validate against the real ADHA conformance pack.

  Structure exercised:
    - ClinicalDocument/id (document ID)
    - ClinicalDocument/effectiveTime (authored time)
    - ClinicalDocument/recordTarget/patientRole/id (IHI extension)
    - component/structuredBody/component/section/entry/observation
    - observation/code (LOINC + SNOMED codings)
    - observation/effectiveTime (observed time)
    - observation/value (PQ — physical quantity with @value @unit)
    - observation/value (ST — string)
    - observation/interpretationCode (@code H | L)
-->
<ClinicalDocument xmlns="urn:hl7-org:v3">
  <id root="2.16.840.1.113883.3.879.270000"
      extension="DOC-SYN-0001"/>
  <effectiveTime value="20260501090000+1000"/>
  <recordTarget>
    <patientRole>
      <id root="1.2.36.1.2001.1003.0"
          extension="8003608000000001"
          assigningAuthorityName="IHI"/>
    </patientRole>
  </recordTarget>
  <component>
    <structuredBody>
      <component>
        <section>
          <code code="11502-2" codeSystem="2.16.840.1.113883.6.1"
                displayName="Laboratory report"/>
          <entry>
            <observation classCode="OBS" moodCode="EVN">
              <code code="2823-3" codeSystem="2.16.840.1.113883.6.1"
                    displayName="Potassium [Moles/volume] in Serum or Plasma">
                <translation code="271001000087101"
                             codeSystem="2.16.840.1.113883.6.96"
                             displayName="Serum potassium"/>
              </code>
              <effectiveTime value="20260501083000+1000"/>
              <value xsi:type="PQ" value="5.8" unit="mmol/L"
                     xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
              <interpretationCode code="H"
                                  codeSystem="2.16.840.1.113883.5.83"/>
            </observation>
          </entry>
          <entry>
            <observation classCode="OBS" moodCode="EVN">
              <code code="33914-3" codeSystem="2.16.840.1.113883.6.1"
                    displayName="Glomerular filtration rate/1.73 sq M.predicted"/>
              <effectiveTime value="20260501083000+1000"/>
              <value xsi:type="PQ" value="42" unit="mL/min/1.73m2"
                     xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
              <interpretationCode code="L"
                                  codeSystem="2.16.840.1.113883.5.83"/>
            </observation>
          </entry>
          <entry>
            <observation classCode="OBS" moodCode="EVN">
              <code code="11556-8" codeSystem="2.16.840.1.113883.6.1"
                    displayName="Microscopy comment"/>
              <effectiveTime value="20260501083000+1000"/>
              <value xsi:type="ST"
                     xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">No organisms seen on Gram stain.</value>
            </observation>
          </entry>
        </section>
      </component>
    </structuredBody>
  </component>
</ClinicalDocument>
