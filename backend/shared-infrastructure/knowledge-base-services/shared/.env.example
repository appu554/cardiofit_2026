# =============================================================================
# Knowledge Base Services - Environment Configuration
# Copy this file to .env and customize for your environment
# =============================================================================

# =============================================================================
# PostgreSQL Configuration (Canonical Fact Store)
# =============================================================================
POSTGRES_USER=kb_admin
POSTGRES_PASSWORD=kb_secure_password_2024
POSTGRES_DB=canonical_facts
POSTGRES_PORT=5433

# Database connection (for services)
DB_HOST=localhost
DB_PORT=5433
DB_USER=kb_admin
DB_PASSWORD=kb_secure_password_2024
DB_NAME=canonical_facts
DB_SSL_MODE=disable

# Connection pool settings
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=1h
DB_CONN_MAX_IDLE_TIME=15m

# Query settings
DB_QUERY_TIMEOUT=30s
DB_MIGRATION_TIMEOUT=5m

# =============================================================================
# Redis Configuration (Tiered Caching)
# =============================================================================
REDIS_PORT=6380
REDIS_HOST=localhost
REDIS_PASSWORD=

# Connection pool
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=3
REDIS_POOL_TIMEOUT=4s

# Timeouts
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s

# Retries
REDIS_MAX_RETRIES=3
REDIS_MIN_RETRY_BACKOFF=100ms
REDIS_MAX_RETRY_BACKOFF=500ms

# =============================================================================
# Cache TTL Configuration (by severity)
# =============================================================================
CACHE_TTL_CONTRAINDICATED=24h
CACHE_TTL_MAJOR=12h
CACHE_TTL_MODERATE=6h
CACHE_TTL_MINOR=2h
CACHE_TTL_DEFAULT=1h

# =============================================================================
# Adminer (Database UI)
# =============================================================================
ADMINER_PORT=8082

# =============================================================================
# Service Ports
# =============================================================================
KB5_PORT=8089
KB6_PORT=8091
KB16_PORT=8092

# =============================================================================
# Data Ingestion Configuration
# =============================================================================
DATA_DIR=./cmd/phase1-ingest/data
BACKUP_DIR=./cmd/phase1-ingest/backup

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# =============================================================================
# Production Overrides (uncomment for production)
# =============================================================================
# DB_SSL_MODE=require
# DB_MAX_OPEN_CONNS=50
# DB_MAX_IDLE_CONNS=25
# DB_CONN_MAX_LIFETIME=2h
