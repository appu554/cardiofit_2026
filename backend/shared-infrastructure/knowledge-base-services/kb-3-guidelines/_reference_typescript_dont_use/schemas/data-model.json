{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clinical-kb.health/schemas/kb3-guideline-evidence/v2.0.0",
  "title": "KB-3 Guideline Evidence Data Model",
  "type": "object",
  
  "definitions": {
    "conflictResolution": {
      "type": "object",
      "properties": {
        "conflicts_with": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "guideline_id": {"type": "string"},
              "rec_id": {"type": "string"},
              "conflict_type": {"$ref": "#/definitions/conflictType"},
              "resolution_strategy": {"type": "string"}
            },
            "required": ["guideline_id", "rec_id", "conflict_type"]
          }
        },
        "harmonization_notes": {"type": "string"}
      }
    },
    
    "conflictType": {
      "type": "string",
      "enum": ["direct_contradiction", "evidence_disagreement", "population_overlap", "target_difference"]
    },
    
    "evidenceQuality": {
      "type": "object",
      "required": ["grade", "quality_score", "supporting_studies"],
      "properties": {
        "grade": {"enum": ["A", "B", "C", "D", "Expert Opinion"]},
        "quality_score": {"type": "number", "minimum": 0, "maximum": 100},
        "supporting_studies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "study_type": {"enum": ["RCT", "Meta-analysis", "Cohort", "Case-control", "Case series"]},
              "sample_size": {"type": "integer", "minimum": 1},
              "pmid": {"type": "string", "pattern": "^[0-9]+$"},
              "quality_assessment": {"type": "string"},
              "publication_year": {"type": "integer", "minimum": 1990, "maximum": 2030}
            },
            "required": ["study_type", "sample_size"]
          }
        },
        "grade_rationale": {"type": "string"},
        "limitations": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    
    "clinicalRecommendation": {
      "type": "object",
      "required": ["rec_id", "statement", "evidence", "domain"],
      "properties": {
        "rec_id": {
          "type": "string",
          "pattern": "^[A-Z0-9-]+$"
        },
        "statement": {
          "type": "string",
          "minLength": 10,
          "maxLength": 2000
        },
        "domain": {
          "type": "string",
          "enum": ["diagnosis", "treatment", "monitoring", "prevention", "prognosis", "risk_assessment"]
        },
        "evidence": {"$ref": "#/definitions/evidenceQuality"},
        "population_criteria": {
          "type": "object",
          "properties": {
            "age_range": {
              "type": "object",
              "properties": {
                "min_age": {"type": "integer", "minimum": 0},
                "max_age": {"type": "integer", "maximum": 150}
              }
            },
            "conditions": {
              "type": "array",
              "items": {"type": "string"}
            },
            "exclusion_criteria": {
              "type": "array",
              "items": {"type": "string"}
            },
            "special_populations": {
              "type": "array",
              "items": {"enum": ["pregnancy", "pediatric", "elderly", "renal_impairment", "hepatic_impairment"]}
            }
          }
        },
        "linked_kb_refs": {
          "type": "object",
          "properties": {
            "kb1_dosing": {
              "type": "array",
              "items": {"type": "string"}
            },
            "kb2_interactions": {
              "type": "array",
              "items": {"type": "string"}
            },
            "kb4_monitoring": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        },
        "conflict_resolution": {"$ref": "#/definitions/conflictResolution"},
        "safety_considerations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "consideration": {"type": "string"},
              "severity": {"enum": ["critical", "major", "minor"]},
              "monitoring_required": {"type": "boolean"}
            }
          }
        }
      }
    },
    
    "safetyOverride": {
      "type": "object",
      "required": ["override_id", "priority", "trigger_conditions", "override_action"],
      "properties": {
        "override_id": {
          "type": "string",
          "pattern": "^SAFETY-[0-9]{3}$"
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "trigger_conditions": {
          "type": "object",
          "properties": {
            "lab_thresholds": {
              "type": "object",
              "patternProperties": {
                "^[a-z_]+$": {
                  "type": "object",
                  "properties": {
                    "operator": {"enum": [">", "<", ">=", "<=", "=="]},
                    "value": {"type": "number"},
                    "unit": {"type": "string"}
                  }
                }
              }
            },
            "conditions": {
              "type": "array",
              "items": {"type": "string"}
            },
            "medications": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        },
        "override_action": {
          "type": "object",
          "properties": {
            "action_type": {"enum": ["contraindicate", "modify_dose", "add_monitoring", "warn"]},
            "description": {"type": "string"},
            "alternatives": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        },
        "affected_guidelines": {
          "type": "array",
          "items": {"type": "string"}
        },
        "requires_audit": {"type": "boolean", "default": true}
      }
    }
  },
  
  "properties": {
    "guideline": {
      "type": "object",
      "required": ["guideline_id", "organization", "version", "effective_date", "recommendations"],
      "properties": {
        "guideline_id": {
          "type": "string",
          "pattern": "^[A-Z0-9-]+$",
          "description": "Unique identifier for the guideline"
        },
        "organization": {
          "type": "string",
          "enum": ["ACC/AHA", "ESC", "WHO", "ADA", "KDIGO", "NICE", "ACP", "AACE"]
        },
        "title": {
          "type": "string",
          "minLength": 10,
          "maxLength": 200
        },
        "region": {
          "type": "string",
          "enum": ["US", "EU", "UK", "AU", "CA", "WHO", "Global"]
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "effective_date": {
          "type": "string",
          "format": "date"
        },
        "superseded_date": {
          "type": "string",
          "format": "date"
        },
        "supersedes": {
          "type": "string",
          "description": "ID of guideline this replaces"
        },
        "condition_primary": {
          "type": "string",
          "description": "Primary condition addressed"
        },
        "icd10_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z][0-9]{2}(\\.[0-9X]{1,3})?$"
          }
        },
        "recommendations": {
          "type": "array",
          "items": {"$ref": "#/definitions/clinicalRecommendation"},
          "minItems": 1
        },
        "evidence_summary": {
          "type": "object",
          "properties": {
            "total_studies": {"type": "integer"},
            "rct_count": {"type": "integer"},
            "meta_analysis_count": {"type": "integer"},
            "overall_quality": {"type": "string", "enum": ["high", "moderate", "low", "very_low"]},
            "publication_span": {
              "type": "object",
              "properties": {
                "earliest_year": {"type": "integer"},
                "latest_year": {"type": "integer"}
              }
            }
          }
        },
        "digital_signature": {
          "type": "string",
          "description": "Cryptographic signature for integrity verification"
        },
        "approval_metadata": {
          "type": "object",
          "properties": {
            "status": {"enum": ["draft", "pending", "approved", "published", "superseded"]},
            "approved_by": {"type": "string"},
            "approval_date": {"type": "string", "format": "date-time"},
            "clinical_review_required": {"type": "boolean"},
            "medical_director_approval": {"type": "boolean"}
          }
        }
      }
    },
    
    "safety_overrides": {
      "type": "array",
      "items": {"$ref": "#/definitions/safetyOverride"}
    },
    
    "metadata": {
      "type": "object",
      "properties": {
        "kb_version": {"type": "string"},
        "created_at": {"type": "string", "format": "date-time"},
        "updated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string"},
        "checksum": {"type": "string"},
        "validation_status": {"enum": ["valid", "invalid", "pending"]}
      },
      "required": ["kb_version", "created_at"]
    }
  },
  
  "required": ["guideline", "metadata"]
}