{
  "name": "kb3-guideline-evidence",
  "version": "3.0.0",
  "description": "KB-3 Guideline Evidence Service with conflict resolution and safety overrides",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "ts-node src/app.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "docker:build": "docker build -t kb3-guideline-evidence:3.0.0 .",
    "docker:run": "docker-compose up",
    "k8s:deploy": "kubectl apply -f k8s/",
    "health": "curl -f http://localhost:8084/health || exit 1",
    "federation": "ts-node src/federation/index.ts",
    "federation:build": "tsc && node dist/federation/index.js",
    "federation:dev": "nodemon --exec ts-node src/federation/index.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.9.3",
    "@apollo/subgraph": "^2.10.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "graphql-tag": "^2.12.6",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "morgan": "^1.10.0",
    "neo4j-driver": "^5.14.0",
    "node-cache": "^5.1.2",
    "pg": "^8.11.3",
    "prom-client": "^15.0.0",
    "redis": "^4.6.10",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.4",
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.20",
    "@types/jest": "^29.5.6",
    "@types/morgan": "^1.9.7",
    "@types/node": "^20.8.6",
    "@types/pg": "^8.10.7",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "clinical-guidelines",
    "evidence-based-medicine",
    "conflict-resolution",
    "safety-overrides",
    "fhir",
    "healthcare"
  ],
  "author": "Clinical Synthesis Hub",
  "license": "PROPRIETARY",
  "repository": {
    "type": "git",
    "url": "https://github.com/clinical-synthesis-hub/cardiofit"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/app.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 95,
        "functions": 95,
        "lines": 95,
        "statements": 95
      }
    }
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint"
    ],
    "extends": [
      "eslint:recommended",
      "@typescript-eslint/recommended"
    ],
    "rules": {
      "@typescript-eslint/no-unused-vars": "error",
      "@typescript-eslint/no-explicit-any": "warn",
      "prefer-const": "error",
      "no-var": "error"
    }
  }
}
