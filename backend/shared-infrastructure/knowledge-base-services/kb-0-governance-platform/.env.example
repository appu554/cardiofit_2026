# =============================================================================
# KB-0 Governance Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and update values as needed

# =============================================================================
# Server Configuration
# =============================================================================
KB0_PORT=8080

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL connection details
KB0_DATABASE_HOST=localhost
KB0_DATABASE_PORT=5500
KB0_DATABASE_NAME=kb0_governance
KB0_DATABASE_USER=kb0_user
KB0_DATABASE_PASSWORD=kb0_secure_password

# =============================================================================
# Redis Configuration
# =============================================================================
KB0_REDIS_URL=redis://localhost:6381

# =============================================================================
# KB-1 Integration (Drug Rules Service)
# =============================================================================
# Required for governance orchestration of KB-1 drug rules
# KB-0 calls KB-1's admin API to sync review/approval state
#
# For Docker: http://host.docker.internal:8081
# For local development: http://localhost:8081
KB1_URL=http://localhost:8081

# =============================================================================
# Other KB Service URLs (Future Integration)
# =============================================================================
# KB2_URL=http://localhost:8082
# KB3_URL=http://localhost:8087
# KB4_URL=http://localhost:8088
# KB5_URL=http://localhost:8089
# KB7_URL=http://localhost:8092

# =============================================================================
# Logging and Monitoring
# =============================================================================
LOG_LEVEL=info
ENABLE_METRICS=true

# =============================================================================
# Security (Production)
# =============================================================================
# JWT_SECRET=your-production-secret-key
# ALLOWED_ORIGINS=https://your-domain.com
