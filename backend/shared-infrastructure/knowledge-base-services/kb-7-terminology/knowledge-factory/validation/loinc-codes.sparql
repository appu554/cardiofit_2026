# SPARQL Validation Query: LOINC Code Count
# Purpose: Verify minimum LOINC code count
# Expected: >90,000 LOINC codes

PREFIX owl: <http://www.w3.org/2002/07/owl#>

SELECT (COUNT(DISTINCT ?code) AS ?count)
WHERE {
  ?code a owl:Class .
  FILTER(STRSTARTS(STR(?code), "http://loinc.org/"))
}

# Validation Rule: ?count > 90000
# If fails: LOINC transformation incomplete or source file issues
