# SPARQL Validation Query: SNOMED Hierarchy Roots
# Purpose: Verify SNOMED root concept structure
# Expected: Exactly 1 root concept (SNOMED CT Concept - 138875005)

PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT (COUNT(?root) AS ?count)
WHERE {
  ?root rdfs:subClassOf <http://snomed.info/id/138875005> .
}

# Validation Rule: ?count = 1
# If fails: SNOMED hierarchy transformation is incorrect
# Note: SNOMED CT Concept (138875005) is the top-level root
