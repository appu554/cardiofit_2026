# SPARQL Validation Query: Orphaned Concepts
# Purpose: Detect concepts without parent relationships
# Expected: <10 orphaned concepts (should be root concepts only)

PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?concept ?label
WHERE {
  ?concept a owl:Class .
  OPTIONAL { ?concept rdfs:label ?label }

  FILTER NOT EXISTS {
    ?concept rdfs:subClassOf ?parent .
  }

  FILTER(?concept != owl:Thing)

  FILTER(
    STRSTARTS(STR(?concept), "http://snomed.info/") ||
    STRSTARTS(STR(?concept), "http://purl.bioontology.org/ontology/RXNORM/") ||
    STRSTARTS(STR(?concept), "http://loinc.org/")
  )
}
LIMIT 100

# Validation Rule: COUNT(?concept) < 10
# If fails: Hierarchy transformation may be incomplete
