# SPARQL Validation Query: Concept Count
# Purpose: Verify minimum concept count threshold
# Expected: >500,000 total concepts across all terminologies

PREFIX owl: <http://www.w3.org/2002/07/owl#>

SELECT (COUNT(DISTINCT ?concept) AS ?count)
WHERE {
  ?concept a owl:Class .
  FILTER(
    STRSTARTS(STR(?concept), "http://snomed.info/") ||
    STRSTARTS(STR(?concept), "http://purl.bioontology.org/ontology/RXNORM/") ||
    STRSTARTS(STR(?concept), "http://loinc.org/")
  )
}

# Validation Rule: ?count > 500000
# If fails: Check transformation completeness
