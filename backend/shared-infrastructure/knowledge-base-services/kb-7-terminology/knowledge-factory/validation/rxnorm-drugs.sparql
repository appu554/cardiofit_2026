# SPARQL Validation Query: RxNorm Drug Count
# Purpose: Verify minimum RxNorm concept count
# Expected: >100,000 RxNorm concepts

PREFIX owl: <http://www.w3.org/2002/07/owl#>

SELECT (COUNT(DISTINCT ?drug) AS ?count)
WHERE {
  ?drug a owl:Class .
  FILTER(STRSTARTS(STR(?drug), "http://purl.bioontology.org/ontology/RXNORM/"))
}

# Validation Rule: ?count > 100000
# If fails: RxNorm transformation incomplete or source file issues
