# SPARQL Query: Validate AMT (Australian Medicines Terminology) presence
# AMT Module ID: 900062011000036103
# Checks for common Australian drug concepts

PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX sct: <http://snomed.info/id/>

# Count AMT concepts (approximate - concepts in AMT module)
SELECT (COUNT(DISTINCT ?concept) AS ?amt_concept_count) WHERE {
  ?concept rdf:type owl:Class .

  # AMT concepts are under the pharmaceutical/medicinal hierarchy
  # and belong to the AMT module
  FILTER(STRSTARTS(STR(?concept), "http://snomed.info/id/"))
}
