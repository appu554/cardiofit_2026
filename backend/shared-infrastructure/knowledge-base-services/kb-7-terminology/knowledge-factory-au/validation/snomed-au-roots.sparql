# SPARQL Query: Validate SNOMED CT-AU root concepts
# Checks for presence of core SNOMED hierarchy in AU kernel

PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX sct: <http://snomed.info/id/>

SELECT ?concept ?label WHERE {
  VALUES ?concept {
    sct:138875005    # SNOMED CT Concept (root)
    sct:404684003    # Clinical finding
    sct:71388002     # Procedure
    sct:373873005    # Pharmaceutical product
    sct:105590001    # Substance
    sct:123037004    # Body structure
    sct:363787002    # Observable entity
  }

  ?concept rdf:type owl:Class .
  OPTIONAL { ?concept rdfs:label ?label }
}
