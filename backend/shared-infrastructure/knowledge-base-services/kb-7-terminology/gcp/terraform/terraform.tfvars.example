# ══════════════════════════════════════════════════════════════════
# KB-7 Knowledge Factory - GCP Terraform Configuration
# ══════════════════════════════════════════════════════════════════
#
# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars
#
# IMPORTANT: terraform.tfvars is gitignored - never commit credentials!
#
# ══════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────
# GCP Project Configuration
# ──────────────────────────────────────────────────────────────────

project_id  = "your-gcp-project-id-here"     # Must match your GCP project
region      = "us-central1"                   # Or: us-east1, europe-west1, asia-northeast1
environment = "production"                    # Options: production, staging, development

# ──────────────────────────────────────────────────────────────────
# External API Credentials (Required)
# ──────────────────────────────────────────────────────────────────

# NHS TRUD API Key
# Get from: https://isd.digital.nhs.uk/trud/
# Format: TRUD-API-KEY-xxxxxxxxxxxxxxxx
nhs_trud_api_key = "your-nhs-trud-api-key-here"

# UMLS API Key
# Get from: https://uts.nlm.nih.gov/
# Format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
umls_api_key = "your-umls-api-key-here"

# LOINC Credentials
# Get from: https://loinc.org/downloads/
loinc_username = "your-loinc-username-here"
loinc_password = "your-loinc-password-here"

# GitHub Personal Access Token
# Get from: https://github.com/settings/tokens
# Scopes required: repo, workflow
# Format: ghp_xxxxxxxxxxxxxxxxxxxx
github_pat = "ghp_your-github-personal-access-token"

# ──────────────────────────────────────────────────────────────────
# Notification Configuration (Optional)
# ──────────────────────────────────────────────────────────────────

# Slack webhook for alerts (leave empty to disable)
slack_webhook_url = ""  # Example: "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

# Email for critical alerts
alert_email = "kb7-alerts@yourdomain.com"

# ──────────────────────────────────────────────────────────────────
# Resource Configuration (Advanced - Use Defaults)
# ──────────────────────────────────────────────────────────────────

# SNOMED Downloader Function
snomed_function_memory    = "10Gi"      # 10GB for 1.2GB SNOMED downloads
snomed_function_timeout   = 3600        # 60 minutes (max for Cloud Functions 2nd gen)
snomed_function_cpu       = "2"         # 2 vCPUs

# RxNorm Downloader Function
rxnorm_function_memory    = "3Gi"       # 3GB for 450MB RxNorm downloads
rxnorm_function_timeout   = 1800        # 30 minutes
rxnorm_function_cpu       = "1"         # 1 vCPU

# LOINC Downloader Function
loinc_function_memory     = "2Gi"       # 2GB for 180MB LOINC downloads
loinc_function_timeout    = 1200        # 20 minutes
loinc_function_cpu        = "1"         # 1 vCPU

# GitHub Dispatcher Function
github_function_memory    = "512Mi"     # Minimal - just API calls
github_function_timeout   = 300         # 5 minutes
github_function_cpu       = "1"         # 1 vCPU

# ──────────────────────────────────────────────────────────────────
# Schedule Configuration
# ──────────────────────────────────────────────────────────────────

# Monthly execution schedule (cron format)
# Default: 1st of month at 2:00 AM UTC
# Format: "minute hour day month weekday"
schedule_cron = "0 2 1 * *"

# Timezone for schedule
schedule_timezone = "UTC"

# ──────────────────────────────────────────────────────────────────
# Storage Configuration
# ──────────────────────────────────────────────────────────────────

# Cloud Storage lifecycle (days to retain old versions)
lifecycle_age_days = 90  # Delete versions older than 90 days

# Storage class
storage_class = "STANDARD"  # Options: STANDARD, NEARLINE, COLDLINE

# ──────────────────────────────────────────────────────────────────
# Cost Management
# ──────────────────────────────────────────────────────────────────

# Maximum concurrent function executions (prevents runaway costs)
max_instance_count = 1  # Only 1 of each function can run at once

# Minimum instances (0 = cold start, 1 = always warm)
min_instance_count = 0  # 0 for cost savings

# ══════════════════════════════════════════════════════════════════
# ESTIMATED MONTHLY COST: $21.50/month
# ══════════════════════════════════════════════════════════════════
#
# Breakdown:
#   Cloud Functions 2nd gen:  $6.00  (4 functions, monthly execution)
#   Cloud Storage:            $4.50  (2GB stored + egress)
#   Cloud Workflows:          $0.50  (1 monthly execution)
#   Secret Manager:           $0.60  (4 secrets)
#   Cloud Scheduler:          $0.10  (1 job)
#   Monitoring & Logging:     $3.00  (logs, metrics, alerts)
#   Cloud Build:              $6.80  (function deployments)
#   ──────────────────────────────────
#   TOTAL:                   $21.50/month
#
# ══════════════════════════════════════════════════════════════════
