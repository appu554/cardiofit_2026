\f0\fs29\fsmilli14667 ### 6.1 Automated Rollback Script
\f1\fs24 \
\

\f0\fs29\fsmilli14667 ```bash
\f1\fs24 \

\f0\fs29\fsmilli14667 #!/bin/bash
\f1\fs24 \

\f0\fs29\fsmilli14667 # kb7_rollback.sh - Rollback to previous known-good state
\f1\fs24 \
\

\f0\fs29\fsmilli14667 set -e
\f1\fs24 \
\

\f0\fs29\fsmilli14667 GRAPHDB_URL=$\{GRAPHDB_URL:-"http://localhost:7200"\}
\f1\fs24 \

\f0\fs29\fsmilli14667 REPO=$\{REPO:-"kb7-production"\}
\f1\fs24 \

\f0\fs29\fsmilli14667 BACKUP_DIR="/opt/kb7/backups"
\f1\fs24 \
\

\f0\fs29\fsmilli14667 # Function to rollback GraphDB
\f1\fs24 \

\f0\fs29\fsmilli14667 rollback_graphdb() \{
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0local backup_file=$1
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0echo "Rolling back GraphDB to: $backup_file"
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0# Clear current repository
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0curl -X DELETE "$GRAPHDB_URL/repositories/$REPO/statements"
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0# Load backup
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0curl -X POST \\
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0-H "Content-Type: application/trig" \\
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0--data-binary @"$backup_file" \\
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0"$GRAPHDB_URL/repositories/$REPO/statements"
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0echo "Rollback complete"
\f1\fs24 \

\f0\fs29\fsmilli14667 \}
\f1\fs24 \
\

\f0\fs29\fsmilli14667 # Function to validate rollback
\f1\fs24 \

\f0\fs29\fsmilli14667 validate_rollback() \{
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0# Run basic SPARQL query to check
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0result=$(curl -s -X POST \\
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0-H "Content-Type: application/sparql-query" \\
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0--data "SELECT (COUNT(*) as ?count) WHERE \{ ?s ?p ?o \}" \\
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0"$GRAPHDB_URL/repositories/$REPO")
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0if [[ $result == *"count"* ]]; then
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0echo "Validation successful"
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0return 0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0else
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0echo "Validation failed"
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0return 1
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0fi
\f1\fs24 \

\f0\fs29\fsmilli14667 \}
\f1\fs24 \
\

\f0\fs29\fsmilli14667 # Main rollback logic
\f1\fs24 \

\f0\fs29\fsmilli14667 if [ -z "$1" ]; then
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0# Use most recent backup
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0BACKUP_FILE=$(ls -t $BACKUP_DIR/*.trig | head -1)
\f1\fs24 \

\f0\fs29\fsmilli14667 else
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0BACKUP_FILE="$BACKUP_DIR/$1"
\f1\fs24 \

\f0\fs29\fsmilli14667 fi
\f1\fs24 \
\

\f0\fs29\fsmilli14667 if [ ! -f "$BACKUP_FILE" ]; then
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0echo "Backup file not found: $BACKUP_FILE"
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0exit 1
\f1\fs24 \

\f0\fs29\fsmilli14667 fi
\f1\fs24 \
\

\f0\fs29\fsmilli14667 rollback_graphdb "$BACKUP_FILE"
\f1\fs24 \
\

\f0\fs29\fsmilli14667 if validate_rollback; then
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0echo "Rollback successful"
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0# Trigger cache refresh
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0curl -X POST "$KB7_API_URL/admin/refresh-cache"
\f1\fs24 \

\f0\fs29\fsmilli14667 else
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0echo "Rollback validation failed!"
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0exit 1
\f1\fs24 \

\f0\fs29\fsmilli14667 fi
\f1\fs24 \

\f0\fs29\fsmilli14667 ```
