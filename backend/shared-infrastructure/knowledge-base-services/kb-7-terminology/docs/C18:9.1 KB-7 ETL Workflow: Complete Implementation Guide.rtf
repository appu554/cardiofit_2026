\f0\fs29\fsmilli14667 ### 1.2 Version Control Integration
\f1\fs24 \
\

\f0\fs29\fsmilli14667 ```bash
\f1\fs24 \

\f0\fs29\fsmilli14667 #!/bin/bash
\f1\fs24 \

\f0\fs29\fsmilli14667 # git_version_sources.sh - Version control for source files
\f1\fs24 \
\

\f0\fs29\fsmilli14667 SOURCES_DIR="/opt/kb7/sources"
\f1\fs24 \

\f0\fs29\fsmilli14667 GIT_REPO="/opt/kb7/git/kb7-sources"
\f1\fs24 \
\

\f0\fs29\fsmilli14667 # Initialize Git LFS for large files
\f1\fs24 \

\f0\fs29\fsmilli14667 cd $GIT_REPO
\f1\fs24 \

\f0\fs29\fsmilli14667 git lfs track "*.zip"
\f1\fs24 \

\f0\fs29\fsmilli14667 git lfs track "*.owl"
\f1\fs24 \
\

\f0\fs29\fsmilli14667 # Function to commit new source
\f1\fs24 \

\f0\fs29\fsmilli14667 commit_source() \{
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0local source_type=$1
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0local file_path=$2
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0local version=$3
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0# Copy to Git repo
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0cp $file_path $GIT_REPO/$source_type/
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0# Generate commit message with metadata
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0commit_msg="feat($source_type): Add $source_type version $version
\f1\fs24 \
\

\f0\fs29\fsmilli14667 Source: $file_path
\f1\fs24 \

\f0\fs29\fsmilli14667 SHA256: $(sha256sum $file_path | cut -d' ' -f1)
\f1\fs24 \

\f0\fs29\fsmilli14667 Date: $(date -I)
\f1\fs24 \

\f0\fs29\fsmilli14667 Automated: true"
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0cd $GIT_REPO
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0git add -A
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0git commit -m "$commit_msg"
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0git tag "$\{source_type\}-$\{version\}"
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0git push --tags origin main
\f1\fs24 \

\f0\fs29\fsmilli14667 \}
\f1\fs24 \
\

\f0\fs29\fsmilli14667 # Process new downloads
\f1\fs24 \

\f0\fs29\fsmilli14667 for source_file in $SOURCES_DIR/staging/*; do
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0if [ -f "$source_file" ]; then
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0# Extract metadata from filename
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0source_type=$(echo $source_file | cut -d'_' -f1)
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0version=$(echo $source_file | cut -d'_' -f2)
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0commit_source $source_type $source_file $version
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0# Move to processed
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0mv $source_file $SOURCES_DIR/processed/
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0fi
\f1\fs24 \

\f0\fs29\fsmilli14667 done
\f1\fs24 \

\f0\fs29\fsmilli14667 ```
\f1\fs24 \
