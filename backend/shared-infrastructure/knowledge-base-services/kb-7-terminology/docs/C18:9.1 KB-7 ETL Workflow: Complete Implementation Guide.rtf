\

\f0\fs29\fsmilli14667 ```python
\f1\fs24 \

\f0\fs29\fsmilli14667 #!/usr/bin/env python3
\f1\fs24 \

\f0\fs29\fsmilli14667 """
\f1\fs24 \

\f0\fs29\fsmilli14667 generate_mapping_template.py - Convert CSV crosswalks to ROBOT templates
\f1\fs24 \

\f0\fs29\fsmilli14667 """
\f1\fs24 \

\f0\fs29\fsmilli14667 import pandas as pd
\f1\fs24 \

\f0\fs29\fsmilli14667 from datetime import datetime
\f1\fs24 \
\

\f0\fs29\fsmilli14667 def csv_to_robot_template(input_csv: str, output_tsv: str):
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0"""Convert clinical mapping CSV to ROBOT template format"""
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0# Read mapping CSV
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0df = pd.read_csv(input_csv)
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0# Create ROBOT template structure
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0template_rows = []
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0# Header rows for ROBOT
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0header1 = ['ID', 'TYPE', 'SC %', 'EC %',\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0'A rdfs:comment', 'A kb7:mappingType',\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0'A kb7:confidence', 'A kb7:policyFlag',
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0'A pav:createdBy', 'A pav:createdOn']
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0header2 = ['ID', 'TYPE', 'SC %', 'EC %',
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0'TEXT', 'IRI', 'FLOAT', 'IRI',\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0'IRI', 'DATE']
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0template_rows.append(header1)
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0template_rows.append(header2)
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0# Process each mapping
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0for idx, row in df.iterrows():
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0mapping_id = f"kb7:mapping_\{idx:05d\}"
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0# Build ROBOT row
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0robot_row = [
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0mapping_id,\'a0 # ID
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0'owl:Class',\'a0 # TYPE
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0f"<http://snomed.info/id/\{row['source_code']\}>",\'a0 # SubClass
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0f"<http://icd10am.au/\{row['target_code']\}>",\'a0 # EquivalentClass
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0f"Mapping from SNOMED \{row['source_code']\} to ICD-10-AM \{row['target_code']\}",
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0row.get('mapping_type', 'skos:exactMatch'),
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0float(row.get('confidence', 1.0)),
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0row.get('policy_flag', 'kb7:AutoMapAllowed'),
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0'kb7:automated_mapper',
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0datetime.now().strftime('%Y-%m-%d')
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0]
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0template_rows.append(robot_row)
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0# Write TSV
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0pd.DataFrame(template_rows[2:], columns=template_rows[0]).to_csv(
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0output_tsv, sep='\\t', index=False
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0)
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0print(f"Generated ROBOT template with \{len(template_rows)-2\} mappings")
\f1\fs24 \
\

\f0\fs29\fsmilli14667 if __name__ == "__main__":
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0csv_to_robot_template(
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0'mappings/snomed_to_icd10am.csv',
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0'templates/snomed_icd10am_robot.tsv'
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0)
\f1\fs24 \

\f0\fs29\fsmilli14667 ```
\f1\fs24 \
