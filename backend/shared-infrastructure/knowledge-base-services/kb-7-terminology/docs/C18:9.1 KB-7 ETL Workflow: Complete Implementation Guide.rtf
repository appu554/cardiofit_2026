\f1\fs24 \

\f0\fs29\fsmilli14667 RF2_SOURCE := ../../sources/snomed-ct-au/latest.zip
\f1\fs24 \

\f0\fs29\fsmilli14667 OWL_OUTPUT := snomed-ct-au.owl
\f1\fs24 \

\f0\fs29\fsmilli14667 OWL_CLASSIFIED := snomed-ct-au-classified.owl
\f1\fs24 \
\

\f0\fs29\fsmilli14667 # SNOMED OWL Toolkit for better RF2 conversion
\f1\fs24 \

\f0\fs29\fsmilli14667 SNOMED_TOOLKIT := java -jar ../bin/snomed-owl-toolkit.jar
\f1\fs24 \
\

\f0\fs29\fsmilli14667 .PHONY: all clean test release
\f1\fs24 \
\

\f0\fs29\fsmilli14667 all: $(OWL_CLASSIFIED) validate test
\f1\fs24 \
\

\f0\fs29\fsmilli14667 # Convert RF2 to OWL using SNOMED OWL Toolkit (better than ROBOT for RF2)
\f1\fs24 \

\f0\fs29\fsmilli14667 $(OWL_OUTPUT): $(RF2_SOURCE)
\f1\fs24 \

\f0\fs29\fsmilli14667 	@echo "Converting RF2 to OWL using SNOMED OWL Toolkit..."
\f1\fs24 \

\f0\fs29\fsmilli14667 	$(SNOMED_TOOLKIT) \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		-rf2-to-owl \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		-rf2-snapshot-archives $(RF2_SOURCE) \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		-uri http://snomed.info/sct/32506021000036107 \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		-version $(shell date +%Y%m%d) \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		-output $@
\f1\fs24 \

\f0\fs29\fsmilli14667 	
\f1\fs24 \

\f0\fs29\fsmilli14667 	@echo "Post-processing with ROBOT..."
\f1\fs24 \

\f0\fs29\fsmilli14667 	$(ROBOT) convert \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--input $@ \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--format owl \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		annotate \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--ontology-iri http://kb7.org/snomed-ct-au.owl \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--version-iri http://kb7.org/snomed-ct-au/$(shell date +%Y-%m-%d).owl \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--annotation rdfs:comment "SNOMED CT-AU for KB-7" \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--output $@
\f1\fs24 \
\

\f0\fs29\fsmilli14667 # Add AMT concepts via template
\f1\fs24 \

\f0\fs29\fsmilli14667 amt-module.owl: src/templates/amt_medicines.tsv
\f1\fs24 \

\f0\fs29\fsmilli14667 	$(ROBOT) template \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--template $< \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--input $(OWL_OUTPUT) \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--prefix "AMT: http://amt.org.au/" \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--output $@
\f1\fs24 \
\

\f0\fs29\fsmilli14667 # Reason and classify
\f1\fs24 \

\f0\fs29\fsmilli14667 $(OWL_CLASSIFIED): $(OWL_OUTPUT) amt-module.owl
\f1\fs24 \

\f0\fs29\fsmilli14667 	@echo "Merging modules and reasoning..."
\f1\fs24 \

\f0\fs29\fsmilli14667 	$(ROBOT) merge \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--input $(OWL_OUTPUT) \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--input amt-module.owl \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		reason \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--reasoner ELK \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--equivalent-classes-allowed all \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--exclude-tautologies structural \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		reduce \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--output $@
\f1\fs24 \
\

\f0\fs29\fsmilli14667 # Validation checks
\f1\fs24 \

\f0\fs29\fsmilli14667 validate: $(OWL_CLASSIFIED)
\f1\fs24 \

\f0\fs29\fsmilli14667 	@echo "Running SPARQL validation checks..."
\f1\fs24 \

\f0\fs29\fsmilli14667 	$(ROBOT) verify \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--input $< \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--queries src/sparql/qc_checks.sparql \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--output-dir reports/
\f1\fs24 \

\f0\fs29\fsmilli14667 	
\f1\fs24 \

\f0\fs29\fsmilli14667 	@echo "Running ROBOT report..."
\f1\fs24 \

\f0\fs29\fsmilli14667 	$(ROBOT) report \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--input $< \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--labels true \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--output reports/robot-report.tsv
\f1\fs24 \
\

\f0\fs29\fsmilli14667 # Custom Australian validation rules
\f1\fs24 \

\f0\fs29\fsmilli14667 au-validate: $(OWL_CLASSIFIED)
\f1\fs24 \

\f0\fs29\fsmilli14667 	$(ROBOT) query \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--input $< \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--query src/sparql/au_specific_checks.sparql \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		check_au_rules.csv
\f1\fs24 \

\f0\fs29\fsmilli14667 	python3 src/scripts/validate_au_rules.py check_au_rules.csv
\f1\fs24 \
\

\f0\fs29\fsmilli14667 # Test for logical consistency
\f1\fs24 \

\f0\fs29\fsmilli14667 test: $(OWL_CLASSIFIED)
\f1\fs24 \

\f0\fs29\fsmilli14667 	$(ROBOT) reason \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--input $< \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--reasoner HermiT \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--dump-inconsistent reports/inconsistent.owl
\f1\fs24 \

\f0\fs29\fsmilli14667 	
\f1\fs24 \

\f0\fs29\fsmilli14667 	@if [ -s reports/inconsistent.owl ]; then \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		echo "ERROR: Ontology is inconsistent!"; \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		exit 1; \\
\f1\fs24 \

\f0\fs29\fsmilli14667 	fi
\f1\fs24 \
\

\f0\fs29\fsmilli14667 # Generate documentation
\f1\fs24 \

\f0\fs29\fsmilli14667 docs:
\f1\fs24 \

\f0\fs29\fsmilli14667 	$(ROBOT) query \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--input $(OWL_CLASSIFIED) \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		--query src/sparql/extract_statistics.sparql \\
\f1\fs24 \

\f0\fs29\fsmilli14667 		stats.csv
\f1\fs24 \

\f0\fs29\fsmilli14667 	python3 src/scripts/generate_docs.py
\f1\fs24 \

\f0\fs29\fsmilli14667 ```
\f1\fs24 \
\

