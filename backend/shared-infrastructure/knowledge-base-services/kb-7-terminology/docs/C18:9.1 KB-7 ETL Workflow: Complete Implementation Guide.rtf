\f0\fs29\fsmilli14667 ### 3.2 SPARQL Quality Checks
\f1\fs24 \
\

\f0\fs29\fsmilli14667 ```sparql
\f1\fs24 \

\f0\fs29\fsmilli14667 # qc_checks.sparql - Quality control queries
\f1\fs24 \
\

\f0\fs29\fsmilli14667 # Check for orphan concepts (no parents)
\f1\fs24 \

\f0\fs29\fsmilli14667 PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
\f1\fs24 \

\f0\fs29\fsmilli14667 PREFIX owl: <http://www.w3.org/2002/07/owl#>
\f1\fs24 \
\

\f0\fs29\fsmilli14667 SELECT ?concept ?label
\f1\fs24 \

\f0\fs29\fsmilli14667 WHERE \{
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0?concept a owl:Class .
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0OPTIONAL \{ ?concept rdfs:label ?label \}
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0FILTER NOT EXISTS \{
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0?concept rdfs:subClassOf ?parent .
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0FILTER(?parent != owl:Thing)
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\}
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0FILTER(?concept != owl:Thing)
\f1\fs24 \

\f0\fs29\fsmilli14667 \}
\f1\fs24 \

\f0\fs29\fsmilli14667 LIMIT 100
\f1\fs24 \
\

\f0\fs29\fsmilli14667 ---
\f1\fs24 \
\

\f0\fs29\fsmilli14667 # Check for missing Australian dialect terms
\f1\fs24 \

\f0\fs29\fsmilli14667 PREFIX sct: <http://snomed.info/id/>
\f1\fs24 \

\f0\fs29\fsmilli14667 PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
\f1\fs24 \
\

\f0\fs29\fsmilli14667 SELECT ?concept ?fsn
\f1\fs24 \

\f0\fs29\fsmilli14667 WHERE \{
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0?concept a owl:Class ;
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0rdfs:label ?fsn .
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0FILTER(CONTAINS(str(?concept), "snomed.info"))
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0FILTER NOT EXISTS \{
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0?concept skos:prefLabel ?ausLabel .
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0FILTER(LANG(?ausLabel) = "en-AU")
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\}
\f1\fs24 \

\f0\fs29\fsmilli14667 \}
\f1\fs24 \
\

\f0\fs29\fsmilli14667 ---
\f1\fs24 \
\

\f0\fs29\fsmilli14667 # Validate AMT medicines have required relationships
\f1\fs24 \

\f0\fs29\fsmilli14667 PREFIX amt: <http://amt.org.au/>
\f1\fs24 \
\

\f0\fs29\fsmilli14667 SELECT ?medicine ?label
\f1\fs24 \

\f0\fs29\fsmilli14667 WHERE \{
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0?medicine a amt:Medicine ;
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0rdfs:label ?label .
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0FILTER NOT EXISTS \{
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0?medicine amt:hasBasisOfStrength ?strength .
\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\}
\f1\fs24 \

\f0\fs29\fsmilli14667 \}
\f1\fs24 \

\f0\fs29\fsmilli14667 ```
\f1\fs24 \
