\f1\fs24 \

\f0\fs29\fsmilli14667 \'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\uc0\u8595 
\f1\fs24 \

\f0\fs29\fsmilli14667 GraphDB (Authoritative Semantic Core)
