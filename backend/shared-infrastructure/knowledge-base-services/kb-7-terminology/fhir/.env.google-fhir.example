# Google FHIR Healthcare API Configuration for KB7 Terminology Service
# Copy this file to .env and configure your Google Cloud settings

# =============================================================================
# Google Cloud Healthcare API Configuration
# =============================================================================

# Required: Google Cloud Project Configuration
GOOGLE_CLOUD_PROJECT_ID=cardiofit-905a8
GOOGLE_CLOUD_LOCATION=asia-south1
GOOGLE_CLOUD_DATASET_ID=clinical-synthesis-hub
GOOGLE_CLOUD_FHIR_STORE_ID=fhir-store

# Authentication (choose one method)
# Method 1: Service Account Key File Path
GOOGLE_CLOUD_CREDENTIALS_PATH=credentials/google-credentials.json

# Method 2: Service Account Key JSON (alternative to file path)
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Method 3: Default Application Credentials (if running on GCP)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# =============================================================================
# Google FHIR API Configuration
# =============================================================================

# Request timeout and retry settings
GOOGLE_FHIR_TIMEOUT=30
GOOGLE_FHIR_MAX_RETRIES=3
GOOGLE_FHIR_RETRY_DELAY=1.0

# Performance settings
GOOGLE_FHIR_MAX_CONCURRENT=10
GOOGLE_FHIR_BATCH_SIZE=100

# Caching configuration
GOOGLE_FHIR_CACHE_TTL=3600

# =============================================================================
# Hybrid Service Configuration
# =============================================================================

# Enable synchronization between local and Google FHIR
GOOGLE_FHIR_SYNC_ENABLED=true
GOOGLE_FHIR_FALLBACK_ENABLED=true
GOOGLE_FHIR_SYNC_INTERVAL=300

# Feature toggles
GOOGLE_FHIR_ENABLE_VERSIONING=true
GOOGLE_FHIR_ENABLE_AUDIT=true

# =============================================================================
# KB7 Integration Configuration
# =============================================================================

# Query router endpoint
KB7_QUERY_ROUTER_URL=http://localhost:8087

# Redis for caching
REDIS_URL=redis://localhost:6379

# =============================================================================
# Logging and Monitoring
# =============================================================================

# Log level for Google FHIR operations
GOOGLE_FHIR_LOG_LEVEL=INFO

# Enable request/response logging
GOOGLE_FHIR_DEBUG_LOGGING=false

# Metrics collection
GOOGLE_FHIR_METRICS_ENABLED=true

# =============================================================================
# Example Usage Commands
# =============================================================================

# 1. Test CodeSystem $lookup with Google FHIR:
# curl "http://localhost:8000/fhir/CodeSystem/\$lookup?system=http://snomed.info/sct&code=73211009&prefer_source=google"

# 2. Test ValueSet $expand with fallback:
# curl "http://localhost:8000/fhir/ValueSet/\$expand?url=http://hl7.org/fhir/ValueSet/administrative-gender"

# 3. Check hybrid service health:
# curl "http://localhost:8000/fhir/terminology/health"

# 4. Get Google FHIR statistics:
# curl "http://localhost:8000/fhir/terminology/google-stats"

# =============================================================================
# Security Notes
# =============================================================================

# 1. Store service account credentials securely
# 2. Use least privilege IAM roles:
#    - roles/healthcare.fhirResourceReader (for read operations)
#    - roles/healthcare.fhirResourceEditor (for write operations)
# 3. Enable audit logging in Google Cloud Healthcare API
# 4. Monitor API usage and quotas
# 5. Use VPC Service Controls for additional security

# =============================================================================
# Required IAM Permissions
# =============================================================================

# The service account needs these permissions:
# - healthcare.fhirStores.searchResources
# - healthcare.fhirResources.create
# - healthcare.fhirResources.read
# - healthcare.fhirResources.update
# - healthcare.fhirResources.delete
# - healthcare.fhirResources.search

# =============================================================================
# Performance Optimization
# =============================================================================

# Enable these for production:
# - Request batching for bulk operations
# - Connection pooling and keep-alive
# - Redis caching with appropriate TTL
# - Circuit breaker patterns for fallback
# - Monitoring and alerting on latency/errors