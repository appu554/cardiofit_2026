// Administrative operations
func (s *EnhancedServer) warmCache(c *gin.Context) {
	var request struct {
		Patterns []string `json:"patterns"`
		Force    bool     `json:"force,omitempty"`
	}

	if err := c.ShouldBindJSON(&request); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid request", "details": err.Error()})
		return
	}

	err := s.terminologyService.WarmCache(request.Patterns, request.Force)
	if err != nil {
		s.logger.WithError(err).Error("Cache warming failed")
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Cache warming failed"})
		return
	}

	c.JSON(http.StatusOK, gin.H{"message": "Cache warming initiated"})
}

func (s *EnhancedServer) invalidateCache(c *gin.Context) {
	var request struct {
		Pattern cache.InvalidationPattern `json:"pattern"`
	}

	if err := c.ShouldBindJSON(&request); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid request", "details": err.Error()})
		return
	}

	err := s.cacheManager.Invalidate(request.Pattern)
	if err != nil {
		s.logger.WithError(err).Error("Cache invalidation failed")
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Cache invalidation failed"})
		return
	}

	c.JSON(http.StatusOK, gin.H{"message": "Cache invalidation completed"})
}

func (s *EnhancedServer) getCacheStatistics(c *gin.Context) {
	stats := s.cacheManager.GetStatistics()
	c.JSON(http.StatusOK, stats)
}

func (s *EnhancedServer) detailedHealthCheck(c *gin.Context) {
	health := s.terminologyService.DetailedHealthCheck()
	
	if health.Status == "healthy" {
		c.JSON(http.StatusOK, health)
	} else {
		c.JSON(http.StatusServiceUnavailable, health)
	}
}

// Enhanced search operations
func (s *EnhancedServer) enhancedSearch(c *gin.Context) {
	var request struct {
		SearchTerm string                        `json:"search_term"`
		Options    services.SearchOptions       `json:"options"`
	}
	
	if err := c.ShouldBindJSON(&request); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid request payload"})
		return
	}
	
	if request.SearchTerm == "" {
		c.JSON(http.StatusBadRequest, gin.H{"error": "search_term is required"})
		return
	}
	
	response, err := s.enhancedSearchService.Search(request.SearchTerm, request.Options)
	if err != nil {
		s.logger.WithError(err).WithField("search_term", request.SearchTerm).Error("Enhanced search failed")
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Search failed"})
		return
	}
	
	c.JSON(http.StatusOK, response)
}

func (s *EnhancedServer) suggestConcepts(c *gin.Context) {
	partialTerm := c.Query("q")
	if partialTerm == "" {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Query parameter 'q' is required"})
		return
	}
	
	options := services.SearchOptions{
		TargetSystem:    c.Query("system"),
		MaxResults:      parseInt(c.Query("limit"), 20),
		IncludeInactive: c.Query("include_inactive") == "true",
	}
	
	response, err := s.enhancedSearchService.SuggestConcepts(partialTerm, options)
	if err != nil {
		s.logger.WithError(err).WithField("partial_term", partialTerm).Error("Concept suggestion failed")
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Suggestion failed"})
		return
	}
	
	c.JSON(http.StatusOK, response)
}

func (s *EnhancedServer) findSimilarConcepts(c *gin.Context) {
	conceptUUID := c.Param("uuid")
	limit := parseInt(c.Query("limit"), 10)
	
	response, err := s.enhancedSearchService.FindSimilarConcepts(conceptUUID, limit)
	if err != nil {
		s.logger.WithError(err).WithField("concept_uuid", conceptUUID).Error("Similar concepts search failed")
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Similar concepts search failed"})
		return
	}
	
	c.JSON(http.StatusOK, response)
}

func (s *EnhancedServer) getSearchStatistics(c *gin.Context) {
	days := parseInt(c.Query("days"), 7)
	
	stats, err := s.enhancedSearchService.SearchStatistics(days)
	if err != nil {
		s.logger.WithError(err).Error("Failed to get search statistics")
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Failed to get search statistics"})
		return
	}
	
	c.JSON(http.StatusOK, stats)
}

// Enhanced concept mapping operations
func (s *EnhancedServer) createConceptMapping(c *gin.Context) {
	var mapping services.ConceptMapping
	
	if err := c.ShouldBindJSON(&mapping); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid mapping data"})
		return
	}
	
	if err := s.conceptMapService.CreateConceptMapping(mapping); err != nil {
		s.logger.WithError(err).Error("Failed to create concept mapping")
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Failed to create mapping"})
		return
	}
	
	c.JSON(http.StatusCreated, gin.H{"message": "Mapping created successfully", "id": mapping.ID})
}

func (s *EnhancedServer) batchTranslateConcepts(c *gin.Context) {
	var request services.BatchTranslationRequest
	
	if err := c.ShouldBindJSON(&request); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid batch translation request"})
		return
	}
	
	if len(request.Concepts) == 0 {
		c.JSON(http.StatusBadRequest, gin.H{"error": "No concepts provided for translation"})
		return
	}
	
	if len(request.Concepts) > 1000 {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Maximum 1000 concepts per batch"})
		return
	}
	
	response, err := s.conceptMapService.BatchTranslateConcepts(request)
	if err != nil {
		s.logger.WithError(err).Error("Batch translation failed")
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Batch translation failed"})
		return
	}
	
	c.JSON(http.StatusOK, response)
}

func (s *EnhancedServer) getMappingStatistics(c *gin.Context) {
	stats, err := s.conceptMapService.GetMappingStatistics()
	if err != nil {
		s.logger.WithError(err).Error("Failed to get mapping statistics")
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Failed to get mapping statistics"})
		return
	}
	
	c.JSON(http.StatusOK, stats)
}

func (s *EnhancedServer) findSemanticMappings(c *gin.Context) {
	sourceSystem := c.Param("source_system")
	sourceCode := c.Param("source_code")
	targetSystem := c.Param("target_system")
	
	// Create a translation request for semantic mapping
	request := services.TranslationRequest{
		SourceSystem: sourceSystem,
		TargetSystem: targetSystem,
		Code:         sourceCode,
	}
	
	response, err := s.conceptMapService.TranslateConcept(request)
	if err != nil {
		s.logger.WithError(err).WithFields(logrus.Fields{
			"source_system": sourceSystem,
			"source_code":   sourceCode,
			"target_system": targetSystem,
		}).Error("Semantic mapping failed")
		
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Semantic mapping failed"})
		return
	}
	
	// Filter to only semantic mappings (those with comments about semantic matching)
	semanticMappings := make([]services.ConceptMapping, 0)
	for _, mapping := range response.Mappings {
		if strings.Contains(strings.ToLower(mapping.Comment), "semantic") {
			semanticMappings = append(semanticMappings, mapping)
		}
	}
	
	result := map[string]interface{}{
		"source_system":    sourceSystem,
		"source_code":      sourceCode,
		"target_system":    targetSystem,
		"semantic_mappings": semanticMappings,
		"count":           len(semanticMappings),
	}
	
	c.JSON(http.StatusOK, result)
}

// Middleware functions
func (s *EnhancedServer) cacheMiddleware() gin.HandlerFunc {
	return func(c *gin.Context) {
		// Add cache headers for cacheable endpoints
		if strings.HasPrefix(c.Request.URL.Path, "/v1/concepts/") && c.Request.Method == "GET" {
			c.Header("Cache-Control", "public, max-age=3600")
		}
		
		c.Next()
	}
}

// Utility functions (same as in original server.go but repeated here for completeness)
func parseInt(s string, defaultValue int) int {
	if s == "" {
		return defaultValue
	}
	
	if i, err := strconv.Atoi(s); err == nil {
		return i
	}
	
	return defaultValue
}