package api

import (
	"net/http"
	"strconv"
	"strings"
	"sync"
	"time"

	"kb-7-terminology/internal/cache"
	"kb-7-terminology/internal/config"
	"kb-7-terminology/internal/metrics"
	"kb-7-terminology/internal/models"
	"kb-7-terminology/internal/services"

	"github.com/gin-gonic/gin"
	"github.com/prometheus/client_golang/prometheus/promhttp"
	"github.com/sirupsen/logrus"
)

// EnhancedServer extends the basic server with advanced terminology operations
type EnhancedServer struct {
	config                *config.Config
	terminologyService    *services.TerminologyService
	expansionService      *services.ExpansionService
	validationService     *services.ValidationService
	snomedService         *services.SNOMEDService
	enhancedSearchService *services.EnhancedSearchService
	conceptMapService     *services.ConceptMapService
	cacheManager          *cache.CacheManager
	logger                *logrus.Logger
	metrics               *metrics.Collector
}

// NewEnhancedServer creates a new enhanced terminology server
func NewEnhancedServer(
	config *config.Config,
	terminologyService *services.TerminologyService,
	expansionService *services.ExpansionService,
	validationService *services.ValidationService,
	snomedService *services.SNOMEDService,
	enhancedSearchService *services.EnhancedSearchService,
	conceptMapService *services.ConceptMapService,
	cacheManager *cache.CacheManager,
	logger *logrus.Logger,
	metrics *metrics.Collector,
) *EnhancedServer {
	return &EnhancedServer{
		config:                config,
		terminologyService:    terminologyService,
		expansionService:      expansionService,
		validationService:     validationService,
		snomedService:         snomedService,
		enhancedSearchService: enhancedSearchService,
		conceptMapService:     conceptMapService,
		cacheManager:          cacheManager,
		logger:             logger,
		metrics:            metrics,
	}
}

// SetupRoutes configures all API routes including FHIR-compliant endpoints
func (s *EnhancedServer) SetupRoutes() *gin.Engine {
	if s.config.Environment == "production" {
		gin.SetMode(gin.ReleaseMode)
	}

	router := gin.New()

	// Add middleware
	router.Use(s.loggingMiddleware())
	router.Use(s.metricsMiddleware())
	router.Use(s.cacheMiddleware())
	router.Use(gin.Recovery())

	if s.config.Environment != "production" {
		router.Use(s.corsMiddleware())
	}

	// Health and monitoring endpoints
	router.GET(s.config.HealthEndpoint, s.healthCheck)
	router.GET("/health/detailed", s.detailedHealthCheck)
	router.GET("/metrics", gin.WrapH(promhttp.Handler()))
	router.GET("/version", s.versionInfo)
	router.GET("/statistics", s.getCacheStatistics)

	// Apollo Federation endpoint
	router.Any("/api/federation", s.FederationHandler)

	// API v1 routes
	v1 := router.Group("/v1")
	{
		// Terminology systems
		v1.GET("/systems", s.listTerminologySystems)
		v1.GET("/systems/:identifier", s.getTerminologySystem)

		// Enhanced concept operations
		v1.GET("/concepts", s.searchConcepts)
		v1.POST("/concepts/search", s.advancedSearch)
		v1.POST("/concepts/search/enhanced", s.enhancedSearch)
		v1.GET("/concepts/suggest", s.suggestConcepts)
		v1.GET("/concepts/:uuid/similar", s.findSimilarConcepts)
		v1.GET("/concepts/:system/:code", s.lookupConcept)
		v1.POST("/concepts/validate", s.validateCode)
		v1.GET("/concepts/:system/:code/hierarchy", s.getConceptHierarchy)
		v1.GET("/concepts/:system/:code/relationships", s.getConceptRelationships)
		v1.GET("/search/statistics", s.getSearchStatistics)

		// Drug-specific endpoints
		v1.GET("/drugs/:rxnorm", s.getDrugInfo)
		v1.GET("/drugs/search", s.searchDrugs)
		v1.GET("/drugs/:rxnorm/interactions", s.getDrugInteractions)

		// Lab test endpoints
		v1.GET("/labs/:loinc", s.getLabInfo)
		v1.GET("/labs/:loinc/references", s.getLabReferences)

		// Value sets - FHIR-compliant
		v1.GET("/valuesets", s.listValueSets)
		v1.GET("/valuesets/:url", s.getValueSet)
		v1.POST("/valuesets/:url/expand", s.expandValueSet)
		v1.POST("/valuesets/validate-code", s.validateValueSetCode)

		// Enhanced concept mappings
		v1.GET("/mappings", s.getConceptMappings)
		v1.POST("/mappings", s.createConceptMapping)
		v1.GET("/mappings/:source_system/:source_code/:target_system", s.getSpecificMapping)
		v1.POST("/mappings/translate", s.translateConcept)
		v1.POST("/mappings/translate/batch", s.batchTranslateConcepts)
		v1.GET("/mappings/statistics", s.getMappingStatistics)
		v1.GET("/mappings/semantic/:source_system/:source_code/:target_system", s.findSemanticMappings)

		// Batch operations
		v1.POST("/batch/lookup", s.batchLookupConcepts)
		v1.POST("/batch/validate", s.batchValidateCodes)
		v1.POST("/batch/translate", s.batchTranslateConcepts)

		// SNOMED CT specific operations
		snomed := v1.Group("/snomed")
		{
			snomed.POST("/expressions/validate", s.validateSNOMEDExpression)
			snomed.POST("/expressions/normalize", s.normalizeSNOMEDExpression)
			snomed.POST("/expressions/classify", s.classifySNOMEDExpression)
			snomed.GET("/expressions/:id", s.getSNOMEDExpression)
		}

		// Administration endpoints
		admin := v1.Group("/admin")
		{
			admin.POST("/cache/warm", s.warmCache)
			admin.POST("/cache/invalidate", s.invalidateCache)
			admin.GET("/cache/stats", s.getCacheStatistics)
			admin.POST("/etl/trigger", s.triggerETL)
			admin.GET("/etl/status", s.getETLStatus)
		}
	}

	// FHIR R4 terminology operations
	fhir := router.Group("/fhir")
	{
		fhir.GET("/CodeSystem", s.listCodeSystems)
		fhir.GET("/CodeSystem/:id", s.getCodeSystem)
		fhir.POST("/CodeSystem/$lookup", s.fhirLookup)
		fhir.POST("/CodeSystem/$validate-code", s.fhirValidateCode)

		fhir.GET("/ValueSet", s.listFHIRValueSets)
		fhir.GET("/ValueSet/:id", s.getFHIRValueSet)
		fhir.POST("/ValueSet/$expand", s.fhirExpandValueSet)
		fhir.POST("/ValueSet/$validate-code", s.fhirValidateValueSetCode)

		fhir.GET("/ConceptMap", s.listConceptMaps)
		fhir.GET("/ConceptMap/:id", s.getConceptMap)
		fhir.POST("/ConceptMap/$translate", s.fhirTranslate)
	}

	return router
}

// Enhanced concept search with advanced filtering
func (s *EnhancedServer) advancedSearch(c *gin.Context) {
	var query models.EnhancedSearchQuery
	if err := c.ShouldBindJSON(&query); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid search query", "details": err.Error()})
		return
	}

	result, err := s.terminologyService.AdvancedSearch(query)
	if err != nil {
		s.logger.WithError(err).Error("Advanced search failed")
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Search failed"})
		return
	}

	c.JSON(http.StatusOK, result)
}

// Get concept hierarchy (parents and children)
func (s *EnhancedServer) getConceptHierarchy(c *gin.Context) {
	system := c.Param("system")
	code := c.Param("code")
	maxDepth := parseInt(c.Query("max_depth"), 5)

	hierarchy, err := s.terminologyService.GetConceptHierarchy(system, code, maxDepth)
	if err != nil {
		s.logger.WithError(err).WithFields(logrus.Fields{
			"system": system,
			"code":   code,
		}).Error("Failed to get concept hierarchy")
		
		c.JSON(http.StatusNotFound, gin.H{"error": "Concept hierarchy not found"})
		return
	}

	c.JSON(http.StatusOK, hierarchy)
}

// Get concept relationships
func (s *EnhancedServer) getConceptRelationships(c *gin.Context) {
	system := c.Param("system")
	code := c.Param("code")
	includeInverse := c.Query("include_inverse") == "true"

	relationships, err := s.terminologyService.GetConceptRelationships(system, code, includeInverse)
	if err != nil {
		s.logger.WithError(err).WithFields(logrus.Fields{
			"system": system,
			"code":   code,
		}).Error("Failed to get concept relationships")
		
		c.JSON(http.StatusNotFound, gin.H{"error": "Concept relationships not found"})
		return
	}

	c.JSON(http.StatusOK, relationships)
}

// Drug-specific operations
func (s *EnhancedServer) getDrugInfo(c *gin.Context) {
	rxnorm := c.Param("rxnorm")
	
	drugInfo, err := s.terminologyService.GetDrugInfo(rxnorm)
	if err != nil {
		s.logger.WithError(err).WithField("rxnorm", rxnorm).Error("Failed to get drug info")
		c.JSON(http.StatusNotFound, gin.H{"error": "Drug not found"})
		return
	}

	c.JSON(http.StatusOK, drugInfo)
}

func (s *EnhancedServer) searchDrugs(c *gin.Context) {
	query := c.Query("q")
	ingredient := c.Query("ingredient")
	doseForm := c.Query("dose_form")
	limit := parseInt(c.Query("limit"), 20)

	results, err := s.terminologyService.SearchDrugs(query, ingredient, doseForm, limit)
	if err != nil {
		s.logger.WithError(err).Error("Drug search failed")
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Drug search failed"})
		return
	}

	c.JSON(http.StatusOK, results)
}

// Lab test operations
func (s *EnhancedServer) getLabInfo(c *gin.Context) {
	loinc := c.Param("loinc")
	
	labInfo, err := s.terminologyService.GetLabInfo(loinc)
	if err != nil {
		s.logger.WithError(err).WithField("loinc", loinc).Error("Failed to get lab info")
