func (s *EnhancedServer) getLabReferences(c *gin.Context) {
	loinc := c.Param("loinc")
	age := parseInt(c.Query("age"), 0)
	sex := c.Query("sex")

	references, err := s.terminologyService.GetLabReferences(loinc, age, sex)
	if err != nil {
		s.logger.WithError(err).WithField("loinc", loinc).Error("Failed to get lab references")
		c.JSON(http.StatusNotFound, gin.H{"error": "Lab references not found"})
		return
	}

	c.JSON(http.StatusOK, references)
}

// Enhanced value set operations
func (s *EnhancedServer) expandValueSet(c *gin.Context) {
	url := c.Param("url")
	
	var params models.ExpansionParameters
	if err := c.ShouldBindJSON(&params); err != nil {
		// Fall back to query parameters
		params = models.ExpansionParameters{
			URL:                 url,
			ValueSetVersion:     c.Query("valueSetVersion"),
			Filter:              c.Query("filter"),
			Offset:              parseInt(c.Query("offset"), 0),
			Count:               parseInt(c.Query("count"), 1000),
			IncludeDesignations: c.Query("includeDesignations") == "true",
			ActiveOnly:          c.Query("activeOnly") != "false", // Default true
		}
	}
	params.URL = url

	expansion, err := s.expansionService.ExpandValueSet(params)
	if err != nil {
		s.logger.WithError(err).WithField("url", url).Error("Failed to expand value set")
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Value set expansion failed"})
		return
	}

	c.JSON(http.StatusOK, expansion)
}

func (s *EnhancedServer) validateValueSetCode(c *gin.Context) {
	var request struct {
		URL     string `json:"url" binding:"required"`
		Code    string `json:"code" binding:"required"`
		System  string `json:"system" binding:"required"`
		Display string `json:"display,omitempty"`
		Version string `json:"version,omitempty"`
	}

	if err := c.ShouldBindJSON(&request); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid request", "details": err.Error()})
		return
	}

	result, err := s.validationService.ValidateValueSetCode(
		request.URL, request.Code, request.System, request.Display, request.Version)
	if err != nil {
		s.logger.WithError(err).Error("Value set code validation failed")
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Validation failed"})
		return
	}

	c.JSON(http.StatusOK, result)
}

// Concept mapping and translation
func (s *EnhancedServer) translateConcept(c *gin.Context) {
	var request struct {
		Code         string `json:"code" binding:"required"`
		System       string `json:"system" binding:"required"`
		TargetSystem string `json:"target_system" binding:"required"`
		Version      string `json:"version,omitempty"`
	}

	if err := c.ShouldBindJSON(&request); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid request", "details": err.Error()})
		return
	}

	mappings, err := s.terminologyService.TranslateConcept(
		request.Code, request.System, request.TargetSystem, request.Version)
	if err != nil {
		s.logger.WithError(err).Error("Concept translation failed")
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Translation failed"})
		return
	}

	c.JSON(http.StatusOK, gin.H{"mappings": mappings})
}

// Batch operations with parallel processing
func (s *EnhancedServer) batchLookupConcepts(c *gin.Context) {
	var request models.BatchLookupRequest
	if err := c.ShouldBindJSON(&request); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid batch request", "details": err.Error()})
		return
	}

	// Validate batch size
	if len(request.Requests) > 1000 {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Batch size exceeds maximum of 1000"})
		return
	}

	start := time.Now()
	response, err := s.terminologyService.BatchLookup(request)
	if err != nil {
		s.logger.WithError(err).Error("Batch lookup failed")
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Batch lookup failed"})
		return
	}

	response.Metadata.ProcessingTimeMs = float64(time.Since(start).Nanoseconds()) / 1e6
	c.JSON(http.StatusOK, response)
}

func (s *EnhancedServer) batchValidateCodes(c *gin.Context) {
	var request models.BatchValidationRequest
	if err := c.ShouldBindJSON(&request); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid batch request", "details": err.Error()})
		return
	}

	if len(request.Requests) > 500 {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Batch size exceeds maximum of 500"})
		return
	}

	start := time.Now()
	response, err := s.validationService.BatchValidate(request)
	if err != nil {
		s.logger.WithError(err).Error("Batch validation failed")
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Batch validation failed"})
		return
	}

	response.Metadata.ProcessingTimeMs = float64(time.Since(start).Nanoseconds()) / 1e6
	c.JSON(http.StatusOK, response)
}

