{
  "mappings": {
    "properties": {
      "term_id": {
        "type": "keyword",
        "fields": {
          "text": {
            "type": "text",
            "analyzer": "medical_standard"
          }
        }
      },
      "concept_id": {
        "type": "keyword"
      },
      "term": {
        "type": "text",
        "analyzer": "medical_standard",
        "search_analyzer": "medical_search",
        "fields": {
          "exact": {
            "type": "keyword",
            "normalizer": "medical_normalizer"
          },
          "autocomplete": {
            "type": "text",
            "analyzer": "medical_autocomplete"
          },
          "phonetic": {
            "type": "text",
            "analyzer": "medical_phonetic"
          }
        }
      },
      "preferred_term": {
        "type": "text",
        "analyzer": "medical_standard",
        "search_analyzer": "medical_search",
        "fields": {
          "exact": {
            "type": "keyword",
            "normalizer": "medical_normalizer"
          }
        }
      },
      "synonyms": {
        "type": "text",
        "analyzer": "medical_standard",
        "search_analyzer": "medical_search"
      },
      "definition": {
        "type": "text",
        "analyzer": "medical_standard"
      },
      "terminology_system": {
        "type": "keyword"
      },
      "terminology_version": {
        "type": "keyword"
      },
      "semantic_tags": {
        "type": "keyword"
      },
      "hierarchy_path": {
        "type": "keyword"
      },
      "parent_concepts": {
        "type": "keyword"
      },
      "child_concepts": {
        "type": "keyword"
      },
      "related_concepts": {
        "type": "keyword"
      },
      "status": {
        "type": "keyword"
      },
      "effective_date": {
        "type": "date",
        "format": "yyyy-MM-dd||yyyy-MM-dd'T'HH:mm:ss||yyyy-MM-dd'T'HH:mm:ss.SSS'Z'"
      },
      "expiry_date": {
        "type": "date",
        "format": "yyyy-MM-dd||yyyy-MM-dd'T'HH:mm:ss||yyyy-MM-dd'T'HH:mm:ss.SSS'Z'"
      },
      "clinical_domain": {
        "type": "keyword"
      },
      "complexity_score": {
        "type": "float"
      },
      "usage_frequency": {
        "type": "long"
      },
      "last_updated": {
        "type": "date"
      },
      "search_metadata": {
        "properties": {
          "boost_factor": {
            "type": "float"
          },
          "search_weight": {
            "type": "float"
          },
          "popularity_score": {
            "type": "float"
          }
        }
      },
      "fhir_mappings": {
        "properties": {
          "code": {
            "type": "keyword"
          },
          "system": {
            "type": "keyword"
          },
          "display": {
            "type": "text",
            "analyzer": "medical_standard"
          },
          "version": {
            "type": "keyword"
          }
        }
      }
    }
  },
  "settings": {
    "index": {
      "number_of_shards": 3,
      "number_of_replicas": 1,
      "refresh_interval": "30s",
      "max_result_window": 50000,
      "analysis": {
        "char_filter": {
          "medical_char_filter": {
            "type": "mapping",
            "mappings": [
              "α => alpha",
              "β => beta",
              "γ => gamma",
              "μ => micro",
              "Ω => omega",
              "& => and",
              "w/ => with",
              "w/o => without",
              "± => plus-minus",
              "≤ => less-equal",
              "≥ => greater-equal",
              "°C => celsius",
              "°F => fahrenheit"
            ]
          },
          "medical_html_strip": {
            "type": "html_strip"
          }
        },
        "tokenizer": {
          "medical_tokenizer": {
            "type": "pattern",
            "pattern": "[\\W&&[^'-]]",
            "lowercase": true
          }
        },
        "filter": {
          "medical_stemmer": {
            "type": "stemmer",
            "language": "english"
          },
          "medical_synonyms": {
            "type": "synonym",
            "synonyms": [
              "heart attack,myocardial infarction,MI,cardiac arrest",
              "high blood pressure,hypertension,HTN",
              "diabetes,diabetes mellitus,DM",
              "stroke,cerebrovascular accident,CVA",
              "blood sugar,glucose,blood glucose",
              "cholesterol,lipid,lipids",
              "medication,medicine,drug,pharmaceutical",
              "prescription,Rx,script",
              "milligram,mg",
              "gram,g,gm",
              "kilogram,kg",
              "milliliter,ml,mL",
              "liter,l,L",
              "tablet,tab,pill",
              "capsule,cap",
              "injection,inj,shot",
              "twice daily,bid,b.i.d",
              "three times daily,tid,t.i.d",
              "four times daily,qid,q.i.d",
              "once daily,daily,qd,q.d",
              "as needed,prn,p.r.n",
              "immediately,stat,STAT",
              "before meals,ac,a.c",
              "after meals,pc,p.c",
              "at bedtime,hs,h.s"
            ]
          },
          "medical_stop": {
            "type": "stop",
            "stopwords": [
              "the", "a", "an", "and", "or", "but", "in", "on", "at", "to", "for", "of", "with", "by"
            ]
          },
          "medical_edge_ngram": {
            "type": "edge_ngram",
            "min_gram": 2,
            "max_gram": 15,
            "token_chars": ["letter", "digit"]
          },
          "medical_word_delimiter": {
            "type": "word_delimiter",
            "generate_word_parts": true,
            "generate_number_parts": true,
            "catenate_words": true,
            "catenate_numbers": true,
            "catenate_all": false,
            "split_on_case_change": true,
            "preserve_original": false
          }
        },
        "analyzer": {
          "medical_standard": {
            "char_filter": ["medical_html_strip", "medical_char_filter"],
            "tokenizer": "standard",
            "filter": [
              "lowercase",
              "medical_word_delimiter",
              "medical_synonyms",
              "medical_stop",
              "medical_stemmer"
            ]
          },
          "medical_search": {
            "char_filter": ["medical_html_strip", "medical_char_filter"],
            "tokenizer": "standard",
            "filter": [
              "lowercase",
              "medical_word_delimiter",
              "medical_synonyms",
              "medical_stop"
            ]
          },
          "medical_autocomplete": {
            "char_filter": ["medical_html_strip", "medical_char_filter"],
            "tokenizer": "medical_tokenizer",
            "filter": [
              "lowercase",
              "medical_word_delimiter",
              "medical_edge_ngram"
            ]
          },
          "medical_exact": {
            "char_filter": ["medical_html_strip"],
            "tokenizer": "keyword",
            "filter": ["lowercase"]
          },
          "medical_phonetic": {
            "tokenizer": "standard",
            "filter": [
              "lowercase",
              "phonetic"
            ]
          }
        },
        "normalizer": {
          "medical_normalizer": {
            "char_filter": ["medical_char_filter"],
            "filter": ["lowercase", "asciifolding"]
          }
        }
      }
    }
  }
}