# KB-7 Core Clinical Terminology Ontology
# CardioFit Clinical Synthesis Hub - Authoritative Knowledge Base

@prefix : <http://cardiofit.ai/kb7/ontology#> .
@prefix kb7: <http://cardiofit.ai/kb7/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix pav: <http://purl.org/pav/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# External Medical Ontology Prefixes
@prefix sct: <http://snomed.info/id/> .
@prefix rxnorm: <http://purl.bioontology.org/ontology/RXNORM/> .
@prefix loinc: <http://loinc.org/> .
@prefix icd10: <http://purl.bioontology.org/ontology/ICD10CM/> .
@prefix icd10am: <http://purl.bioontology.org/ontology/ICD10AM/> .
@prefix amt: <http://nehta.gov.au/amt#> .

<http://cardiofit.ai/kb7/ontology> rdf:type owl:Ontology ;
    owl:versionIRI <http://cardiofit.ai/kb7/ontology/1.0.0> ;
    pav:version "1.0.0" ;
    dc:title "KB-7 Clinical Terminology Ontology"@en ;
    dc:description "Authoritative clinical terminology mappings and policy framework for CardioFit Clinical Synthesis Hub"@en ;
    dc:creator "CardioFit Clinical Informatics Team"@en ;
    pav:createdOn "2025-09-19T19:30:00Z"^^xsd:dateTime ;
    pav:lastUpdatedOn "2025-09-19T19:30:00Z"^^xsd:dateTime ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This ontology provides the semantic foundation for clinical terminology management, mapping governance, and policy enforcement in the KB-7 Terminology Service."@en ;
    owl:imports <http://www.w3.org/ns/prov-o> .

#################################################################
#    Annotation properties
#################################################################

### Clinical Policy Annotations

kb7:doNotAutoMap rdf:type owl:AnnotationProperty ;
    rdfs:label "Do Not Auto-Map"@en ;
    rdfs:comment "Policy flag indicating that a mapping for this concept requires manual clinical review and should not be automated."@en ;
    rdfs:domain kb7:ConceptMapping ;
    rdfs:range xsd:boolean .

kb7:requiresClinicalReview rdf:type owl:AnnotationProperty ;
    rdfs:label "Requires Clinical Review"@en ;
    rdfs:comment "Policy flag indicating that changes to this concept or mapping require clinical specialist approval."@en ;
    rdfs:domain [ rdf:type owl:Class ; owl:unionOf ( kb7:ClinicalConcept kb7:ConceptMapping ) ] ;
    rdfs:range xsd:boolean .

kb7:safetyLevel rdf:type owl:AnnotationProperty ;
    rdfs:label "Clinical Safety Level"@en ;
    rdfs:comment "Clinical safety classification: critical, high, medium, low"@en ;
    rdfs:domain kb7:ClinicalConcept ;
    rdfs:range [ rdf:type rdfs:Datatype ; owl:oneOf ( "critical" "high" "medium" "low" ) ] .

kb7:australianOnly rdf:type owl:AnnotationProperty ;
    rdfs:label "Australian Healthcare Only"@en ;
    rdfs:comment "Regional restriction flag for Australian healthcare contexts"@en ;
    rdfs:domain kb7:ClinicalConcept ;
    rdfs:range xsd:boolean .

kb7:regulatoryStatus rdf:type owl:AnnotationProperty ;
    rdfs:label "Regulatory Status"@en ;
    rdfs:comment "TGA/PBS regulatory approval status"@en ;
    rdfs:domain kb7:ClinicalConcept ;
    rdfs:range [ rdf:type rdfs:Datatype ; owl:oneOf ( "approved" "pending" "withdrawn" "experimental" ) ] .

### Mapping Quality Annotations

kb7:mappingConfidence rdf:type owl:AnnotationProperty ;
    rdfs:label "Mapping Confidence"@en ;
    rdfs:comment "Confidence score for concept mapping accuracy (0.0 to 1.0)"@en ;
    rdfs:domain kb7:ConceptMapping ;
    rdfs:range [ rdf:type rdfs:Datatype ; owl:onDatatype xsd:decimal ; owl:minInclusive "0.0"^^xsd:decimal ; owl:maxInclusive "1.0"^^xsd:decimal ] .

kb7:validationStatus rdf:type owl:AnnotationProperty ;
    rdfs:label "Validation Status"@en ;
    rdfs:comment "Clinical validation status of the mapping"@en ;
    rdfs:domain kb7:ConceptMapping ;
    rdfs:range [ rdf:type rdfs:Datatype ; owl:oneOf ( "validated" "pending" "rejected" "deprecated" ) ] .

kb7:evidenceLevel rdf:type owl:AnnotationProperty ;
    rdfs:label "Evidence Level"@en ;
    rdfs:comment "Clinical evidence level supporting the mapping"@en ;
    rdfs:domain kb7:ConceptMapping ;
    rdfs:range [ rdf:type rdfs:Datatype ; owl:oneOf ( "high" "moderate" "low" "expert_opinion" ) ] .

#################################################################
#    Object Properties
#################################################################

### Core Mapping Relations

kb7:mapsTo rdf:type owl:ObjectProperty ;
    rdfs:label "maps to"@en ;
    rdfs:comment "Direct mapping relationship between clinical concepts"@en ;
    rdfs:domain kb7:ClinicalConcept ;
    rdfs:range kb7:ClinicalConcept .

kb7:approximatelyMapsTo rdf:type owl:ObjectProperty ;
    rdfs:label "approximately maps to"@en ;
    rdfs:comment "Approximate mapping relationship with potential information loss"@en ;
    rdfs:subPropertyOf kb7:mapsTo .

kb7:narrowerThan rdf:type owl:ObjectProperty ;
    rdfs:label "narrower than"@en ;
    rdfs:comment "Source concept is more specific than target concept"@en ;
    rdfs:subPropertyOf kb7:mapsTo .

kb7:broaderThan rdf:type owl:ObjectProperty ;
    rdfs:label "broader than"@en ;
    rdfs:comment "Source concept is more general than target concept"@en ;
    rdfs:subPropertyOf kb7:mapsTo .

### Clinical Relationships

kb7:hasInteraction rdf:type owl:ObjectProperty ;
    rdfs:label "has interaction"@en ;
    rdfs:comment "Indicates a clinical drug interaction"@en ;
    rdfs:domain kb7:MedicationConcept ;
    rdfs:range kb7:DrugInteraction .

kb7:contraindicated rdf:type owl:ObjectProperty ;
    rdfs:label "contraindicated"@en ;
    rdfs:comment "Clinical contraindication relationship"@en ;
    rdfs:domain kb7:ClinicalConcept ;
    rdfs:range kb7:ClinicalCondition .

kb7:hasIndication rdf:type owl:ObjectProperty ;
    rdfs:label "has indication"@en ;
    rdfs:comment "Clinical indication for use"@en ;
    rdfs:domain kb7:MedicationConcept ;
    rdfs:range kb7:ClinicalCondition .

### Provenance Relations

kb7:derivedFromMapping rdf:type owl:ObjectProperty ;
    rdfs:label "derived from mapping"@en ;
    rdfs:comment "Links a concept to its source mapping"@en ;
    rdfs:domain kb7:ClinicalConcept ;
    rdfs:range kb7:ConceptMapping .

kb7:reviewedBy rdf:type owl:ObjectProperty ;
    rdfs:label "reviewed by"@en ;
    rdfs:comment "Clinical specialist who reviewed this mapping"@en ;
    rdfs:domain kb7:ConceptMapping ;
    rdfs:range kb7:ClinicalReviewer .

#################################################################
#    Data properties
#################################################################

### Concept Identifiers

kb7:sourceCode rdf:type owl:DatatypeProperty ;
    rdfs:label "source code"@en ;
    rdfs:comment "Original terminology code being mapped from"@en ;
    rdfs:domain kb7:ConceptMapping ;
    rdfs:range xsd:string .

kb7:targetCode rdf:type owl:DatatypeProperty ;
    rdfs:label "target code"@en ;
    rdfs:comment "Target terminology code being mapped to"@en ;
    rdfs:domain kb7:ConceptMapping ;
    rdfs:range xsd:string .

kb7:conceptId rdf:type owl:DatatypeProperty ;
    rdfs:label "concept identifier"@en ;
    rdfs:comment "Unique identifier within terminology system"@en ;
    rdfs:domain kb7:ClinicalConcept ;
    rdfs:range xsd:string .

### Clinical Metadata

kb7:dosageForm rdf:type owl:DatatypeProperty ;
    rdfs:label "dosage form"@en ;
    rdfs:comment "Pharmaceutical dosage form"@en ;
    rdfs:domain kb7:MedicationConcept ;
    rdfs:range xsd:string .

kb7:activeIngredient rdf:type owl:DatatypeProperty ;
    rdfs:label "active ingredient"@en ;
    rdfs:comment "Active pharmaceutical ingredient"@en ;
    rdfs:domain kb7:MedicationConcept ;
    rdfs:range xsd:string .

kb7:severity rdf:type owl:DatatypeProperty ;
    rdfs:label "severity"@en ;
    rdfs:comment "Clinical severity level"@en ;
    rdfs:domain [ rdf:type owl:Class ; owl:unionOf ( kb7:DrugInteraction kb7:ClinicalCondition ) ] ;
    rdfs:range [ rdf:type rdfs:Datatype ; owl:oneOf ( "mild" "moderate" "severe" "critical" ) ] .

### Australian Healthcare Properties

kb7:pbsCode rdf:type owl:DatatypeProperty ;
    rdfs:label "PBS code"@en ;
    rdfs:comment "Pharmaceutical Benefits Scheme code"@en ;
    rdfs:domain kb7:MedicationConcept ;
    rdfs:range xsd:string .

kb7:artgNumber rdf:type owl:DatatypeProperty ;
    rdfs:label "ARTG number"@en ;
    rdfs:comment "Australian Register of Therapeutic Goods number"@en ;
    rdfs:domain kb7:MedicationConcept ;
    rdfs:range xsd:string .

kb7:tgaSchedule rdf:type owl:DatatypeProperty ;
    rdfs:label "TGA schedule"@en ;
    rdfs:comment "Therapeutic Goods Administration scheduling classification"@en ;
    rdfs:domain kb7:MedicationConcept ;
    rdfs:range [ rdf:type rdfs:Datatype ; owl:oneOf ( "S2" "S3" "S4" "S8" "S9" ) ] .

#################################################################
#    Classes
#################################################################

### Core Clinical Concepts

kb7:ClinicalConcept rdf:type owl:Class ;
    rdfs:label "Clinical Concept"@en ;
    rdfs:comment "Abstract base class for all clinical terminology concepts"@en .

kb7:MedicationConcept rdf:type owl:Class ;
    rdfs:label "Medication Concept"@en ;
    rdfs:comment "Clinical concept representing medications, drugs, and pharmaceutical products"@en ;
    rdfs:subClassOf kb7:ClinicalConcept .

kb7:ClinicalCondition rdf:type owl:Class ;
    rdfs:label "Clinical Condition"@en ;
    rdfs:comment "Clinical concept representing diseases, disorders, and medical conditions"@en ;
    rdfs:subClassOf kb7:ClinicalConcept .

kb7:DiagnosticConcept rdf:type owl:Class ;
    rdfs:label "Diagnostic Concept"@en ;
    rdfs:comment "Clinical concept representing diagnostic tests and procedures"@en ;
    rdfs:subClassOf kb7:ClinicalConcept .

kb7:AnatomicalConcept rdf:type owl:Class ;
    rdfs:label "Anatomical Concept"@en ;
    rdfs:comment "Clinical concept representing anatomical structures and body parts"@en ;
    rdfs:subClassOf kb7:ClinicalConcept .

### Mapping Framework

kb7:ConceptMapping rdf:type owl:Class ;
    rdfs:label "Concept Mapping"@en ;
    rdfs:comment "Semantic mapping between concepts from different terminology systems"@en .

kb7:EquivalentMapping rdf:type owl:Class ;
    rdfs:label "Equivalent Mapping"@en ;
    rdfs:comment "Mapping indicating semantic equivalence between concepts"@en ;
    rdfs:subClassOf kb7:ConceptMapping .

kb7:ApproximateMapping rdf:type owl:Class ;
    rdfs:label "Approximate Mapping"@en ;
    rdfs:comment "Mapping with potential information loss or gain"@en ;
    rdfs:subClassOf kb7:ConceptMapping .

kb7:HierarchicalMapping rdf:type owl:Class ;
    rdfs:label "Hierarchical Mapping"@en ;
    rdfs:comment "Mapping between concepts at different levels of specificity"@en ;
    rdfs:subClassOf kb7:ConceptMapping .

### Clinical Safety Framework

kb7:DrugInteraction rdf:type owl:Class ;
    rdfs:label "Drug Interaction"@en ;
    rdfs:comment "Clinical drug-drug interaction with associated severity and mechanism"@en .

kb7:Contraindication rdf:type owl:Class ;
    rdfs:label "Contraindication"@en ;
    rdfs:comment "Clinical contraindication for medication or procedure use"@en .

kb7:ClinicalGuideline rdf:type owl:Class ;
    rdfs:label "Clinical Guideline"@en ;
    rdfs:comment "Evidence-based clinical practice guideline"@en .

### Governance Framework

kb7:ClinicalReviewer rdf:type owl:Class ;
    rdfs:label "Clinical Reviewer"@en ;
    rdfs:comment "Clinical specialist responsible for reviewing terminology changes"@en .

kb7:PolicyRule rdf:type owl:Class ;
    rdfs:label "Policy Rule"@en ;
    rdfs:comment "Clinical governance rule constraining terminology operations"@en .

kb7:AuditRecord rdf:type owl:Class ;
    rdfs:label "Audit Record"@en ;
    rdfs:comment "W3C PROV-O compliant audit record for terminology changes"@en .

### Regional Specializations

kb7:AustralianConcept rdf:type owl:Class ;
    rdfs:label "Australian Healthcare Concept"@en ;
    rdfs:comment "Clinical concept specific to Australian healthcare context"@en ;
    rdfs:subClassOf kb7:ClinicalConcept .

kb7:AMTConcept rdf:type owl:Class ;
    rdfs:label "AMT Concept"@en ;
    rdfs:comment "Australian Medicines Terminology concept"@en ;
    rdfs:subClassOf kb7:AustralianConcept, kb7:MedicationConcept .

kb7:ICD10AMConcept rdf:type owl:Class ;
    rdfs:label "ICD-10-AM Concept"@en ;
    rdfs:comment "ICD-10 Australian Modification concept"@en ;
    rdfs:subClassOf kb7:AustralianConcept, kb7:ClinicalCondition .

#################################################################
#    Individuals
#################################################################

### Example Clinical Reviewers

kb7:DrMargaret_Chen rdf:type owl:NamedIndividual, kb7:ClinicalReviewer ;
    rdfs:label "Dr. Margaret Chen"@en ;
    rdfs:comment "TGA Specialist - Regulatory compliance review"@en ;
    kb7:specialization "TGA Regulatory Compliance"^^xsd:string ;
    kb7:reviewDomain "medication_regulation"^^xsd:string .

kb7:DrJames_Wilson rdf:type owl:NamedIndividual, kb7:ClinicalReviewer ;
    rdfs:label "Dr. James Wilson"@en ;
    rdfs:comment "PBS Specialist - Pharmaceutical economics review"@en ;
    kb7:specialization "PBS Pharmaceutical Economics"^^xsd:string ;
    kb7:reviewDomain "medication_economics"^^xsd:string .

### Example Policy Rules

kb7:MedicationAutoMapPolicy rdf:type owl:NamedIndividual, kb7:PolicyRule ;
    rdfs:label "Medication Auto-Mapping Policy"@en ;
    rdfs:comment "High-risk medications require manual clinical review before auto-mapping"@en ;
    kb7:ruleDescription "IF medication.safetyLevel = 'critical' OR 'high' THEN requiresClinicalReview = true"^^xsd:string ;
    kb7:enforcementLevel "mandatory"^^xsd:string .

#################################################################
#    Example Concept Mappings
#################################################################

### Essential Hypertension Mapping (SNOMED CT to ICD-10)

kb7:mapping_hypertension_sct_icd10 rdf:type kb7:EquivalentMapping ;
    rdfs:label "Essential Hypertension Mapping (SNOMED CT → ICD-10)"@en ;
    kb7:sourceCode "59621000"^^xsd:string ;  # SNOMED CT: Essential hypertension
    kb7:targetCode "I10"^^xsd:string ;       # ICD-10: Essential hypertension
    kb7:mapsTo sct:59621000, icd10:I10 ;
    kb7:mappingConfidence "0.95"^^xsd:decimal ;
    kb7:validationStatus "validated"^^xsd:string ;
    kb7:evidenceLevel "high"^^xsd:string ;
    kb7:doNotAutoMap "false"^^xsd:boolean ;
    kb7:requiresClinicalReview "false"^^xsd:boolean ;
    kb7:safetyLevel "medium"^^xsd:string ;
    pav:createdBy <http://cardiofit.ai/users/clinical-informaticist-001> ;
    pav:createdOn "2025-09-19T19:30:00Z"^^xsd:dateTime ;
    prov:wasDerivedFrom <http://snomed.org/sct/32506021000036107/version/20250731> ;
    rdfs:comment "Well-established mapping for essential hypertension with high clinical confidence"@en .

### High-Risk Medication Mapping (Warfarin)

kb7:mapping_warfarin_rxnorm_amt rdf:type kb7:ApproximateMapping ;
    rdfs:label "Warfarin Mapping (RxNorm → AMT)"@en ;
    kb7:sourceCode "11289"^^xsd:string ;     # RxNorm: Warfarin
    kb7:targetCode "3849011000036100"^^xsd:string ; # AMT: Warfarin
    kb7:mapsTo rxnorm:11289, amt:3849011000036100 ;
    kb7:mappingConfidence "0.88"^^xsd:decimal ;
    kb7:validationStatus "validated"^^xsd:string ;
    kb7:evidenceLevel "high"^^xsd:string ;
    kb7:doNotAutoMap "true"^^xsd:boolean ;   # High-risk medication
    kb7:requiresClinicalReview "true"^^xsd:boolean ;
    kb7:safetyLevel "critical"^^xsd:string ;
    kb7:australianOnly "false"^^xsd:boolean ;
    kb7:regulatoryStatus "approved"^^xsd:string ;
    kb7:tgaSchedule "S4"^^xsd:string ;
    kb7:pbsCode "1234A"^^xsd:string ;
    pav:createdBy <http://cardiofit.ai/users/clinical-pharmacist-002> ;
    pav:createdOn "2025-09-19T19:30:00Z"^^xsd:dateTime ;
    kb7:reviewedBy kb7:DrMargaret_Chen ;
    rdfs:comment "Critical safety medication requiring manual review due to narrow therapeutic index and interaction risks"@en .

#################################################################
#    Validation Rules (SHACL-style constraints as comments)
#################################################################

# Every ConceptMapping MUST have:
# - kb7:sourceCode (exactly 1)
# - kb7:targetCode (exactly 1)
# - kb7:mappingConfidence (exactly 1, between 0.0 and 1.0)
# - pav:createdBy (exactly 1)
# - pav:createdOn (exactly 1)

# Every ClinicalConcept with safetyLevel "critical" or "high" MUST have:
# - kb7:requiresClinicalReview = true

# Every MedicationConcept with kb7:australianOnly = true MUST have:
# - kb7:tgaSchedule (exactly 1)
# - kb7:regulatoryStatus (exactly 1)