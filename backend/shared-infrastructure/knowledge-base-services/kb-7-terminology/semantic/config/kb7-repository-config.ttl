# KB-7 Terminology Repository Configuration for OntoNext GraphDB
@prefix rep: <http://www.openrdf.org/config/repository#> .
@prefix sr: <http://www.openrdf.org/config/repository/sail#> .
@prefix sail: <http://www.openrdf.org/config/sail#> .
@prefix owlim: <http://www.ontotext.com/trree/owlim#> .
@prefix kb7: <http://cardiofit.ai/kb7/config#> .

[] a rep:Repository ;
   rep:repositoryID "kb7-terminology" ;
   rdfs:label "KB-7 Clinical Terminology Repository" ;
   rep:repositoryImpl [
      rep:repositoryType "graphdb:SailRepository" ;
      sr:sailImpl [
         sail:sailType "graphdb:Sail" ;

         # Repository Configuration
         owlim:repository-type "file-repository" ;
         owlim:entity-index-size "10000000" ;
         owlim:entity-id-size "32" ;
         owlim:imports "./ontologies" ;
         owlim:defaultNS "" ;

         # Performance Settings
         owlim:cache-memory "2g" ;
         owlim:tuple-index-memory "1g" ;
         owlim:fts-memory "512m" ;
         owlim:fts-index-policy "never" ; # Disable for clinical data

         # Clinical Safety Settings
         owlim:check-for-inconsistencies "true" ;
         owlim:disable-same-as "false" ;
         owlim:enable-context-index "true" ;
         owlim:enable-predicate-list "true" ;

         # OWL 2 RL Reasoning for Clinical Ontologies
         owlim:ruleset "owl2-rl-optimized" ;
         owlim:partial-rdfs "true" ;
         owlim:enable-literal-index "true" ;

         # Transaction Settings
         owlim:transaction-mode "safe" ;
         owlim:transaction-isolation "true" ;
         owlim:query-timeout "0" ;
         owlim:query-limit-results "0" ;

         # Clinical Terminology Specific Settings
         owlim:base-URL "http://cardiofit.ai/kb7/" ;
         owlim:read-only "false" ;
         owlim:nonInterpretablePredicates "http://cardiofit.ai/kb7/policy#doNotAutoMap,http://cardiofit.ai/kb7/policy#requiresClinicalReview" ;

         # Namespace Declarations for Clinical Standards
         owlim:namespace [
            owlim:namespace-prefix "kb7" ;
            owlim:namespace-name "http://cardiofit.ai/kb7/ontology#"
         ] ;
         owlim:namespace [
            owlim:namespace-prefix "sct" ;
            owlim:namespace-name "http://snomed.info/id/"
         ] ;
         owlim:namespace [
            owlim:namespace-prefix "rxnorm" ;
            owlim:namespace-name "http://purl.bioontology.org/ontology/RXNORM/"
         ] ;
         owlim:namespace [
            owlim:namespace-prefix "loinc" ;
            owlim:namespace-name "http://loinc.org/"
         ] ;
         owlim:namespace [
            owlim:namespace-prefix "icd10" ;
            owlim:namespace-name "http://purl.bioontology.org/ontology/ICD10CM/"
         ] ;
         owlim:namespace [
            owlim:namespace-prefix "amt" ;
            owlim:namespace-name "http://nehta.gov.au/amt#"
         ] ;
         owlim:namespace [
            owlim:namespace-prefix "prov" ;
            owlim:namespace-name "http://www.w3.org/ns/prov#"
         ] ;
         owlim:namespace [
            owlim:namespace-prefix "pav" ;
            owlim:namespace-name "http://purl.org/pav/"
         ] ;

         # Context Settings for Versioning
         owlim:enable-context-index "true" ;
         owlim:context-index-policy "default" ;
      ]
   ] .