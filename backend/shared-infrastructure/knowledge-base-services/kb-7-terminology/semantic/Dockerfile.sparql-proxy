FROM golang:1.21-alpine AS builder

WORKDIR /app
COPY semantic/sparql-proxy/ .
RUN go mod download
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o sparql-proxy .

FROM alpine:3.18
RUN apk --no-cache add ca-certificates curl
WORKDIR /root/

COPY --from=builder /app/sparql-proxy .

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD curl -f http://localhost:8095/health || exit 1

EXPOSE 8095
CMD ["./sparql-proxy"]