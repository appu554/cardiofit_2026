# KB-7 Terminology Service Configuration Example
# Copy this file to .env and modify the values for your environment

# =============================================================================
# Server Configuration
# =============================================================================
PORT=8087
ENVIRONMENT=development
VERSION=1.0.0
LOG_LEVEL=info

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL connection string
DATABASE_URL=postgresql://kb_user:kb_password@localhost:5433/clinical_governance

# Path to database migration files
MIGRATIONS_PATH=./migrations

# =============================================================================
# Cache Configuration  
# =============================================================================
# Redis connection string
REDIS_URL=redis://localhost:6380/7

# =============================================================================
# Terminology Configuration
# =============================================================================
# Supported regions for terminology systems
SUPPORTED_REGIONS=US,EU,CA,AU

# Primary terminology database name
TERMINOLOGY_DB=clinical_governance

# =============================================================================
# GraphQL Configuration
# =============================================================================
# GraphQL endpoint path
GRAPHQL_ENDPOINT=/graphql

# Enable GraphQL introspection (disable in production)
GRAPHQL_INTROSPECT=true

# Enable GraphQL Playground (disable in production)
GRAPHQL_PLAYGROUND=true

# =============================================================================
# Federation Configuration
# =============================================================================
# Enable Apollo Federation support
FEDERATION_ENABLED=true

# Apollo Gateway URL for federation
GATEWAY_URL=http://localhost:4000/graphql

# =============================================================================
# Monitoring Configuration
# =============================================================================
# Enable Prometheus metrics endpoint
METRICS_ENABLED=true

# Health check endpoint path
HEALTH_ENDPOINT=/health

# =============================================================================
# Evidence Envelope Configuration
# =============================================================================
# Enable evidence envelope features
EVIDENCE_ENVELOPE_ENABLED=true

# Evidence envelope database
EVIDENCE_ENVELOPE_DB=clinical_governance

# =============================================================================
# ETL Configuration
# =============================================================================
# Default ETL batch size
ETL_BATCH_SIZE=10000

# Number of ETL worker processes
ETL_WORKERS=4

# Enable ETL debug logging
ETL_DEBUG=false

# Data directory for terminology files
DATA_DIR=./data

# =============================================================================
# Security Configuration (Production)
# =============================================================================
# JWT secret for authentication (use a strong 256-bit key in production)
# JWT_SECRET=your-256-bit-secret-key-here

# API rate limiting (requests per minute)
# API_RATE_LIMIT=1000

# CORS allowed origins (comma-separated)
# CORS_ORIGINS=https://your-frontend-domain.com

# Enable HTTPS
# ENABLE_HTTPS=false

# TLS certificate path
# TLS_CERT_PATH=/etc/ssl/certs/kb7.crt

# TLS private key path
# TLS_KEY_PATH=/etc/ssl/private/kb7.key

# =============================================================================
# Performance Tuning
# =============================================================================
# Database connection pool settings
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# Cache TTL settings (in seconds)
CACHE_CONCEPT_TTL=3600
CACHE_SEARCH_TTL=1800
CACHE_VALIDATION_TTL=3600

# Request timeout (in seconds)
REQUEST_TIMEOUT=30

# =============================================================================
# GraphDB Configuration (Semantic Layer)
# =============================================================================
# GraphDB connection URL
GRAPHDB_URL=http://localhost:7200

# GraphDB repository name
GRAPHDB_REPOSITORY=kb7-terminology

# GraphDB credentials (leave empty for unauthenticated access)
GRAPHDB_USERNAME=
GRAPHDB_PASSWORD=

# Enable GraphDB semantic layer
GRAPHDB_ENABLED=true

# =============================================================================
# Neo4j Configuration (Single-Region Mode - Legacy)
# =============================================================================
# Neo4j bolt connection URL
NEO4J_URL=bolt://localhost:7687

# Neo4j authentication credentials
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# Neo4j database name
NEO4J_DATABASE=kb7

# Enable Neo4j for hierarchy traversals
NEO4J_ENABLED=false

# =============================================================================
# Neo4j Multi-Region Configuration (Phase 7 - Regional Kernels)
# =============================================================================
# Enable multi-region mode for separate Neo4j databases per region
# When enabled, requests with X-Region header are routed to regional databases
NEO4J_MULTI_REGION_ENABLED=false

# Default region when X-Region header is not provided
# Valid values: au, in, us
NEO4J_DEFAULT_REGION=us

# -----------------------------------------------------------------------------
# Australia (AU) Regional Neo4j Configuration
# Terminology: AMT (Australian Medicines Terminology), SNOMED CT-AU
# Module ID: 900062011000036103
# -----------------------------------------------------------------------------
NEO4J_AU_URL=bolt://neo4j-au.example.com:7687
NEO4J_AU_USERNAME=neo4j
NEO4J_AU_PASSWORD=
NEO4J_AU_DATABASE=kb7-au
NEO4J_AU_ENABLED=true

# -----------------------------------------------------------------------------
# India (IN) Regional Neo4j Configuration
# Terminology: CDCI (Central Drug Standard Control Index), SNOMED CT
# -----------------------------------------------------------------------------
NEO4J_IN_URL=bolt://neo4j-in.example.com:7687
NEO4J_IN_USERNAME=neo4j
NEO4J_IN_PASSWORD=
NEO4J_IN_DATABASE=kb7-in
NEO4J_IN_ENABLED=true

# -----------------------------------------------------------------------------
# United States (US) Regional Neo4j Configuration
# Terminology: RxNorm, SNOMED CT-US, LOINC, ICD-10-CM
# Module ID: 731000124108
# -----------------------------------------------------------------------------
NEO4J_US_URL=bolt://neo4j-us.example.com:7687
NEO4J_US_USERNAME=neo4j
NEO4J_US_PASSWORD=
NEO4J_US_DATABASE=kb7-us
NEO4J_US_ENABLED=true

# =============================================================================
# Kafka CDC Configuration (Phase 6.2 - Change Data Capture)
# =============================================================================
# Kafka broker addresses
KAFKA_BROKERS=localhost:9092

# Kafka topic for CDC events
KAFKA_CDC_TOPIC=kb7.graphdb.changes

# Kafka consumer group ID
KAFKA_GROUP_ID=kb7-neo4j-sync

# Enable Kafka CDC for real-time Neo4j synchronization
KAFKA_CDC_ENABLE=false

# =============================================================================
# Rule Manager Configuration
# =============================================================================
# Seed 18 FHIR R4 builtin value sets on startup (run once)
SEED_BUILTIN_VALUE_SETS=false