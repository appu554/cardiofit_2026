# KB-7 Sample Clinical Medications Data
# Comprehensive medication concepts with external terminology mappings

@prefix : <http://cardiofit.ai/kb7/ontology#> .
@prefix kb7: <http://cardiofit.ai/kb7/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sct: <http://snomed.info/id/> .
@prefix rxnorm: <http://purl.bioontology.org/ontology/RXNORM/> .
@prefix loinc: <http://loinc.org/> .
@prefix amt: <http://nehta.gov.au/amt#> .

#################################################################
#    Sample Medication Concepts
#################################################################

### Aspirin - Cardiovascular Protection
kb7:aspirin-81mg a kb7:MedicationConcept ;
    rdfs:label "Aspirin 81mg Low-Dose"@en ;
    rdfs:comment "Low-dose aspirin for cardiovascular protection"@en ;
    kb7:mapsTo sct:387458008 ;        # SNOMED CT: Aspirin
    kb7:mapsTo rxnorm:243670 ;        # RxNorm: Aspirin 81 MG Oral Tablet
    kb7:mapsTo amt:25503011000036104 ; # AMT: aspirin 100 mg tablet
    kb7:safetyLevel "low-risk"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:regulatoryStatus "approved"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:evidenceLevel "high"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:australianOnly false ;
    kb7:requiresClinicalReview false ;
    kb7:mappingConfidence "0.95"^^<http://www.w3.org/2001/XMLSchema#float> ;
    kb7:validationStatus "validated"^^<http://www.w3.org/2001/XMLSchema#string> .

### Warfarin - Anticoagulation
kb7:warfarin-5mg a kb7:MedicationConcept ;
    rdfs:label "Warfarin 5mg Tablet"@en ;
    rdfs:comment "Oral anticoagulant for thromboembolism prevention"@en ;
    kb7:mapsTo sct:48603004 ;         # SNOMED CT: Warfarin
    kb7:mapsTo rxnorm:855332 ;        # RxNorm: Warfarin Sodium 5 MG Oral Tablet
    kb7:mapsTo amt:31087011000036107 ; # AMT: warfarin sodium 5 mg tablet
    kb7:safetyLevel "high-risk"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:regulatoryStatus "approved"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:evidenceLevel "high"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:australianOnly false ;
    kb7:requiresClinicalReview true ;
    kb7:mappingConfidence "0.98"^^<http://www.w3.org/2001/XMLSchema#float> ;
    kb7:validationStatus "validated"^^<http://www.w3.org/2001/XMLSchema#string> .

### Metformin - Diabetes Management
kb7:metformin-500mg a kb7:MedicationConcept ;
    rdfs:label "Metformin 500mg Tablet"@en ;
    rdfs:comment "First-line treatment for type 2 diabetes"@en ;
    kb7:mapsTo sct:109081006 ;        # SNOMED CT: Metformin
    kb7:mapsTo rxnorm:860975 ;        # RxNorm: Metformin hydrochloride 500 MG Oral Tablet
    kb7:mapsTo amt:31100011000036101 ; # AMT: metformin hydrochloride 500 mg tablet
    kb7:safetyLevel "moderate-risk"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:regulatoryStatus "approved"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:evidenceLevel "high"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:australianOnly false ;
    kb7:requiresClinicalReview false ;
    kb7:mappingConfidence "0.97"^^<http://www.w3.org/2001/XMLSchema#float> ;
    kb7:validationStatus "validated"^^<http://www.w3.org/2001/XMLSchema#string> .

### Atorvastatin - Cholesterol Management
kb7:atorvastatin-20mg a kb7:MedicationConcept ;
    rdfs:label "Atorvastatin 20mg Tablet"@en ;
    rdfs:comment "HMG-CoA reductase inhibitor for hypercholesterolemia"@en ;
    kb7:mapsTo sct:83367003 ;         # SNOMED CT: Atorvastatin
    kb7:mapsTo rxnorm:617312 ;        # RxNorm: Atorvastatin 20 MG Oral Tablet
    kb7:mapsTo amt:31095011000036108 ; # AMT: atorvastatin 20 mg tablet
    kb7:safetyLevel "moderate-risk"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:regulatoryStatus "approved"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:evidenceLevel "high"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:australianOnly false ;
    kb7:requiresClinicalReview false ;
    kb7:mappingConfidence "0.96"^^<http://www.w3.org/2001/XMLSchema#float> ;
    kb7:validationStatus "validated"^^<http://www.w3.org/2001/XMLSchema#string> .

### Lisinopril - ACE Inhibitor
kb7:lisinopril-10mg a kb7:MedicationConcept ;
    rdfs:label "Lisinopril 10mg Tablet"@en ;
    rdfs:comment "ACE inhibitor for hypertension and heart failure"@en ;
    kb7:mapsTo sct:29046004 ;         # SNOMED CT: Lisinopril
    kb7:mapsTo rxnorm:314076 ;        # RxNorm: Lisinopril 10 MG Oral Tablet
    kb7:mapsTo amt:31112011000036102 ; # AMT: lisinopril 10 mg tablet
    kb7:safetyLevel "moderate-risk"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:regulatoryStatus "approved"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:evidenceLevel "high"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:australianOnly false ;
    kb7:requiresClinicalReview false ;
    kb7:mappingConfidence "0.95"^^<http://www.w3.org/2001/XMLSchema#float> ;
    kb7:validationStatus "validated"^^<http://www.w3.org/2001/XMLSchema#string> .

#################################################################
#    Clinical Conditions
#################################################################

### Hypertension
kb7:hypertension a kb7:ClinicalCondition ;
    rdfs:label "Essential Hypertension"@en ;
    rdfs:comment "High blood pressure requiring pharmacological management"@en ;
    kb7:mapsTo sct:59621000 ;         # SNOMED CT: Essential hypertension
    kb7:evidenceLevel "high"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:requiresClinicalReview false ;
    kb7:validationStatus "validated"^^<http://www.w3.org/2001/XMLSchema#string> .

### Type 2 Diabetes
kb7:type2-diabetes a kb7:ClinicalCondition ;
    rdfs:label "Type 2 Diabetes Mellitus"@en ;
    rdfs:comment "Non-insulin dependent diabetes mellitus"@en ;
    kb7:mapsTo sct:44054006 ;         # SNOMED CT: Type 2 diabetes mellitus
    kb7:evidenceLevel "high"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:requiresClinicalReview false ;
    kb7:validationStatus "validated"^^<http://www.w3.org/2001/XMLSchema#string> .

### Atrial Fibrillation
kb7:atrial-fibrillation a kb7:ClinicalCondition ;
    rdfs:label "Atrial Fibrillation"@en ;
    rdfs:comment "Irregular heart rhythm requiring anticoagulation"@en ;
    kb7:mapsTo sct:49436004 ;         # SNOMED CT: Atrial fibrillation
    kb7:evidenceLevel "high"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:requiresClinicalReview true ;
    kb7:validationStatus "validated"^^<http://www.w3.org/2001/XMLSchema#string> .

#################################################################
#    Drug Interactions
#################################################################

### Aspirin + Warfarin = Bleeding Risk
kb7:aspirin-warfarin-interaction a kb7:DrugInteraction ;
    rdfs:label "Aspirin-Warfarin Bleeding Risk"@en ;
    rdfs:comment "Concurrent use increases risk of major bleeding events"@en ;
    kb7:involves kb7:aspirin-81mg ;
    kb7:involves kb7:warfarin-5mg ;
    kb7:safetyLevel "high-risk"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:requiresClinicalReview true ;
    kb7:evidenceLevel "high"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:validationStatus "validated"^^<http://www.w3.org/2001/XMLSchema#string> .

### ACE Inhibitor + Metformin = Kidney Function Monitoring
kb7:ace-metformin-interaction a kb7:DrugInteraction ;
    rdfs:label "ACE Inhibitor-Metformin Kidney Monitoring"@en ;
    rdfs:comment "Requires enhanced kidney function monitoring"@en ;
    kb7:involves kb7:lisinopril-10mg ;
    kb7:involves kb7:metformin-500mg ;
    kb7:safetyLevel "moderate-risk"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:requiresClinicalReview true ;
    kb7:evidenceLevel "moderate"^^<http://www.w3.org/2001/XMLSchema#string> ;
    kb7:validationStatus "validated"^^<http://www.w3.org/2001/XMLSchema#string> .

