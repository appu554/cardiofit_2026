{
  "dashboard": {
    "id": null,
    "uid": "kb7-terminology",
    "title": "KB-7 Terminology Service Dashboard",
    "tags": ["kb7", "terminology", "graphdb", "knowledge-base"],
    "timezone": "browser",
    "schemaVersion": 27,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h"],
      "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
    },
    "panels": [
      {
        "id": 1,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "type": "graph",
        "title": "GraphDB Triple Count Over Time",
        "description": "Total RDF triples in kb7-terminology repository",
        "targets": [
          {
            "expr": "kb7_graphdb_triple_count{repository=\"kb7-terminology\"}",
            "legendFormat": "Total Triples",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "label": "Triple Count",
            "format": "short",
            "min": 0
          },
          {
            "label": "",
            "format": "short"
          }
        ],
        "xaxis": {
          "mode": "time",
          "show": true
        },
        "lines": true,
        "fill": 1,
        "linewidth": 2,
        "points": false,
        "bars": false,
        "stack": false,
        "legend": {
          "show": true,
          "values": true,
          "current": true,
          "max": true,
          "min": false
        },
        "nullPointMode": "null",
        "tooltip": {
          "shared": true,
          "sort": 0,
          "value_type": "individual"
        }
      },
      {
        "id": 2,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "type": "graph",
        "title": "Concept Count by Terminology",
        "description": "Breakdown of concepts: SNOMED-CT, RxNorm, LOINC",
        "targets": [
          {
            "expr": "kb7_concept_count{terminology=\"SNOMED\"}",
            "legendFormat": "SNOMED-CT Concepts",
            "refId": "A"
          },
          {
            "expr": "kb7_concept_count{terminology=\"RxNorm\"}",
            "legendFormat": "RxNorm Drugs",
            "refId": "B"
          },
          {
            "expr": "kb7_concept_count{terminology=\"LOINC\"}",
            "legendFormat": "LOINC Codes",
            "refId": "C"
          }
        ],
        "yaxes": [
          {
            "label": "Concept Count",
            "format": "short",
            "min": 0
          },
          {
            "label": "",
            "format": "short"
          }
        ],
        "xaxis": {
          "mode": "time",
          "show": true
        },
        "lines": true,
        "fill": 2,
        "linewidth": 2,
        "points": false,
        "stack": true,
        "legend": {
          "show": true,
          "values": true,
          "current": true
        }
      },
      {
        "id": 3,
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
        "type": "graph",
        "title": "Query Latency (p50, p95, p99)",
        "description": "SPARQL query latency percentiles",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(kb7_query_latency_seconds_bucket[5m]))",
            "legendFormat": "p50 Latency",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(kb7_query_latency_seconds_bucket[5m]))",
            "legendFormat": "p95 Latency",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(kb7_query_latency_seconds_bucket[5m]))",
            "legendFormat": "p99 Latency",
            "refId": "C"
          }
        ],
        "yaxes": [
          {
            "label": "Latency",
            "format": "s",
            "min": 0,
            "max": null
          },
          {
            "label": "",
            "format": "short"
          }
        ],
        "xaxis": {
          "mode": "time",
          "show": true
        },
        "lines": true,
        "fill": 0,
        "linewidth": 2,
        "points": false,
        "legend": {
          "show": true,
          "values": true,
          "current": true,
          "avg": true
        },
        "alert": {
          "conditions": [
            {
              "evaluator": {
                "params": [0.1],
                "type": "gt"
              },
              "operator": {
                "type": "and"
              },
              "query": {
                "params": ["B", "5m", "now"]
              },
              "reducer": {
                "params": [],
                "type": "avg"
              },
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "for": "5m",
          "frequency": "1m",
          "handler": 1,
          "message": "KB-7 p95 query latency exceeds 100ms",
          "name": "High Query Latency"
        }
      },
      {
        "id": 4,
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
        "type": "singlestat",
        "title": "SPARQL Endpoint Health",
        "description": "GraphDB endpoint availability",
        "targets": [
          {
            "expr": "up{job=\"kb7-graphdb\"}",
            "refId": "A"
          }
        ],
        "format": "none",
        "valueName": "current",
        "valueFontSize": "80%",
        "thresholds": "0.5,1",
        "colors": ["#d44a3a", "#e0b400", "#299c46"],
        "colorBackground": true,
        "valueMaps": [
          {
            "value": "1",
            "text": "UP"
          },
          {
            "value": "0",
            "text": "DOWN"
          }
        ],
        "sparkline": {
          "show": true,
          "lineColor": "rgb(31, 120, 193)",
          "fillColor": "rgba(31, 118, 189, 0.18)"
        }
      },
      {
        "id": 5,
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
        "type": "graph",
        "title": "Cache Hit Ratio",
        "description": "Redis cache hit vs miss rate",
        "targets": [
          {
            "expr": "rate(kb7_cache_hits_total[5m]) / (rate(kb7_cache_hits_total[5m]) + rate(kb7_cache_misses_total[5m])) * 100",
            "legendFormat": "Hit Ratio %",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "label": "Hit Ratio (%)",
            "format": "percent",
            "min": 0,
            "max": 100
          },
          {
            "label": "",
            "format": "short"
          }
        ],
        "xaxis": {
          "mode": "time",
          "show": true
        },
        "lines": true,
        "fill": 2,
        "linewidth": 2,
        "points": false,
        "legend": {
          "show": true,
          "values": true,
          "current": true,
          "avg": true
        },
        "thresholds": [
          {
            "value": 90,
            "colorMode": "critical",
            "op": "lt",
            "fill": true,
            "line": true
          }
        ]
      },
      {
        "id": 6,
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 16},
        "type": "table",
        "title": "Kernel Deployment Timeline",
        "description": "Recent kernel deployments and rollbacks",
        "targets": [
          {
            "expr": "kb7_deployment_timestamp",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "transform": "table",
        "columns": [
          {
            "text": "Version",
            "value": "version"
          },
          {
            "text": "Event Type",
            "value": "event_type"
          },
          {
            "text": "Timestamp",
            "value": "timestamp"
          },
          {
            "text": "Concept Count",
            "value": "concept_count"
          },
          {
            "text": "Duration (s)",
            "value": "duration_seconds"
          },
          {
            "text": "Status",
            "value": "status"
          }
        ],
        "sort": {
          "col": 2,
          "desc": true
        },
        "styles": [
          {
            "pattern": "Status",
            "type": "string",
            "mappings": [
              {
                "text": "Success",
                "value": "success"
              },
              {
                "text": "Failed",
                "value": "failure"
              }
            ],
            "thresholds": [],
            "colorMode": "cell",
            "colors": ["#299c46", "#e0b400", "#d44a3a"]
          },
          {
            "pattern": "Timestamp",
            "type": "date",
            "dateFormat": "YYYY-MM-DD HH:mm:ss"
          },
          {
            "pattern": "Concept Count",
            "type": "number",
            "decimals": 0,
            "unit": "short"
          }
        ]
      },
      {
        "id": 7,
        "gridPos": {"h": 6, "w": 6, "x": 0, "y": 26},
        "type": "singlestat",
        "title": "GraphDB Repository Size",
        "description": "Current repository disk usage",
        "targets": [
          {
            "expr": "kb7_graphdb_repository_size_bytes{repository=\"kb7-terminology\"}",
            "refId": "A"
          }
        ],
        "format": "bytes",
        "valueName": "current",
        "valueFontSize": "80%",
        "colorBackground": false,
        "colorValue": false,
        "thresholds": "",
        "sparkline": {
          "show": true,
          "lineColor": "rgb(31, 120, 193)",
          "fillColor": "rgba(31, 118, 189, 0.18)"
        }
      },
      {
        "id": 8,
        "gridPos": {"h": 6, "w": 6, "x": 6, "y": 26},
        "type": "singlestat",
        "title": "Query Error Rate",
        "description": "Failed queries per second",
        "targets": [
          {
            "expr": "rate(kb7_query_errors_total[5m])",
            "refId": "A"
          }
        ],
        "format": "ops",
        "valueName": "current",
        "valueFontSize": "80%",
        "thresholds": "0.1,1",
        "colors": ["#299c46", "#e0b400", "#d44a3a"],
        "colorBackground": true,
        "sparkline": {
          "show": true,
          "lineColor": "rgb(212, 74, 58)",
          "fillColor": "rgba(212, 74, 58, 0.18)"
        }
      },
      {
        "id": 9,
        "gridPos": {"h": 6, "w": 6, "x": 12, "y": 26},
        "type": "singlestat",
        "title": "Active Snapshot Version",
        "description": "Currently deployed kernel version",
        "targets": [
          {
            "expr": "kb7_active_snapshot_version",
            "refId": "A"
          }
        ],
        "format": "none",
        "valueName": "name",
        "valueFontSize": "100%",
        "colorBackground": false,
        "colorValue": false,
        "mappingType": 1,
        "valueMaps": []
      },
      {
        "id": 10,
        "gridPos": {"h": 6, "w": 6, "x": 18, "y": 26},
        "type": "singlestat",
        "title": "Deployment Success Rate",
        "description": "Successful deployments in last 30 days",
        "targets": [
          {
            "expr": "sum(kb7_deployment_success_total{period=\"30d\"}) / sum(kb7_deployment_total{period=\"30d\"}) * 100",
            "refId": "A"
          }
        ],
        "format": "percent",
        "valueName": "current",
        "valueFontSize": "80%",
        "decimals": 1,
        "thresholds": "90,95",
        "colors": ["#d44a3a", "#e0b400", "#299c46"],
        "colorBackground": true,
        "sparkline": {
          "show": false
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "environment",
          "type": "query",
          "query": "label_values(kb7_graphdb_triple_count, environment)",
          "current": {
            "text": "production",
            "value": "production"
          },
          "options": [],
          "refresh": 1,
          "includeAll": false,
          "multi": false
        },
        {
          "name": "repository",
          "type": "query",
          "query": "label_values(kb7_graphdb_triple_count{environment=\"$environment\"}, repository)",
          "current": {
            "text": "kb7-terminology",
            "value": "kb7-terminology"
          },
          "options": [],
          "refresh": 1,
          "includeAll": false,
          "multi": false
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Deployments",
          "datasource": "Prometheus",
          "expr": "changes(kb7_deployment_timestamp[1m]) > 0",
          "tagKeys": "version,event_type",
          "textFormat": "{{event_type}}: {{version}}",
          "iconColor": "rgba(0, 211, 255, 1)",
          "enable": true
        }
      ]
    }
  }
}
