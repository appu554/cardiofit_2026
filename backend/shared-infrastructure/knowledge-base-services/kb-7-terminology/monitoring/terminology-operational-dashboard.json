{
  "dashboard": {
    "id": null,
    "title": "KB-7 Terminology Service - Operational Dashboard",
    "tags": ["kb-services", "terminology", "operational"],
    "timezone": "browser",
    "refresh": "30s",
    "schemaVersion": 16,
    "version": 1,
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {},
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    },
    "panels": [
      {
        "id": 1,
        "title": "Service Health Status",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"kb-7-terminology\"}",
            "legendFormat": "Service Status",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "options": {
                  "0": {
                    "text": "DOWN",
                    "color": "red"
                  },
                  "1": {
                    "text": "UP",
                    "color": "green"
                  }
                },
                "type": "value"
              }
            ],
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "green",
                  "value": 1
                }
              ]
            },
            "unit": "short"
          }
        },
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Request Rate (req/sec)",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(terminology_lookups_total[5m])",
            "legendFormat": "Lookup Rate",
            "refId": "A"
          },
          {
            "expr": "rate(search_queries_total[5m])",
            "legendFormat": "Search Rate",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "min": 0
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Response Time P95 (ms)",
        "type": "stat",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"kb-7-terminology\"}[5m])) * 1000",
            "legendFormat": "P95 Latency",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "min": 0,
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 15
                },
                {
                  "color": "red",
                  "value": 25
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 4,
        "title": "Cache Hit Rate (%)",
        "type": "stat",
        "targets": [
          {
            "expr": "terminology_cache_hit_rate{cache_level=\"L1\"} * 100",
            "legendFormat": "L1 Cache",
            "refId": "A"
          },
          {
            "expr": "terminology_cache_hit_rate{cache_level=\"L2\"} * 100",
            "legendFormat": "L2 Cache",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 85
                },
                {
                  "color": "green",
                  "value": 95
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 18,
          "y": 0
        }
      },
      {
        "id": 5,
        "title": "Request Volume Over Time",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(terminology_lookups_total[1m])",
            "legendFormat": "Lookups/sec",
            "refId": "A"
          },
          {
            "expr": "rate(search_queries_total[1m])",
            "legendFormat": "Searches/sec",
            "refId": "B"
          },
          {
            "expr": "rate(code_validation_total[1m])",
            "legendFormat": "Validations/sec",
            "refId": "C"
          }
        ],
        "yAxes": [
          {
            "label": "Requests per second",
            "min": 0
          },
          {
            "show": false
          }
        ],
        "lines": true,
        "fill": 1,
        "linewidth": 2,
        "pointradius": 2,
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 4
        }
      },
      {
        "id": 6,
        "title": "Response Time Percentiles",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"kb-7-terminology\"}[5m])) * 1000",
            "legendFormat": "P50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"kb-7-terminology\"}[5m])) * 1000",
            "legendFormat": "P95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"kb-7-terminology\"}[5m])) * 1000",
            "legendFormat": "P99",
            "refId": "C"
          }
        ],
        "yAxes": [
          {
            "label": "Response time (ms)",
            "min": 0
          },
          {
            "show": false
          }
        ],
        "lines": true,
        "fill": 0,
        "linewidth": 2,
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 4
        }
      },
      {
        "id": 7,
        "title": "Error Rate by Endpoint",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"kb-7-terminology\",status=~\"4..|5..\"}[5m]) / rate(http_requests_total{job=\"kb-7-terminology\"}[5m]) * 100",
            "legendFormat": "{{method}} {{endpoint}}",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "Error rate (%)",
            "min": 0
          },
          {
            "show": false
          }
        ],
        "lines": true,
        "fill": 1,
        "linewidth": 2,
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 12
        }
      },
      {
        "id": 8,
        "title": "Terminology Accuracy",
        "type": "stat",
        "targets": [
          {
            "expr": "code_validation_accuracy{code_system=\"snomed\"} * 100",
            "legendFormat": "SNOMED CT",
            "refId": "A"
          },
          {
            "expr": "code_validation_accuracy{code_system=\"icd10\"} * 100",
            "legendFormat": "ICD-10",
            "refId": "B"
          },
          {
            "expr": "code_validation_accuracy{code_system=\"rxnorm\"} * 100",
            "legendFormat": "RxNorm",
            "refId": "C"
          },
          {
            "expr": "code_validation_accuracy{code_system=\"loinc\"} * 100",
            "legendFormat": "LOINC",
            "refId": "D"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 95,
            "max": 100,
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 99
                },
                {
                  "color": "green",
                  "value": 99.9
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 12
        }
      },
      {
        "id": 9,
        "title": "Database Connection Pool",
        "type": "graph",
        "targets": [
          {
            "expr": "db_connections_active{service=\"kb-7-terminology\"}",
            "legendFormat": "Active Connections",
            "refId": "A"
          },
          {
            "expr": "db_connections_idle{service=\"kb-7-terminology\"}",
            "legendFormat": "Idle Connections",
            "refId": "B"
          },
          {
            "expr": "db_connections_max{service=\"kb-7-terminology\"}",
            "legendFormat": "Max Connections",
            "refId": "C"
          }
        ],
        "yAxes": [
          {
            "label": "Connections",
            "min": 0
          },
          {
            "show": false
          }
        ],
        "lines": true,
        "fill": 1,
        "linewidth": 2,
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 20
        }
      },
      {
        "id": 10,
        "title": "Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "process_resident_memory_bytes{job=\"kb-7-terminology\"} / 1024 / 1024",
            "legendFormat": "Resident Memory (MB)",
            "refId": "A"
          },
          {
            "expr": "go_memstats_heap_inuse_bytes{job=\"kb-7-terminology\"} / 1024 / 1024",
            "legendFormat": "Heap In Use (MB)",
            "refId": "B"
          },
          {
            "expr": "go_memstats_heap_alloc_bytes{job=\"kb-7-terminology\"} / 1024 / 1024",
            "legendFormat": "Heap Allocated (MB)",
            "refId": "C"
          }
        ],
        "yAxes": [
          {
            "label": "Memory (MB)",
            "min": 0
          },
          {
            "show": false
          }
        ],
        "lines": true,
        "fill": 0,
        "linewidth": 2,
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 20
        }
      }
    ]
  }
}