{
  "info": {
    "name": "KB-7 Terminology Service API",
    "description": "Complete API collection for KB-7 Terminology Service with THREE-CHECK PIPELINE validation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "kb7-terminology-api-v1"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8087",
      "type": "string"
    },
    {
      "key": "region",
      "value": "au",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Health & System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Check service health status including database, cache, and GraphDB connections."
          }
        },
        {
          "name": "Version Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/version",
              "host": ["{{baseUrl}}"],
              "path": ["version"]
            },
            "description": "Get service version and list of capabilities."
          }
        },
        {
          "name": "Metrics (Prometheus)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/metrics",
              "host": ["{{baseUrl}}"],
              "path": ["metrics"]
            },
            "description": "Prometheus metrics endpoint for monitoring."
          }
        }
      ]
    },
    {
      "name": "2. Region Management",
      "item": [
        {
          "name": "List Supported Regions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/regions",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "regions"]
            },
            "description": "List all supported terminology regions (AU, US, IN)."
          }
        },
        {
          "name": "Get Current Region Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Region",
                "value": "{{region}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/region",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "region"]
            },
            "description": "Get terminology info for the current region (from X-Region header)."
          }
        }
      ]
    },
    {
      "name": "3. Rule Engine (THREE-CHECK PIPELINE)",
      "item": [
        {
          "name": "Seed Builtin Value Sets",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/rules/seed",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "rules", "seed"]
            },
            "description": "FIRST TIME SETUP: Seed 18+ FHIR R4 value sets to the database."
          }
        },
        {
          "name": "List Rule Value Sets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/rules/valuesets?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "rules", "valuesets"],
              "query": [
                {"key": "limit", "value": "20"},
                {"key": "offset", "value": "0", "disabled": true},
                {"key": "type", "value": "extensional", "disabled": true}
              ]
            },
            "description": "List all rule-based value sets with optional filtering."
          }
        },
        {
          "name": "Get Value Set Definition",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/rules/valuesets/SepsisDiagnosis",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "rules", "valuesets", "SepsisDiagnosis"]
            },
            "description": "Get the definition and codes for a specific value set."
          }
        },
        {
          "name": "Expand Value Set",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/rules/valuesets/SepsisDiagnosis/expand",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "rules", "valuesets", "SepsisDiagnosis", "expand"]
            },
            "description": "Expand a value set to get all codes (with caching)."
          }
        },
        {
          "name": "⭐ Validate Code (THREE-CHECK)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-Region", "value": "{{region}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"448417001\",\n  \"system\": \"http://snomed.info/sct\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/rules/valuesets/SepsisDiagnosis/validate",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "rules", "valuesets", "SepsisDiagnosis", "validate"]
            },
            "description": "MAIN API: Validate a code using the THREE-CHECK PIPELINE (Expansion → Exact Match → Subsumption). Returns full pipeline audit trail."
          }
        },
        {
          "name": "⭐ Classify Code (Reverse Lookup)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"91302008\",\n  \"system\": \"http://snomed.info/sct\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/rules/classify",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "rules", "classify"]
            },
            "description": "REVERSE LOOKUP: Find ALL value sets that contain a given code (via exact match or subsumption)."
          }
        },
        {
          "name": "Refresh Value Set Cache",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/rules/valuesets/SepsisDiagnosis/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "rules", "valuesets", "SepsisDiagnosis", "refresh"]
            },
            "description": "Force refresh the cache for a value set."
          }
        }
      ]
    },
    {
      "name": "4. Subsumption Testing",
      "item": [
        {
          "name": "⭐ Test Subsumption (IS-A)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-Region", "value": "{{region}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code_a\": \"22973011000036107\",\n  \"code_b\": \"414984009\",\n  \"system\": \"http://snomed.info/sct\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/subsumption/test",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "subsumption", "test"]
            },
            "description": "Test if code_a IS-A code_b (subsumption relationship). Uses Neo4j ELK materialized hierarchy."
          }
        },
        {
          "name": "Batch Subsumption Test",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tests\": [\n    {\"code_a\": \"22973011000036107\", \"code_b\": \"414984009\", \"system\": \"http://snomed.info/sct\"},\n    {\"code_a\": \"448417001\", \"code_b\": \"91302008\", \"system\": \"http://snomed.info/sct\"}\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/subsumption/test/batch",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "subsumption", "test", "batch"]
            },
            "description": "Test multiple subsumption relationships at once."
          }
        },
        {
          "name": "Get Ancestors",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"448417001\",\n  \"system\": \"http://snomed.info/sct\",\n  \"max_depth\": 5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/subsumption/ancestors",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "subsumption", "ancestors"]
            },
            "description": "Get all ancestors (parent concepts) up to max_depth."
          }
        },
        {
          "name": "Get Descendants",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"91302008\",\n  \"system\": \"http://snomed.info/sct\",\n  \"max_depth\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/subsumption/descendants",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "subsumption", "descendants"]
            },
            "description": "Get all descendants (child concepts) up to max_depth."
          }
        },
        {
          "name": "Find Common Ancestors",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code_a\": \"448417001\",\n  \"code_b\": \"10001005\",\n  \"system\": \"http://snomed.info/sct\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/subsumption/common-ancestors",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "subsumption", "common-ancestors"]
            },
            "description": "Find common ancestors between two concepts."
          }
        },
        {
          "name": "Get Subsumption Config",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/subsumption/config",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "subsumption", "config"]
            },
            "description": "Get current subsumption service configuration."
          }
        }
      ]
    },
    {
      "name": "5. Concept Operations",
      "item": [
        {
          "name": "Search Concepts",
          "request": {
            "method": "GET",
            "header": [
              {"key": "X-Region", "value": "{{region}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/concepts?q=sepsis&system=http://snomed.info/sct&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "concepts"],
              "query": [
                {"key": "q", "value": "sepsis"},
                {"key": "system", "value": "http://snomed.info/sct"},
                {"key": "limit", "value": "10"}
              ]
            },
            "description": "Search for concepts by text query."
          }
        },
        {
          "name": "Lookup Concept",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/concepts/http%3A%2F%2Fsnomed.info%2Fsct/91302008",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "concepts", "http%3A%2F%2Fsnomed.info%2Fsct", "91302008"]
            },
            "description": "Lookup a specific concept by system and code."
          }
        },
        {
          "name": "Validate Code",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"91302008\",\n  \"system\": \"http://snomed.info/sct\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/concepts/validate",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "concepts", "validate"]
            },
            "description": "Validate that a code exists in a terminology system."
          }
        },
        {
          "name": "Batch Lookup Concepts",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codes\": [\n    {\"code\": \"91302008\", \"system\": \"http://snomed.info/sct\"},\n    {\"code\": \"448417001\", \"system\": \"http://snomed.info/sct\"}\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/concepts/batch-lookup",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "concepts", "batch-lookup"]
            },
            "description": "Lookup multiple concepts at once."
          }
        }
      ]
    },
    {
      "name": "6. Value Sets (FHIR)",
      "item": [
        {
          "name": "List Value Sets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/valuesets?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "valuesets"],
              "query": [
                {"key": "limit", "value": "10"}
              ]
            },
            "description": "List FHIR value sets."
          }
        },
        {
          "name": "Get Value Set",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/valuesets/http%3A%2F%2Fhl7.org%2Ffhir%2FValueSet%2Fadministrative-gender",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "valuesets", "http%3A%2F%2Fhl7.org%2Ffhir%2FValueSet%2Fadministrative-gender"]
            },
            "description": "Get a specific FHIR value set."
          }
        },
        {
          "name": "Expand Value Set",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/valuesets/http%3A%2F%2Fhl7.org%2Ffhir%2FValueSet%2Fadministrative-gender/expand",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "valuesets", "http%3A%2F%2Fhl7.org%2Ffhir%2FValueSet%2Fadministrative-gender", "expand"]
            },
            "description": "Expand a FHIR value set."
          }
        },
        {
          "name": "Validate Code in Value Set",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"male\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/valuesets/http%3A%2F%2Fhl7.org%2Ffhir%2FValueSet%2Fadministrative-gender/validate-code",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "valuesets", "http%3A%2F%2Fhl7.org%2Ffhir%2FValueSet%2Fadministrative-gender", "validate-code"]
            },
            "description": "Validate a code in a FHIR value set."
          }
        },
        {
          "name": "Get Builtin Value Set Count",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/valuesets/builtin/count",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "valuesets", "builtin", "count"]
            },
            "description": "Get count of builtin value sets."
          }
        }
      ]
    },
    {
      "name": "7. HCC/RAF Calculation",
      "item": [
        {
          "name": "Map ICD-10 to HCC",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/hcc/map/E1122",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "hcc", "map", "E1122"]
            },
            "description": "Map a single ICD-10 code to HCC category."
          }
        },
        {
          "name": "Batch Map ICD-10 to HCC",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codes\": [\"E1122\", \"I10\", \"J449\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/hcc/map/batch",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "hcc", "map", "batch"]
            },
            "description": "Batch map ICD-10 codes to HCC categories."
          }
        },
        {
          "name": "Calculate RAF Score",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patient_id\": \"12345\",\n  \"age\": 67,\n  \"sex\": \"M\",\n  \"icd10_codes\": [\"E1122\", \"I10\", \"J449\"],\n  \"model_version\": \"V28\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/hcc/raf/calculate",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "hcc", "raf", "calculate"]
            },
            "description": "Calculate Risk Adjustment Factor for a patient."
          }
        },
        {
          "name": "Get HCC Hierarchies",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/hcc/hierarchies",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "hcc", "hierarchies"]
            },
            "description": "Get HCC hierarchy information."
          }
        },
        {
          "name": "Get HCC Coefficients",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/hcc/coefficients",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "hcc", "coefficients"]
            },
            "description": "Get RAF coefficients for HCC categories."
          }
        }
      ]
    },
    {
      "name": "8. Semantic Operations",
      "item": [
        {
          "name": "Execute SPARQL Query",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"SELECT ?s ?p ?o WHERE { ?s ?p ?o } LIMIT 10\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/semantic/sparql",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "semantic", "sparql"]
            },
            "description": "Execute a SPARQL query against GraphDB."
          }
        },
        {
          "name": "Get Concept by URI",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/semantic/concepts/http%3A%2F%2Fsnomed.info%2Fid%2F91302008",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "semantic", "concepts", "http%3A%2F%2Fsnomed.info%2Fid%2F91302008"]
            },
            "description": "Get a concept by its full URI."
          }
        },
        {
          "name": "Get Drug Interactions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/semantic/drug-interactions/http%3A%2F%2Fsnomed.info%2Fid%2F414984009",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "semantic", "drug-interactions", "http%3A%2F%2Fsnomed.info%2Fid%2F414984009"]
            },
            "description": "Get drug interactions for a medication."
          }
        },
        {
          "name": "Get Semantic Mappings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/semantic/mappings/91302008",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "semantic", "mappings", "91302008"]
            },
            "description": "Get semantic mappings for a code."
          }
        }
      ]
    },
    {
      "name": "9. Translation",
      "item": [
        {
          "name": "Translate Concept",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"91302008\",\n  \"source_system\": \"http://snomed.info/sct\",\n  \"target_system\": \"http://hl7.org/fhir/sid/icd-10\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/translate",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "translate"]
            },
            "description": "Translate a concept between terminology systems."
          }
        },
        {
          "name": "Batch Translate Concepts",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"translations\": [\n    {\n      \"code\": \"91302008\",\n      \"source_system\": \"http://snomed.info/sct\",\n      \"target_system\": \"http://hl7.org/fhir/sid/icd-10\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/translate/batch",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "translate", "batch"]
            },
            "description": "Batch translate concepts."
          }
        }
      ]
    },
    {
      "name": "10. Concept Mappings",
      "item": [
        {
          "name": "Get Concept Mappings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/mappings",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "mappings"]
            },
            "description": "Get available concept mappings."
          }
        },
        {
          "name": "Get Specific Mapping",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/mappings/http%3A%2F%2Fsnomed.info%2Fsct/91302008/http%3A%2F%2Fhl7.org%2Ffhir%2Fsid%2Ficd-10",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "mappings", "http%3A%2F%2Fsnomed.info%2Fsct", "91302008", "http%3A%2F%2Fhl7.org%2Ffhir%2Fsid%2Ficd-10"]
            },
            "description": "Get a specific mapping between systems."
          }
        }
      ]
    }
  ]
}
