# KB-6 Formulary Management Service - Environment Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=8087
GRPC_PORT=8086
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=info

# =============================================================================
# POSTGRESQL DATABASE
# =============================================================================
# Local development
DB_HOST=localhost
DB_PORT=5436
DB_NAME=kb_formulary
DB_USER=kb6_admin
DB_PASSWORD=kb6_secure_password
DB_SSLMODE=disable

# Docker/Production (uses service name)
# DB_HOST=kb6-postgres
# DB_PORT=5432
# DB_SSLMODE=require

# Connection pool settings
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# =============================================================================
# REDIS CACHE
# =============================================================================
REDIS_URL=localhost:6386
REDIS_PASSWORD=
REDIS_DB=0

# Docker/Production
# REDIS_URL=kb6-redis:6379

# Cache TTL settings (in seconds)
CACHE_TTL_FORMULARY=3600
CACHE_TTL_COVERAGE=1800
CACHE_TTL_ALTERNATIVES=7200

# =============================================================================
# ELASTICSEARCH
# =============================================================================
ELASTICSEARCH_URL=http://localhost:9206
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# Docker/Production
# ELASTICSEARCH_URL=http://kb6-elasticsearch:9200

# Index settings
ES_INDEX_FORMULARY=kb6_formulary
ES_INDEX_DRUGS=kb6_drugs

# =============================================================================
# EXTERNAL SERVICE INTEGRATIONS
# =============================================================================
# KB-7 Terminology Service (RxNorm/SNOMED lookups)
KB7_TERMINOLOGY_URL=http://localhost:8087
KB7_TERMINOLOGY_ENABLED=true

# KB-5 Drug Interactions Service
KB5_INTERACTIONS_URL=http://localhost:8089
KB5_INTERACTIONS_ENABLED=true

# =============================================================================
# PRIOR AUTHORIZATION SETTINGS
# =============================================================================
PA_DEFAULT_APPROVAL_DAYS=365
PA_STANDARD_REVIEW_HOURS=72
PA_URGENT_REVIEW_HOURS=24
PA_EXPEDITED_REVIEW_HOURS=4
PA_AUTO_APPROVE_ENABLED=false

# =============================================================================
# STEP THERAPY SETTINGS
# =============================================================================
ST_OVERRIDE_APPROVAL_DAYS=180
ST_HISTORY_LOOKBACK_DAYS=365

# =============================================================================
# QUANTITY LIMIT SETTINGS
# =============================================================================
QL_OVERRIDE_APPROVAL_DAYS=90
QL_DEFAULT_MAX_FILLS_PER_YEAR=12

# =============================================================================
# METRICS & MONITORING
# =============================================================================
METRICS_ENABLED=true
METRICS_PATH=/metrics
METRICS_PORT=9090

# Prometheus
PROMETHEUS_ENABLED=true

# Grafana (for dashboards)
GRAFANA_ENABLED=true
GRAFANA_URL=http://localhost:3000

# =============================================================================
# SECURITY
# =============================================================================
# JWT Authentication
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRY=24h

# API Keys for service-to-service communication
API_KEY_ENABLED=false
API_KEY=your-api-key-change-in-production

# CORS settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_SECOND=100
RATE_LIMIT_BURST=200

# =============================================================================
# HEALTH CHECK
# =============================================================================
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=5s

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_PA_ENABLED=true
FEATURE_ST_ENABLED=true
FEATURE_QL_ENABLED=true
FEATURE_ALTERNATIVES_ENABLED=true
FEATURE_COST_ANALYSIS_ENABLED=true
FEATURE_INVENTORY_ENABLED=true
