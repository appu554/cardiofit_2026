# Patient Service Environment Variables

# Server settings
PORT=8003

# MongoDB settings (legacy, will be removed)
MONGODB_URL=mongodb+srv://admin:password@cluster0.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=clinical_synthesis_hub

# Google Cloud Healthcare API settings
USE_GOOGLE_HEALTHCARE_API=true
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_DATASET_ID=clinical-synthesis-hub
GOOGLE_CLOUD_FHIR_STORE_ID=fhir-store
GOOGLE_CLOUD_CREDENTIALS_PATH=/path/to/your/credentials.json

# FHIR Service URL
FHIR_SERVICE_URL=http://localhost:8004

# Auth Service URL
AUTH_SERVICE_URL=http://localhost:8001/api

# CORS settings
BACKEND_CORS_ORIGINS=["*"]
