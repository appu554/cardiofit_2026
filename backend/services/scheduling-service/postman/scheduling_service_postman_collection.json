{
  "info": {
    "name": "Scheduling Service API",
    "description": "Comprehensive API testing for the Scheduling Service with FHIR-compliant appointment, schedule, and slot management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8014",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "your_jwt_token_here",
      "type": "string"
    },
    {
      "key": "appointment_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "schedule_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "slot_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Appointments",
      "item": [
        {
          "name": "Create Appointment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('appointment_id', response.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"proposed\",\n  \"description\": \"Regular checkup appointment\",\n  \"start\": \"2024-02-15T10:00:00Z\",\n  \"end\": \"2024-02-15T10:30:00Z\",\n  \"minutes_duration\": 30,\n  \"comment\": \"Patient requested morning appointment\",\n  \"participant\": [\n    {\n      \"status\": \"accepted\",\n      \"actor\": {\n        \"reference\": \"Patient/patient-123\",\n        \"display\": \"John Doe\"\n      },\n      \"required\": \"required\"\n    },\n    {\n      \"status\": \"accepted\",\n      \"actor\": {\n        \"reference\": \"Practitioner/practitioner-456\",\n        \"display\": \"Dr. Smith\"\n      },\n      \"required\": \"required\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/appointments",
              "host": ["{{base_url}}"],
              "path": ["api", "appointments"]
            }
          }
        },
        {
          "name": "Get Appointment",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/appointments/{{appointment_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "appointments", "{{appointment_id}}"]
            }
          }
        },
        {
          "name": "Search Appointments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/appointments?status=proposed&patient_id=patient-123",
              "host": ["{{base_url}}"],
              "path": ["api", "appointments"],
              "query": [
                {
                  "key": "status",
                  "value": "proposed"
                },
                {
                  "key": "patient_id",
                  "value": "patient-123"
                }
              ]
            }
          }
        },
        {
          "name": "Update Appointment",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"booked\",\n  \"comment\": \"Appointment confirmed by patient\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/appointments/{{appointment_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "appointments", "{{appointment_id}}"]
            }
          }
        },
        {
          "name": "Cancel Appointment",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"cancelled\",\n  \"comment\": \"Patient requested cancellation\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/appointments/{{appointment_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "appointments", "{{appointment_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Schedules",
      "item": [
        {
          "name": "Create Schedule",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('schedule_id', response.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"active\": true,\n  \"actor\": [\n    {\n      \"reference\": \"Practitioner/practitioner-456\",\n      \"display\": \"Dr. Smith\"\n    }\n  ],\n  \"comment\": \"Regular clinic hours for Dr. Smith\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/schedules",
              "host": ["{{base_url}}"],
              "path": ["api", "schedules"]
            }
          }
        },
        {
          "name": "Get Schedule",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/schedules/{{schedule_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "schedules", "{{schedule_id}}"]
            }
          }
        },
        {
          "name": "Search Schedules",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/schedules?actor_id=practitioner-456&active=true",
              "host": ["{{base_url}}"],
              "path": ["api", "schedules"],
              "query": [
                {
                  "key": "actor_id",
                  "value": "practitioner-456"
                },
                {
                  "key": "active",
                  "value": "true"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Slots",
      "item": [
        {
          "name": "Create Slot",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('slot_id', response.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schedule_reference\": \"Schedule/{{schedule_id}}\",\n  \"status\": \"free\",\n  \"start\": \"2024-02-15T09:00:00Z\",\n  \"end\": \"2024-02-15T09:30:00Z\",\n  \"overbooked\": false,\n  \"comment\": \"Available morning slot\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/slots",
              "host": ["{{base_url}}"],
              "path": ["api", "slots"]
            }
          }
        },
        {
          "name": "Get Slot",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/slots/{{slot_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "slots", "{{slot_id}}"]
            }
          }
        },
        {
          "name": "Search Available Slots",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/slots?status=free&start=2024-02-15T00:00:00Z&end=2024-02-15T23:59:59Z",
              "host": ["{{base_url}}"],
              "path": ["api", "slots"],
              "query": [
                {
                  "key": "status",
                  "value": "free"
                },
                {
                  "key": "start",
                  "value": "2024-02-15T00:00:00Z"
                },
                {
                  "key": "end",
                  "value": "2024-02-15T23:59:59Z"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "GraphQL Federation",
      "item": [
        {
          "name": "Federation Schema Introspection",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query IntrospectionQuery { __schema { queryType { name } mutationType { name } types { name kind } } }\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/federation",
              "host": ["{{base_url}}"],
              "path": ["api", "federation"]
            }
          }
        },
        {
          "name": "Get Patient Appointments",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query GetPatientAppointments($patientId: ID!) { patient(id: $patientId) { id appointments { id status start end description participant { status actor { reference display } } } } }\",\n  \"variables\": {\n    \"patientId\": \"patient-123\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/federation",
              "host": ["{{base_url}}"],
              "path": ["api", "federation"]
            }
          }
        }
      ]
    }
  ]
}
