# =============================================================================
# CardioFit Notification Service - Docker Environment Configuration
# =============================================================================
# Copy this file to .env.docker and fill in your actual values
# Usage: docker-compose --env-file .env.docker up

# =============================================================================
# EXTERNAL NOTIFICATION SERVICES
# =============================================================================

# Twilio (SMS & Voice) - Get from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+12345678900

# SendGrid (Email) - Get from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=notifications@cardiofit.com
SENDGRID_FROM_NAME=CardioFit Notifications

# Firebase (Push Notifications) - Get from Firebase Console
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
FIREBASE_PROJECT_ID=cardiofit-prod
FIREBASE_ENABLED=true

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================

# Environment
ENVIRONMENT=docker
LOG_LEVEL=info

# Notification Delivery Mode
# Options: live, mock, test
# - live: Send real notifications via Twilio/SendGrid/Firebase
# - mock: Simulate notifications without actually sending
# - test: Test mode with detailed logging
NOTIFICATION_DELIVERY_MODE=live

# Grafana Admin Password (for monitoring dashboard)
GRAFANA_PASSWORD=your_secure_grafana_password

# =============================================================================
# DATABASE CONFIGURATION (Optional - defaults work for Docker Compose)
# =============================================================================

# These are set automatically by docker-compose, only override if needed
# DATABASE_URL=postgres://cardiofit_user:cardiofit_pass@postgres:5432/cardiofit_db?sslmode=disable
# REDIS_ADDR=redis:6379
# KAFKA_BROKERS=kafka:9092
