// getDrugRules handles GET /v1/items/{drug_id}
func (s *Server) getDrugRules(c *gin.Context) {
	drugID := c.Param("drug_id")
	if drugID == "" {
		s.respondWithError(c, http.StatusBadRequest, "drug_id is required", nil)
		return
	}

	// Parse query parameters
	var params models.GetRulesParams
	if err := c.ShouldBindQuery(&params); err != nil {
		s.respondWithError(c, http.StatusBadRequest, "Invalid query parameters", map[string]string{
			"error": err.Error(),
		})
		return
	}

	// Record metrics
	s.metrics.IncrementCounter("drug_rules_requests_total", map[string]string{
		"drug_id": drugID,
		"region":  getStringValue(params.Region),
	})

	// Check cache first
	cacheKey := fmt.Sprintf("drug_rules:%s:%s:%s", drugID, 
		getStringValue(params.Version), getStringValue(params.Region))
	
	if cachedData, err := s.cache.Get(cacheKey); err == nil && cachedData != nil {
		s.metrics.IncrementCounter("cache_hits_total", map[string]string{"type": "drug_rules"})
		
		var response models.DrugRulesResponse
		if err := json.Unmarshal(cachedData, &response); err == nil {
			s.setCacheHeaders(c, response.ETag, 3600)
			s.respondWithSuccess(c, response)
			return
		}
	}
	s.metrics.IncrementCounter("cache_misses_total", map[string]string{"type": "drug_rules"})

	// Get from database
	ruleService := services.NewRuleService(s.db, s.cache, s.logger)
	rulePack, err := ruleService.GetDrugRules(drugID, params.Version, params.Region)
	if err != nil {
		if err == services.ErrRuleNotFound {
			s.respondWithError(c, http.StatusNotFound, "Drug rules not found", map[string]string{
				"drug_id": drugID,
			})
			return
		}
		s.logger.WithError(err).Error("Failed to get drug rules")
		s.respondWithError(c, http.StatusInternalServerError, "Internal server error", nil)
		return
	}

	// Verify signature if strict mode
	strictSignature := params.StrictSignature != nil && *params.StrictSignature
	if strictSignature && !rulePack.SignatureValid {
		s.respondWithError(c, http.StatusPreconditionFailed, "Invalid signature", map[string]string{
			"drug_id": drugID,
			"version": rulePack.Version,
		})
		return
	}

	// Apply regional filtering if specified
	content := rulePack.Content
	selectedRegion := params.Region
	if params.Region != nil {
		if override, exists := content.RegionalVariations[*params.Region]; exists {
			content = applyRegionalOverride(content, override)
		} else {
			// Try fallback hierarchy: specific -> jurisdiction -> global
			if fallbackRegion := findFallbackRegion(*params.Region); fallbackRegion != "" {
				if override, exists := content.RegionalVariations[fallbackRegion]; exists {
					content = applyRegionalOverride(content, override)
					selectedRegion = &fallbackRegion
				}
			}
		}
	}

	// Build response
	response := models.DrugRulesResponse{
		DrugID:         drugID,
		Version:        rulePack.Version,
		ContentSHA:     rulePack.ContentSHA,
		SignatureValid: rulePack.SignatureValid,
		SelectedRegion: selectedRegion,
		Content:        content,
		CacheControl:   "public, max-age=3600",
		ETag:           rulePack.ContentSHA,
	}

	// Cache the response
	if responseData, err := json.Marshal(response); err == nil {
		s.cache.Set(cacheKey, responseData, 3600*time.Second)
	}

	// Set cache headers and respond
	s.setCacheHeaders(c, response.ETag, 3600)
	s.respondWithSuccess(c, response)
}

// validateRules handles POST /v1/validate - Enhanced with comprehensive TOML validation
func (s *Server) validateRules(c *gin.Context) {
	if !s.validateContentType(c, "application/json") {
		return
	}

	var request models.ValidationRequest
	if err := c.ShouldBindJSON(&request); err != nil {
		s.respondWithError(c, http.StatusBadRequest, "Invalid request body", map[string]string{
			"error": err.Error(),
		})
		return
	}

	// Record metrics
	s.metrics.IncrementCounter("validation_requests_total", nil)

	// Enhanced TOML validation with comprehensive error reporting
	validationResult := s.validateTOMLContent(request.Content)
	if !validationResult.IsValid {
		s.respondWithError(c, http.StatusBadRequest, "TOML validation failed", map[string]interface{}{
			"errors":   validationResult.Errors,
			"warnings": validationResult.Warnings,
		})
		return
	}

	// Parse TOML content after validation
	var content models.DrugRuleContent
	if err := toml.Unmarshal([]byte(request.Content), &content); err != nil {
		s.respondWithError(c, http.StatusBadRequest, "Invalid TOML content", map[string]string{
			"error": err.Error(),
		})
		return
	}

	// Validate content
	validator := services.NewValidationService(s.db, s.logger)
	result, err := validator.ValidateRuleContent(&content, request.Regions)
	if err != nil {
		s.logger.WithError(err).Error("Validation failed")
		s.respondWithError(c, http.StatusInternalServerError, "Validation failed", nil)
		return
	}

	// Record validation result
	if result.Valid {
		s.metrics.IncrementCounter("validation_success_total", nil)
	} else {
		s.metrics.IncrementCounter("validation_failure_total", nil)
	}

	s.respondWithSuccess(c, result)
}

// hotloadRules handles POST /v1/hotload
func (s *Server) hotloadRules(c *gin.Context) {
	if !s.validateContentType(c, "application/json") {
		return
	}

	var request models.HotloadRequest
	if err := c.ShouldBindJSON(&request); err != nil {
		s.respondWithError(c, http.StatusBadRequest, "Invalid request body", map[string]string{
			"error": err.Error(),
		})
		return
	}

	// Record metrics
	s.metrics.IncrementCounter("hotload_requests_total", map[string]string{
		"drug_id": request.DrugID,
	})

	// Extract user info for audit
	userInfo := s.extractUserInfo(c)

	// Check governance approval
	if approved, err := s.governance.IsApproved(request.DrugID, request.Version); err != nil || !approved {
		s.respondWithError(c, http.StatusForbidden, "Governance approval required", map[string]string{
			"drug_id": request.DrugID,
			"version": request.Version,
		})
		return
	}

	// Verify signature
	if valid, err := s.governance.VerifySignature(request.Content, request.Signature, request.SignedBy); err != nil || !valid {
		s.metrics.IncrementCounter("signature_validation_failures_total", nil)
		s.respondWithError(c, http.StatusPreconditionFailed, "Invalid signature", map[string]string{
			"signed_by": request.SignedBy,
		})
		return
	}
	s.metrics.IncrementCounter("signature_validations_total", nil)

	// Parse and validate content
	var content models.DrugRuleContent
	if err := toml.Unmarshal([]byte(request.Content), &content); err != nil {
		s.respondWithError(c, http.StatusBadRequest, "Invalid TOML content", map[string]string{
			"error": err.Error(),
		})
		return
	}

	// Calculate content hash
	hash := sha256.Sum256([]byte(request.Content))
	contentSHA := hex.EncodeToString(hash[:])

	// Create rule pack
	rulePack := &models.DrugRulePack{
		DrugID:         request.DrugID,
		Version:        request.Version,
		ContentSHA:     contentSHA,
		SignedBy:       request.SignedBy,
		SignatureValid: true,
		Regions:        request.Regions,
		Content:        content,
		Signature:      request.Signature,
	}

	// Get approval details
	if approval, err := s.governance.GetApproval(request.DrugID, request.Version); err == nil {
		rulePack.ClinicalReviewer = approval.ClinicalReviewer
		rulePack.ClinicalReviewDate = &approval.ClinicalReviewDate
	}

	// Save to database
	ruleService := services.NewRuleService(s.db, s.cache, s.logger)
	if err := ruleService.SaveRulePack(rulePack); err != nil {
		s.logger.WithError(err).Error("Failed to save rule pack")
		s.respondWithError(c, http.StatusInternalServerError, "Failed to save rule pack", nil)
		return
	}

	// Invalidate cache
	s.cache.InvalidatePattern(fmt.Sprintf("drug_rules:%s:*", request.DrugID))

	// Emit event
	if err := s.emitRulePackUpdatedEvent(rulePack, userInfo); err != nil {
		s.logger.WithError(err).Warn("Failed to emit event")
	}

	// Record success metrics
	s.metrics.IncrementCounter("hotload_success_total", map[string]string{
		"drug_id": request.DrugID,
	})

	// Build response
	response := models.HotloadResponse{
		Success:        true,
		DrugID:         request.DrugID,
		Version:        request.Version,
		ContentSHA:     contentSHA,
		RegionsUpdated: request.Regions,
		Message:        "Rule pack successfully deployed",
	}

	s.respondWithSuccess(c, response)
}

