// Helper functions

func getStringValue(ptr *string) string {
	if ptr == nil {
		return ""
	}
	return *ptr
}

func applyRegionalOverride(base models.DrugRuleContent, override models.RegionalOverride) models.DrugRuleContent {
	result := base
	
	if override.DoseCalculation != nil {
		result.DoseCalculation = *override.DoseCalculation
	}
	
	if override.SafetyVerification != nil {
		result.SafetyVerification = *override.SafetyVerification
	}
	
	if override.MonitoringReq != nil {
		result.MonitoringRequirements = override.MonitoringReq
	}
	
	return result
}

func findFallbackRegion(region string) string {
	// Simple fallback logic - in production, use more sophisticated hierarchy
	fallbacks := map[string]string{
		"CA": "US",  // Canada falls back to US
		"AU": "US",  // Australia falls back to US
		"UK": "EU",  // UK falls back to EU
	}
	
	return fallbacks[region]
}

func (s *Server) emitRulePackUpdatedEvent(rulePack *models.DrugRulePack, userInfo map[string]string) error {
	// TODO: Implement event emission to Kafka
	s.logger.WithFields(logrus.Fields{
		"drug_id": rulePack.DrugID,
		"version": rulePack.Version,
		"user_id": userInfo["user_id"],
	}).Info("Rule pack updated event")
	
	return nil
}

