# KB-1 Drug Dosing Rules Service - Environment Configuration
# Copy this file to .env and adjust values as needed

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=8081
DEBUG=false

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Option 1: Direct PostgreSQL connection
DATABASE_URL=postgresql://kb_drug_rules_user:kb_password@localhost:5481/kb_drug_rules?sslmode=disable

# Option 2: Supabase connection (if using Supabase)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_API_KEY=your-api-key
# SUPABASE_JWT_SECRET=your-jwt-secret
# SUPABASE_DB_PASSWORD=your-db-password

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_URL=redis://localhost:6382/0
CACHE_TTL=3600
CACHE_MAX_SIZE=10000
CACHE_EVICTION_TTL=300

# ============================================================================
# S3/MINIO CONFIGURATION (Optional - for artifact storage)
# ============================================================================
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=kb-artifacts
# S3_ACCESS_KEY=admin
# S3_SECRET_KEY=password123

# ============================================================================
# KAFKA CONFIGURATION (Optional - for event streaming)
# ============================================================================
# KAFKA_BROKERS=localhost:9092
# KAFKA_TOPIC=kb-events

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# SIGNING_KEY_PATH=/app/keys/signing.key
# JWT_SECRET=your-jwt-secret-here

# ============================================================================
# GOVERNANCE CONFIGURATION
# ============================================================================
REQUIRE_APPROVAL=false
REQUIRE_SIGNATURE=false
# ALLOWED_REVIEWERS=user1,user2
# ALLOWED_SIGNERS=signer1,signer2

# ============================================================================
# REGIONAL CONFIGURATION
# ============================================================================
DEFAULT_REGION=US
SUPPORTED_REGIONS=US,EU,CA,AU,IN

# ============================================================================
# MONITORING CONFIGURATION
# ============================================================================
METRICS_ENABLED=true
METRICS_PATH=/metrics
TRACING_ENABLED=false
# TRACING_ENDPOINT=http://localhost:14268/api/traces
