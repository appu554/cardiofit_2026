# Supabase Configuration for KB-Drug-Rules Service
# Copy this file to .env.supabase and fill in your Supabase credentials

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================

# Your Supabase project URL (found in Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase API key (anon/public key from Settings > API)
SUPABASE_API_KEY=your-supabase-anon-key

# Your Supabase JWT secret (from Settings > API)
SUPABASE_JWT_SECRET=your-jwt-secret

# Your database password (from Settings > Database)
SUPABASE_DB_PASSWORD=your-database-password

# Alternative: Direct database URL (if you prefer this approach)
# DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require

# ===========================================
# SERVICE CONFIGURATION
# ===========================================

# Service port
PORT=8081

# Debug mode
DEBUG=true

# Redis configuration (you can use Supabase Redis or external Redis)
REDIS_URL=redis://localhost:6379/0

# ===========================================
# SECURITY CONFIGURATION
# ===========================================

# Signing key path for digital signatures
SIGNING_KEY_PATH=/app/keys/signing.key

# JWT secret for service authentication
JWT_SECRET=your-service-jwt-secret

# Governance settings
REQUIRE_APPROVAL=true
REQUIRE_SIGNATURE=true

# ===========================================
# REGIONAL CONFIGURATION
# ===========================================

# Supported regions
SUPPORTED_REGIONS=US,EU,CA,AU

# Default region
DEFAULT_REGION=US

# ===========================================
# MONITORING CONFIGURATION
# ===========================================

# Enable metrics collection
METRICS_ENABLED=true

# Enable distributed tracing
TRACING_ENABLED=true

# Jaeger endpoint (if using)
TRACING_ENDPOINT=http://jaeger:14268/api/traces

# ===========================================
# KAFKA CONFIGURATION (Optional)
# ===========================================

# Kafka brokers for event streaming
KAFKA_BROKERS=localhost:9092

# Kafka topic for KB events
KAFKA_TOPIC=kb-events

# ===========================================
# S3/MINIO CONFIGURATION (Optional)
# ===========================================

# S3 endpoint for artifact storage
S3_ENDPOINT=http://minio:9000

# S3 bucket name
S3_BUCKET=kb-artifacts

# S3 credentials
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password123

# ===========================================
# INSTRUCTIONS
# ===========================================

# 1. Copy this file to .env.supabase
# 2. Go to your Supabase project dashboard
# 3. Navigate to Settings > API
# 4. Copy your Project URL to SUPABASE_URL
# 5. Copy your anon/public key to SUPABASE_API_KEY
# 6. Copy your JWT secret to SUPABASE_JWT_SECRET
# 7. Navigate to Settings > Database
# 8. Copy your database password to SUPABASE_DB_PASSWORD
# 9. Update other configuration values as needed
# 10. Run: docker-compose --env-file .env.supabase -f docker-compose.dev.yml up

# ===========================================
# SUPABASE SETUP NOTES
# ===========================================

# 1. Create the following tables in your Supabase database:
#    - drug_rule_packs
#    - governance_approvals
#    - audit_log
#    - drug_latest_versions

# 2. Enable Row Level Security (RLS) on all tables

# 3. Create appropriate RLS policies for your use case

# 4. Consider creating a service role user for the application

# 5. Set up proper indexes for performance

