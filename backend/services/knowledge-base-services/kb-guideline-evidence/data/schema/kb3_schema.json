{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clinical-kb.health/schemas/kb3-guideline-evidence/v3.0.0",
  "title": "KB-3 Guideline Evidence Schema",
  "type": "object",
  "required": ["metadata", "guidelines"],
  
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["kb_name", "version", "last_updated", "status"],
      "properties": {
        "kb_name": {"const": "kb_guideline_evidence"},
        "version": {
          "type": "string", 
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "last_updated": {
          "type": "string", 
          "format": "date-time"
        },
        "status": {
          "enum": ["draft", "review", "approved", "active", "deprecated"]
        },
        "digital_signature": {"type": "string"},
        "approvers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "role", "approved_at"],
            "properties": {
              "name": {"type": "string"},
              "role": {"type": "string"},
              "approved_at": {"type": "string", "format": "date-time"}
            }
          }
        }
      }
    },
    
    "guidelines": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["guideline_id", "source", "condition", "version", "effective_date", "recommendations"],
        "properties": {
          "guideline_id": {
            "type": "string",
            "pattern": "^[A-Z]{2,10}(-[A-Z]{2,10})*-[A-Z0-9]{2,10}-\\d{4}$",
            "description": "Format: ORG-TOPIC-YEAR (e.g., ADA-DM-2025)"
          },
          "source": {
            "type": "object",
            "required": ["organization", "full_name", "country", "region"],
            "properties": {
              "organization": {"type": "string"},
              "full_name": {"type": "string"},
              "country": {"type": "string"},
              "region": {"enum": ["US", "EU", "AU", "WHO", "CA", "UK", "ASIA"]}
            }
          },
          "condition": {
            "type": "object",
            "required": ["primary", "icd10_codes"],
            "properties": {
              "primary": {"type": "string"},
              "secondary": {"type": "array", "items": {"type": "string"}},
              "icd10_codes": {
                "type": "array", 
                "items": {"type": "string", "pattern": "^[A-Z]\\d{2}(\\.\\d{1,2})?$"}
              },
              "snomed_codes": {
                "type": "array", 
                "items": {"type": "string", "pattern": "^\\d+$"}
              }
            }
          },
          "version": {"type": "string"},
          "effective_date": {"type": "string", "format": "date"},
          "superseded_date": {"type": ["string", "null"], "format": "date"},
          "supersedes": {"type": ["string", "null"]},
          "publication": {
            "type": "object",
            "properties": {
              "doi": {"type": "string", "pattern": "^10\\..+"},
              "pmid": {"type": "string", "pattern": "^\\d+$"},
              "url": {"type": "string", "format": "uri"},
              "journal": {"type": "string"},
              "year": {"type": "integer", "minimum": 1950, "maximum": 2030}
            }
          },
          "recommendations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["rec_id", "domain", "recommendation", "evidence_grade"],
              "properties": {
                "rec_id": {
                  "type": "string",
                  "pattern": "^[A-Z]{2,10}(-[A-Z]{2,10})*-[A-Z0-9]{2,10}-\\d{4}-\\d{3}$",
                  "description": "Format: ORG-TOPIC-YEAR-SEQ (e.g., ADA-DM-2025-001)"
                },
                "domain": {
                  "type": "string",
                  "enum": [
                    "diagnosis", 
                    "screening", 
                    "pharmacologic_therapy", 
                    "nonpharmacologic_therapy",
                    "glycemic_control", 
                    "cardiovascular", 
                    "treatment", 
                    "monitoring",
                    "prevention", 
                    "sick_day", 
                    "perioperative",
                    "lifestyle",
                    "education"
                  ]
                },
                "subdomain": {"type": "string"},
                "recommendation": {
                  "type": "string", 
                  "minLength": 10
                },
                "evidence_grade": {
                  "enum": ["A", "B", "C", "D", "Expert Opinion", "Good Practice Point"]
                },
                "strength": {
                  "enum": ["Strong", "Conditional", "Weak", "Against"]
                },
                "class_of_recommendation": {
                  "enum": ["I", "IIa", "IIb", "III"]
                },
                "level_of_evidence": {
                  "enum": ["A", "B-R", "B-NR", "C-LD", "C-EO"]
                },
                "applicability": {
                  "type": "object",
                  "properties": {
                    "populations": {
                      "type": "array", 
                      "items": {"type": "string"}
                    },
                    "exclusions": {
                      "type": "array", 
                      "items": {"type": "string"}
                    },
                    "special_populations": {
                      "type": "object",
                      "properties": {
                        "elderly": {"type": "string"},
                        "pediatric": {"type": "string"},
                        "pregnancy": {"type": "string"},
                        "renal_impairment": {"type": "string"},
                        "hepatic_impairment": {"type": "string"},
                        "heart_failure": {"type": "string"},
                        "aboriginal_torres_strait": {"type": "string"},
                        "indigenous_australian": {"type": "string"}
                      }
                    }
                  }
                },
                "linked_kb_refs": {
                  "type": "object",
                  "properties": {
                    "kb1_dosing": {
                      "type": "array",
                      "items": {"type": "string"}
                    },
                    "kb2_phenotypes": {
                      "type": "array", 
                      "items": {"type": "string"}
                    },
                    "kb4_safety": {
                      "type": "array",
                      "items": {"type": "string"}
                    },
                    "kb5_interactions": {
                      "type": "array",
                      "items": {"type": "string"}
                    },
                    "kb6_formulary": {
                      "type": "array",
                      "items": {"type": "string"}
                    },
                    "kb7_terminology": {
                      "type": "array",
                      "items": {"type": "string"}
                    }
                  }
                },
                "metrics": {
                  "type": "object",
                  "properties": {
                    "outcome_measure": {"type": "string"},
                    "nnt": {"type": ["number", "null"], "minimum": 1},
                    "nnh": {"type": ["number", "null"], "minimum": 1},
                    "absolute_risk_reduction": {
                      "type": ["number", "null"], 
                      "minimum": 0, 
                      "maximum": 1
                    },
                    "relative_risk_reduction": {
                      "type": ["number", "null"], 
                      "minimum": 0, 
                      "maximum": 1
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  
  "definitions": {
    "evidence_grade_hierarchy": {
      "description": "Evidence grades in order of strength",
      "A": "High quality evidence from RCTs or systematic reviews",
      "B": "Moderate quality evidence from RCTs with limitations",
      "C": "Low quality evidence from observational studies",
      "D": "Very low quality evidence or expert opinion",
      "Expert Opinion": "Consensus expert opinion in absence of evidence",
      "Good Practice Point": "Recommended best practice"
    },
    
    "strength_hierarchy": {
      "description": "Recommendation strength levels",
      "Strong": "Benefits clearly outweigh harms or vice versa",
      "Conditional": "Benefits and harms closely balanced",
      "Weak": "Uncertainty about balance of benefits and harms",
      "Against": "Harms outweigh benefits"
    },
    
    "class_of_recommendation": {
      "description": "ACC/AHA classification system",
      "I": "Strong recommendation - should be performed",
      "IIa": "Moderate recommendation - reasonable to perform",
      "IIb": "Weak recommendation - may be reasonable",
      "III": "Recommendation against - should not be performed"
    },
    
    "level_of_evidence": {
      "description": "ACC/AHA evidence levels",
      "A": "Multiple randomized trials or meta-analyses",
      "B-R": "Moderate evidence from randomized trials",
      "B-NR": "Moderate evidence from non-randomized studies",
      "C-LD": "Limited data from randomized trials",
      "C-EO": "Expert opinion based on clinical experience"
    }
  },
  
  "additionalProperties": false
}