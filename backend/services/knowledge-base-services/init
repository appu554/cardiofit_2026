#!/bin/bash

# Knowledge Base Services Initialization Script
# Comprehensive setup and initialization for the Clinical Synthesis Hub KB Services
# Supports Docker, local, and development environments

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Emojis for better UX
ROCKET="🚀"
CHECK="✅"
WARNING="⚠️"
ERROR="❌"
INFO="ℹ️"
GEAR="⚙️"
DATABASE="🗄️"
NETWORK="🌐"
SECURITY="🔒"

print_header() {
    echo -e "${CYAN}========================================${NC}"
    echo -e "${CYAN}$1${NC}"
    echo -e "${CYAN}========================================${NC}"
    echo ""
}

print_status() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

print_gear() {
    echo -e "${PURPLE}[SETUP]${NC} $1"
}

# Function to check if command exists
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Function to detect OS
detect_os() {
    if [[ "$OSTYPE" == "msys" || "$OSTYPE" == "cygwin" ]]; then
        echo "windows"
    elif [[ "$OSTYPE" == "darwin"* ]]; then
        echo "macos"
    elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
        echo "linux"
    else
        echo "unknown"
    fi
}

# Function to check prerequisites
check_prerequisites() {
    print_status "Checking system prerequisites..."
    local missing=()
    
    # Check Docker
    if ! command_exists docker; then
        missing+=("docker")
        print_warning "Docker not found"
    else
        if ! docker info >/dev/null 2>&1; then
            print_warning "Docker daemon is not running"
            missing+=("docker-running")
        else
            print_success "Docker is available and running"
        fi
    fi
    
    # Check Docker Compose
    if ! command_exists docker-compose && ! docker compose version >/dev/null 2>&1; then
        missing+=("docker-compose")
        print_warning "Docker Compose not found"
    else
        print_success "Docker Compose is available"
    fi
    
    # Check Go
    if ! command_exists go; then
        missing+=("go")
        print_warning "Go not found (optional for Docker setup)"
    else
        go_version=$(go version | cut -d' ' -f3)
        print_success "Go is available ($go_version)"
    fi
    
    # Check Make
    if ! command_exists make; then
        missing+=("make")
        print_warning "Make not found (optional, using manual commands)"
    else
        print_success "Make is available"
    fi
    
    # Check curl
    if ! command_exists curl; then
        missing+=("curl")
        print_warning "curl not found (needed for health checks)"
    else
        print_success "curl is available"
    fi
    
    # Check jq (optional)
    if ! command_exists jq; then
        print_warning "jq not found (optional, for pretty JSON output)"
    else
        print_success "jq is available"
    fi
    
    return ${#missing[@]}
}

# Function to install missing prerequisites
install_prerequisites() {
    local os=$(detect_os)
    print_gear "Installing missing prerequisites for $os..."
    
    case $os in
        "linux")
            print_status "Please install missing tools using your package manager:"
            echo "  sudo apt-get update && sudo apt-get install -y docker.io docker-compose curl jq make golang-go"
            echo "  # or"
            echo "  sudo yum install -y docker docker-compose curl jq make golang"
            ;;
        "macos")
            print_status "Please install missing tools:"
            echo "  # Install Homebrew if not already installed"
            echo "  /bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\""
            echo "  # Then install tools"
            echo "  brew install docker docker-compose curl jq make go"
            ;;
        "windows")
            print_status "Please install missing tools:"
            echo "  1. Docker Desktop: https://www.docker.com/products/docker-desktop"
            echo "  2. Go: https://golang.org/dl/"
            echo "  3. Make: http://gnuwin32.sourceforge.net/packages/make.htm"
            echo "  4. curl and jq are included in most modern Windows environments"
            ;;
        *)
            print_warning "Unknown OS, please install Docker, Docker Compose, Go, Make, curl, and jq manually"
            ;;
    esac
}

# Function to setup directory structure
setup_directories() {
    print_gear "Setting up directory structure..."
    
    local dirs=("logs" "keys" "data" "backup" "config")
    
    for dir in "${dirs[@]}"; do
        if [ ! -d "$dir" ]; then
            mkdir -p "$dir"
            print_success "Created directory: $dir"
        else
            print_status "Directory already exists: $dir"
        fi
    done
}

# Function to generate encryption keys
generate_keys() {
    print_gear "Generating encryption keys..."
    
    if [ ! -f "keys/signing.key" ]; then
        mkdir -p keys
        openssl rand -base64 32 > keys/signing.key
        chmod 600 keys/signing.key
        print_success "Generated signing key"
    else
        print_status "Signing key already exists"
    fi
    
    if [ ! -f "keys/jwt.secret" ]; then
        openssl rand -base64 64 > keys/jwt.secret
        chmod 600 keys/jwt.secret
        print_success "Generated JWT secret"
    else
        print_status "JWT secret already exists"
    fi
}

# Function to setup environment files
setup_environment() {
    print_gear "Setting up environment configuration..."
    
    # Docker environment
    if [ ! -f ".env.docker" ]; then
        cat > .env.docker << EOF
# Docker Environment Configuration
DATABASE_URL=postgresql://kb_drug_rules_user:kb_password@kb-postgres:5432/kb_drug_rules
REDIS_URL=redis://kb-redis:6379/0
PORT=8081
DEBUG=true
JWT_SECRET=kb-jwt-secret-key-for-development
SUPPORTED_REGIONS=US,EU,CA,AU
DEFAULT_REGION=US
REQUIRE_APPROVAL=false
REQUIRE_SIGNATURE=false
METRICS_ENABLED=true
TRACING_ENABLED=false
EOF
        print_success "Created .env.docker"
    else
        print_status ".env.docker already exists"
    fi
    
    # Local environment
    if [ ! -f ".env.local" ]; then
        cat > .env.local << EOF
# Local Development Environment Configuration
DATABASE_URL=postgresql://kb_drug_rules_user:kb_password@localhost:5432/kb_drug_rules
REDIS_URL=redis://localhost:6379/0
PORT=8081
DEBUG=true
JWT_SECRET=kb-jwt-secret-key-for-local-development
SUPPORTED_REGIONS=US,EU,CA,AU
DEFAULT_REGION=US
REQUIRE_APPROVAL=false
REQUIRE_SIGNATURE=false
METRICS_ENABLED=true
TRACING_ENABLED=false
EOF
        print_success "Created .env.local"
    else
        print_status ".env.local already exists"
    fi
    
    # Supabase environment template
    if [ ! -f ".env.supabase.example" ]; then
        cat > .env.supabase.example << EOF
# Supabase Environment Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_API_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres
REDIS_URL=redis://localhost:6379/0
PORT=8081
DEBUG=true
JWT_SECRET=kb-jwt-secret-key-for-supabase
SUPPORTED_REGIONS=US,EU,CA,AU
DEFAULT_REGION=US
REQUIRE_APPROVAL=true
REQUIRE_SIGNATURE=true
METRICS_ENABLED=true
TRACING_ENABLED=true
EOF
        print_success "Created .env.supabase.example"
    else
        print_status ".env.supabase.example already exists"
    fi
}

# Function to build services
build_services() {
    print_gear "Building services..."
    
    if command_exists make; then
        make build
    else
        print_status "Building KB-Drug-Rules service manually..."
        if [ -d "kb-drug-rules" ]; then
            cd kb-drug-rules
            if command_exists go; then
                go mod download
                go build -o bin/kb-drug-rules ./cmd/server
                print_success "Built kb-drug-rules"
            else
                print_warning "Go not available, skipping build"
            fi
            cd ..
        fi
    fi
}

# Function to start services
start_services() {
    local mode=$1
    print_gear "Starting services in $mode mode..."
    
    case $mode in
        "docker")
            if command_exists make; then
                make run-kb-docker
            else
                print_status "Starting with docker-compose..."
                if command_exists docker-compose; then
                    docker-compose -f docker-compose.kb-only.yml up -d
                else
                    docker compose -f docker-compose.kb-only.yml up -d
                fi
            fi
            ;;
        "local")
            if command_exists make; then
                make setup-local
                make run-local
            else
                print_warning "Local setup requires manual PostgreSQL and Redis setup"
                print_status "Please run: ./scripts/setup-local-postgres.sh"
            fi
            ;;
        "dev")
            if command_exists make; then
                make run-dev
            else
                print_status "Starting development environment..."
                if command_exists docker-compose; then
                    docker-compose -f docker-compose.dev.yml up -d
                else
                    docker compose -f docker-compose.dev.yml up -d
                fi
            fi
            ;;
    esac
}

# Function to run health checks
health_check() {
    print_gear "Running health checks..."
    
    local services=("http://localhost:8081/health")
    local all_healthy=true
    
    print_status "Waiting for services to start..."
    sleep 15
    
    for service in "${services[@]}"; do
        print_status "Checking $service..."
        if curl -s -f "$service" >/dev/null 2>&1; then
            print_success "Service is healthy: $service"
        else
            print_warning "Service not ready: $service"
            all_healthy=false
        fi
    done
    
    if $all_healthy; then
        print_success "All services are healthy!"
    else
        print_warning "Some services are not ready yet"
    fi
}

# Function to run tests
run_tests() {
    print_gear "Running tests..."
    
    if command_exists make; then
        make test
    else
        print_status "Running tests manually..."
        if [ -d "kb-drug-rules" ] && command_exists go; then
            cd kb-drug-rules
            go test -v ./...
            cd ..
        fi
    fi
}

# Function to show service information
show_info() {
    print_header "$ROCKET Clinical Synthesis Hub - Knowledge Base Services"
    
    echo -e "${GREEN}Services available at:${NC}"
    echo -e "  $DATABASE KB-Drug-Rules API:    http://localhost:8081"
    echo -e "  $NETWORK Health Check:          http://localhost:8081/health"
    echo -e "  📈 Metrics:                     http://localhost:8081/metrics"
    echo -e "  $DATABASE Database (Adminer):   http://localhost:8082"
    echo -e "  📊 Prometheus:                  http://localhost:9090"
    echo -e "  📈 Grafana:                     http://localhost:3000"
    echo ""
    
    echo -e "${GREEN}Database Connection:${NC}"
    echo -e "  Host:     localhost"
    echo -e "  Port:     5433 (Docker) / 5432 (Local)"
    echo -e "  Database: kb_drug_rules"
    echo -e "  Username: kb_drug_rules_user"
    echo -e "  Password: kb_password"
    echo ""
    
    echo -e "${GREEN}Quick Test Commands:${NC}"
    echo -e "  curl http://localhost:8081/health"
    echo -e "  curl http://localhost:8081/v1/items/metformin"
    echo ""
    
    echo -e "${GREEN}Management Commands:${NC}"
    echo -e "  make help                       # Show all available commands"
    echo -e "  make stop-kb                    # Stop services"
    echo -e "  make logs-kb                    # View logs"
    echo -e "  make health                     # Check service health"
    echo -e "  make test                       # Run tests"
    echo ""
}

# Function to show help
show_help() {
    echo -e "${CYAN}Clinical Synthesis Hub - Knowledge Base Services Initializer${NC}"
    echo ""
    echo "Usage: ./init [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  --mode MODE          Setup mode: docker, local, dev (default: docker)"
    echo "  --skip-prereq        Skip prerequisite checks"
    echo "  --skip-build         Skip building services"
    echo "  --skip-start         Skip starting services"
    echo "  --skip-test          Skip running tests"
    echo "  --quick              Quick setup (docker mode, skip tests)"
    echo "  --info-only          Show service information only"
    echo "  --help               Show this help message"
    echo ""
    echo "Modes:"
    echo "  docker              Full Docker setup (recommended)"
    echo "  local               Local development setup"
    echo "  dev                 Full development environment"
    echo ""
    echo "Examples:"
    echo "  ./init                           # Full Docker setup"
    echo "  ./init --quick                   # Quick Docker setup"
    echo "  ./init --mode local              # Local development setup"
    echo "  ./init --mode dev --skip-build   # Dev setup without building"
    echo ""
}

# Main initialization function
main() {
    local mode="docker"
    local skip_prereq=false
    local skip_build=false
    local skip_start=false
    local skip_test=false
    local quick=false
    local info_only=false
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --mode)
                mode="$2"
                shift 2
                ;;
            --skip-prereq)
                skip_prereq=true
                shift
                ;;
            --skip-build)
                skip_build=true
                shift
                ;;
            --skip-start)
                skip_start=true
                shift
                ;;
            --skip-test)
                skip_test=true
                shift
                ;;
            --quick)
                quick=true
                skip_test=true
                shift
                ;;
            --info-only)
                info_only=true
                shift
                ;;
            --help|-h)
                show_help
                exit 0
                ;;
            *)
                print_error "Unknown option: $1"
                show_help
                exit 1
                ;;
        esac
    done
    
    # Navigate to script directory
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    cd "$SCRIPT_DIR"
    
    # Show info only if requested
    if $info_only; then
        show_info
        exit 0
    fi
    
    # Start initialization
    print_header "$ROCKET Clinical Synthesis Hub - KB Services Initialization"
    
    echo -e "${GREEN}Initializing Knowledge Base Services...${NC}"
    echo -e "${GREEN}Mode: $mode${NC}"
    echo ""
    
    # Check prerequisites
    if ! $skip_prereq; then
        if ! check_prerequisites; then
            print_warning "Some prerequisites are missing"
            read -p "Would you like to see installation instructions? (y/N): " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                install_prerequisites
                print_status "Please install missing prerequisites and run the init script again"
                exit 1
            fi
        fi
    fi
    
    # Setup directories and environment
    setup_directories
    setup_environment
    
    # Generate keys if using local or Supabase setup
    if [[ "$mode" != "docker" ]]; then
        if command_exists openssl; then
            generate_keys
        else
            print_warning "OpenSSL not found, skipping key generation"
        fi
    fi
    
    # Build services
    if ! $skip_build; then
        build_services
    fi
    
    # Start services
    if ! $skip_start; then
        start_services "$mode"
        health_check
    fi
    
    # Run tests
    if ! $skip_test; then
        run_tests
    fi
    
    # Show final information
    print_header "$CHECK Setup Complete!"
    show_info
    
    if $quick; then
        echo -e "${YELLOW}$INFO Quick setup completed. Run './init --mode $mode --skip-build --skip-start' to see full options.${NC}"
    fi
}

# Run main function with all arguments
main "$@"