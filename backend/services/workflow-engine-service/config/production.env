# Production Environment Configuration for Calculate > Validate > Commit Workflow

# Service Configuration
SERVICE_NAME=workflow-engine-service
SERVICE_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8050
API_PREFIX=/api/v1

# Database Configuration
DATABASE_URL=postgresql://workflow_user:secure_password@postgresql:5432/workflow_proposals
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# External Service URLs
SAFETY_GATEWAY_URL=http://safety-gateway:8080
MEDICATION_SERVICE_URL=http://medication-service:8004
CONTEXT_SERVICE_URL=http://context-service:8011

# Authentication
JWT_SECRET_KEY=your-production-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# Monitoring Configuration
ENABLE_PROMETHEUS_METRICS=true
PROMETHEUS_PORT=8051
ENABLE_HEALTH_CHECKS=true
HEALTH_CHECK_INTERVAL_SECONDS=30

# Performance Configuration
WORKFLOW_TIMEOUT_SECONDS=30
MAX_CONCURRENT_WORKFLOWS=100
CALCULATE_TIMEOUT_MS=175
VALIDATE_TIMEOUT_MS=100
COMMIT_TIMEOUT_MS=50

# Tracing Configuration
ENABLE_DISTRIBUTED_TRACING=true
JAEGER_ENDPOINT=http://jaeger:14268/api/traces
TRACE_SAMPLE_RATE=0.1

# Logging Configuration
LOG_FORMAT=json
LOG_STRUCTURED=true
LOG_FILE_PATH=/var/log/workflow-engine/app.log
LOG_RETENTION_DAYS=30

# Security Configuration
CORS_ORIGINS=["http://localhost:4000", "https://cardiofit.clinical-synthesis-hub.com"]
ALLOWED_HOSTS=["localhost", "workflow-engine", "*.clinical-synthesis-hub.com"]
RATE_LIMIT_REQUESTS_PER_MINUTE=1000

# Redis Configuration (for caching and session management)
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL_SECONDS=300

# Kafka Configuration (for event publishing)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_WORKFLOW_EVENTS=workflow-events
KAFKA_TOPIC_VALIDATION_EVENTS=validation-events
KAFKA_PRODUCER_BATCH_SIZE=16384
KAFKA_PRODUCER_LINGER_MS=10

# Alert Configuration
ALERT_EMAIL_ENABLED=true
ALERT_SMTP_HOST=smtp.clinical-synthesis-hub.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USERNAME=alerts@clinical-synthesis-hub.com
ALERT_SMTP_PASSWORD=your-smtp-password
ALERT_FROM_EMAIL=workflow-alerts@clinical-synthesis-hub.com
ALERT_TO_EMAILS=["ops@clinical-synthesis-hub.com", "dev@clinical-synthesis-hub.com"]

# Resource Limits
MAX_MEMORY_MB=2048
MAX_CPU_CORES=4
MAX_FILE_DESCRIPTORS=65536

# Backup and Recovery
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=90
BACKUP_S3_BUCKET=cardiofit-workflow-backups
BACKUP_S3_REGION=us-east-1

# Compliance and Audit
AUDIT_LOG_ENABLED=true
AUDIT_LOG_LEVEL=INFO
PHI_ENCRYPTION_ENABLED=true
DATA_RETENTION_DAYS=2555  # 7 years for medical records
HIPAA_COMPLIANCE_ENABLED=true

# Circuit Breaker Configuration
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=60
CIRCUIT_BREAKER_TIMEOUT_SECONDS=10