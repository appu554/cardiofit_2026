# Workflow Engine Service - Environment Configuration Template
# Copy this file to .env and configure with your actual values

# Service Configuration
SERVICE_NAME=workflow-engine-service
SERVICE_PORT=8017
DEBUG=true
LOG_LEVEL=info

# Database Configuration (PostgreSQL)
DATABASE_URL=postgres://workflow_user:workflow_password@localhost:5432/workflow_engine?sslmode=disable
DATABASE_MAX_CONNECTIONS=10
DATABASE_MIN_CONNECTIONS=5
DATABASE_ACQUIRE_TIMEOUT=30s
DATABASE_IDLE_TIMEOUT=600s
DATABASE_MAX_LIFETIME=1800s

# External Service URLs
AUTH_SERVICE_URL=http://localhost:8001
MEDICATION_SERVICE_URL=http://localhost:8004
SAFETY_GATEWAY_URL=http://localhost:8018
FLOW2_GO_URL=http://localhost:8080
FLOW2_RUST_URL=http://localhost:8090
CONTEXT_GATEWAY_URL=http://localhost:8016

# Google Cloud Healthcare API (optional)
USE_GOOGLE_HEALTHCARE_API=false
GOOGLE_CLOUD_PROJECT=cardiofit-905a8
GOOGLE_CLOUD_LOCATION=asia-south1
GOOGLE_CLOUD_DATASET=clinical-synthesis-hub
GOOGLE_CLOUD_FHIR_STORE=fhir-store
GOOGLE_APPLICATION_CREDENTIALS=credentials/google-credentials.json

# Camunda Configuration (optional)
USE_CAMUNDA_CLOUD=false
CAMUNDA_ENGINE_URL=http://localhost:8080/engine-rest
CAMUNDA_CLOUD_CLIENT_ID=
CAMUNDA_CLOUD_CLIENT_SECRET=
CAMUNDA_CLOUD_CLUSTER_ID=
CAMUNDA_CLOUD_REGION=
CAMUNDA_CLOUD_AUTHORIZATION_SERVER_URL=https://login.cloud.camunda.io/oauth/token

# Workflow Engine Configuration
WORKFLOW_EXECUTION_TIMEOUT=3600s
WORKFLOW_TASK_ASSIGNMENT_TIMEOUT=86400s
WORKFLOW_EVENT_POLLING_INTERVAL=30s
WORKFLOW_TASK_POLLING_INTERVAL=10s
WORKFLOW_MOCK_MODE=false
WORKFLOW_ENABLE_WEBHOOKS=true
WORKFLOW_ENABLE_FHIR_MONITORING=true

# Performance Targets (milliseconds)
PERFORMANCE_CALCULATE_TARGET_MS=175
PERFORMANCE_VALIDATE_TARGET_MS=100
PERFORMANCE_COMMIT_TARGET_MS=50
PERFORMANCE_TOTAL_TARGET_MS=325

# Monitoring and Observability
MONITORING_PROMETHEUS_ENABLED=true
MONITORING_JAEGER_ENDPOINT=http://localhost:14268/api/traces
MONITORING_METRICS_PORT=9090
MONITORING_HEALTH_CHECK_INTERVAL=30s

# Security Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-256-bits
JWT_EXPIRATION=24h

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=100

# Redis Configuration (for caching and sessions)
REDIS_URL=redis://:redis_password@localhost:6379/0
REDIS_PASSWORD=redis_password

# Development/Testing Flags
MOCK_EXTERNAL_SERVICES=false
ENABLE_CORS=true
ENABLE_REQUEST_LOGGING=true
ENABLE_METRICS_ENDPOINT=true