# Medication Service V2 Environment Configuration

# Server Configuration
SERVER_PORT=8009
GRAPHQL_PORT=8005
GRPC_PORT=50005

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medication_service
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# Google Cloud Healthcare API Configuration (from patient-service)
USE_GOOGLE_HEALTHCARE_API=true
GOOGLE_CLOUD_PROJECT_ID=cardiofit-905a8
GOOGLE_CLOUD_LOCATION=asia-south1
GOOGLE_CLOUD_DATASET_ID=clinical-synthesis-hub
GOOGLE_CLOUD_FHIR_STORE_ID=fhir-store
GOOGLE_CLOUD_CREDENTIALS_PATH=credentials/google-credentials.json

# Alternative: Use environment variable for credentials (JSON string)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# Or set GOOGLE_APPLICATION_CREDENTIALS_JSON with the JSON content

# External Services
CONTEXT_SERVICE_URL=http://localhost:8007
WORKFLOW_ENGINE_URL=http://localhost:8020
CLINICAL_ENGINE_URL=http://localhost:8090

# Knowledge Base Services
KB_DRUG_RULES_URL=http://localhost:8081
KB_GUIDELINES_URL=http://localhost:8084

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Monitoring
METRICS_ENABLED=true
TRACING_ENABLED=false
TRACING_ENDPOINT=localhost:6831

# Performance
ENABLE_CACHE=true
CACHE_TTL=3600
MAX_WORKERS=10
QUEUE_SIZE=100