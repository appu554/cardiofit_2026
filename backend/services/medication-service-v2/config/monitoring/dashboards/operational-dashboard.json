{
  "dashboard": {
    "id": null,
    "title": "Medication Service V2 - Operational Dashboard",
    "tags": ["healthcare", "medication-service", "operational"],
    "style": "dark",
    "timezone": "UTC",
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Service Overview",
        "type": "stat",
        "gridPos": {"h": 6, "w": 24, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "up{job=\"medication-service-v2\"}",
            "legendFormat": "Service Status",
            "refId": "A"
          },
          {
            "expr": "medication_service_http_requests_total",
            "legendFormat": "Total Requests",
            "refId": "B"
          },
          {
            "expr": "rate(medication_service_http_requests_total[5m]) * 60",
            "legendFormat": "Requests/min",
            "refId": "C"
          },
          {
            "expr": "rate(medication_service_errors_total[5m]) / rate(medication_service_http_requests_total[5m]) * 100",
            "legendFormat": "Error Rate %",
            "refId": "D"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 80},
                {"color": "red", "value": 90}
              ]
            },
            "unit": "none"
          }
        }
      },
      {
        "id": 2,
        "title": "Request Rate (req/min)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
        "targets": [
          {
            "expr": "rate(medication_service_http_requests_total[5m]) * 60",
            "legendFormat": "{{method}} {{endpoint}}",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "Requests per minute",
            "min": 0
          },
          {"show": false}
        ],
        "legend": {"show": true, "rightSide": true}
      },
      {
        "id": 3,
        "title": "Response Time Percentiles",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(medication_service_http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "50th percentile",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(medication_service_http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "95th percentile",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(medication_service_http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "99th percentile",
            "refId": "C"
          }
        ],
        "yAxes": [
          {
            "label": "Response Time (seconds)",
            "min": 0
          },
          {"show": false}
        ],
        "thresholds": [
          {
            "value": 0.25,
            "colorMode": "critical",
            "op": "gt",
            "fill": true,
            "line": true
          }
        ]
      },
      {
        "id": 4,
        "title": "Error Rate by Type",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
        "targets": [
          {
            "expr": "rate(medication_service_errors_total[5m])",
            "legendFormat": "{{error_type}} - {{component}}",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "Errors per second",
            "min": 0
          },
          {"show": false}
        ]
      },
      {
        "id": 5,
        "title": "Database & Cache Performance",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
        "targets": [
          {
            "expr": "medication_service_database_connections_active",
            "legendFormat": "DB Connections",
            "refId": "A"
          },
          {
            "expr": "medication_service_redis_connections_active",
            "legendFormat": "Redis Connections",
            "refId": "B"
          },
          {
            "expr": "medication_service_cache_hit_ratio",
            "legendFormat": "Cache Hit Ratio ({{cache_type}})",
            "refId": "C"
          }
        ],
        "yAxes": [
          {
            "label": "Count / Ratio",
            "min": 0
          },
          {"show": false}
        ]
      },
      {
        "id": 6,
        "title": "Business Metrics",
        "type": "stat",
        "gridPos": {"h": 6, "w": 24, "x": 0, "y": 22},
        "targets": [
          {
            "expr": "increase(medication_service_proposals_total[1h])",
            "legendFormat": "Proposals (1h)",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(medication_service_proposal_processing_duration_seconds_bucket[5m]))",
            "legendFormat": "Proposal Processing P95 (s)",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.95, rate(medication_service_recipe_resolution_duration_seconds_bucket[5m]))",
            "legendFormat": "Recipe Resolution P95 (s)",
            "refId": "C"
          },
          {
            "expr": "histogram_quantile(0.95, rate(medication_service_clinical_calculation_duration_seconds_bucket[5m]))",
            "legendFormat": "Clinical Calc P95 (s)",
            "refId": "D"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 0.1},
                {"color": "red", "value": 0.25}
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Workflow Performance",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
        "targets": [
          {
            "expr": "rate(medication_service_recipe_resolution_duration_seconds_sum[5m]) / rate(medication_service_recipe_resolution_duration_seconds_count[5m])",
            "legendFormat": "Recipe Resolution Avg",
            "refId": "A"
          },
          {
            "expr": "rate(medication_service_snapshot_creation_duration_seconds_sum[5m]) / rate(medication_service_snapshot_creation_duration_seconds_count[5m])",
            "legendFormat": "Snapshot Creation Avg",
            "refId": "B"
          },
          {
            "expr": "rate(medication_service_clinical_calculation_duration_seconds_sum[5m]) / rate(medication_service_clinical_calculation_duration_seconds_count[5m])",
            "legendFormat": "Clinical Calculation Avg",
            "refId": "C"
          }
        ],
        "yAxes": [
          {
            "label": "Average Duration (seconds)",
            "min": 0
          },
          {"show": false}
        ],
        "thresholds": [
          {
            "value": 0.1,
            "colorMode": "critical",
            "op": "gt"
          }
        ]
      },
      {
        "id": 8,
        "title": "System Resources",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
        "targets": [
          {
            "expr": "process_resident_memory_bytes",
            "legendFormat": "Memory Usage",
            "refId": "A"
          },
          {
            "expr": "rate(process_cpu_seconds_total[5m]) * 100",
            "legendFormat": "CPU Usage %",
            "refId": "B"
          },
          {
            "expr": "go_goroutines",
            "legendFormat": "Goroutines",
            "refId": "C"
          }
        ],
        "yAxes": [
          {
            "label": "Usage",
            "min": 0
          },
          {"show": false}
        ]
      }
    ],
    "templating": {
      "list": [
        {
          "name": "instance",
          "type": "query",
          "query": "label_values(medication_service_http_requests_total, instance)",
          "current": {
            "selected": false,
            "text": "All",
            "value": "$__all"
          },
          "includeAll": true
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Deployments",
          "datasource": "Prometheus",
          "expr": "increase(medication_service_build_info[1m])",
          "step": "60s",
          "iconColor": "blue",
          "tags": ["deployment"]
        }
      ]
    }
  }
}