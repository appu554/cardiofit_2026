{
  "info": {
    "name": "Organization Management Service",
    "description": "API collection for testing the Organization Management Service endpoints",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8012",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "organization_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      },
      "response": []
    },
    {
      "name": "Create Organization",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "    const response = pm.response.json();",
              "    if (response.id) {",
              "        pm.collectionVariables.set('organization_id', response.id);",
              "        console.log('Organization ID saved:', response.id);",
              "    }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"City General Hospital\",\n  \"legal_name\": \"City General Hospital Inc.\",\n  \"trading_name\": \"City General\",\n  \"organization_type\": \"hospital\",\n  \"active\": true,\n  \"telecom\": [\n    {\n      \"system\": \"phone\",\n      \"value\": \"+1-555-123-4567\",\n      \"use\": \"work\"\n    },\n    {\n      \"system\": \"email\",\n      \"value\": \"info@citygeneral.com\",\n      \"use\": \"work\"\n    }\n  ],\n  \"address\": [\n    {\n      \"use\": \"work\",\n      \"type\": \"physical\",\n      \"line\": [\"123 Healthcare Drive\"],\n      \"city\": \"Medical City\",\n      \"state\": \"CA\",\n      \"postal_code\": \"90210\",\n      \"country\": \"US\"\n    }\n  ],\n  \"website_url\": \"https://citygeneral.com\",\n  \"tax_id\": \"12-3456789\",\n  \"license_number\": \"HL-2023-001\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/organizations",
          "host": ["{{base_url}}"],
          "path": ["api", "organizations"]
        }
      },
      "response": []
    },
    {
      "name": "Get Organization by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/organizations/{{organization_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "organizations", "{{organization_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "Update Organization",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Updated City General Hospital\",\n  \"website_url\": \"https://updated-citygeneral.com\",\n  \"active\": true\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/organizations/{{organization_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "organizations", "{{organization_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "Search Organizations",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/organizations?name=City&type=hospital&active=true",
          "host": ["{{base_url}}"],
          "path": ["api", "organizations"],
          "query": [
            {
              "key": "name",
              "value": "City"
            },
            {
              "key": "type",
              "value": "hospital"
            },
            {
              "key": "active",
              "value": "true"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Submit for Verification",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"documents\": [\n    \"https://example.com/license.pdf\",\n    \"https://example.com/registration.pdf\"\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/organizations/{{organization_id}}/verify",
          "host": ["{{base_url}}"],
          "path": ["api", "organizations", "{{organization_id}}", "verify"]
        }
      },
      "response": []
    },
    {
      "name": "Approve Organization",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"notes\": \"Organization verified and approved for operation\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/organizations/{{organization_id}}/approve",
          "host": ["{{base_url}}"],
          "path": ["api", "organizations", "{{organization_id}}", "approve"]
        }
      },
      "response": []
    },
    {
      "name": "Delete Organization",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/organizations/{{organization_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "organizations", "{{organization_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "GraphQL - Get Organization",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"query GetOrganization($id: ID!) { organization(id: $id) { id name organizationType status telecom { system value use } address { line city state postalCode country } } }\",\n  \"variables\": {\n    \"id\": \"{{organization_id}}\"\n  }\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/federation",
          "host": ["{{base_url}}"],
          "path": ["api", "federation"]
        }
      },
      "response": []
    },
    {
      "name": "GraphQL - Search Organizations",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"query SearchOrganizations($name: String, $type: OrganizationType) { organizations(name: $name, organizationType: $type) { organizations { id name organizationType status } totalCount hasMore } }\",\n  \"variables\": {\n    \"name\": \"City\",\n    \"type\": \"HOSPITAL\"\n  }\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/federation",
          "host": ["{{base_url}}"],
          "path": ["api", "federation"]
        }
      },
      "response": []
    },
    {
      "name": "GraphQL - Create Organization",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"mutation CreateOrganization($data: OrganizationInput!) { createOrganization(organizationData: $data) { id name status } }\",\n  \"variables\": {\n    \"data\": {\n      \"name\": \"GraphQL Test Hospital\",\n      \"organizationType\": \"HOSPITAL\",\n      \"active\": true\n    }\n  }\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/federation",
          "host": ["{{base_url}}"],
          "path": ["api", "federation"]
        }
      },
      "response": []
    }
  ]
}
