{
  "dashboard": {
    "id": null,
    "title": "Safety Gateway Platform - Production Dashboard",
    "tags": ["safety-gateway", "clinical", "monitoring"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "System Overview",
        "type": "stat",
        "targets": [
          {
            "expr": "safety_gateway_requests_total",
            "legendFormat": "Total Requests"
          },
          {
            "expr": "rate(safety_gateway_requests_total[5m])",
            "legendFormat": "Request Rate"
          },
          {
            "expr": "safety_gateway_requests_in_flight",
            "legendFormat": "Active Requests"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Response Time Distribution",
        "type": "heatmap",
        "targets": [
          {
            "expr": "rate(safety_gateway_request_duration_seconds_bucket[5m])",
            "legendFormat": "{{le}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "Safety Decisions by Status",
        "type": "piechart",
        "targets": [
          {
            "expr": "sum by (status) (safety_gateway_decisions_total)",
            "legendFormat": "{{status}}"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Risk Score Distribution",
        "type": "histogram",
        "targets": [
          {
            "expr": "safety_gateway_risk_score_distribution_bucket",
            "legendFormat": "Risk Score {{le}}"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8}
      },
      {
        "id": 5,
        "title": "Engine Health Status",
        "type": "stat",
        "targets": [
          {
            "expr": "safety_gateway_engine_health_status",
            "legendFormat": "{{engine_name}}"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8}
      },
      {
        "id": 6,
        "title": "CAE Service Performance",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(safety_gateway_cae_requests_total[5m])",
            "legendFormat": "CAE Request Rate"
          },
          {
            "expr": "histogram_quantile(0.95, rate(safety_gateway_cae_request_duration_seconds_bucket[5m]))",
            "legendFormat": "CAE 95th Percentile Latency"
          },
          {
            "expr": "safety_gateway_cae_connection_status",
            "legendFormat": "CAE Connection Status"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 7,
        "title": "Error Rates",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(safety_gateway_engine_errors_total[5m])",
            "legendFormat": "{{engine_name}} - {{error_type}}"
          },
          {
            "expr": "rate(safety_gateway_requests_total{status_code!~\"2..\"}[5m])",
            "legendFormat": "HTTP Errors"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      },
      {
        "id": 8,
        "title": "Override Token Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(safety_gateway_override_tokens_used_total[5m])",
            "legendFormat": "{{reason}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24}
      },
      {
        "id": 9,
        "title": "Cache Performance",
        "type": "graph",
        "targets": [
          {
            "expr": "safety_gateway_cache_hit_rate",
            "legendFormat": "{{cache_level}} - {{cache_type}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24}
      },
      {
        "id": 10,
        "title": "Circuit Breaker Status",
        "type": "stat",
        "targets": [
          {
            "expr": "safety_gateway_circuit_breaker_status",
            "legendFormat": "{{service}} - {{endpoint}}"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 32}
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "30s",
    "schemaVersion": 30,
    "version": 1
  }
}
