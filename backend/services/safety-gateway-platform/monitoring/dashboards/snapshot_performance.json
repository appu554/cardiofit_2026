{
  "dashboard": {
    "id": null,
    "title": "Safety Gateway - Snapshot Performance Dashboard",
    "tags": ["safety-gateway", "snapshot", "performance", "phase3"],
    "timezone": "browser",
    "refresh": "10s",
    "schemaVersion": 37,
    "version": 1,
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Performance Overview",
        "type": "stat",
        "targets": [
          {
            "expr": "request_latency_p95_seconds{request_type=\"snapshot_request\"}",
            "legendFormat": "P95 Latency",
            "refId": "A"
          },
          {
            "expr": "cache_hit_rate_current{cache_level=\"overall\"}",
            "legendFormat": "Cache Hit Rate",
            "refId": "B"
          },
          {
            "expr": "target_latency_compliance_ratio{service_tier=\"standard\"}",
            "legendFormat": "SLA Compliance",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "green", "value": 85}
              ]
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "P95 Latency"},
              "properties": [
                {"id": "unit", "value": "s"},
                {"id": "thresholds", "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": 0},
                    {"color": "yellow", "value": 0.15},
                    {"color": "red", "value": 0.2}
                  ]
                }}
              ]
            }
          ]
        },
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
        "options": {
          "orientation": "horizontal",
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          },
          "displayMode": "basic",
          "colorMode": "background"
        }
      },
      {
        "id": 2,
        "title": "Request Latency Distribution",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(snapshot_processing_duration_seconds_bucket[5m]))",
            "legendFormat": "P50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(snapshot_processing_duration_seconds_bucket[5m]))",
            "legendFormat": "P95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(snapshot_processing_duration_seconds_bucket[5m]))",
            "legendFormat": "P99",
            "refId": "C"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "spanNulls": false,
              "fillOpacity": 10,
              "gradientMode": "opacity"
            }
          }
        },
        "options": {
          "tooltip": {"mode": "single", "sort": "none"},
          "legend": {"displayMode": "list", "placement": "bottom"}
        }
      },
      {
        "id": 3,
        "title": "Cache Performance",
        "type": "timeseries",
        "targets": [
          {
            "expr": "cache_hit_rate_current{cache_level=\"l1\"}",
            "legendFormat": "L1 Hit Rate",
            "refId": "A"
          },
          {
            "expr": "cache_hit_rate_current{cache_level=\"l2\"}",
            "legendFormat": "L2 Hit Rate",
            "refId": "B"
          },
          {
            "expr": "cache_hit_rate_current{cache_level=\"overall\"}",
            "legendFormat": "Overall Hit Rate",
            "refId": "C"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "green", "value": 85}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Snapshot Request Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(snapshot_requests_total[5m])",
            "legendFormat": "Requests/sec",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 6, "w": 8, "x": 0, "y": 16},
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        }
      },
      {
        "id": 5,
        "title": "Cache Operations",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(cache_operations_total{operation=\"get\"}[5m])",
            "legendFormat": "Get Operations/sec",
            "refId": "A"
          },
          {
            "expr": "rate(cache_operations_total{operation=\"set\"}[5m])",
            "legendFormat": "Set Operations/sec",
            "refId": "B"
          },
          {
            "expr": "rate(cache_operations_total{operation=\"delete\"}[5m])",
            "legendFormat": "Delete Operations/sec",
            "refId": "C"
          }
        ],
        "gridPos": {"h": 6, "w": 8, "x": 8, "y": 16},
        "fieldConfig": {
          "defaults": {
            "unit": "ops"
          }
        }
      },
      {
        "id": 6,
        "title": "System Memory Pressure",
        "type": "gauge",
        "targets": [
          {
            "expr": "system_memory_pressure_ratio",
            "legendFormat": "Memory Pressure",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 6, "w": 8, "x": 16, "y": 16},
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 0.7},
                {"color": "red", "value": 0.9}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          },
          "orientation": "auto",
          "displayMode": "gradient"
        }
      },
      {
        "id": 7,
        "title": "Cache Memory Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "cache_memory_usage_bytes{cache_level=\"l1\"}",
            "legendFormat": "L1 Memory",
            "refId": "A"
          },
          {
            "expr": "cache_memory_usage_bytes{cache_level=\"l2\"}",
            "legendFormat": "L2 Memory",
            "refId": "B"
          }
        ],
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 22},
        "fieldConfig": {
          "defaults": {
            "unit": "bytes"
          }
        }
      },
      {
        "id": 8,
        "title": "Compression Performance",
        "type": "timeseries",
        "targets": [
          {
            "expr": "snapshot_compression_ratio{compression_algorithm=\"gzip\"}",
            "legendFormat": "Gzip Ratio",
            "refId": "A"
          },
          {
            "expr": "snapshot_compression_ratio{compression_algorithm=\"zstd\"}",
            "legendFormat": "Zstd Ratio",
            "refId": "B"
          },
          {
            "expr": "rate(compression_savings_bytes_total[5m])",
            "legendFormat": "Savings Rate",
            "refId": "C"
          }
        ],
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 22},
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Savings Rate"},
              "properties": [
                {"id": "unit", "value": "Bps"}
              ]
            }
          ]
        }
      },
      {
        "id": 9,
        "title": "Concurrent Requests",
        "type": "stat",
        "targets": [
          {
            "expr": "concurrent_requests_current",
            "legendFormat": "Active Requests",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 28},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 50},
                {"color": "red", "value": 100}
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "title": "SLA Violations",
        "type": "stat",
        "targets": [
          {
            "expr": "increase(sla_violations_total[1h])",
            "legendFormat": "Violations (1h)",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 28},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 5}
              ]
            }
          }
        }
      },
      {
        "id": 11,
        "title": "Cache Optimization Events",
        "type": "stat",
        "targets": [
          {
            "expr": "increase(cache_optimization_events_total[1h])",
            "legendFormat": "Optimizations (1h)",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 28},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "colorMode": "background",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "grey", "value": 0},
                {"color": "blue", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 12,
        "title": "Performance Score",
        "type": "gauge",
        "targets": [
          {
            "expr": "user_experience_score{metric_category=\"performance\"}",
            "legendFormat": "Performance Score",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 28},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "green", "value": 90}
              ]
            }
          }
        },
        "options": {
          "orientation": "auto",
          "displayMode": "gradient"
        }
      },
      {
        "id": 13,
        "title": "Engine Performance Comparison",
        "type": "bargauge",
        "targets": [
          {
            "expr": "engine_performance_score{metric_type=\"latency\"}",
            "legendFormat": "{{engine_id}} Latency",
            "refId": "A"
          },
          {
            "expr": "engine_performance_score{metric_type=\"throughput\"}",
            "legendFormat": "{{engine_id}} Throughput",
            "refId": "B"
          }
        ],
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 32},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 60},
                {"color": "green", "value": 80}
              ]
            }
          }
        },
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient"
        }
      },
      {
        "id": 14,
        "title": "GC Pause Times",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(gc_pause_time_seconds_bucket[5m]))",
            "legendFormat": "P95 GC Pause",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.99, rate(gc_pause_time_seconds_bucket[5m]))",
            "legendFormat": "P99 GC Pause",
            "refId": "B"
          }
        ],
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 32},
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 0.01},
                {"color": "red", "value": 0.1}
              ]
            }
          }
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "instance",
          "type": "query",
          "query": "label_values(snapshot_requests_total, instance)",
          "refresh": 1,
          "includeAll": true,
          "multi": true
        },
        {
          "name": "cache_level",
          "type": "query", 
          "query": "label_values(cache_hit_rate_current, cache_level)",
          "refresh": 1,
          "includeAll": true,
          "multi": true
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Cache Optimizations",
          "enable": true,
          "iconColor": "blue",
          "target": {
            "expr": "changes(cache_optimization_events_total[1m]) > 0"
          }
        },
        {
          "name": "SLA Violations",
          "enable": true,
          "iconColor": "red",
          "target": {
            "expr": "changes(sla_violations_total[1m]) > 0"
          }
        }
      ]
    }
  }
}