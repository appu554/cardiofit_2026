{
  "dashboard": {
    "id": null,
    "title": "Safety Gateway - Cache Analytics Dashboard",
    "tags": ["safety-gateway", "cache", "analytics", "phase3"],
    "timezone": "browser",
    "refresh": "30s",
    "schemaVersion": 37,
    "version": 1,
    "time": {
      "from": "now-4h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Cache Performance Summary",
        "type": "stat",
        "targets": [
          {
            "expr": "cache_hit_rate_current{cache_level=\"overall\", time_window=\"1h\"}",
            "legendFormat": "Hit Rate (1h)",
            "refId": "A"
          },
          {
            "expr": "rate(cache_operations_total{operation=\"get\"}[5m])",
            "legendFormat": "Get Ops/sec",
            "refId": "B"
          },
          {
            "expr": "cache_eviction_rate_per_minute{cache_level=\"l1\"}",
            "legendFormat": "L1 Evictions/min",
            "refId": "C"
          },
          {
            "expr": "cache_compression_ratio{cache_level=\"l1\"}",
            "legendFormat": "Compression Ratio",
            "refId": "D"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "green", "value": 85}
              ]
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Hit Rate (1h)"},
              "properties": [
                {"id": "unit", "value": "percent"},
                {"id": "decimals", "value": 1}
              ]
            },
            {
              "matcher": {"id": "byName", "options": "Get Ops/sec"},
              "properties": [
                {"id": "unit", "value": "ops"},
                {"id": "thresholds", "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": 0},
                    {"color": "blue", "value": 100}
                  ]
                }}
              ]
            }
          ]
        },
        "options": {
          "orientation": "horizontal",
          "colorMode": "background"
        }
      },
      {
        "id": 2,
        "title": "Cache Hit Rate Trends",
        "type": "timeseries",
        "targets": [
          {
            "expr": "cache_hit_rate_current{cache_level=\"l1\", time_window=\"5m\"}",
            "legendFormat": "L1 Cache (5m window)",
            "refId": "A"
          },
          {
            "expr": "cache_hit_rate_current{cache_level=\"l2\", time_window=\"5m\"}",
            "legendFormat": "L2 Cache (5m window)",
            "refId": "B"
          },
          {
            "expr": "cache_hit_rate_current{cache_level=\"overall\", time_window=\"5m\"}",
            "legendFormat": "Overall (5m window)",
            "refId": "C"
          },
          {
            "expr": "cache_hit_rate_current{cache_level=\"overall\", time_window=\"1h\"}",
            "legendFormat": "Overall (1h window)",
            "refId": "D"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 10
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 70},
                {"color": "yellow", "value": 85},
                {"color": "green", "value": 95}
              ]
            }
          }
        },
        "options": {
          "tooltip": {"mode": "multi", "sort": "desc"},
          "legend": {"displayMode": "list", "placement": "bottom"}
        }
      },
      {
        "id": 3,
        "title": "Cache Access Patterns",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(cache_access_patterns_total{pattern_type=\"hot_data\"}[5m])",
            "legendFormat": "Hot Data Access",
            "refId": "A"
          },
          {
            "expr": "rate(cache_access_patterns_total{pattern_type=\"cold_data\"}[5m])",
            "legendFormat": "Cold Data Access",
            "refId": "B"
          },
          {
            "expr": "rate(cache_access_patterns_total{pattern_type=\"temporal_locality\"}[5m])",
            "legendFormat": "Temporal Locality",
            "refId": "C"
          },
          {
            "expr": "rate(cache_access_patterns_total{pattern_type=\"spatial_locality\"}[5m])",
            "legendFormat": "Spatial Locality",
            "refId": "D"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {
              "drawStyle": "line",
              "lineWidth": 1,
              "fillOpacity": 20,
              "stacking": {"mode": "normal"}
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Cache Operation Latency",
        "type": "heatmap",
        "targets": [
          {
            "expr": "increase(cache_operation_duration_seconds_bucket{operation=\"get\"}[5m])",
            "legendFormat": "{{le}}",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "fieldConfig": {
          "defaults": {
            "custom": {
              "hideFrom": {
                "legend": false,
                "tooltip": false,
                "vis": false
              },
              "scaleDistribution": {
                "type": "linear"
              }
            }
          }
        },
        "options": {
          "calculate": true,
          "color": {
            "mode": "spectrum",
            "scheme": "Spectral",
            "steps": 128
          },
          "yAxis": {
            "axisPlacement": "left",
            "reverse": false,
            "unit": "s"
          }
        }
      },
      {
        "id": 5,
        "title": "Cache Eviction Analysis",
        "type": "piechart",
        "targets": [
          {
            "expr": "sum by (eviction_reason) (rate(cache_eviction_rate_per_minute[1h]))",
            "legendFormat": "{{eviction_reason}}",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "hideFrom": {
                "legend": false,
                "tooltip": false,
                "vis": false
              }
            }
          }
        },
        "options": {
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"],
            "fields": ""
          },
          "pieType": "pie",
          "tooltip": {"mode": "single", "sort": "none"},
          "legend": {"displayMode": "list", "placement": "right"}
        }
      },
      {
        "id": 6,
        "title": "Memory Utilization by Cache Level",
        "type": "timeseries",
        "targets": [
          {
            "expr": "cache_memory_usage_bytes{cache_level=\"l1\"} / 1024 / 1024",
            "legendFormat": "L1 Memory (MB)",
            "refId": "A"
          },
          {
            "expr": "cache_memory_usage_bytes{cache_level=\"l2\"} / 1024 / 1024",
            "legendFormat": "L2 Memory (MB)",
            "refId": "B"
          },
          {
            "expr": "(cache_memory_usage_bytes{cache_level=\"l1\"} + cache_memory_usage_bytes{cache_level=\"l2\"}) / 1024 / 1024",
            "legendFormat": "Total Memory (MB)",
            "refId": "C"
          }
        ],
        "gridPos": {"h": 6, "w": 8, "x": 0, "y": 24},
        "fieldConfig": {
          "defaults": {
            "unit": "decbytes",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Total Memory (MB)"},
              "properties": [
                {"id": "custom.drawStyle", "value": "line"},
                {"id": "custom.lineWidth", "value": 3},
                {"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}
              ]
            }
          ]
        }
      },
      {
        "id": 7,
        "title": "Cache Warming Status",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(cache_warmup_duration_seconds_bucket[10m]))",
            "legendFormat": "P95 Warmup Duration",
            "refId": "A"
          },
          {
            "expr": "rate(cache_warmup_duration_seconds_count[5m])",
            "legendFormat": "Warmup Events/sec",
            "refId": "B"
          }
        ],
        "gridPos": {"h": 6, "w": 8, "x": 8, "y": 24},
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Warmup Events/sec"},
              "properties": [
                {"id": "unit", "value": "ops"}
              ]
            }
          ]
        }
      },
      {
        "id": 8,
        "title": "Compression Effectiveness",
        "type": "stat",
        "targets": [
          {
            "expr": "cache_compression_ratio{algorithm=\"gzip\"}",
            "legendFormat": "Gzip Ratio",
            "refId": "A"
          },
          {
            "expr": "cache_compression_ratio{algorithm=\"zstd\"}",
            "legendFormat": "Zstd Ratio",
            "refId": "B"
          },
          {
            "expr": "sum(rate(compression_savings_bytes_total[1h])) / 1024 / 1024",
            "legendFormat": "Savings MB/h",
            "refId": "C"
          }
        ],
        "gridPos": {"h": 6, "w": 8, "x": 16, "y": 24},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 1},
                {"color": "yellow", "value": 2},
                {"color": "green", "value": 3}
              ]
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Savings MB/h"},
              "properties": [
                {"id": "unit", "value": "decbytes"},
                {"id": "thresholds", "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "grey", "value": 0},
                    {"color": "green", "value": 100}
                  ]
                }}
              ]
            }
          ]
        },
        "options": {
          "colorMode": "background",
          "orientation": "horizontal"
        }
      },
      {
        "id": 9,
        "title": "Cache Optimization Recommendations",
        "type": "table",
        "targets": [
          {
            "expr": "cache_recommendations_active",
            "legendFormat": "{{recommendation_type}}",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 30},
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "auto",
              "displayMode": "auto"
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Priority"},
              "properties": [
                {"id": "custom.displayMode", "value": "color-background"},
                {"id": "thresholds", "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": 1},
                    {"color": "yellow", "value": 2},
                    {"color": "red", "value": 3}
                  ]
                }}
              ]
            }
          ]
        },
        "options": {
          "showHeader": true,
          "sortBy": [
            {
              "desc": false,
              "displayName": "Priority"
            }
          ]
        }
      },
      {
        "id": 10,
        "title": "Data Age Distribution",
        "type": "barchart",
        "targets": [
          {
            "expr": "sum by (data_age) (cache_access_patterns_total{pattern_type=\"data_age\"})",
            "legendFormat": "{{data_age}}",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 30},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "orientation": "horizontal",
              "barWidth": 0.8
            },
            "color": {
              "mode": "palette-classic"
            }
          }
        },
        "options": {
          "orientation": "horizontal",
          "xTickLabelRotation": 0,
          "xTickLabelSpacing": 100
        }
      },
      {
        "id": 11,
        "title": "Cache Performance Efficiency",
        "type": "gauge",
        "targets": [
          {
            "expr": "((cache_hit_rate_current{cache_level=\"overall\"} / 100) * 0.4) + ((100 - cache_eviction_rate_per_minute{cache_level=\"l1\"}) / 100 * 0.3) + ((cache_compression_ratio{algorithm=\"gzip\"} / 5) * 0.3) * 100",
            "legendFormat": "Efficiency Score",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 38},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 60},
                {"color": "green", "value": 80}
              ]
            }
          }
        },
        "options": {
          "orientation": "auto",
          "displayMode": "gradient"
        }
      },
      {
        "id": 12,
        "title": "Cache Optimization Events Timeline",
        "type": "timeseries",
        "targets": [
          {
            "expr": "increase(cache_optimization_events_total{optimization_type=\"ttl_adjustment\"}[5m])",
            "legendFormat": "TTL Adjustments",
            "refId": "A"
          },
          {
            "expr": "increase(cache_optimization_events_total{optimization_type=\"warmup_trigger\"}[5m])",
            "legendFormat": "Warmup Triggers",
            "refId": "B"
          },
          {
            "expr": "increase(cache_optimization_events_total{optimization_type=\"compression_change\"}[5m])",
            "legendFormat": "Compression Changes",
            "refId": "C"
          },
          {
            "expr": "increase(cache_optimization_events_total{optimization_type=\"eviction_policy\"}[5m])",
            "legendFormat": "Eviction Policy Changes",
            "refId": "D"
          }
        ],
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 38},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "drawStyle": "bars",
              "barAlignment": 0,
              "fillOpacity": 80,
              "stacking": {"mode": "normal"}
            }
          }
        },
        "options": {
          "tooltip": {"mode": "multi", "sort": "desc"},
          "legend": {"displayMode": "list", "placement": "bottom"}
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "cache_level",
          "type": "query",
          "query": "label_values(cache_hit_rate_current, cache_level)",
          "refresh": 1,
          "includeAll": true,
          "multi": true,
          "current": {
            "selected": true,
            "text": "All",
            "value": "$__all"
          }
        },
        {
          "name": "time_window",
          "type": "custom",
          "options": [
            {"text": "5 minutes", "value": "5m"},
            {"text": "1 hour", "value": "1h"},
            {"text": "24 hours", "value": "24h"}
          ],
          "current": {
            "selected": true,
            "text": "1 hour",
            "value": "1h"
          }
        },
        {
          "name": "compression_algorithm",
          "type": "query",
          "query": "label_values(cache_compression_ratio, algorithm)",
          "refresh": 1,
          "includeAll": true,
          "multi": true
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Cache Warmup Events",
          "enable": true,
          "iconColor": "green",
          "target": {
            "expr": "changes(cache_warmup_duration_seconds_count[1m]) > 0",
            "step": "60s"
          }
        },
        {
          "name": "Optimization Events",
          "enable": true,
          "iconColor": "blue",
          "target": {
            "expr": "changes(cache_optimization_events_total[1m]) > 0",
            "step": "60s"
          }
        }
      ]
    }
  }
}