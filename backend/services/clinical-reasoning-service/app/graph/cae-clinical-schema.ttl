# Clinical Assertion Engine - GraphDB Schema
# Turtle RDF format for GraphDB import
# This file defines the foundational graph schema for CAE clinical intelligence

@prefix cae: <http://clinical-assertion-engine.org/ontology/> .
@prefix sct: <http://snomed.info/id/> .
@prefix rxnorm: <http://purl.bioontology.org/ontology/RXNORM/> .
@prefix loinc: <http://loinc.org/rdf/> .
@prefix fhir: <http://hl7.org/fhir/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

# ============================================================================
# CORE CLINICAL ENTITIES
# ============================================================================

# Patient Entity with Clinical Context
cae:Patient a owl:Class ;
    rdfs:label "Patient" ;
    rdfs:comment "Patient entity with comprehensive clinical context" .

cae:hasPatientId a owl:DatatypeProperty ;
    rdfs:domain cae:Patient ;
    rdfs:range xsd:string ;
    rdfs:label "Patient ID" .

cae:hasAge a owl:DatatypeProperty ;
    rdfs:domain cae:Patient ;
    rdfs:range xsd:integer ;
    rdfs:label "Patient Age" .

cae:hasGender a owl:DatatypeProperty ;
    rdfs:domain cae:Patient ;
    rdfs:range xsd:string ;
    rdfs:label "Patient Gender" .

cae:hasWeight a owl:DatatypeProperty ;
    rdfs:domain cae:Patient ;
    rdfs:range xsd:decimal ;
    rdfs:label "Patient Weight" .

# Medication Entity with RxNorm Integration
cae:Medication a owl:Class ;
    rdfs:label "Medication" ;
    rdfs:comment "Medication entity with RxNorm codes and clinical properties" .

cae:hasRxNormCode a owl:DatatypeProperty ;
    rdfs:domain cae:Medication ;
    rdfs:range xsd:string ;
    rdfs:label "RxNorm Code" .

cae:hasGenericName a owl:DatatypeProperty ;
    rdfs:domain cae:Medication ;
    rdfs:range xsd:string ;
    rdfs:label "Generic Name" .

cae:hasBrandName a owl:DatatypeProperty ;
    rdfs:domain cae:Medication ;
    rdfs:range xsd:string ;
    rdfs:label "Brand Name" .

cae:hasTherapeuticClass a owl:DatatypeProperty ;
    rdfs:domain cae:Medication ;
    rdfs:range xsd:string ;
    rdfs:label "Therapeutic Class" .

# Clinical Condition with SNOMED Integration
cae:Condition a owl:Class ;
    rdfs:label "Clinical Condition" ;
    rdfs:comment "Clinical condition with SNOMED CT codes" .

cae:hasSnomedCode a owl:DatatypeProperty ;
    rdfs:domain cae:Condition ;
    rdfs:range xsd:string ;
    rdfs:label "SNOMED CT Code" .

cae:hasConditionName a owl:DatatypeProperty ;
    rdfs:domain cae:Condition ;
    rdfs:range xsd:string ;
    rdfs:label "Condition Name" .

cae:hasSeverity a owl:DatatypeProperty ;
    rdfs:domain cae:Condition ;
    rdfs:range xsd:string ;
    rdfs:label "Condition Severity" .

# ============================================================================
# DYNAMIC CLINICAL RELATIONSHIPS (Learning Capabilities)
# ============================================================================

# Drug-Drug Interaction with Learning Properties
cae:DrugInteraction a owl:Class ;
    rdfs:label "Drug Interaction" ;
    rdfs:comment "Dynamic drug interaction with learning capabilities" .

cae:interactsWith a owl:ObjectProperty ;
    rdfs:domain cae:Medication ;
    rdfs:range cae:Medication ;
    rdfs:label "Interacts With" .

cae:hasInteractionSeverity a owl:DatatypeProperty ;
    rdfs:domain cae:DrugInteraction ;
    rdfs:range xsd:string ;
    rdfs:label "Interaction Severity" .

cae:hasConfidenceScore a owl:DatatypeProperty ;
    rdfs:domain cae:DrugInteraction ;
    rdfs:range xsd:decimal ;
    rdfs:label "Confidence Score" .

cae:hasEvidenceStrength a owl:DatatypeProperty ;
    rdfs:domain cae:DrugInteraction ;
    rdfs:range xsd:string ;
    rdfs:label "Evidence Strength" .

cae:hasOverrideRate a owl:DatatypeProperty ;
    rdfs:domain cae:DrugInteraction ;
    rdfs:range xsd:decimal ;
    rdfs:label "Override Rate" .

cae:hasOutcomeCorrelation a owl:DatatypeProperty ;
    rdfs:domain cae:DrugInteraction ;
    rdfs:range xsd:decimal ;
    rdfs:label "Outcome Correlation" .

cae:hasPatientCount a owl:DatatypeProperty ;
    rdfs:domain cae:DrugInteraction ;
    rdfs:range xsd:integer ;
    rdfs:label "Patient Count" .

cae:hasLastUpdated a owl:DatatypeProperty ;
    rdfs:domain cae:DrugInteraction ;
    rdfs:range xsd:dateTime ;
    rdfs:label "Last Updated" .

cae:hasLearningSource a owl:DatatypeProperty ;
    rdfs:domain cae:DrugInteraction ;
    rdfs:range xsd:string ;
    rdfs:label "Learning Source" .

# Clinical Assertions with Provenance
cae:ClinicalAssertion a owl:Class ;
    rdfs:label "Clinical Assertion" ;
    rdfs:comment "CAE-generated clinical assertion with full provenance" .

cae:hasAssertionId a owl:DatatypeProperty ;
    rdfs:domain cae:ClinicalAssertion ;
    rdfs:range xsd:string ;
    rdfs:label "Assertion ID" .

cae:hasAssertionType a owl:DatatypeProperty ;
    rdfs:domain cae:ClinicalAssertion ;
    rdfs:range xsd:string ;
    rdfs:label "Assertion Type" .

cae:hasAssertionSeverity a owl:DatatypeProperty ;
    rdfs:domain cae:ClinicalAssertion ;
    rdfs:range xsd:string ;
    rdfs:label "Assertion Severity" .

cae:hasAssertionConfidence a owl:DatatypeProperty ;
    rdfs:domain cae:ClinicalAssertion ;
    rdfs:range xsd:decimal ;
    rdfs:label "Assertion Confidence" .

cae:hasGeneratedAt a owl:DatatypeProperty ;
    rdfs:domain cae:ClinicalAssertion ;
    rdfs:range xsd:dateTime ;
    rdfs:label "Generated At" .

cae:basedOnEvidence a owl:ObjectProperty ;
    rdfs:domain cae:ClinicalAssertion ;
    rdfs:range cae:ClinicalEvidence ;
    rdfs:label "Based On Evidence" .

# Clinical Evidence
cae:ClinicalEvidence a owl:Class ;
    rdfs:label "Clinical Evidence" ;
    rdfs:comment "Clinical evidence supporting assertions" .

cae:hasEvidenceType a owl:DatatypeProperty ;
    rdfs:domain cae:ClinicalEvidence ;
    rdfs:range xsd:string ;
    rdfs:label "Evidence Type" .

cae:hasEvidenceSource a owl:DatatypeProperty ;
    rdfs:domain cae:ClinicalEvidence ;
    rdfs:range xsd:string ;
    rdfs:label "Evidence Source" .

# ============================================================================
# LEARNING AND OUTCOME TRACKING
# ============================================================================

# Clinical Outcomes for Learning
cae:ClinicalOutcome a owl:Class ;
    rdfs:label "Clinical Outcome" ;
    rdfs:comment "Clinical outcome for CAE learning" .

cae:hasOutcomeType a owl:DatatypeProperty ;
    rdfs:domain cae:ClinicalOutcome ;
    rdfs:range xsd:string ;
    rdfs:label "Outcome Type" .

cae:hasOutcomeSeverity a owl:DatatypeProperty ;
    rdfs:domain cae:ClinicalOutcome ;
    rdfs:range xsd:integer ;
    rdfs:label "Outcome Severity" .

cae:hasOutcomeDate a owl:DatatypeProperty ;
    rdfs:domain cae:ClinicalOutcome ;
    rdfs:range xsd:dateTime ;
    rdfs:label "Outcome Date" .

cae:resultedFrom a owl:ObjectProperty ;
    rdfs:domain cae:ClinicalOutcome ;
    rdfs:range cae:ClinicalAssertion ;
    rdfs:label "Resulted From" .

# Clinician Override Tracking
cae:ClinicalOverride a owl:Class ;
    rdfs:label "Clinical Override" ;
    rdfs:comment "Clinician override of CAE assertion for learning" .

cae:hasOverrideReason a owl:DatatypeProperty ;
    rdfs:domain cae:ClinicalOverride ;
    rdfs:range xsd:string ;
    rdfs:label "Override Reason" .

cae:hasOverrideTimestamp a owl:DatatypeProperty ;
    rdfs:domain cae:ClinicalOverride ;
    rdfs:range xsd:dateTime ;
    rdfs:label "Override Timestamp" .

cae:overrodeAssertion a owl:ObjectProperty ;
    rdfs:domain cae:ClinicalOverride ;
    rdfs:range cae:ClinicalAssertion ;
    rdfs:label "Overrode Assertion" .

cae:performedBy a owl:ObjectProperty ;
    rdfs:domain cae:ClinicalOverride ;
    rdfs:range cae:Clinician ;
    rdfs:label "Performed By" .

# Clinician Entity
cae:Clinician a owl:Class ;
    rdfs:label "Clinician" ;
    rdfs:comment "Healthcare provider entity" .

cae:hasClinicianId a owl:DatatypeProperty ;
    rdfs:domain cae:Clinician ;
    rdfs:range xsd:string ;
    rdfs:label "Clinician ID" .

cae:hasSpecialty a owl:DatatypeProperty ;
    rdfs:domain cae:Clinician ;
    rdfs:range xsd:string ;
    rdfs:label "Medical Specialty" .

cae:hasExperienceYears a owl:DatatypeProperty ;
    rdfs:domain cae:Clinician ;
    rdfs:range xsd:integer ;
    rdfs:label "Years of Experience" .

# ============================================================================
# PATIENT SIMILARITY AND CONTEXT
# ============================================================================

# Patient Similarity for Graph Intelligence
cae:similarTo a owl:ObjectProperty ;
    rdfs:domain cae:Patient ;
    rdfs:range cae:Patient ;
    rdfs:label "Similar To" .

cae:hasSimilarityScore a owl:DatatypeProperty ;
    rdfs:range xsd:decimal ;
    rdfs:label "Similarity Score" .

cae:hasSimilarityFactors a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Similarity Factors" .

# Clinical Context Relationships
cae:hasCondition a owl:ObjectProperty ;
    rdfs:domain cae:Patient ;
    rdfs:range cae:Condition ;
    rdfs:label "Has Condition" .

cae:prescribedMedication a owl:ObjectProperty ;
    rdfs:domain cae:Patient ;
    rdfs:range cae:Medication ;
    rdfs:label "Prescribed Medication" .

cae:experiencedOutcome a owl:ObjectProperty ;
    rdfs:domain cae:Patient ;
    rdfs:range cae:ClinicalOutcome ;
    rdfs:label "Experienced Outcome" .

# ============================================================================
# TEMPORAL AND ENCOUNTER CONTEXT
# ============================================================================

# Encounter Context
cae:Encounter a owl:Class ;
    rdfs:label "Clinical Encounter" ;
    rdfs:comment "Clinical encounter with temporal context" .

cae:hasEncounterId a owl:DatatypeProperty ;
    rdfs:domain cae:Encounter ;
    rdfs:range xsd:string ;
    rdfs:label "Encounter ID" .

cae:hasEncounterType a owl:DatatypeProperty ;
    rdfs:domain cae:Encounter ;
    rdfs:range xsd:string ;
    rdfs:label "Encounter Type" .

cae:hasEncounterDate a owl:DatatypeProperty ;
    rdfs:domain cae:Encounter ;
    rdfs:range xsd:dateTime ;
    rdfs:label "Encounter Date" .

cae:partOfEncounter a owl:ObjectProperty ;
    rdfs:domain cae:ClinicalAssertion ;
    rdfs:range cae:Encounter ;
    rdfs:label "Part Of Encounter" .

# Facility Context
cae:Facility a owl:Class ;
    rdfs:label "Healthcare Facility" ;
    rdfs:comment "Healthcare facility context" .

cae:hasFacilityId a owl:DatatypeProperty ;
    rdfs:domain cae:Facility ;
    rdfs:range xsd:string ;
    rdfs:label "Facility ID" .

cae:hasDepartment a owl:DatatypeProperty ;
    rdfs:domain cae:Facility ;
    rdfs:range xsd:string ;
    rdfs:label "Department" .

cae:occurredAt a owl:ObjectProperty ;
    rdfs:domain cae:Encounter ;
    rdfs:range cae:Facility ;
    rdfs:label "Occurred At" .

# ============================================================================
# LEARNING RELATIONSHIP TYPES (Phase 1 Advanced Features)
# ============================================================================

# Learning Relationships for Dynamic Intelligence
cae:OVERRODE a owl:ObjectProperty ;
    rdfs:label "Overrode" ;
    rdfs:comment "Clinician overrode this assertion" .

cae:EXPERIENCED a owl:ObjectProperty ;
    rdfs:label "Experienced" ;
    rdfs:comment "Patient experienced this outcome" .

cae:SIMILAR_TO a owl:ObjectProperty ;
    rdfs:label "Similar To" ;
    rdfs:comment "Entity is similar to another entity" .

cae:LEARNED_FROM a owl:ObjectProperty ;
    rdfs:label "Learned From" ;
    rdfs:comment "Knowledge learned from this source" .

# Temporal Pattern Storage
cae:TemporalPattern a owl:Class ;
    rdfs:label "Temporal Pattern" ;
    rdfs:comment "Time-based medication sequences and outcomes" .

cae:hasPatternId a owl:DatatypeProperty ;
    rdfs:domain cae:TemporalPattern ;
    rdfs:range xsd:string ;
    rdfs:label "Pattern ID" .

cae:hasSequenceOrder a owl:DatatypeProperty ;
    rdfs:domain cae:TemporalPattern ;
    rdfs:range xsd:integer ;
    rdfs:label "Sequence Order" .

cae:hasTimeInterval a owl:DatatypeProperty ;
    rdfs:domain cae:TemporalPattern ;
    rdfs:range xsd:duration ;
    rdfs:label "Time Interval" .

cae:hasPatternConfidence a owl:DatatypeProperty ;
    rdfs:domain cae:TemporalPattern ;
    rdfs:range xsd:decimal ;
    rdfs:label "Pattern Confidence" .

# Context Vector Storage for Patient Similarity
cae:ContextVector a owl:Class ;
    rdfs:label "Context Vector" ;
    rdfs:comment "Patient similarity vectors for graph algorithms" .

cae:hasVectorId a owl:DatatypeProperty ;
    rdfs:domain cae:ContextVector ;
    rdfs:range xsd:string ;
    rdfs:label "Vector ID" .

cae:hasVectorDimensions a owl:DatatypeProperty ;
    rdfs:domain cae:ContextVector ;
    rdfs:range xsd:string ;
    rdfs:label "Vector Dimensions" .

cae:hasVectorValues a owl:DatatypeProperty ;
    rdfs:domain cae:ContextVector ;
    rdfs:range xsd:string ;
    rdfs:label "Vector Values" .

cae:hasContextVector a owl:ObjectProperty ;
    rdfs:domain cae:Patient ;
    rdfs:range cae:ContextVector ;
    rdfs:label "Has Context Vector" .
