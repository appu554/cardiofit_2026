{
  "dashboard": {
    "id": null,
    "title": "Context Services - Clinical Data Intelligence Hub",
    "tags": ["context-services", "clinical", "microservices"],
    "style": "dark",
    "timezone": "browser",
    "refresh": "10s",
    "schemaVersion": 27,
    "version": 1,
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Service Health Overview",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=~\"context-gateway-go|clinical-data-hub-rust\"}",
            "legendFormat": "{{job}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "displayMode": "list",
              "orientation": "horizontal"
            },
            "mappings": [
              {
                "options": {
                  "0": {"color": "red", "text": "DOWN"},
                  "1": {"color": "green", "text": "UP"}
                },
                "type": "value"
              }
            ],
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 1}
              ]
            }
          }
        },
        "gridPos": {"h": 4, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Request Rate (req/sec)",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(context_gateway_requests_total[5m])",
            "legendFormat": "Context Gateway"
          },
          {
            "expr": "rate(clinical_hub_requests_total[5m])",
            "legendFormat": "Clinical Hub"
          }
        ],
        "yAxes": [
          {"label": "Requests/sec", "min": 0},
          {"show": false}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "Response Time (95th percentile)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(context_gateway_request_duration_seconds_bucket[5m]))",
            "legendFormat": "Context Gateway P95"
          },
          {
            "expr": "histogram_quantile(0.95, rate(clinical_hub_request_duration_milliseconds_bucket[5m])) / 1000",
            "legendFormat": "Clinical Hub P95"
          }
        ],
        "yAxes": [
          {"label": "Seconds", "min": 0},
          {"show": false}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4}
      },
      {
        "id": 4,
        "title": "Cache Performance",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(clinical_hub_cache_hits_total[5m])",
            "legendFormat": "Cache Hits/sec"
          },
          {
            "expr": "rate(clinical_hub_cache_misses_total[5m])",
            "legendFormat": "Cache Misses/sec"
          },
          {
            "expr": "rate(clinical_hub_cache_hits_total[5m]) / (rate(clinical_hub_cache_hits_total[5m]) + rate(clinical_hub_cache_misses_total[5m]))",
            "legendFormat": "Hit Ratio",
            "yAxis": 2
          }
        ],
        "yAxes": [
          {"label": "Operations/sec", "min": 0},
          {"label": "Hit Ratio", "min": 0, "max": 1}
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12}
      },
      {
        "id": 5,
        "title": "Cache Layer Latencies",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(clinical_hub_cache_l1_duration_microseconds_bucket[5m])) / 1000",
            "legendFormat": "L1 Cache P95 (ms)"
          },
          {
            "expr": "histogram_quantile(0.95, rate(clinical_hub_cache_l2_duration_milliseconds_bucket[5m]))",
            "legendFormat": "L2 Cache P95 (ms)"
          },
          {
            "expr": "histogram_quantile(0.95, rate(clinical_hub_cache_l3_duration_milliseconds_bucket[5m]))",
            "legendFormat": "L3 Cache P95 (ms)"
          }
        ],
        "yAxes": [
          {"label": "Milliseconds", "min": 0},
          {"show": false}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20}
      },
      {
        "id": 6,
        "title": "Error Rates",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(context_gateway_errors_total[5m])",
            "legendFormat": "Context Gateway Errors/sec"
          },
          {
            "expr": "rate(clinical_hub_errors_total[5m])",
            "legendFormat": "Clinical Hub Errors/sec"
          }
        ],
        "yAxes": [
          {"label": "Errors/sec", "min": 0},
          {"show": false}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20}
      },
      {
        "id": 7,
        "title": "Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "context_gateway_memory_usage_bytes / 1024 / 1024",
            "legendFormat": "Context Gateway (MB)"
          },
          {
            "expr": "clinical_hub_memory_usage_bytes / 1024 / 1024",
            "legendFormat": "Clinical Hub (MB)"
          },
          {
            "expr": "clinical_hub_cache_l1_size_bytes / 1024 / 1024",
            "legendFormat": "L1 Cache (MB)"
          }
        ],
        "yAxes": [
          {"label": "Megabytes", "min": 0},
          {"show": false}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28}
      },
      {
        "id": 8,
        "title": "Snapshot Operations",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(context_gateway_snapshots_created_total[5m])",
            "legendFormat": "Snapshots Created/sec"
          },
          {
            "expr": "rate(context_gateway_snapshots_retrieved_total[5m])",
            "legendFormat": "Snapshots Retrieved/sec"
          },
          {
            "expr": "rate(context_gateway_snapshot_validation_total[5m])",
            "legendFormat": "Validations/sec"
          }
        ],
        "yAxes": [
          {"label": "Operations/sec", "min": 0},
          {"show": false}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28}
      },
      {
        "id": 9,
        "title": "Data Aggregation Performance",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(clinical_hub_aggregations_total[5m])",
            "legendFormat": "Aggregations/sec"
          },
          {
            "expr": "histogram_quantile(0.95, rate(clinical_hub_aggregation_duration_milliseconds_bucket[5m]))",
            "legendFormat": "Aggregation P95 Latency (ms)"
          }
        ],
        "yAxes": [
          {"label": "Operations/sec", "min": 0},
          {"label": "Milliseconds", "min": 0}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 36}
      },
      {
        "id": 10,
        "title": "Stream Processing",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(clinical_hub_stream_events_processed_total[5m])",
            "legendFormat": "Events Processed/sec"
          },
          {
            "expr": "clinical_hub_stream_processing_lag_seconds",
            "legendFormat": "Processing Lag (seconds)"
          }
        ],
        "yAxes": [
          {"label": "Events/sec", "min": 0},
          {"label": "Seconds", "min": 0}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 36}
      },
      {
        "id": 11,
        "title": "Infrastructure Health",
        "type": "table",
        "targets": [
          {
            "expr": "up{job=~\"redis-cluster|mongo-context|postgres-hub|kafka-context\"}",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "columns": [
                {"text": "Service", "value": "job"},
                {"text": "Status", "value": "Value"}
              ]
            }
          }
        ],
        "fieldConfig": {
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Status"},
              "properties": [
                {
                  "id": "custom.displayMode",
                  "value": "color-background"
                },
                {
                  "id": "mappings",
                  "value": [
                    {
                      "options": {
                        "0": {"color": "red", "text": "DOWN"},
                        "1": {"color": "green", "text": "UP"}
                      },
                      "type": "value"
                    }
                  ]
                }
              ]
            }
          ]
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 44}
      },
      {
        "id": 12,
        "title": "Recipe Execution Metrics",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(context_gateway_recipes_executed_total[5m])",
            "legendFormat": "Recipes Executed/sec"
          },
          {
            "expr": "rate(context_gateway_recipe_validation_failures_total[5m])",
            "legendFormat": "Validation Failures/sec"
          },
          {
            "expr": "histogram_quantile(0.95, rate(context_gateway_recipe_execution_duration_seconds_bucket[5m]))",
            "legendFormat": "Execution P95 Latency (s)"
          }
        ],
        "yAxes": [
          {"label": "Operations/sec", "min": 0},
          {"label": "Seconds", "min": 0}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 44}
      }
    ],
    "templating": {
      "list": [
        {
          "name": "service",
          "type": "query",
          "query": "label_values(up, job)",
          "current": {
            "value": "All",
            "text": "All"
          },
          "includeAll": true,
          "multi": true
        },
        {
          "name": "instance",
          "type": "query",
          "query": "label_values(up{job=~\"$service\"}, instance)",
          "current": {
            "value": "All",
            "text": "All"
          },
          "includeAll": true,
          "multi": true
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Deployments",
          "datasource": "prometheus",
          "expr": "changes(up[1m]) > 0",
          "iconColor": "blue",
          "tags": ["deployment"]
        }
      ]
    }
  }
}