// Build script for Clinical Data Hub Rust Service
// Handles Protocol Buffer compilation and build optimizations

use std::io::Result;

fn main() -> Result<()> {
    // Configure Protocol Buffers compilation
    tonic_build::compile_protos("proto/clinical_data_hub.proto")?;

    // Recompile if proto files change
    println!("cargo:rerun-if-changed=proto/clinical_data_hub.proto");
    
    // Optimize for the target CPU
    println!("cargo:rustc-env=RUSTFLAGS=-C target-cpu=native");
    
    // Enable link-time optimization in release builds
    #[cfg(not(debug_assertions))]
    {
        println!("cargo:rustc-link-arg=-flto");
    }
    
    Ok(())
}