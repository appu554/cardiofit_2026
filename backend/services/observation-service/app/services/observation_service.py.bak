import logging
from typing import List, Optional, Dict, Any, Union
from datetime import datetime
import uuid
import json
from app.core.config import settings
from app.shared.google_healthcare.client import GoogleHealthcareClient

# Configure logging
logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

# Singleton instance
_observation_service_instance = None

def get_observation_service():
    """Get or create a singleton instance of the Observation service."""
    global _observation_service_instance
    if _observation_service_instance is None:
        _observation_service_instance = ObservationService()
    return _observation_service_instance

class ObservationService:
    """Service for managing FHIR Observation resources using Google Healthcare API."""
    
    def __init__(self):
        """Initialize the Google Healthcare API client."""
        self.client = GoogleHealthcareClient(
            project_id=settings.GOOGLE_CLOUD_PROJECT,
            location=settings.HEALTHCARE_LOCATION,
            dataset_id=settings.HEALTHCARE_DATASET,
            fhir_store_id=settings.FHIR_STORE,
            credentials_path=settings.GOOGLE_APPLICATION_CREDENTIALS or None
        )
        self.client.initialize()
    
    @staticmethod
    def _format_observation(observation: Dict[str, Any]) -> Dict[str, Any]:
        """Format observation data for the API response."""
        # Extract the ID from the FHIR resource URL if present
        if 'id' in observation and observation['id'].startswith('Observation/'):
            observation['id'] = observation['id'].split('/')[-1]
        return observation
    
    async def create_observation(self, observation_data: Dict[str, Any]) -> Dict[str, Any]:
        """
        Create a new FHIR Observation resource.
        
        Args:
            observation_data: Dictionary containing observation data in FHIR format
            
        Returns:
            Dict containing the created observation
        """
        try:
            logger.info("Creating new observation in FHIR store")
            
            # Ensure resource type is set
            observation_data['resourceType'] = 'Observation'
            
            # Generate ID if not provided
            if 'id' not in observation_data:
                observation_data['id'] = f"obs-{uuid.uuid4()}"
            
            # Create the observation in FHIR store
            created_obs = await self.client.create_resource(
                resource_type='Observation',
                resource_id=observation_data['id'],
                resource=observation_data
            )
            
            logger.info(f"Successfully created observation with ID: {created_obs.get('id')}")
            return self._format_observation(created_obs)
            
        except Exception as e:
            logger.error(f"Error creating observation: {str(e)}")
            raise
    
    async def get_observation(self, observation_id: str) -> Optional[Dict[str, Any]]:
        """
        Get a FHIR Observation resource by ID.
        
        Args:
            observation_id: The ID of the observation to retrieve
            
        Returns:
            Dict containing the observation data, or None if not found
        """
        try:
            logger.info(f"Fetching observation with ID: {observation_id}")
            
            # Get the observation from FHIR store
            observation = await self.client.get_resource(
                resource_type='Observation',
                resource_id=observation_id
            )
            
            if not observation:
                logger.warning(f"Observation with ID {observation_id} not found")
                return None
                
            return self._format_observation(observation)
            
        except Exception as e:
            logger.error(f"Error getting observation {observation_id}: {str(e)}")
            return None
    
    async def update_observation(self, observation_id: str, observation_data: Dict[str, Any]) -> Optional[Dict[str, Any]]:
        """
        Update an existing FHIR Observation resource.
        
        Args:
            observation_id: The ID of the observation to update
            observation_data: Dictionary containing the updated observation data
            
        Returns:
            Dict containing the updated observation, or None if update failed
        """
        try:
            logger.info(f"Updating observation with ID: {observation_id}")
            
            # Get the current observation to ensure it exists
            current_obs = await self.get_observation(observation_id)
            if not current_obs:
                logger.warning(f"Cannot update: Observation with ID {observation_id} not found")
                return None
            
            # Ensure resource type and ID are set correctly
            observation_data['resourceType'] = 'Observation'
            observation_data['id'] = observation_id
            
            # Update the observation in FHIR store
            updated_obs = await self.client.update_resource(
                resource_type='Observation',
                resource_id=observation_id,
                resource=observation_data
            )
            
            logger.info(f"Successfully updated observation with ID: {observation_id}")
            return self._format_observation(updated_obs)
            
        except Exception as e:
            logger.error(f"Error updating observation {observation_id}: {str(e)}")
            return None
    
    async def delete_observation(self, observation_id: str) -> bool:
        """
        Delete a FHIR Observation resource (soft delete by marking as 'entered-in-error').
        
        Args:
            observation_id: The ID of the observation to delete
            
        Returns:
            bool: True if deletion was successful, False otherwise
        """
        try:
            logger.info(f"Deleting observation with ID: {observation_id}")
            
            # Get the current observation
            current_obs = await self.get_observation(observation_id)
            if not current_obs:
                logger.warning(f"Cannot delete: Observation with ID {observation_id} not found")
                return False
            
            # Mark as entered-in-error (soft delete)
            current_obs['status'] = 'entered-in-error'
            
            # Update the observation with the new status
            await self.client.update_resource(
                resource_type='Observation',
                resource_id=observation_id,
                resource=current_obs
            )
            
            logger.info(f"Successfully marked observation {observation_id} as entered-in-error")
            return True
            
        except Exception as e:
            logger.error(f"Error deleting observation {observation_id}: {str(e)}")
            return False
    
    async def search_observations(
        self,
        patient_id: Optional[str] = None,
        category: Optional[str] = None,
        code: Optional[str] = None,
        date: Optional[str] = None,
        status: Optional[str] = None,
        page: int = 1,
        count: int = 10
    ) -> Dict[str, Any]:
        """
        Search for FHIR Observation resources with filtering and pagination.
        
        Args:
            patient_id: Filter by patient ID
            category: Filter by observation category
            code: Filter by observation code
            date: Filter by date (YYYY-MM-DD format)
            status: Filter by status
            page: Page number (1-based)
            count: Number of items per page
            
        Returns:
            Dict containing the search results and pagination info
        """
        try:
            logger.info("Searching for observations with filters")
            
            # Build search parameters
            params = {}
            
            if patient_id:
                params['patient'] = f"Patient/{patient_id}"
                
            if category:
                params['category'] = category
                
            if code:
                params['code'] = code
                
            if date:
                params['date'] = f"eq{date}"
                
            if status:
                params['status'] = status
            
            # Add pagination parameters
            params['_count'] = count
            if page > 1:
                params['_page'] = page
            
            # Search for observations in FHIR store
            search_result = await self.client.search(
                resource_type='Observation',
                parameters=params
            )
            
            # Format the response
            observations = []
            if 'entry' in search_result:
                observations = [self._format_observation(entry['resource']) 
                             for entry in search_result['entry']]
            
            # Get total count for pagination
            total = search_result.get('total', 0) if 'total' in search_result else len(observations)
            
            return {
                "observations": observations,
                "total": total,
                "page": page,
                "count": len(observations),
                "has_more": (page * count) < total
            }
            
        except Exception as e:
            logger.error(f"Error searching observations: {str(e)}")
            return {
                "observations": [],
                "total": 0,
                "page": page,
                "count": 0,
                "has_more": False
            }
        return observations
    
    async def get_patient_observations(
        self, 
        patient_id: str, 
        category: Optional[str] = None,
        code: Optional[str] = None,
        date: Optional[str] = None,
        status: Optional[str] = None,
        page: int = 1,
        count: int = 10
    ) -> Dict[str, Any]:
        """
        Get observations for a specific patient with optional filters.
        
        Args:
            patient_id: ID of the patient
            category: Filter by observation category
            code: Filter by observation code
            date: Filter by date (YYYY-MM-DD format)
            status: Filter by status
            page: Page number (1-based)
            count: Number of items per page
            
        Returns:
            Dict containing the search results and pagination info
        """
        return await self.search_observations(
            patient_id=patient_id,
            category=category,
            code=code,
            date=date,
            status=status,
            page=page,
            count=count
        )
    
