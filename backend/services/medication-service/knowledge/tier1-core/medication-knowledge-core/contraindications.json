{
  "metadata": {
    "version": "1.0.0",
    "last_updated": "2024-01-15",
    "source": "FDA prescribing information, clinical guidelines",
    "description": "Contraindications database for medication safety screening"
  },
  "contraindications": {
    "vancomycin": {
      "absolute": [
        {
          "condition": "vancomycin_allergy",
          "severity": "ABSOLUTE",
          "description": "Known hypersensitivity to vancomycin",
          "rationale": "Risk of anaphylaxis or severe allergic reaction",
          "alternatives": ["linezolid", "daptomycin", "ceftaroline"]
        }
      ],
      "relative": [
        {
          "condition": "severe_hearing_loss",
          "severity": "RELATIVE",
          "description": "Pre-existing severe hearing impairment",
          "rationale": "Vancomycin is ototoxic and may worsen hearing loss",
          "management": "Use only if benefits outweigh risks, monitor hearing closely",
          "alternatives": ["linezolid", "daptomycin"]
        },
        {
          "condition": "severe_renal_impairment",
          "severity": "RELATIVE",
          "description": "Creatinine clearance <30 mL/min",
          "rationale": "Increased risk of nephrotoxicity and drug accumulation",
          "management": "Dose adjustment required, monitor levels and renal function",
          "alternatives": ["linezolid", "daptomycin"]
        }
      ]
    },
    "warfarin": {
      "absolute": [
        {
          "condition": "active_bleeding",
          "severity": "ABSOLUTE",
          "description": "Active pathological bleeding",
          "rationale": "Anticoagulation will worsen bleeding",
          "alternatives": ["mechanical_compression", "surgical_intervention"]
        },
        {
          "condition": "pregnancy",
          "severity": "ABSOLUTE",
          "description": "Pregnancy (especially first trimester)",
          "rationale": "Teratogenic effects, fetal bleeding risk",
          "alternatives": ["heparin", "enoxaparin"]
        },
        {
          "condition": "severe_liver_disease",
          "severity": "ABSOLUTE",
          "description": "Severe hepatic impairment with coagulopathy",
          "rationale": "Impaired synthesis of clotting factors",
          "alternatives": ["direct_oral_anticoagulants"]
        }
      ],
      "relative": [
        {
          "condition": "high_bleeding_risk",
          "severity": "RELATIVE",
          "description": "History of GI bleeding, falls risk, age >75",
          "rationale": "Increased risk of major bleeding complications",
          "management": "Lower INR targets, frequent monitoring, fall prevention",
          "alternatives": ["direct_oral_anticoagulants", "antiplatelet_therapy"]
        },
        {
          "condition": "poor_compliance",
          "severity": "RELATIVE",
          "description": "History of medication non-adherence",
          "rationale": "Erratic dosing leads to unstable anticoagulation",
          "management": "Patient education, simplified dosing, monitoring",
          "alternatives": ["direct_oral_anticoagulants"]
        }
      ]
    },
    "acetaminophen": {
      "absolute": [
        {
          "condition": "acetaminophen_allergy",
          "severity": "ABSOLUTE",
          "description": "Known hypersensitivity to acetaminophen",
          "rationale": "Risk of allergic reaction",
          "alternatives": ["ibuprofen", "aspirin", "naproxen"]
        }
      ],
      "relative": [
        {
          "condition": "severe_liver_disease",
          "severity": "RELATIVE",
          "description": "Severe hepatic impairment or cirrhosis",
          "rationale": "Increased risk of hepatotoxicity",
          "management": "Reduce dose, monitor liver function",
          "alternatives": ["ibuprofen", "topical_analgesics"]
        },
        {
          "condition": "chronic_alcohol_use",
          "severity": "RELATIVE",
          "description": "Chronic alcohol consumption >3 drinks/day",
          "rationale": "Increased risk of hepatotoxicity",
          "management": "Limit dose to <2g daily, monitor liver function",
          "alternatives": ["ibuprofen", "naproxen"]
        },
        {
          "condition": "malnutrition",
          "severity": "RELATIVE",
          "description": "Severe malnutrition or fasting state",
          "rationale": "Depleted glutathione stores increase toxicity risk",
          "management": "Reduce dose, ensure adequate nutrition",
          "alternatives": ["ibuprofen", "topical_analgesics"]
        }
      ]
    }
  },
  "condition_definitions": {
    "vancomycin_allergy": {
      "icd10": "Z88.1",
      "description": "Allergy to vancomycin",
      "screening_questions": ["Previous reaction to vancomycin?", "Red man syndrome history?"]
    },
    "severe_hearing_loss": {
      "icd10": "H90.3",
      "description": "Severe sensorineural hearing loss",
      "screening_questions": ["Hearing aids required?", "Previous ototoxic drug exposure?"]
    },
    "active_bleeding": {
      "icd10": "R58",
      "description": "Active pathological bleeding",
      "screening_questions": ["Current bleeding?", "Recent surgery?", "GI bleeding history?"]
    },
    "pregnancy": {
      "icd10": "Z33.1",
      "description": "Pregnancy state",
      "screening_questions": ["Pregnant or trying to conceive?", "Last menstrual period?"]
    },
    "severe_liver_disease": {
      "icd10": "K72.90",
      "description": "Severe hepatic impairment",
      "screening_questions": ["Liver disease history?", "Jaundice?", "Ascites?"]
    }
  },
  "severity_definitions": {
    "ABSOLUTE": "Never use - risk always outweighs benefit",
    "RELATIVE": "Use with caution - benefits may outweigh risks in specific situations"
  }
}
