# Device Data Ingestion Service Configuration

# Service Configuration
PROJECT_NAME="Device Data Ingestion Service"
VERSION="1.0.0"
API_PREFIX="/api/v1"
DEBUG=false

# Server Configuration  
HOST="0.0.0.0"
PORT=8015

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS="pkc-619z3.us-east1.gcp.confluent.cloud:9092"
KAFKA_API_KEY="LGJ3AQ2L6VRPW4S2"
KAFKA_API_SECRET="your-kafka-api-secret-here"
KAFKA_TOPIC_DEVICE_DATA="raw-device-data.v1"

# Authentication Configuration
AUTH_SERVICE_URL="http://localhost:8001"
API_KEY_HEADER="X-API-Key"

# Rate Limiting Configuration
