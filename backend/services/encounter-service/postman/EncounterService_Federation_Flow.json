{
	"info": {
		"_postman_id": "encounter-federation-flow-001",
		"name": "EncounterService Federation Flow",
		"description": "Complete architecture flow testing for Encounter Management Service:\nAPI Gateway (8005) → Auth Service (8001) → Apollo Federation Gateway (4000) → EncounterService (8020) → Google Healthcare API",
