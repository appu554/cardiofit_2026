						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"query GetEncounter($id: ID!) { encounter(id: $id) { id resourceType status class subject { reference display } period { start end } participant { individual { reference display } } location { location { reference display } status } } }\",\n    \"variables\": {\n        \"id\": \"{{encounter_id}}\"\n    }\n}"
