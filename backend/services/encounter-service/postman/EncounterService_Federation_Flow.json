									"        console.log('Status:', response.data.encounter.status);",
									"        console.log('Class:', response.data.encounter.class);",
									"    } else {",
									"        console.log('⚠️ No encounter found with this ID');",
									"    }",
									"} else {",
									"    console.log('❌ Failed to retrieve encounter');",
									"}"
