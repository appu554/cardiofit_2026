# Kafka Configuration (Confluent Cloud)
KAFKA_BOOTSTRAP_SERVERS=pkc-your-cluster.us-east-1.aws.confluent.cloud:9092
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=your-api-key
KAFKA_SASL_PASSWORD=your-api-secret

# Kafka Consumer Settings
KAFKA_GROUP_ID=module8-fhir-store-projector
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_ENABLE_AUTO_COMMIT=false

# Topic Configuration
KAFKA_TOPIC_FHIR_UPSERT=prod.ehr.fhir.upsert
KAFKA_TOPIC_DLQ=prod.ehr.dlq.fhir-store-projector

# Batch Settings (small batches for API calls)
BATCH_SIZE=20
BATCH_TIMEOUT_SECONDS=10

# Google Cloud Healthcare API Configuration
GOOGLE_CLOUD_PROJECT_ID=cardiofit-905a8
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_DATASET_ID=cardiofit_fhir_dataset
GOOGLE_CLOUD_FHIR_STORE_ID=cardiofit_fhir_store
GOOGLE_APPLICATION_CREDENTIALS=credentials/google-credentials.json

# API Rate Limiting
MAX_REQUESTS_PER_SECOND=200
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_FACTOR=2

# Service Configuration
SERVICE_PORT=8056
LOG_LEVEL=INFO

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL_SECONDS=30
