  "test_scenarios": [
    {
      "scenario": "CREATE new resource",
      "description": "First write of a resource creates it in FHIR Store",
      "expected_operation": "CREATE",
      "expected_http_code": 201
    },
    {
      "scenario": "UPDATE existing resource",
      "description": "Subsequent writes update the existing resource",
      "expected_operation": "UPDATE",
      "expected_http_code": 200
    },
    {
      "scenario": "Validation error",
      "description": "Invalid resource structure sent to DLQ",
      "expected_operation": "DLQ",
      "dlq_topic": "prod.ehr.dlq.fhir-store-projector"
    },
    {
      "scenario": "Batch processing",
      "description": "Multiple resources processed in single batch",
      "batch_size": 20,
      "expected_throughput": "~200 resources/sec"
    }
  ],
