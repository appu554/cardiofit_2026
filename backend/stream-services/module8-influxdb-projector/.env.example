# InfluxDB Configuration
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=cardiofit
INFLUXDB_TOKEN=your_influxdb_token_here
INFLUXDB_BUCKET_REALTIME=vitals_realtime
INFLUXDB_BUCKET_1MIN=vitals_1min
INFLUXDB_BUCKET_1HOUR=vitals_1hour

# Batch Settings
INFLUXDB_BATCH_SIZE=200
INFLUXDB_FLUSH_INTERVAL=5000

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=pkc-9q8rv.ap-south-2.aws.confluent.cloud:9092
KAFKA_SASL_USERNAME=your_kafka_key
KAFKA_SASL_PASSWORD=your_kafka_secret
KAFKA_CONSUMER_GROUP=influxdb-projector-group
KAFKA_TOPIC=prod.ehr.events.enriched

# Service Configuration
SERVICE_PORT=8054
SERVICE_NAME=influxdb-projector
LOG_LEVEL=INFO
