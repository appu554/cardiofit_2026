# Development Environment Configuration for Stage 2: Storage Fan-Out Service

# Service Configuration
PORT=8042
DEBUG=true
SERVICE_NAME=stage2-storage-fanout

# Kafka Configuration for Development
KAFKA_BOOTSTRAP_SERVERS=pkc-619z3.us-east1.gcp.confluent.cloud:9092
KAFKA_API_KEY=LGJ3AQ2L6VRPW4S2
KAFKA_API_SECRET=2hYzQLmG1XGyQ9oLZcjwAIBdAZUS6N4JoWD8oZQhk0qVBmmyVVHU7TqoLjYef0kl
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN

# Kafka Topics
KAFKA_INPUT_TOPIC=validated-device-data.v1
KAFKA_DLQ_TOPIC=sink-write-failures.v1
KAFKA_CONSUMER_GROUP=stage2-storage-fanout-dev

# Kafka Consumer Settings
KAFKA_AUTO_OFFSET_RESET=latest
KAFKA_ENABLE_AUTO_COMMIT=true
KAFKA_AUTO_COMMIT_INTERVAL_MS=1000
KAFKA_MAX_POLL_RECORDS=10
KAFKA_SESSION_TIMEOUT_MS=30000
KAFKA_HEARTBEAT_INTERVAL_MS=3000

# Multi-Sink Configuration
PARALLEL_WRITES=true
THREAD_POOL_SIZE=3
SINK_TIMEOUT_SECONDS=30
BATCH_SIZE=10

# FHIR Store Configuration (Disabled for local testing)
FHIR_STORE_ENABLED=false
GOOGLE_CLOUD_PROJECT=cardiofit-905a8
GOOGLE_CLOUD_LOCATION=asia-south1
GOOGLE_CLOUD_DATASET=clinical-synthesis-hub
GOOGLE_CLOUD_FHIR_STORE=fhir-store
GOOGLE_APPLICATION_CREDENTIALS=

# Elasticsearch Configuration (Disabled for local testing)
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_INDEX_PREFIX=device-readings-dev
ELASTICSEARCH_TIMEOUT=30

# MongoDB Configuration (Local MongoDB)
MONGODB_ENABLED=true
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=clinical_synthesis_hub_dev
MONGODB_COLLECTION=device_readings_raw
MONGODB_TIMEOUT=30

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# Circuit Breaker Configuration
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30

# Retry Configuration
RETRY_ENABLED=true
RETRY_MAX_ATTEMPTS=2
RETRY_BACKOFF_FACTOR=2.0
RETRY_MAX_WAIT=30

# Monitoring Configuration
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9042
METRICS_ENABLED=true

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=5

# Logging Configuration
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# Performance Configuration
MAX_CONCURRENT_REQUESTS=50
REQUEST_TIMEOUT=30
CONNECTION_POOL_SIZE=10
