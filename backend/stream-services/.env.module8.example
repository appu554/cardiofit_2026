# ========================================
# Module 8 Storage Projectors Configuration
# ========================================

# ========================================
# KAFKA CONFIGURATION (Confluent Cloud)
# ========================================
KAFKA_BOOTSTRAP_SERVERS=pkc-xxxxx.us-east-1.aws.confluent.cloud:9092
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=your-kafka-api-key
KAFKA_SASL_PASSWORD=your-kafka-api-secret

# ========================================
# POSTGRESQL CONFIGURATION
# Container: a2f55d83b1fa (cardiofit-postgres-analytics)
# Network IP: 172.21.0.4
# ========================================
POSTGRES_HOST=172.21.0.4
POSTGRES_PORT=5432
POSTGRES_DB=cardiofit_analytics
POSTGRES_USER=cardiofit
POSTGRES_PASSWORD=your-postgres-password

# ========================================
# MONGODB CONFIGURATION
# Infrastructure service (module8-mongodb)
# ========================================
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DATABASE=module8_clinical

# ========================================
# ELASTICSEARCH CONFIGURATION
# Infrastructure service (module8-elasticsearch)
# ========================================
ELASTICSEARCH_URL=http://elasticsearch:9200

# ========================================
# CLICKHOUSE CONFIGURATION
# Infrastructure service (module8-clickhouse)
# ========================================
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=module8_analytics
CLICKHOUSE_USER=module8_user
CLICKHOUSE_PASSWORD=module8_password

# ========================================
# INFLUXDB CONFIGURATION
# Container: 8502fd5d078d (cardiofit-influxdb)
# Network IP: 172.21.0.3
# ========================================
INFLUXDB_URL=http://172.21.0.3:8086
INFLUXDB_TOKEN=cardiofit-influx-token-123456
INFLUXDB_ORG=cardiofit
INFLUXDB_BUCKET=clinical_metrics

# ========================================
# NEO4J CONFIGURATION
# Container: e8b3df4d8a02 (neo4j)
# External container - requires network connection
# ========================================
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=cardiofit

# ========================================
# GOOGLE FHIR STORE CONFIGURATION
# ========================================
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_LOCATION=us-central1
GOOGLE_DATASET_ID=cardiofit_fhir_dataset
GOOGLE_FHIR_STORE_ID=cardiofit_fhir_store
GOOGLE_CREDENTIALS_PATH=/path/to/google-credentials.json

# ========================================
# PROCESSING CONFIGURATION
# ========================================
LOG_LEVEL=INFO
BATCH_SIZE=100
FLUSH_INTERVAL=10

# ========================================
# MONITORING CONFIGURATION (Optional)
# ========================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=true
GRAFANA_PORT=3000
