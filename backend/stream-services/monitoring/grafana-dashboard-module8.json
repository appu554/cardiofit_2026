{
  "dashboard": {
    "id": null,
    "uid": "module8-projectors",
    "title": "Module 8 Storage Projectors Dashboard",
    "tags": ["module8", "projectors", "storage"],
    "timezone": "utc",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "type": "graph",
        "title": "Throughput - Events Processed per Second",
        "targets": [
          {
            "expr": "rate(projector_messages_processed_total[5m])",
            "legendFormat": "{{projector}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Events/sec"},
          {"format": "short"}
        ],
        "legend": {"show": true, "values": true, "current": true, "max": true}
      },
      {
        "id": 2,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "type": "graph",
        "title": "Consumer Lag by Projector",
        "targets": [
          {
            "expr": "projector_consumer_lag",
            "legendFormat": "{{projector}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Messages"},
          {"format": "short"}
        ],
        "alert": {
          "conditions": [
            {
              "evaluator": {"params": [1000], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"type": "avg"}
            }
          ]
        },
        "thresholds": [
          {"value": 1000, "colorMode": "critical"}
        ]
      },
      {
        "id": 3,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "type": "graph",
        "title": "Batch Processing Latency (p95, p99)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(projector_batch_processing_seconds_bucket[5m]))",
            "legendFormat": "p95 - {{projector}}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.99, rate(projector_batch_processing_seconds_bucket[5m]))",
            "legendFormat": "p99 - {{projector}}",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Duration"},
          {"format": "short"}
        ]
      },
      {
        "id": 4,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "type": "graph",
        "title": "Error Rate",
        "targets": [
          {
            "expr": "rate(projector_messages_failed_total[5m]) / rate(projector_messages_consumed_total[5m])",
            "legendFormat": "{{projector}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "percentunit", "label": "Error Rate"},
          {"format": "short"}
        ],
        "thresholds": [
          {"value": 0.05, "colorMode": "critical"}
        ]
      },
      {
        "id": 5,
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
        "type": "graph",
        "title": "CPU Usage",
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total{job='module8-projectors'}[5m]) * 100",
            "legendFormat": "{{projector}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "percent", "label": "CPU %", "max": 100},
          {"format": "short"}
        ]
      },
      {
        "id": 6,
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16},
        "type": "graph",
        "title": "Memory Usage",
        "targets": [
          {
            "expr": "process_memory_bytes{job='module8-projectors'} / 1024 / 1024",
            "legendFormat": "{{projector}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "mbytes", "label": "Memory MB"},
          {"format": "short"}
        ]
      },
      {
        "id": 7,
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16},
        "type": "graph",
        "title": "Database Query Latency (p95)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(database_query_duration_seconds_bucket[5m]))",
            "legendFormat": "{{projector}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Duration"},
          {"format": "short"}
        ]
      },
      {
        "id": 8,
        "gridPos": {"h": 6, "w": 6, "x": 0, "y": 24},
        "type": "stat",
        "title": "Total Events Processed (1h)",
        "targets": [
          {
            "expr": "sum(increase(projector_messages_processed_total[1h]))",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
          "textMode": "value_and_name"
        }
      },
      {
        "id": 9,
        "gridPos": {"h": 6, "w": 6, "x": 6, "y": 24},
        "type": "stat",
        "title": "Average Throughput",
        "targets": [
          {
            "expr": "avg(rate(projector_messages_processed_total[5m]))",
            "refId": "A"
          }
        ],
        "options": {
          "unit": "ops",
          "reduceOptions": {"values": false, "calcs": ["lastNotNull"]}
        }
      },
      {
        "id": 10,
        "gridPos": {"h": 6, "w": 6, "x": 12, "y": 24},
        "type": "stat",
        "title": "Total Errors (1h)",
        "targets": [
          {
            "expr": "sum(increase(projector_messages_failed_total[1h]))",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
          "colorMode": "background"
        },
        "thresholds": {
          "steps": [
            {"value": 0, "color": "green"},
            {"value": 100, "color": "yellow"},
            {"value": 1000, "color": "red"}
          ]
        }
      },
      {
        "id": 11,
        "gridPos": {"h": 6, "w": 6, "x": 18, "y": 24},
        "type": "stat",
        "title": "Services Up",
        "targets": [
          {
            "expr": "count(up{job='module8-projectors'} == 1)",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
          "colorMode": "background"
        },
        "thresholds": {
          "steps": [
            {"value": 0, "color": "red"},
            {"value": 6, "color": "yellow"},
            {"value": 8, "color": "green"}
          ]
        }
      },
      {
        "id": 12,
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 30},
        "type": "table",
        "title": "Projector Status Summary",
        "targets": [
          {
            "expr": "up{job='module8-projectors'}",
            "format": "table",
            "instant": true,
            "refId": "A"
          },
          {
            "expr": "rate(projector_messages_processed_total[5m])",
            "format": "table",
            "instant": true,
            "refId": "B"
          },
          {
            "expr": "projector_consumer_lag",
            "format": "table",
            "instant": true,
            "refId": "C"
          },
          {
            "expr": "rate(projector_messages_failed_total[5m])",
            "format": "table",
            "instant": true,
            "refId": "D"
          }
        ],
        "transformations": [
          {
            "id": "merge",
            "options": {}
          },
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true, "Job": true},
              "renameByName": {
                "projector": "Projector",
                "Value #A": "Status",
                "Value #B": "Throughput (msg/s)",
                "Value #C": "Consumer Lag",
                "Value #D": "Error Rate (msg/s)"
              }
            }
          }
        ]
      },
      {
        "id": 13,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40},
        "type": "graph",
        "title": "Database Connection Pool Usage",
        "targets": [
          {
            "expr": "database_connection_pool_active / database_connection_pool_max",
            "legendFormat": "{{projector}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "percentunit", "label": "Pool Usage %"},
          {"format": "short"}
        ],
        "thresholds": [
          {"value": 0.80, "colorMode": "critical"}
        ]
      },
      {
        "id": 14,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 40},
        "type": "graph",
        "title": "DLQ Messages Rate",
        "targets": [
          {
            "expr": "rate(projector_dlq_messages_total[5m])",
            "legendFormat": "{{projector}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Messages/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 15,
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 48},
        "type": "sankey",
        "title": "Event Flow Diagram",
        "description": "Visual representation of event flow from Kafka topics to storage systems",
        "targets": [
          {
            "expr": "sum by (topic, projector) (rate(projector_messages_consumed_total[5m]))",
            "format": "table",
            "refId": "A"
          }
        ]
      }
    ]
  }
}
