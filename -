### 2.2 Advanced Transformer Service

```python
#!/usr/bin/env python3
"""
kb_adapter_transformer.py - Transform KB changes to runtime updates
"""
import asyncio
import json
from typing import Dict, List, Any, Optional
from dataclasses import dataclass
from enum import Enum
import aiokafka
from confluent_kafka.avro import AvroConsumer, AvroProducer
import aiohttp
from py2neo import Graph
import redis.asyncio as aioredis
import logging
from datetime import datetime

class ChangeType(Enum):
    TERMINOLOGY = "terminology"
    SAFETY_RULE = "safety_rule"
    CLINICAL_CONTEXT = "clinical_context"
    MAPPING = "mapping"
    INTERACTION = "interaction"

@dataclass
class KnowledgeChange:
    change_type: ChangeType
    entity_id: str
    operation: str  # INSERT, UPDATE, DELETE
    before: Optional[Dict]
    after: Optional[Dict]
    timestamp: datetime
    source_kb: str

class AdapterTransformer:
    def __init__(self, config: Dict):
        self.config = config
        self.setup_logging()
        self.setup_connections()
        
    def setup_logging(self):
        logging.basicConfig(
            level=logging.INFO,
            format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'
        )
        self.logger = logging.getLogger(__name__)
        
    def setup_connections(self):
        # Kafka consumers and producers
        self.consumer = AvroConsumer({
            'bootstrap.servers': self.config['kafka']['brokers'],
            'group.id': 'kb-adapter-transformer',
            'schema.registry.url': self.config['kafka']['schema_registry'],
            'auto.offset.reset': 'earliest'
        })
        
        self.producer = AvroProducer({
            'bootstrap.servers': self.config['kafka']['brokers'],
            'schema.registry.url': self.config['kafka']['schema_registry']
        })
        
        # GraphDB SPARQL endpoint
        self.graphdb_url = self.config['graphdb']['url']
        
        # Neo4j connection pool
        self.neo4j = Graph(
            self.config['neo4j']['uri'],
            auth=(self.config['neo4j']['user'], self.config['neo4j']['password'])
        )
        
        # Redis connection pool
        self.redis_pool = None  # Will be initialized async
        
    async def init_redis(self):
        self.redis_pool = await aioredis.create_redis_pool(
            self.config['redis']['url'],
            minsize=5, maxsize=20
        )
    
    async def process_changes(self):
        """Main processing loop"""
        await self.init_redis()
        
        # Subscribe to all KB change topics
        topics = [
            'kb.changes.terminology',
            'kb.changes.safety_rules',
            'kb.changes.clinical_context',
            'kb.changes.mappings'
        ]
        self.consumer.subscribe(topics)
        
        while True:
            msg = self.consumer.poll(timeout=1.0)
            if msg is None:
                continue
                
            try:
                change = self.parse_change_event(msg)
                
                # Route to appropriate handler
                if change.change_type == ChangeType.TERMINOLOGY:
                    await self.handle_terminology_change(change)
                elif change.change_type == ChangeType.SAFETY_RULE:
                    await self.handle_safety_rule_change(change)
                elif change.change_type == ChangeType.INTERACTION:
                    await self.handle_interaction_change(change)
                elif change.change_type == ChangeType.MAPPING:
                    await self.handle_mapping_change(change)
                
                self.consumer.commit()
                
            except Exception as e:
                self.logger.error(f"Error processing change: {e}")
                # Send to DLQ
                await self.send_to_dlq(msg, str(e))
    
    def parse_change_event(self, msg) -> KnowledgeChange:
        """Parse Debezium change event"""
        value = msg.value()
        
        return KnowledgeChange(
            change_type=ChangeType(value.get('__table')),
            entity_id=value.get('id'),
            operation=value.get('__op'),  # c=create, u=update, d=delete
            before=value.get('__before'),
            after=value.get('__after'),
            timestamp=datetime.fromtimestamp(value.get('__ts_ms') / 1000),
            source_kb=value.get('__source_kb', 'unknown')
        )
    
    async def handle_terminology_change(self, change: KnowledgeChange):
        """Handle changes to terminology (KB-7)"""
        
        # Fetch full context from GraphDB
        concept_data = await self.fetch_concept_from_graphdb(change.entity_id)
        
        if not concept_data:
            self.logger.warning(f"Concept {change.entity_id} not found in GraphDB")
            return
        
        # Generate Neo4j updates
        cypher_statements = self.generate_terminology_cypher(concept_data, change)
        
        # Generate Redis updates
        redis_commands = self.generate_terminology_redis(concept_data, change)
        
        # Execute updates
        await self.execute_neo4j_batch(cypher_statements)
        await self.execute_redis_batch(redis_commands)
        
        # Publish completion event
        await self.publish_update_event({
            'type': 'terminology_updated',
            'entity_id': change.entity_id,
            'timestamp': change.timestamp.isoformat(),
            'neo4j_nodes': len(cypher_statements),
            'redis_keys': len(redis_commands)
        })
    
    async def handle_safety_rule_change(self, change: KnowledgeChange):
        """Handle changes to safety rules (KB-4)"""
        
        # Fetch the complete rule with its context
        rule_data = await self.fetch_safety_rule_from_graphdb(change.entity_id)
        
        # Complex transformation for drug interaction networks
        if rule_data.get('type') == 'drug_interaction':
            await self.update_interaction_network(rule_data, change)
        elif rule_data.get('type') == 'contraindication':
            await self.update_contraindication_graph(rule_data, change)
        elif rule_data.get('type') == 'monitoring':
            await self.update_monitoring_rules(rule_data, change)
    
    async def update_interaction_network(self, rule_data: Dict, change: KnowledgeChange):
        """Update drug interaction network in Neo4j"""
        
        # Extract drug classes and interaction details
        drug1_class = rule_data['drug1_class']
        drug2_class = rule_data['drug2_class']
        severity = rule_data['severity']
        mechanism = rule_data.get('mechanism', '')
        
        # Build Cypher for interaction network
        if change.operation == 'd':  # Delete
            cypher = """
            MATCH (d1:DrugClass {id: $drug1})-[r:INTERACTS_WITH]-(d2:DrugClass {id: $drug2})
            DELETE r
            """
        else:  # Create or Update
            cypher = """
            MERGE (d1:DrugClass {id: $drug1})
            MERGE (d2:DrugClass {id: $drug2})
            MERGE (d1)-[r:INTERACTS_WITH]-(d2)
            SET r.severity = $severity,
                r.mechanism = $mechanism,
                r.kb4_ref = $rule_id,
                r.last_sync = datetime(),
                r.evidence_level = $evidence
            """
        
        params = {
            'drug1': drug1_class,
            'drug2': drug2_class,
            'severity': severity,
            'mechanism': mechanism,
            'rule_id': change.entity_id,
            'evidence': rule_data.get('evidence_level', 'expert_consensus')
        }
        
        # Execute in Neo4j
        await self.execute_neo4j_query(cypher, params)
        
        # Update Redis cache for fast lookups
        cache_key = f"interaction:{drug1_class}:{drug2_class}"
        cache_value = json.dumps({
            'severity': severity,
            'mechanism': mechanism,
            'rule_id': change.entity_id
        })
        
        await self.redis_pool.setex(cache_key, 300, cache_value)  # 5 min TTL
        
        # Invalidate affected patient risk scores
        await self.invalidate_patient_caches(drug1_class, drug2_class)
    
    async def fetch_concept_from_graphdb(self, concept_id: str) -> Optional[Dict]:
        """Fetch complete concept data from GraphDB using SPARQL"""
        
        sparql_query = """
        PREFIX sct: <http://snomed.info/id/>
        PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
        PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
        
        SELECT ?concept ?label ?parent ?synonym ?definition
        WHERE {
            BIND(sct:%s as ?concept)
            ?concept rdfs:label ?label .
            OPTIONAL { ?concept rdfs:subClassOf ?parent }
            OPTIONAL { ?concept skos:altLabel ?synonym }
            OPTIONAL { ?concept skos:definition ?definition }
        }
        """ % concept_id
        
        async with aiohttp.ClientSession() as session:
            async with session.post(
                f"{self.graphdb_url}/repositories/kb7/statements",
                data={'query': sparql_query},
                headers={'Accept': 'application/sparql-results+json'}
            ) as response:
                if response.status == 200:
                    results = await response.json()
                    return self.parse_sparql_results(results)
        
        return None
    
    def generate_terminology_cypher(self, concept_data: Dict, change: KnowledgeChange) -> List[str]:
        """Generate Cypher statements for terminology updates"""
        
        statements = []
        
        if change.operation == 'd':  # Delete
            statements.append(f"""
                MATCH (c:Concept {{id: '{change.entity_id}'}})
                DETACH DELETE c
            """)
        else:
            # Create/Update main concept
            statements.append(f"""
                MERGE (c:Concept {{id: '{change.entity_id}'}})
                SET c.label = '{concept_data['label']}',
                    c.system = '{concept_data.get('system', 'SNOMED')}',
                    c.active = {str(concept_data.get('active', True)).lower()},
                    c.last_sync = datetime()
            """)
            
            # Update parent relationships
            for parent in concept_data.get('parents', []):
                statements.append(f"""
                    MATCH (c:Concept {{id: '{change.entity_id}'}})
                    MERGE (p:Concept {{id: '{parent}'}})
                    MERGE (c)-[:IS_A]->(p)
                """)
            
            # Update synonyms
            for synonym in concept_data.get('synonyms', []):
                statements.append(f"""
                    MATCH (c:Concept {{id: '{change.entity_id}'}})
                    MERGE (s:Synonym {{text: '{synonym}'}})
                    MERGE (s)-[:SYNONYM_OF]->(c)
                """)
        
        return statements
    
    def generate_terminology_redis(self, concept_data: Dict, change: KnowledgeChange) -> List[tuple]:
        """Generate Redis commands for terminology updates"""
        
        commands = []
        
        if change.operation == 'd':
            # Delete all related keys
            commands.append(('DEL', f"concept:{change.entity_id}"))
            commands.append(('DEL', f"label:{change.entity_id}"))
            commands.append(('SREM', 'valid_concepts', change.entity_id))
        else:
            # Update concept data
            commands.append(('HSET', f"concept:{change.entity_id}", {
                'label': concept_data['label'],
                'system': concept_data.get('system', 'SNOMED'),
                'active': str(concept_data.get('active', True))
            }))
            
            # Update label lookup
            commands.append(('SET', f"label:{change.entity_id}", concept_data['label']))
            
            # Add to valid concepts set
            if concept_data.get('active', True):
                commands.append(('SADD', 'valid_concepts', change.entity_id))
        
        return commands
    
    async def execute_neo4j_batch(self, statements: List[str]):
        """Execute batch of Cypher statements"""
        
        tx = self.neo4j.begin()
        try:
            for statement in statements:
                tx.run(statement)
            tx.commit()
            self.logger.info(f"Executed {len(statements)} Neo4j updates")
        except Exception as e:
            tx.rollback()
            self.logger.error(f"Neo4j batch failed: {e}")
            raise
    
    async def execute_redis_batch(self, commands: List[tuple]):
        """Execute batch of Redis commands"""
        
        pipe = self.redis_pool.pipeline()
        
        for cmd in commands:
            if cmd[0] == 'SET':
                pipe.set(cmd[1], cmd[2])
            elif cmd[0] == 'HSET':
                pipe.hset(cmd[1], mapping=cmd[2])
            elif cmd[0] == 'DEL':
                pipe.delete(cmd[1])
            elif cmd[0] == 'SADD':
                pipe.sadd(cmd[1], cmd[2])
            elif cmd[0] == 'SREM':
                pipe.srem(cmd[1], cmd[2])
        
        await pipe.execute()
        self.logger.info(f"Executed {len(commands)} Redis updates")
    
    async def invalidate_patient_caches(self, *drug_classes):
        """Invalidate cached risk scores for affected patients"""
        
        # Find patients on these drug classes
        cypher = """
        MATCH (p:Patient)-[:PRESCRIBED]->(m:Medication)-[:BELONGS_TO]->(dc:DrugClass)
        WHERE dc.id IN $drug_classes
        RETURN DISTINCT p.id as patient_id
        """
        
        result = self.neo4j.run(cypher, drug_classes=list(drug_classes))
        
        # Invalidate each patient's cached risk score
        pipe = self.redis_pool.pipeline()
        for record in result:
            pipe.delete(f"risk_score:{record['patient_id']}")
        
        await pipe.execute()
        
        self.logger.info(f"Invalidated caches for {len(result)} patients")
    
    async def publish_update_event(self, event_data: Dict):
        """Publish update completion event"""
        
        event_data['timestamp'] = datetime.now().isoformat()
        
        self.producer.produce(
            topic='runtime.updates.completed',
            value=event_data,
            key=event_data.get('entity_id', '')
        )
        self.producer.flush()

