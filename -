```java
// FHIRStoreSink.java
public class FHIRStoreSink extends RichSinkFunction<FHIRResource> {
    
    private transient FhirContext fhirContext;
    private transient IGenericClient fhirClient;
    private transient MetricGroup metrics;
    
    @Override
    public void open(Configuration parameters) throws Exception {
        super.open(parameters);
        
        // Initialize FHIR client
        fhirContext = FhirContext.forR4();
        fhirClient = fhirContext.newRestfulGenericClient(
            getRuntimeContext().getExecutionConfig()
                .getGlobalJobParameters().get("fhir.server.url"));
        
        // Setup metrics
        metrics = getRuntimeContext().getMetricGroup();
        metrics.counter("fhir_writes_total");
        metrics.histogram("fhir_write_latency_ms", new DescriptiveStatisticsHistogram());
    }
    
    @Override
    public void invoke(FHIRResource resource, Context context) throws Exception {
        long startTime = System.currentTimeMillis();
        
        try {
            if (resource instanceof Flag) {
                Flag flag = (Flag) resource;
                
                // Set metadata
                flag.getMeta()
                    .addTag("http://kb7.org/tags", "auto-generated", "Flink Insight")
                    .setLastUpdated(new Date());
                
                // Create or update
                MethodOutcome outcome = fhirClient
                    .update()
                    .resource(flag)
                    .conditional()
                    .where(Flag.IDENTIFIER.exactly().code(flag.getIdentifierFirstRep().getValue()))
                    .execute();
                
                metrics.counter("fhir_writes_total").inc();
                
            } else if (resource instanceof RiskAssessment) {
                RiskAssessment risk = (RiskAssessment) resource;
                
                // Similar handling for RiskAssessment
                MethodOutcome outcome = fhirClient
                    .create()
                    .resource(risk)
                    .execute();
                
                metrics.counter("fhir_writes_total").inc();
            }
            
        } catch (Exception e) {
            metrics.counter("fhir_write_errors").inc();
            log.error("Failed to write to FHIR store", e);
            
            // Send to DLQ
            sendToDeadLetterQueue(resource, e);
        } finally {
            long duration = System.currentTimeMillis() - startTime;
            metrics.histogram("fhir_write_latency_ms").update(duration);
        }
    }
}
