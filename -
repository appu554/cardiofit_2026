## 3. Flink Output Distribution Pattern

### 3.1 Multi-Sink Architecture

```java
// FlinkInsightDistributor.java
public class FlinkInsightDistributor {
    
    public static void main(String[] args) throws Exception {
        StreamExecutionEnvironment env = 
            StreamExecutionEnvironment.getExecutionEnvironment();
        
        // Configure checkpointing for exactly-once semantics
        env.enableCheckpointing(5000);
        env.getCheckpointConfig().setCheckpointingMode(
            CheckpointingMode.EXACTLY_ONCE);
        
        // Source: Processed insights from Flink
        DataStream<ClinicalInsight> insights = env
            .addSource(new FlinkKafkaConsumer<>(
                "flink.processed.insights",
                new ClinicalInsightSchema(),
                kafkaProps))
            .name("Insight Source");
        
        // Branch stream for different severity levels
        OutputTag<ClinicalInsight> criticalTag = 
            new OutputTag<ClinicalInsight>("critical"){};
        OutputTag<ClinicalInsight> warningTag = 
            new OutputTag<ClinicalInsight>("warning"){};
        
        SingleOutputStreamOperator<ClinicalInsight> mainStream = insights
            .process(new ProcessFunction<ClinicalInsight, ClinicalInsight>() {
                @Override
                public void processElement(
                    ClinicalInsight insight,
                    Context ctx,
                    Collector<ClinicalInsight> out) {
                    
                    if (insight.getSeverity() == Severity.CRITICAL) {
                        ctx.output(criticalTag, insight);
                    } else if (insight.getSeverity() == Severity.WARNING) {
                        ctx.output(warningTag, insight);
                    }
                    
                    out.collect(insight); // All insights to main stream
                }
            });
        
        // Sink 1: FHIR Store (System of Record)
        mainStream
            .map(new InsightToFHIRMapper())
            .addSink(new FHIRStoreSink())
            .name("FHIR Store Sink");
        
        // Sink 2: Elasticsearch (System of Retrieval)
        mainStream
            .map(new InsightToElasticsearchMapper())
            .addSink(new ElasticsearchSink<>(
                buildElasticsearchSinkFunction(),
                elasticsearchConfig))
            .name("Elasticsearch Sink");
        
        // Sink 3: Push Notifications (System of Engagement)
        // Only for critical insights
        mainStream.getSideOutput(criticalTag)
            .filter(insight -> insight.requiresImmediateAction())
            .map(new InsightToNotificationMapper())
            .addSink(new FirebasePushSink())
            .name("Push Notification Sink");
        
        // Sink 4: Audit Log
        mainStream
            .map(insight -> new AuditEvent(
                insight.getInsightId(),
                insight.getPatientId(),
                insight.getType(),
                insight.getTimestamp(),
                insight.getSeverity()))
            .addSink(new KafkaSink<>("audit.clinical.insights"))
            .name("Audit Sink");
        
        // Sink 5: Optional Neo4j Summary
        // Lightweight summary for graph queries
        mainStream
            .filter(insight -> insight.getSeverity() == Severity.CRITICAL)
            .map(insight -> String.format(
                "MERGE (p:Patient {id: '%s'}) " +
                "MERGE (a:Alert {id: '%s', type: '%s', severity: '%s'}) " +
                "MERGE (p)-[:HAS_ACTIVE_ALERT {since: datetime()}]->(a)",
                insight.getPatientId(),
                insight.getInsightId(),
                insight.getType(),
                insight.getSeverity()))
            .addSink(new Neo4jCypherSink())
            .name("Neo4j Summary Sink");
        
        env.execute("Clinical Insight Distribution");
    }
}
