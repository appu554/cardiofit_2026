            title=f"⚠️ Critical Alert: {insight['type']}",
            body=f"Patient {insight['patient_name']}: {insight['summary']}",
        )
        
        # Build message with deep link
        message = messaging.MulticastMessage(
            notification=notification,
            data={
                'insight_id': insight['insight_id'],
                'patient_id': insight['patient_id'],
                'type': insight['type'],
                'deep_link': f"app://insights/{insight['insight_id']}"
            },
            tokens=clinician_tokens,
            android=messaging.AndroidConfig(
                priority='high',
                notification=messaging.AndroidNotification(
                    sound='critical_alert.wav',
                    color='#ff0000',
                    notification_priority=messaging.AndroidNotificationPriority.MAX
                )
            ),
            apns=messaging.APNSConfig(
                payload=messaging.APNSPayload(
                    aps=messaging.Aps(
                        alert=messaging.ApsAlert(
                            title=notification.title,
                            body=notification.body
                        ),
                        sound=messaging.CriticalSound(
