{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vaidshala.internal/schemas/evidence-envelope.json",
  "title": "Evidence Envelope Schema",
  "description": "Audit trail linking inputs, logic, and outputs",
  "type": "object",
  "properties": {
    "envelopeId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this evidence envelope"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the clinical decision was made"
    },
    "inputs": {
      "type": "object",
      "properties": {
        "patientId": {
          "type": "string",
          "description": "Hashed patient identifier"
        },
        "fhirResources": {
          "type": "array",
          "items": { "type": "string" },
          "description": "FHIR resource references used"
        },
        "requestContext": {
          "type": "object",
          "description": "Additional context from the request"
        }
      },
      "required": ["patientId"]
    },
    "logic": {
      "type": "object",
      "properties": {
        "library": {
          "type": "string",
          "description": "CQL library name"
        },
        "version": {
          "type": "string",
          "description": "Library version"
        },
        "elmHash": {
          "type": "string",
          "description": "SHA256 hash of the ELM artifact"
        },
        "valueSetsUsed": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": { "type": "string" },
              "version": { "type": "string" }
            }
          }
        }
      },
      "required": ["library", "version", "elmHash"]
    },
    "outputs": {
      "type": "object",
      "properties": {
        "recommendations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string" },
              "severity": { "type": "string", "enum": ["critical", "high", "moderate", "low", "info"] },
              "message": { "type": "string" },
              "evidence": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "alerts": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "metrics": {
          "type": "object",
          "description": "Quality metrics and scores"
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "executorVersion": { "type": "string" },
        "terminologyVersion": { "type": "string" },
        "region": { "type": "string", "enum": ["IN", "AU", "US", "UK"] },
        "executionDurationMs": { "type": "number" }
      }
    },
    "signature": {
      "type": "string",
      "description": "Ed25519 signature of the envelope contents"
    }
  },
  "required": ["envelopeId", "timestamp", "inputs", "logic", "outputs"]
}
