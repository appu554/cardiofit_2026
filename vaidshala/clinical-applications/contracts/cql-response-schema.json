{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vaidshala.internal/schemas/cql-response.json",
  "title": "CQL Response Schema",
  "description": "Response format from CQL execution in the runtime platform",
  "type": "object",
  "properties": {
    "libraryName": {
      "type": "string",
      "description": "Name of the CQL library executed"
    },
    "libraryVersion": {
      "type": "string",
      "description": "Version of the CQL library"
    },
    "patientId": {
      "type": "string",
      "description": "FHIR Patient resource ID (may be hashed)"
    },
    "executionTime": {
      "type": "string",
      "format": "date-time",
      "description": "When the CQL was executed"
    },
    "results": {
      "type": "object",
      "description": "Expression results keyed by expression name",
      "additionalProperties": true
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Any warnings during execution"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "expression": { "type": "string" },
          "message": { "type": "string" },
          "severity": { "type": "string", "enum": ["error", "warning", "info"] }
        }
      },
      "description": "Any errors during execution"
    },
    "evidenceEnvelopeId": {
      "type": "string",
      "description": "Reference to the evidence envelope for this execution"
    }
  },
  "required": ["libraryName", "libraryVersion", "executionTime", "results"]
}
