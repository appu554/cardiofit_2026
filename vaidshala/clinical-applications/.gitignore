# Clinical Applications .gitignore

# Build outputs
dist/
build/
out/
.next/
.nuxt/

# Dependencies
node_modules/
.npm/
.pnpm-store/
__pycache__/
*.pyc
.venv/
venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
*.tmp

# Test outputs
test-results/
coverage/
.nyc_output/
junit/

# Environment files (NEVER commit)
.env
.env.local
.env.*.local
.env.development
.env.production

# Secrets (NEVER commit)
*.pem
*.key
*.secret
secrets/
credentials/

# TypeScript
*.tsbuildinfo

# Storybook
storybook-static/

# Bundle analysis
.bundle-analyzer/

# Cache
.cache/
.parcel-cache/
.eslintcache
