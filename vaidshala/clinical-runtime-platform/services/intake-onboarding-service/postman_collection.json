{
  "info": {
    "name": "CardioFit Intake-Onboarding Service",
    "description": "Full E2E collection for the Intake-Onboarding Service.\n\nFlow: Create Patient → Create Encounter → Enroll → Fill Slots (50) → Safety → Submit Review → Approve → Check-in → Check-in Slots\n\n**Test Patient**: Venkatesh Iyer, 65M, South Indian, T2DM x15 years, CKD 3a, HTN, dyslipidemia, 8 medications.\n\n**Setup**: Run requests in order — test scripts auto-set `patient_id`, `encounter_id`, etc.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8141" },
    { "key": "patient_id", "value": "" },
    { "key": "encounter_id", "value": "" },
    { "key": "review_entry_id", "value": "" },
    { "key": "checkin_session_id", "value": "" },
    { "key": "reviewer_id", "value": "00000000-0000-0000-0000-000000000099" },
    { "key": "tenant_id", "value": "00000000-0000-0000-0000-000000000001" }
  ],
  "item": [
    {
      "name": "Infrastructure",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/healthz"
          }
        },
        {
          "name": "Readiness Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/readyz"
          }
        },
        {
          "name": "Prometheus Metrics",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/metrics"
          }
        }
      ]
    },
    {
      "name": "1. Patient Registration & Enrollment",
      "description": "5-step flow: Create Patient (with demographics) → Lookup Patient → Create Encounter → Enroll → Edit Demographics\n\nPatient: Venkatesh Iyer, 65M, Chennai, T2DM x15y, CKD 3a",
      "item": [
        {
          "name": "1.1 Create Patient (Venkatesh Iyer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    pm.collectionVariables.set('patient_id', json.patient_id);",
                  "    pm.test('Has patient_id', function() {",
                  "        pm.expect(json.patient_id).to.be.a('string');",
                  "    });",
                  "    pm.test('Status is created or existing', function() {",
                  "        pm.expect(['created', 'existing']).to.include(json.status);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/fhir/Patient",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"given_name\": \"Venkatesh\",\n  \"family_name\": \"Iyer\",\n  \"phone\": \"+919841234567\",\n  \"abha_id\": \"91-8765-4321-0987\",\n  \"email\": \"venkatesh.iyer@email.com\",\n  \"age\": 65,\n  \"gender\": \"male\",\n  \"ethnicity\": \"south_asian\",\n  \"primary_language\": \"ta\"\n}"
            }
          }
        },
        {
          "name": "1.1b Lookup Patient by Phone",
          "description": "Search for a patient by phone number. Returns patient_id and basic info if found.",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/fhir/Patient?phone=%2B919841234567",
            "header": []
          }
        },
        {
          "name": "1.1c Lookup Patient by Email",
          "description": "Search for a patient by email. Returns patient_id and basic info if found.",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/fhir/Patient?email=venkatesh.iyer@email.com",
            "header": []
          }
        },
        {
          "name": "1.2 Create Encounter (intake)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('encounter_id', json.encounter_id);",
                  "    pm.test('Has encounter_id', function() {",
                  "        pm.expect(json.encounter_id).to.be.a('string');",
                  "    });",
                  "    pm.test('Type is intake', function() {",
                  "        pm.expect(json.type).to.eql('intake');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/fhir/Patient/{{patient_id}}/Encounter",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"intake\"\n}"
            }
          }
        },
        {
          "name": "1.2b Create Encounter (lab)",
          "description": "Example: lab visit for blood work",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/fhir/Patient/{{patient_id}}/Encounter",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"lab\"\n}"
            }
          }
        },
        {
          "name": "1.2c Create Encounter (checkup)",
          "description": "Example: routine follow-up checkup",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/fhir/Patient/{{patient_id}}/Encounter",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"checkup\"\n}"
            }
          }
        },
        {
          "name": "1.3 Enroll in Program",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.test('Patient enrolled', function() {",
                  "        pm.expect(json.status).to.eql('enrolled');",
                  "    });",
                  "    pm.test('Returns next_node', function() {",
                  "        pm.expect(json.next_node.node_id).to.eql('body_measurements');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/fhir/Patient/{{patient_id}}/$enroll",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"encounter_id\": \"{{encounter_id}}\",\n  \"channel_type\": \"CORPORATE\",\n  \"tenant_id\": \"{{tenant_id}}\"\n}"
            }
          }
        },
        {
          "name": "1.4 Edit Patient Demographics",
          "description": "PUT to update identity-level fields. Venkatesh Iyer: 65M, South Asian, Tamil speaker.",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/fhir/Patient/{{patient_id}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"age\": 65,\n  \"gender\": \"male\",\n  \"ethnicity\": \"south_asian\",\n  \"primary_language\": \"ta\",\n  \"given_name\": \"Venkatesh\",\n  \"family_name\": \"Iyer\"\n}"
            }
          }
        }
      ]
    },
    {
