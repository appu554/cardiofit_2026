    {
      "name": "11. Review Queue",
      "description": "Before submitting review, manually update enrollment state:\n\n```sql\nUPDATE enrollments SET state = 'INTAKE_COMPLETED' WHERE encounter_id = '<encounter_id>';\n```",
      "item": [
        {
          "name": "11.1 Submit for Review",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('review_entry_id', json.id);",
                  "    pm.test('Review entry created', function() {",
                  "        pm.expect(json.id).to.be.a('string');",
                  "    });",
                  "    pm.test('Has risk_stratum', function() {",
                  "        pm.expect(json.risk_stratum).to.be.oneOf(['LOW', 'MEDIUM', 'HIGH']);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/fhir/Encounter/{{encounter_id}}/$submit-review",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hard_stop_count\": 0,\n  \"soft_flag_count\": 3,\n  \"age\": 65,\n  \"med_count\": 8,\n  \"egfr_value\": 52\n}"
            }
          }
        },
        {
          "name": "11.2 Approve Review",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/fhir/ReviewEntry/{{review_entry_id}}/$approve",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-ID", "value": "{{reviewer_id}}" }
            ]
          }
        },
        {
          "name": "11.3 Request Clarification (alt)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/fhir/ReviewEntry/{{review_entry_id}}/$request-clarification",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-ID", "value": "{{reviewer_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slot_names\": [\"egfr\", \"serum_creatinine\", \"uacr\"],\n  \"notes\": \"UACR 180 with eGFR 52 suggests A2 category — please verify if UACR was fasting morning sample\"\n}"
            }
          }
        },
        {
          "name": "11.4 Escalate (alt)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/fhir/ReviewEntry/{{review_entry_id}}/$escalate",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-ID", "value": "{{reviewer_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Complex polypharmacy with CKD 3a and suboptimal adherence\",\n  \"notes\": \"8 medications with 0.65 adherence score, eGFR 52, on glimepiride + insulin — needs nephrologist + endocrinologist review for potential deprescribing\"\n}"
            }
          }
        }
      ]
    },
