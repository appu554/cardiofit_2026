{
  "info": {
    "name": "CardioFit Intake-Onboarding Service",
    "description": "Full E2E collection for the Intake-Onboarding Service.\n\nFlow: Enroll → Fill Slots (50) → Safety → Submit Review → Approve → Check-in → Check-in Slots\n\n**Setup**: Run \"1. Enroll Patient\" first — it auto-sets `patient_id` and `encounter_id` variables for subsequent requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8141" },
    { "key": "patient_id", "value": "" },
    { "key": "encounter_id", "value": "" },
    { "key": "review_entry_id", "value": "" },
    { "key": "checkin_session_id", "value": "" },
    { "key": "reviewer_id", "value": "00000000-0000-0000-0000-000000000099" },
    { "key": "tenant_id", "value": "00000000-0000-0000-0000-000000000001" }
  ],
  "item": [
    {
      "name": "Infrastructure",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/healthz"
          }
        },
        {
          "name": "Readiness Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/readyz"
          }
        },
        {
          "name": "Prometheus Metrics",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/metrics"
          }
        }
      ]
    },
    {
      "name": "1. Enrollment",
      "item": [
        {
          "name": "1.1 Enroll Patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('patient_id', json.patient_id);",
                  "    pm.collectionVariables.set('encounter_id', json.encounter_id);",
                  "    pm.test('Patient enrolled', function() {",
                  "        pm.expect(json.status).to.eql('enrolled');",
                  "    });",
                  "    pm.test('Has patient_id', function() {",
                  "        pm.expect(json.patient_id).to.be.a('string');",
                  "    });",
                  "    pm.test('Has encounter_id', function() {",
                  "        pm.expect(json.encounter_id).to.be.a('string');",
                  "    });",
                  "    pm.test('Returns next_node', function() {",
                  "        pm.expect(json.next_node.node_id).to.eql('demographics_basic');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/fhir/Patient/$enroll",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"given_name\": \"Ravi\",\n  \"family_name\": \"Kumar\",\n  \"phone\": \"+919876543210\",\n  \"abha_id\": \"91-2345-6789-0123\",\n  \"channel_type\": \"CORPORATE\",\n  \"tenant_id\": \"{{tenant_id}}\"\n}"
            }
          }
        }
      ]
    },
