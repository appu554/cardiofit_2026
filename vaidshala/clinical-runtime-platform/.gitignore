# Clinical Runtime Platform .gitignore

# Build artifacts
*.jar
*.war
*.ear
target/
dist/
out/

# Docker
*.tar
docker-compose.override.yml

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
.terraform.lock.hcl

# Kubernetes
*.kubeconfig
kubeconfig

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# Dependencies
node_modules/
.npm/
__pycache__/
*.pyc
.venv/
venv/
vendor/

# Test outputs
test-results/
coverage/
.nyc_output/

# Secrets (NEVER commit)
*.pem
*.key
*.secret
.env
.env.local
.env.*.local
secrets/
credentials/

# Downloaded artifacts (pulled at runtime)
artifacts/
elm/
valuesets/
manifests/
