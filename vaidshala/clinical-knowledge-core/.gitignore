# Clinical Knowledge Core .gitignore

# Build artifacts
build/cql-to-elm/*.json
build/valueset-expansion/*.json
build/manifests/*.json
!build/**/.gitkeep

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# Dependencies (if using tooling)
node_modules/
.npm/
__pycache__/
*.pyc
.venv/
venv/

# Test outputs
test-results/
coverage/
.nyc_output/

# Secrets (NEVER commit)
*.pem
*.key
*.secret
.env
.env.local
.env.*.local
.keys/

# Build outputs (generated artifacts)
build/*.tar.gz
build/*.sig
build/signatures/

# Lock files for local expansion (keep in .gitignore)
*.lock.json
