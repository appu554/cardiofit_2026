{
  "query": "mutation CreateObservation($input: ObservationInput!) { createObservation(input: $input) { success message observation { id resourceType status code { text } subject { reference } effectiveDateTime valueQuantity { value unit } } } }",
  "variables": {
    "input": {
      "status": "final",
      "code": {
        "coding": [
          {
            "system": "http://loinc.org",
            "code": "8867-4",
            "display": "Heart rate"
          }
        ],
        "text": "Heart rate"
      },
      "subject": {
        "reference": "Patient/example-patient-id"
      },
      "effectiveDateTime": "2024-01-15T10:30:00Z",
      "valueQuantity": {
        "value": 72.0,
        "unit": "beats/min",
        "system": "http://unitsofmeasure.org",
        "code": "/min"
      }
    }
  }
}
