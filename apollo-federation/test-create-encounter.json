{
  "query": "mutation CreateNewEncounter($encounter: CreateEncounterInput!) { createEncounter(encounter: $encounter) { id resourceType status encounterClass subject { reference display } participant { type { text } individual { reference display } } period { start end } } }",
  "variables": {
    "encounter": {
      "status": "PLANNED",
      "encounterClass": "OUTPATIENT",
      "subject": {
        "reference": "Patient/example-patient-123",
        "display": "John Doe"
      },
      "type": [
        {
          "text": "Routine consultation"
        }
      ],
      "priority": {
        "text": "Routine"
      },
      "participant": [
        {
          "type": [
            {
              "text": "Primary care physician"
            }
          ],
          "individual": {
            "reference": "Practitioner/dr-smith",
            "display": "Dr. Smith"
          }
        }
      ],
      "period": {
        "start": "2024-01-15T09:00:00Z",
        "end": "2024-01-15T10:00:00Z"
      },
      "reasonCode": [
        {
          "text": "Annual checkup"
        }
      ],
      "serviceProvider": {
        "reference": "Organization/clinic-123",
        "display": "Main Street Clinic"
      }
    }
  }
}
