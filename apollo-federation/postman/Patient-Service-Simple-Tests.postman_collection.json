{
	"info": {
		"_postman_id": "f5e8a3d2-7c9e-4b5a-8f1c-d6e9a2f8e3b2",
		"name": "Patient Service Simple Tests",
		"description": "Simplified collection for testing just the Patient Service through the complete flow",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Get Auth Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"",
									"if (jsonData.access_token) {",
									"    pm.collectionVariables.set(\"auth_token\", jsonData.access_token);",
									"    console.log(\"Token saved to collection variable: auth_token\");",
									"} else {",
									"    console.log(\"No token found in response\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"test@example.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{api_gateway_url}}/api/auth/token",
							"host": [
								"{{api_gateway_url}}"
							],
							"path": [
								"api",
								"auth",
								"token"
							]
						},
						"description": "Get an authentication token from the Auth Service through the API Gateway"
					},
					"response": []
				}
			]
		},
		{
			"name": "2. Patient Service Tests",
			"item": [
				{
					"name": "Get Patients (API Gateway)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"query { patients(limit: 10) { items { id name { family given } gender birthDate } total page count } }\"\n}"
						},
						"url": {
							"raw": "{{api_gateway_url}}/api/graphql",
							"host": [
								"{{api_gateway_url}}"
							],
							"path": [
								"api",
								"graphql"
							]
						},
						"description": "Get patients through the API Gateway > Auth > Apollo Federation > Patient Service flow"
					},
					"response": []
				},
				{
					"name": "Create Patient (API Gateway)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"",
									"if (jsonData.data && jsonData.data.createPatient && jsonData.data.createPatient.patient && jsonData.data.createPatient.patient.id) {",
									"    pm.collectionVariables.set(\"patient_id\", jsonData.data.createPatient.patient.id);",
									"    console.log(\"Patient ID saved to collection variable: patient_id\");",
									"} else {",
									"    console.log(\"No patient ID found in response\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"mutation($input: CreatePatientInput!) { createPatient(input: $input) { patient { id name { family given } gender birthDate } } }\",\n    \"variables\": {\n        \"input\": {\n            \"name\": [{\n                \"family\": \"Smith\",\n                \"given\": [\"John\", \"Test\"]\n            }],\n            \"gender\": \"male\",\n            \"birthDate\": \"1980-01-01\",\n            \"telecom\": [{\n                \"system\": \"phone\",\n                \"value\": \"555-123-4567\",\n                \"use\": \"home\"\n            }, {\n                \"system\": \"email\",\n                \"value\": \"john.smith@example.com\"\n            }],\n            \"address\": [{\n                \"use\": \"home\",\n                \"line\": [\"123 Main St\"],\n                \"city\": \"Anytown\",\n                \"state\": \"CA\",\n                \"postalCode\": \"12345\",\n                \"country\": \"USA\"\n            }],\n            \"active\": true\n        }\n    }\n}"
						},
						"url": {
							"raw": "{{api_gateway_url}}/api/graphql",
							"host": [
								"{{api_gateway_url}}"
							],
							"path": [
								"api",
								"graphql"
							]
						},
						"description": "Create a new patient through the API Gateway"
					},
					"response": []
				},
				{
					"name": "Get Patient by ID (API Gateway)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"query($id: String!) { patient(id: $id) { id name { family given } gender birthDate telecom { system value } address { line city state postalCode country } } }\",\n    \"variables\": {\n        \"id\": \"{{patient_id}}\"\n    }\n}"
						},
						"url": {
							"raw": "{{api_gateway_url}}/api/graphql",
							"host": [
								"{{api_gateway_url}}"
							],
							"path": [
								"api",
								"graphql"
							]
						},
						"description": "Get a specific patient by ID through the API Gateway"
					},
					"response": []
				}
			]
		},
		{
			"name": "3. Federation Gateway Tests",
			"item": [
				{
					"name": "Federation Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{federation_gateway_url}}/health",
							"host": [
								"{{federation_gateway_url}}"
							],
							"path": [
								"health"
							]
						},
						"description": "Check the health of the Apollo Federation Gateway and its services"
					},
					"response": []
				},
				{
					"name": "Get Patients (Direct Federation)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"query { patients(limit: 10) { items { id name { family given } gender birthDate } total page count } }\"\n}"
						},
						"url": {
							"raw": "{{federation_gateway_url}}/graphql",
							"host": [
								"{{federation_gateway_url}}"
							],
							"path": [
								"graphql"
							]
						},
						"description": "Get patients directly from the Federation Gateway"
					},
					"response": []
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "api_gateway_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "federation_gateway_url",
			"value": "http://localhost:4000",
			"type": "string"
		},
		{
			"key": "auth_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "patient_id",
			"value": "",
			"type": "string"
		}
	]
}
