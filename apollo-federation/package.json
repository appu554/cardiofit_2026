{
  "name": "apollo-federation-server",
  "version": "2.0.0",
  "description": "Enhanced Apollo Federation server with UI interaction support for Clinical Synthesis Hub",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node index.js",
    "start:ui": "node workflow-ui-gateway.js",
    "start:analytics": "node services/analytics-service.js",
    "dev": "nodemon index.js",
    "dev:ui": "nodemon workflow-ui-gateway.js",
    "dev:analytics": "nodemon services/analytics-service.js",
    "simple": "node simple-gateway.js",
    "working": "node working-gateway.js",
    "rover": "node rover-gateway.js",
    "generate-supergraph": "node generate-supergraph.js",
    "generate-supergraph:ui": "node generate-supergraph-with-ui.js",
    "rover-supergraph": "rover supergraph compose --config ./supergraph.yaml --output ./supergraph.graphql",
    "rover-supergraph:ui": "rover supergraph compose --config ./supergraph-ui-config.yaml --output ./supergraph-with-ui.graphql",
    "test:ui-integration": "node test-ui-integration.js",
    "test:connectivity": "node -e \"require('./test-ui-integration').testBasicConnectivity()\"",
    "deploy:ui": "npm run generate-supergraph:ui && npm run test:ui-integration && npm run start:ui",
    "test:analytics": "node test-analytics-dashboard.js"
  },
  "dependencies": {
    "@apollo/gateway": "^2.5.1",
    "@apollo/server": "^4.9.3",
    "@apollo/subgraph": "^2.10.2",
    "@graphql-tools/schema": "^10.0.0",
    "@graphql-tools/stitch": "^9.0.0",
    "apollo-server-testing": "^2.25.4",
    "axios": "^1.5.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "graphql-subscriptions": "^2.0.0",
    "graphql-tag": "^2.12.6",
    "graphql-ws": "^5.14.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "node-fetch": "^3.3.2",
    "pg": "^8.16.3",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "apollo-federation",
    "graphql",
    "clinical-workflow",
    "ui-interaction",
    "healthcare",
    "real-time",
    "subscriptions"
  ]
}
